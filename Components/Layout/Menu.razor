@inject NavigationManager Navigation
@using PETRO_BOT.Services.Toast
@inject ToastService ToastService
@implements IDisposable

<style>
    /* Estilos premium para los botones circulares de la barra lateral en Modo Claro */
    #sidebar-thin .sidebar-circle-btn {
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
    }

    #sidebar-thin .sidebar-circle-btn:hover {
        background-color: #f8fafc;
        border-color: #cbd5e1;
        color: #0f172a;
        transform: scale(1.05);
    }

    #sidebar-thin .sidebar-circle-btn.active {
        background-color: #0f172a !important;
        border-color: #0f172a !important;
        color: #ffffff !important;
        box-shadow: 0 8px 16px rgba(15, 23, 42, 0.15) !important;
    }

    /* Ocultar barra lateral en móvil y abrir con Overlay */
    @@media (max-width: 1023px) {
        #sidebar-thin {
            transform: translateX(-110%);
        }
        #sidebar-thin.open {
            transform: translateX(0);
        }
    }
</style>

<aside id="sidebar-thin" class="fixed inset-y-4 left-4 lg:relative lg:inset-0 z-40 w-[80px] bg-white border border-slate-200 rounded-[28px] py-8 flex flex-col items-center justify-between transition-transform duration-300 ease-in-out shadow-sm lg:translate-x-0 shrink-0">

    <!-- Top Logo Block from mockup (two connected squares) -->
    <div class="flex flex-col items-center gap-6">
        <div class="shrink-0 w-10 h-10 bg-white rounded-full flex items-center justify-center overflow-hidden border border-slate-200 shadow-sm cursor-pointer hover:border-slate-400 transition-all duration-300 hover:scale-105" @onclick='() => Navigation.NavigateTo("/")'>
            <img src="https://media.licdn.com/dms/image/v2/D4E0BAQFEVlfbMzAqjA/company-logo_200_200/company-logo_200_200/0/1732657776519?e=1779926400&v=beta&t=45NdwFLZ_Nsv_k9OMuDHjE7HVfTWOXe51qU82jtVbgA"
                 alt="Logo"
                 class="w-full h-full object-cover">
        </div>
        
        <!-- Separator -->
        <span class="w-6 h-px bg-slate-200"></span>
    </div>

    <!-- Center Stack of circular buttons from mockup -->
    <nav class="flex flex-col gap-4">
        
        <!-- Button 1: Grid (Home) -->
        <button class="sidebar-circle-btn @(EsRutaActiva("/") ? "active" : "")" 
                title="Inicio / Dashboard" 
                @onclick='() => Navigation.NavigateTo("/")'>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
            </svg>
        </button>
 
        <!-- Button 2: File (Registro Ventas) -->
        <button class="sidebar-circle-btn @(EsRutaActiva("/RegistroVentas") || EsRutaActiva("/ConfigGrifos") ? "active" : "")" 
                title="Registro de Ventas" 
                @onclick='() => Navigation.NavigateTo("/RegistroVentas")'>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
        </button>

        <!-- Button 3: Chart (Mock) -->
        <button class="sidebar-circle-btn" 
                title="Estadísticas / Reportes"
                @onclick='() => ToastService.Info("Estadísticas Consolidadas - Simulado")'>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
            </svg>
        </button>
 
    </nav>

    <!-- Bottom Logout Circle Button -->
    <button class="sidebar-circle-btn hover:!bg-red-50 hover:!border-red-200 hover:!text-red-650" 
            title="Salir" 
            @onclick='() => ToastService.Warning("Operación: Cerrar Sesión")'>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
        </svg>
    </button>

</aside>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool EsRutaActiva(string path)
    {
        try
        {
            var uri = new Uri(Navigation.Uri);
            var localPath = uri.LocalPath.Trim('/');
            var targetPath = path.Trim('/');
            
            if (string.IsNullOrEmpty(targetPath))
            {
                return string.IsNullOrEmpty(localPath);
            }
            
            return string.Equals(localPath, targetPath, StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }
}