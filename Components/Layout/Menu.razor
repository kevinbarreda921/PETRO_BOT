@inject NavigationManager Navigation
@using PETRO_BOT.Services.Toast
@inject ToastService ToastService
@implements IDisposable

<style>
    /* Fixed circle button with floating tooltip label */
    .sidebar-btn-wrap {
        position: relative;
        display: flex;
        align-items: center;
        transition: transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
        transform-origin: left center;
    }

    .sidebar-btn-wrap:hover {
        transform: scale(1.2);
        z-index: 10;
    }

    #sidebar-thin .sidebar-circle-btn {
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        cursor: pointer;
        transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
        flex-shrink: 0;
        position: relative;
        z-index: 2;
    }

    #sidebar-thin .sidebar-circle-btn:hover {
        background-color: #f8fafc;
        border-color: #cbd5e1;
        color: #0f172a;
    }

    #sidebar-thin .sidebar-circle-btn.active {
        background-color: #0f172a !important;
        border-color: #0f172a !important;
        color: #ffffff !important;
        box-shadow: 0 8px 16px rgba(15, 23, 42, 0.15) !important;
    }

    #sidebar-thin .sidebar-circle-btn.active:hover {
    }

    /* Pill extension that slides out from behind the button */
    .sidebar-btn-wrap .sidebar-tooltip {
        position: absolute;
        left: 1.5rem;
        top: 0;
        height: 3rem;
        display: flex;
        align-items: center;
        padding-left: 2rem;
        padding-right: 1rem;
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-left: none;
        border-radius: 0 9999px 9999px 0;
        color: #0f172a;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transform: translateX(-12px);
        transition: opacity 200ms ease, transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 1;
    }

    #sidebar-thin:hover .sidebar-tooltip {
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
    }

    /* Active state: dark pill extension */
    .sidebar-btn-wrap:has(.active) .sidebar-tooltip {
        background-color: #1e293b;
        border-color: #1e293b;
        color: #ffffff;
    }

    /* Logout button hover */
    .sidebar-btn-wrap.logout-wrap .sidebar-circle-btn:hover {
        background-color: #fef2f2 !important;
        border-color: #fecaca !important;
        color: #b91c1c !important;
    }

    .sidebar-btn-wrap.logout-wrap .sidebar-tooltip {
        background-color: #fef2f2;
        border-color: #fecaca;
        color: #b91c1c;
    }

    /* Ocultar barra lateral en móvil y abrir con Overlay */
    @@media (max-width: 1023px) {
        #sidebar-thin {
            transform: translateX(-110%);
        }
        #sidebar-thin.open {
            transform: translateX(0);
        }
    }
</style>

<aside id="sidebar-thin" class="fixed inset-y-4 left-4 lg:relative lg:inset-0 z-40 w-[80px] bg-white border border-slate-200 rounded-[28px] py-8 flex flex-col items-center justify-between transition-transform duration-300 ease-in-out shadow-sm lg:translate-x-0 shrink-0">

    <!-- Top Logo -->
    <div class="flex flex-col items-center gap-6">
        <div class="shrink-0 w-10 h-10 bg-white rounded-full flex items-center justify-center overflow-hidden border border-slate-200 shadow-sm cursor-pointer hover:border-slate-400 transition-all duration-300 hover:scale-105" @onclick='() => Navigation.NavigateTo("/")'>
            <img src="img/logo.jpg"
                 alt="Logo"
                 class="w-full h-full object-cover">
        </div>
        
        <!-- Separator -->
        <span class="w-6 h-px bg-slate-200"></span>
    </div>

    <!-- Center Stack of circle buttons with floating tooltips -->
    <nav class="flex flex-col gap-4">
        
        <!-- Button 1: Home -->
        <div class="sidebar-btn-wrap">
            <button class="sidebar-circle-btn @(EsRutaActiva("/") ? "active" : "")" 
                    @onclick='() => Navigation.NavigateTo("/")'>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                </svg>
            </button>
            <span class="sidebar-tooltip">Inicio</span>
        </div>
 
        <!-- Button 2: Registro Ventas -->
        <div class="sidebar-btn-wrap">
            <button class="sidebar-circle-btn @(EsRutaActiva("/RegistroVentas") || EsRutaActiva("/ConfigGrifos") ? "active" : "")" 
                    @onclick='() => Navigation.NavigateTo("/RegistroVentas")'>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </button>
            <span class="sidebar-tooltip">Registro de ventas</span>
        </div>

        <!-- Button 3: Registro Descuentos -->
        <div class="sidebar-btn-wrap">
            <button class="sidebar-circle-btn @(EsRutaActiva("/RegistroDescuentos") || EsRutaActiva("/ConfigDescuentos") ? "active" : "")" 
                    @onclick='() => Navigation.NavigateTo("/RegistroDescuentos")'>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </button>
            <span class="sidebar-tooltip">Registro de descuentos</span>
        </div>

        <!-- Button 4: Validación Precio Lista -->
        <div class="sidebar-btn-wrap">
            <button class="sidebar-circle-btn @(EsRutaActiva("/ValidacionPrecioLista") || EsRutaActiva("/ReportePreciosPorDia") ? "active" : "")" 
                    @onclick='() => Navigation.NavigateTo("/ValidacionPrecioLista")'>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                </svg>
            </button>
            <span class="sidebar-tooltip">Validación precio lista</span>
        </div>

        <!-- Button 5: Chart -->
        <div class="sidebar-btn-wrap">
            <button class="sidebar-circle-btn" 
                    @onclick='() => ToastService.Info("Estadísticas Consolidadas - Simulado")'>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                </svg>
            </button>
            <span class="sidebar-tooltip">Reportes</span>
        </div>
 
    </nav>

    <!-- Bottom Logout Button -->
    <div class="sidebar-btn-wrap logout-wrap">
        <button class="sidebar-circle-btn" 
                @onclick='() => ToastService.Warning("Operación: Cerrar Sesión")'>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
        </button>
        <span class="sidebar-tooltip">Salir</span>
    </div>

</aside>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool EsRutaActiva(string path)
    {
        try
        {
            var uri = new Uri(Navigation.Uri);
            var localPath = uri.LocalPath.Trim('/');
            var targetPath = path.Trim('/');
            
            if (string.IsNullOrEmpty(targetPath))
            {
                return string.IsNullOrEmpty(localPath);
            }
            
            return string.Equals(localPath, targetPath, StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }
}