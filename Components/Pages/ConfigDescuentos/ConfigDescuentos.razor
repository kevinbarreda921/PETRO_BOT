    private void AbrirModalVerPlantilla()
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.Plantilla)) return;
        
        if (string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.NombreHoja))
        {
            ToastService.Error("Configure primero el campo 'Hoja Excel' para la plantilla de destino.");
            return;
        }

        try
        {
            string plantillasDir = Path.Combine(ConfiguracionService.ObtenerWebRootPath(env.WebRootPath), "bd", "RegistroVentas", "Plantillas");
            string filePath = Path.Combine(plantillasDir, grifoSeleccionado.RegistroDescuentosWrite.Plantilla);
            if (!File.Exists(filePath))
            {
                ToastService.Error("El archivo de la plantilla no se encuentra en el servidor.");
                return;
            }

            viendoRegistroVentasModal = false;
            plantillaExcelNombre = grifoSeleccionado.RegistroDescuentosWrite.Plantilla;
            plantillaExcelHojas.Clear();

            string targetSheet = grifoSeleccionado.RegistroDescuentosWrite.NombreHoja;
            
            ExcelPackage.License.SetNonCommercialPersonal("PETROBOT");
            using (var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
            using (var package = new ExcelPackage(stream))
            {
                var match = package.Workbook.Worksheets.FirstOrDefault(s => string.Equals(s.Name, targetSheet, StringComparison.OrdinalIgnoreCase));
                if (match != null)
                {
                    plantillaExcelHojas.Add(match.Name);
                    CargarDatosHojaExcel(match.Name);
                }
                else
                {
                    ToastService.Error($"La hoja '{targetSheet}' no se encontró en el archivo Excel.");
                    return;
                }
            }

            mostrarModalVerPlantilla = true;
            _shouldScrollSelectedCell = true;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al abrir la plantilla: " + ex.Message);
        }
    }

