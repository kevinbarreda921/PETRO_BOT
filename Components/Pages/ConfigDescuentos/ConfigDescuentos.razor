@code {
    private bool mostrarModalHojasRegistroDescuentos = false;
    private List<string> hojasRegistroDescuentos = new List<string>();

    private string? estadoOriginalJson;
    private bool mostrarModalConfirmacionCambios = false;
    private int? grifoPendienteSeleccionar = null;
    private TaskCompletionSource<bool>? _tcsNavegacion;

    private void AbrirModalHojasRegistroDescuentos()
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.Plantilla))
        {
            ToastService.Error("Carga primero la plantilla de destino.");
            return;
        }

        try
        {
            string dir = Path.Combine(ConfiguracionService.ObtenerWebRootPath(env.WebRootPath), "bd", "RegistroVentas", "Plantillas");
            string filePath = Path.Combine(dir, grifoSeleccionado.RegistroDescuentosWrite.Plantilla);
            
            if (!File.Exists(filePath))
            {
                ToastService.Error("El archivo de plantilla no se encuentra en el servidor.");
                return;
            }

            hojasRegistroDescuentos.Clear();
            ExcelPackage.License.SetNonCommercialPersonal("PETROBOT");
            using (var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
            using (var package = new ExcelPackage(stream))
            {
                foreach (var sheet in package.Workbook.Worksheets)
                {
                    hojasRegistroDescuentos.Add(sheet.Name);
                }
            }

            mostrarModalHojasRegistroDescuentos = true;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al leer la plantilla: " + ex.Message);
        }
    }

    private void CerrarModalHojasRegistroDescuentos()
    {
        mostrarModalHojasRegistroDescuentos = false;
    }

    private void SeleccionarHojaRegistroDescuentos(string hoja)
    {
        if (grifoSeleccionado != null && grifoSeleccionado.RegistroDescuentosWrite != null)
        {
            grifoSeleccionado.RegistroDescuentosWrite.NombreHoja = hoja;
            StateHasChanged();
        }
        CerrarModalHojasRegistroDescuentos();
    }
    
    private void LimpiarHojaExcelDescuentos()
    {
        if (grifoSeleccionado != null && grifoSeleccionado.RegistroDescuentosWrite != null)
        {
            grifoSeleccionado.RegistroDescuentosWrite.NombreHoja = null;
            StateHasChanged();
        }
    }

    private void ActualizarEstadoOriginal()
    {
        if (grifoSeleccionado != null)
        {
            estadoOriginalJson = JsonSerializer.Serialize(grifoSeleccionado);
        }
        else
        {
            estadoOriginalJson = null;
        }
    }

    private bool HayCambiosSinGuardar()
    {
        if (grifoSeleccionado == null || string.IsNullOrEmpty(estadoOriginalJson)) return false;
        try
        {
            string estadoActual = JsonSerializer.Serialize(grifoSeleccionado);
            return estadoOriginalJson != estadoActual;
        }
        catch { return false; }
    }

    private async Task ConfirmExit(LocationChangingContext context)
    {
        if (HayCambiosSinGuardar())
        {
            mostrarModalConfirmacionCambios = true;
            _tcsNavegacion = new TaskCompletionSource<bool>();
            
            StateHasChanged();
            bool proceed = await _tcsNavegacion.Task;
            if (!proceed)
            {
                context.PreventNavigation();
            }
        }
    }

    private void ModalGuardarYContinuar()
    {
        GuardarConfiguracion();
        ContinuarAccionPendiente();
    }

    private void ModalDescartarYContinuar()
    {
        ContinuarAccionPendiente();
    }

    private void ContinuarAccionPendiente()
    {
        mostrarModalConfirmacionCambios = false;
        
        if (grifoPendienteSeleccionar.HasValue)
        {
            SeleccionarGrifoInternal(grifoPendienteSeleccionar.Value);
            grifoPendienteSeleccionar = null;
        }
        else if (_tcsNavegacion != null)
        {
            _tcsNavegacion.SetResult(true);
            _tcsNavegacion = null;
        }
    }

    private void ModalCancelarCambios()
    {
        mostrarModalConfirmacionCambios = false;
        grifoPendienteSeleccionar = null;
        if (_tcsNavegacion != null)
        {
            _tcsNavegacion.SetResult(false);
            _tcsNavegacion = null;
        }
    }
    private List<RegistroVentasGrifo> grifosList = new();
    private RegistroVentasGrifo? grifoSeleccionado = null;
    private bool _shouldScrollSelectedCell = false;
    private List<string> clientesLeidosModal = new();

    // Custom modern confirmation modal state
    private bool mostrarModalConfirm = false;
    private string confirmTitulo = "";
    private string confirmMensaje = "";
    private string confirmTipo = "danger"; // "danger" or "warning"
    private Action? confirmAccion = null;

    private void MostrarConfirmacion(string titulo, string mensaje, string tipo, Action accion)
    {
        confirmTitulo = titulo;
        confirmMensaje = mensaje;
        confirmTipo = tipo;
        confirmAccion = accion;
        mostrarModalConfirm = true;
    }

    private void AceptarConfirmacion()
    {
        mostrarModalConfirm = false;
        confirmAccion?.Invoke();
        confirmAccion = null;
    }

    private void CancelarConfirmacion()
    {
        mostrarModalConfirm = false;
        confirmAccion = null;
    }

    public class CeldaExcelInfo
    {
        public string Valor { get; set; } = "";
        public string ColorFondoHex { get; set; } = "";
        public string ColorTextoHex { get; set; } = "";
        public bool IsBold { get; set; }
        public bool IsItalic { get; set; }
        public int? FontSize { get; set; }
        public string Alignment { get; set; } = ""; // "left", "center", "right"
    }

    private bool mostrarModalVerPlantilla = false;
    private string plantillaExcelNombre = "";
    private List<List<CeldaExcelInfo>> plantillaExcelFilas = new();
    private List<double> plantillaExcelColumnWidths = new();
    private List<string> plantillaExcelHojas = new();
    private string plantillaExcelHojaSeleccionada = "";

    private readonly string[] mapeoFilasKeys = { };

    private readonly string[] columnasEscrituraKeys = {
        "TarjetaLiquidos", "TarjetaGLP", "DescLiquidos", "DescGLP"
    };

    private bool mostrarModalNuevoGrifo = false;
    private string nuevoGrifoNombre = "";

    private bool mostrarModalCliente = false;
#pragma warning disable CS0414
    private bool isEditingClient = false;
#pragma warning restore CS0414
    private int editingClienteId = 0;
    private string nuevoClienteColumna = "";
    private string nuevoClienteNombre = "";

    protected override void OnInitialized()
    {
        System.Text.Encoding.RegisterProvider(System.Text.CodePagesEncodingProvider.Instance);
        CargarConfiguracion();
        CargarNombreArchivoRegistroVentas();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScrollSelectedCell)
        {
            _shouldScrollSelectedCell = false;
            await Task.Delay(250); // Give the modal animations and rendering enough time to stabilize
            try
            {
                await JSRuntime.InvokeVoidAsync("scrollSelectedCellIntoView");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error triggering scrollSelectedCellIntoView: " + ex.Message);
            }
        }
    }

    private string archivoRegistroVentasNombre = "";
    private bool viendoRegistroVentasModal = false;

    private void CargarNombreArchivoRegistroVentas()
    {
        try
        {
            string dir = Path.Combine(ConfiguracionService.ObtenerWebRootPath(env.WebRootPath), "bd", "RegistroVentas", "RegistroVentas");
            if (Directory.Exists(dir))
            {
                var files = Directory.GetFiles(dir, "*.xlsx");
                if (files.Length > 0)
                {
                    archivoRegistroVentasNombre = Path.GetFileName(files[0]);
                    return;
                }
            }
        }
        catch {}
        archivoRegistroVentasNombre = "";
    }

    private string GetWriteConfigValue(string propName)
    {
        if (grifoSeleccionado?.RegistroDescuentosWrite == null) return "";
        return propName switch
        {
            "ColumnaFecha" => grifoSeleccionado.RegistroDescuentosWrite.ColumnaFecha,
            "TarjetaLiquidos" => grifoSeleccionado.RegistroDescuentosWrite.TarjetaLiquidos,
            "TarjetaGLP" => grifoSeleccionado.RegistroDescuentosWrite.TarjetaGLP,
            "DescLiquidos" => grifoSeleccionado.RegistroDescuentosWrite.DescLiquidos,
            "DescGLP" => grifoSeleccionado.RegistroDescuentosWrite.DescGLP,
            _ => ""
        };
    }

    private List<string> writeProps = new List<string> { "ColumnaFecha", "TarjetaLiquidos", "TarjetaGLP", "DescLiquidos", "DescGLP" };

    private string GetFriendlyWriteLabel(string propName)
    {
        return propName switch
        {
            "ColumnaFecha" => "Columna Fecha",
            "TarjetaLiquidos" => "Tarjeta Líquidos",
            "TarjetaGLP" => "Tarjeta GLP",
            "DescLiquidos" => "Desc. Líquidos",
            "DescGLP" => "Desc. GLP",
            _ => propName
        };
    }


    private void LimpiarWriteCol(string propName)
    {
        SetWriteConfigValue(propName, "");
        ToastService.Success($"Columna para {GetFriendlyWriteLabel(propName)} removida.");
    }

    private void SetWriteConfigValue(string propName, string? val)
    {
        if (grifoSeleccionado?.RegistroDescuentosWrite == null) return;
        var prop = typeof(RegistroDescuentosWriteConfig).GetProperty(propName);
        prop?.SetValue(grifoSeleccionado.RegistroDescuentosWrite, val ?? "");
        StateHasChanged();
    }

    private void CargarConfiguracion()
    {
        grifosList = ConfiguracionService.ObtenerGrifosDB();
        if (grifoSeleccionado != null)
        {
            var fresh = grifosList.Find(g => g.Id == grifoSeleccionado.Id);
            if (fresh != null)
            {
                grifoSeleccionado = fresh;
            }
        }
    }

    private string GetConfigValue(string propName, bool isCol)
    {
        if (grifoSeleccionado == null) return "";
        string dbFieldName = (isCol ? "Col_" : "Fila_") + propName;
        var prop = typeof(RegistroVentasConfiguracion).GetProperty(dbFieldName);
        return (prop?.GetValue(grifoSeleccionado.Configuracion) as string) ?? "";
    }

    private string GetConfigLabel(string propName, bool isCol)
    {
        string val = GetConfigValue(propName, isCol);
        if (string.IsNullOrWhiteSpace(val)) return "Sin Valor";
        
        if (!isCol) // Row configurations
        {
            int colIndex = -1;
            int rowIndex = -1;
            
            if (val.Contains(","))
            {
                var parts = val.Split(',');
                if (parts.Length == 2 && int.TryParse(parts[0], out int c) && int.TryParse(parts[1], out int r))
                {
                    colIndex = c;
                    rowIndex = r;
                }
            }
            else if (int.TryParse(val, out int r))
            {
                rowIndex = r;
                string customCol = GetConfigValue(propName, true);
                if (!string.IsNullOrWhiteSpace(customCol))
                {
                    int parsedCol = ConfiguracionService.GetExcelColumnIndex(customCol);
                    if (parsedCol >= 0)
                    {
                        colIndex = parsedCol;
                    }
                }
            }
            
            if (colIndex >= 0 && rowIndex >= 1)
            {
                string colLetter = GetExcelColumnName(colIndex);
                return $"{colLetter}{rowIndex}";
            }
            
            return $"Fila {val}"; // legacy fallback
        }
        return val; // columns
    }

    private string GetConfigLabelFull(string propName)
    {
        string val = GetConfigValue(propName, false);
        if (string.IsNullOrWhiteSpace(val)) return "Sin Asignar";
        
        int colIndex = -1;
        int rowIndex = -1;
        
        if (val.Contains(","))
        {
            var parts = val.Split(',');
            if (parts.Length == 2 && int.TryParse(parts[0], out int c) && int.TryParse(parts[1], out int r))
            {
                colIndex = c;
                rowIndex = r;
            }
        }
        else if (int.TryParse(val, out int r))
        {
            rowIndex = r;
            string customCol = GetConfigValue(propName, true);
            if (!string.IsNullOrWhiteSpace(customCol))
            {
                int parsedCol = ConfiguracionService.GetExcelColumnIndex(customCol);
                if (parsedCol >= 0)
                {
                    colIndex = parsedCol;
                }
            }
        }
        
        if (colIndex >= 0 && rowIndex >= 1)
        {
            string colLetter = GetExcelColumnName(colIndex);
            return $"{colLetter}{rowIndex} (Columna: {colIndex}, Fila: {rowIndex})";
        }
        
        return $"Fila {val}";
    }

