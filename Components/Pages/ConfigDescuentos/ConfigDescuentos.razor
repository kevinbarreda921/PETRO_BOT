@page "/ConfigDescuentos"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using PETRO_BOT.Services.Services
@using PETRO_BOT.Models.Configuracion
@using System.IO
@using System.Text.Json
@using ExcelDataReader
@using OfficeOpenXml
@using OfficeOpenXml.Style
@using Microsoft.AspNetCore.Components.Routing

<NavigationLock ConfirmExternalNavigation="@HayCambiosSinGuardar()" OnBeforeInternalNavigation="ConfirmExit" />

<div class="flex flex-col gap-6 animate-new-row">

    <!-- ============================================== -->
    <!-- MAIN GRID: THE SYSTEM CONTROL & CONFIGURATION -->
    <!-- ============================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

        <!-- Left Column (col-span-4): Fuel stations selector list, styled like mockup breakdown -->
        <div class="lg:col-span-4 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 animate-fade-in-up anim-delay-75" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full overflow-hidden">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                    <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Config. Descuentos - Grifos</h3>
                    <button @onclick="AbrirModalAgregarGrifo" class="bg-[#0f172a] hover:bg-slate-800 text-white text-[9px] font-black uppercase tracking-wider rounded-xl px-3.5 py-2 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-1.5 cursor-pointer">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                        <span>Agregar nuevo grifo</span>
                    </button>
                </div>

                <!-- Custom station rows in Mockup style -->
                <div class="flex flex-col gap-3 overflow-y-auto custom-scrollbar flex-1 pr-1">
                    @{ int idx = 1; }
                    @foreach (var grifo in grifosList)
                    {
                        var gName = grifo.Nombre;
                        var esSeleccionado = grifoSeleccionado != null && grifo.Id == grifoSeleccionado.Id;
                        var currentIdx = idx++;
                        <div @onclick="() => SeleccionarGrifo(grifo.Id)" 
                             class="flex items-center justify-between group/ch p-3 rounded-2xl border transition-all cursor-pointer animate-fade-in-up @(esSeleccionado ? "bg-[#0f172a] border-[#0f172a] text-white shadow-lg scale-[1.01]" : "bg-transparent border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900")"
                             style="animation-delay: @(currentIdx * 30)ms;">
                            
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 @(esSeleccionado ? "bg-slate-800 border border-slate-700" : "bg-slate-100 border border-slate-200")">
                                    <span class="text-xs font-black @(esSeleccionado ? "text-slate-200" : "text-slate-500")">#@currentIdx</span>
                                </div>
                                <div>
                                    <span class="text-xs font-black block uppercase tracking-wide">@gName</span>
                                    <span class="text-[8px] text-slate-400 font-bold block mt-0.5">Configurado</span>
                                </div>
                            </div>

                            <button class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer @(esSeleccionado ? "bg-slate-800 border border-slate-750 text-white hover:text-slate-100" : "bg-white border border-slate-200 text-slate-700 hover:text-slate-900 hover:border-slate-350")">
                                Config
                            </button>

                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column (col-span-8): Form and active mapping editors, styled like Transaction Perf -->
        <div class="lg:col-span-8 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 overflow-y-auto custom-scrollbar animate-fade-in-up anim-delay-150" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full">
                
                @if (grifoSeleccionado == null)
                {
                    <div class="py-24 flex flex-col items-center justify-center gap-4">
                        <div class="bg-slate-50 p-6 rounded-full border border-slate-200 text-slate-400 shadow-sm">
                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                        </div>
                        <span class="text-[10px] font-black text-slate-450 uppercase tracking-[0.25em]">Selecciona un grifo para editar su mapeo</span>
                    </div>
                }
                else
                {
                    <!-- Active Edit Board form -->
                    <div @key="grifoSeleccionado.Id" class="flex flex-col gap-6 flex-1 min-h-0">
                        
                                        <!-- Header and action bar in ONE row -->
                        <div class="flex flex-col md:flex-row flex-wrap md:items-center justify-between border-b border-slate-150 pb-4 gap-3 w-full animate-fade-in-up anim-delay-75">
                            <!-- Left: Nombre del Grifo Inline -->
                            <div class="flex items-center gap-2 shrink-0 justify-center md:justify-start w-full md:w-auto">
                                <label class="text-[8px] font-black text-slate-400 uppercase tracking-widest shrink-0">Grifo:</label>
                                <input type="text" @bind="grifoSeleccionado.Nombre" class="text-xs font-black text-slate-900 uppercase tracking-wider border border-slate-200 rounded-xl px-3 py-1.5 outline-none focus:border-slate-450 focus:bg-white bg-slate-50 w-32 sm:w-40 transition-all font-bold shrink-0" />
                            </div>


                      

                            <!-- Right: General buttons -->
                            <div class="flex flex-row flex-wrap items-center gap-1.5 shrink-0 justify-center w-full md:w-auto">
                                <button @onclick="ConfirmarEliminarGrifo" class="px-3 py-1.5 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shrink-0">Eliminar</button>
                                <button @onclick="ConfirmarEliminarConfiguracion" class="px-3 py-1.5 bg-amber-50 text-amber-700 border border-amber-200 hover:bg-amber-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shrink-0">Eliminar configuración</button>
                                <button @onclick="CancelarEdicion" class="px-3 py-1.5 bg-white border border-slate-200 text-slate-700 hover:bg-slate-55 hover:text-slate-950 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shrink-0">Cancelar</button>
                                <button @onclick="GuardarConfiguracion" class="px-4 py-1.5 bg-[#0f172a] text-white hover:bg-slate-800 rounded-xl text-[9px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer shrink-0">Guardar</button>
                            </div>
                        </div>

                        
                        <!-- Caja 1: Coordenadas de Lectura (Read-only) -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm animate-fade-in-up anim-delay-150">
                            <div class="flex items-center justify-between border-b border-slate-200 pb-2 mb-4">
                                <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] flex items-center gap-2">
                                    <span class="w-1.5 h-3 bg-[#0f172a] rounded-full"></span> Coordenadas de Lectura (Heredado de Config. Grifos)
                                </h4>
                                <!-- Origen pill moved here -->
                                <div class="flex flex-row items-center gap-2 bg-white border border-slate-200 rounded-xl p-1 px-3 shadow-sm">
                                    <span class="w-1.5 h-1.5 bg-blue-500 rounded-full shrink-0"></span>
                                    <span class="text-[10px] font-bold text-slate-700 truncate max-w-[150px]" title="@archivoRegistroVentasNombre">
                                        @(string.IsNullOrWhiteSpace(archivoRegistroVentasNombre) ? "Reg. Ventas sin cargar" : archivoRegistroVentasNombre)
                                    </span>
                                    <div class="flex items-center gap-1 shrink-0 ml-1">
                                        <InputFile id="registroVentasUpload" OnChange="CargarRegistroVentasArchivo" accept=".xlsx" class="hidden" />
                                        <label for="registroVentasUpload" class="px-3 py-1 bg-[#0f172a] hover:bg-slate-800 text-white rounded-lg text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center justify-center gap-1.5 shadow-sm">
                                            <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                            <span>Cargar Origen</span>
                                        </label>
                                        <button @onclick="AbrirModalVerRegistroVentas" disabled="@(string.IsNullOrWhiteSpace(archivoRegistroVentasNombre))" class="px-3 py-1 bg-[#0f172a] hover:bg-slate-800 text-white disabled:bg-slate-250 disabled:text-slate-400 disabled:cursor-not-allowed rounded-lg text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center justify-center gap-1.5 shadow-sm">
                                            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            <span>Ver</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Hoja Excel</label>
                                    <input type="text" readonly class="w-full rounded-xl px-3 py-2 text-xs font-bold border border-slate-200 bg-slate-100 text-slate-600 select-none outline-none min-h-[34px]" value="@(grifoSeleccionado.RegistroVentasWrite?.NombreHoja)" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Tarjeta Líquidos</label>
                                    <input type="text" readonly class="w-full rounded-xl px-3 py-2 text-xs font-bold border border-slate-200 bg-slate-100 text-slate-600 select-none outline-none min-h-[34px]" value="@(grifoSeleccionado.RegistroVentasWrite?.Total_Tarjeta_de_Credito_Liquidos)" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Tarjeta GLP</label>
                                    <input type="text" readonly class="w-full rounded-xl px-3 py-2 text-xs font-bold border border-slate-200 bg-slate-100 text-slate-600 select-none outline-none min-h-[34px]" value="@(grifoSeleccionado.RegistroVentasWrite?.Total_Tarjeta_de_Credito_GLP)" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Desc. Líquidos</label>
                                    <input type="text" readonly class="w-full rounded-xl px-3 py-2 text-xs font-bold border border-slate-200 bg-slate-100 text-slate-600 select-none outline-none min-h-[34px]" value="@(grifoSeleccionado.RegistroVentasWrite?.DescuentoLiquidos)" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Desc. GLP</label>
                                    <input type="text" readonly class="w-full rounded-xl px-3 py-2 text-xs font-bold border border-slate-200 bg-slate-100 text-slate-600 select-none outline-none min-h-[34px]" value="@(grifoSeleccionado.RegistroVentasWrite?.DescuentoGLP)" />
                                </div>
                            </div>
                        </div>

                        <!-- Caja 2: Coordenadas de Escritura -->
                        <div class="bg-indigo-50/50 border border-indigo-100 rounded-[20px] p-5 shadow-sm animate-fade-in-up anim-delay-200 mt-6 mb-8">
                            <div class="flex items-center justify-between border-b border-indigo-200 pb-2 mb-4">
                                <h4 class="text-[9px] font-black text-indigo-800 uppercase tracking-[0.15em] flex items-center gap-2">
                                    <span class="w-1.5 h-3 bg-indigo-600 rounded-full"></span> Coordenadas de Escritura (Mapeo de Descuentos)
                                </h4>
                                <!-- Destino pill moved here -->
                                <div class="flex flex-row items-center gap-2 bg-white border border-indigo-200 rounded-xl p-1 px-3 shadow-sm">
                                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full shrink-0"></span>
                                    <span class="text-[10px] font-bold text-indigo-900 truncate max-w-[150px]" title="@grifoSeleccionado.RegistroDescuentosWrite?.Plantilla">
                                        @(string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.Plantilla) ? "Plantilla sin cargar" : grifoSeleccionado.RegistroDescuentosWrite?.Plantilla)
                                    </span>
                                    <div class="flex items-center gap-1 shrink-0 ml-1">
                                        <InputFile id="fileUpload" OnChange="CargarPlantillaArchivo" accept=".xlsx" class="hidden" />
                                        <label for="fileUpload" class="px-3 py-1 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center justify-center gap-1.5 shadow-sm">
                                            <svg class="w-3 h-3 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                            <span>Cargar Destino</span>
                                        </label>
                                        <button @onclick="AbrirModalVerPlantillaSoloVer" disabled="@(string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.Plantilla))" class="px-3 py-1 bg-indigo-600 hover:bg-indigo-700 text-white disabled:bg-indigo-200 disabled:text-indigo-400 disabled:cursor-not-allowed rounded-lg text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center justify-center gap-1.5 shadow-sm">
                                            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            <span>Ver</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Hoja Excel Input -->
                            <div class="flex flex-col gap-1 mb-4 w-1/3">
                                <label class="text-[8px] font-black text-indigo-600 uppercase tracking-wider shrink-0">Hoja Excel:</label>
                                <div class="relative flex items-center">
                                    <button @onclick="AbrirModalHojasRegistroDescuentos" type="button" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300 border text-left select-none cursor-pointer flex items-center justify-between gap-1 min-h-[34px]" style='@(!string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.NombreHoja) ? "background-color: #4f46e5 !important; border-color: #4f46e5 !important; color: #ffffff !important;" : "background-color: #e0e7ff !important; border-color: #c7d2fe !important; color: #4338ca !important;")' title='@(!string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.NombreHoja) ? grifoSeleccionado.RegistroDescuentosWrite.NombreHoja : "ELEGIR HOJA")'>
                                        <span class="truncate">@(!string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.NombreHoja) ? grifoSeleccionado.RegistroDescuentosWrite.NombreHoja : "ELEGIR HOJA")</span>
                                        <svg class="w-3 h-3 ml-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </button>
                                    @if (!string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.NombreHoja))
                                    {
                                        <button @onclick="LimpiarHojaExcelDescuentos" type="button" class="absolute right-1 p-1 bg-white hover:bg-rose-50 border border-slate-200 hover:border-rose-200 rounded-lg text-slate-450 hover:text-rose-600 transition-all cursor-pointer shadow-sm select-none font-bold" title="Limpiar valor">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                                        </button>
                                    }
                                </div>
                            </div>

                            <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
                                @foreach (var prop in writeProps)
                                {
                                    <div class="flex flex-col gap-1">
                                        <label class="text-[8px] font-black text-indigo-600 uppercase truncate" title="@prop">@GetFriendlyWriteLabel(prop)</label>
                                        <div class="relative flex items-center">
                                            <button @onclick="() => ActivarSeleccionWriteCol(prop)" type="button" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300 border text-center select-none cursor-pointer flex items-center justify-center gap-1 min-h-[34px]" style='@(!string.IsNullOrWhiteSpace(GetWriteConfigValue(prop)) ? "background-color: #4f46e5 !important; border-color: #4f46e5 !important; color: #ffffff !important;" : "background-color: #e0e7ff !important; border-color: #c7d2fe !important; color: #4338ca !important;")' title='@(!string.IsNullOrWhiteSpace(GetWriteConfigValue(prop)) ? GetWriteConfigValue(prop) : "Sin Asignar")'>
                                                <span>@(!string.IsNullOrWhiteSpace(GetWriteConfigValue(prop)) ? GetWriteConfigValue(prop) : "Sin Valor")</span>
                                                <svg class="w-3 h-3 ml-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            </button>
                                            @if (!string.IsNullOrWhiteSpace(GetWriteConfigValue(prop)))
                                            {
                                                <button @onclick="() => LimpiarWriteCol(prop)" type="button" class="absolute right-1 p-1 bg-white hover:bg-rose-50 border border-slate-200 hover:border-rose-200 rounded-lg text-slate-450 hover:text-rose-600 transition-all cursor-pointer shadow-sm select-none font-bold" title="Limpiar valor">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- ELASIC DIALOG MODALS IN DARK GLASSMORPHISM -->
<!-- ============================================== -->

<!-- 1. MODAL NUEVO GRIFO -->
@if (mostrarModalNuevoGrifo)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAgregarGrifo"></div>
        <div class="bg-white border border-slate-200 w-full max-w-md rounded-[28px] shadow-2xl overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Agregar Nuevo Grifo</h3>
                <button @onclick="CerrarModalAgregarGrifo" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-55 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Nombre del Grifo</label>
                    <input type="text" @bind="nuevoGrifoNombre" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-800 placeholder-slate-400 outline-none focus:border-slate-450 transition-all text-center uppercase font-bold" placeholder="EJ: BRASIL" />
                </div>
            </div>
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalAgregarGrifo" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cancelar</button>
                <button @onclick="AgregarNuevoGrifo" class="px-5 py-2.5 bg-[#0f172a] text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">Crear Grifo</button>
            </div>
        </div>
    </div>
}



<!-- 3. MODAL VER PLANTILLA EXCEL -->
@if (mostrarModalVerPlantilla)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalVerPlantilla"></div>
        <div class="bg-white border border-slate-200 w-full max-w-[96vw] rounded-[28px] shadow-2xl overflow-hidden flex flex-col hover:border-slate-350 transition-all duration-300 animate-modal-in" style="max-height: 90vh;">
            
            <!-- Modal Header -->
            <div class="px-6 py-5 border-b border-slate-150 flex items-center justify-between bg-slate-50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center border border-emerald-200">
                        <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Previsualización de Plantilla</h3>
                        <span class="text-[9px] text-slate-450 font-bold block uppercase mt-0.5">Archivo: @plantillaExcelNombre</span>
                    </div>
                </div>
                <button @onclick="CerrarModalVerPlantilla" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <!-- Sheet Selector Tabs -->
            @if (!viendoRegistroVentasModal)
            {
                <div class="px-6 py-3 border-b border-slate-100 bg-white flex items-center gap-3 overflow-hidden">
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider shrink-0">Hojas de Trabajo:</span>
                    <div class="flex items-center gap-2 overflow-x-auto pb-1.5 custom-scrollbar flex-1 whitespace-nowrap scroll-smooth">
                        @foreach (var sheet in plantillaExcelHojas)
                        {
                            var esHojaActiva = string.Equals(sheet, plantillaExcelHojaSeleccionada, StringComparison.OrdinalIgnoreCase);
                            <button @onclick="() => CargarDatosHojaExcel(sheet)" 
                                    class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center gap-1.5 shrink-0 @(esHojaActiva ? "bg-emerald-600 text-white shadow-md scale-[1.01]" : "bg-slate-100 hover:bg-slate-200 text-slate-600 hover:text-slate-800 border border-transparent")">
                                <span class="w-1.5 h-1.5 rounded-full @(esHojaActiva ? "bg-white animate-pulse" : "bg-slate-400")"></span>
                                <span>@sheet</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- Modal Body (Excel-like Grid) -->
            <div class="p-6 overflow-hidden bg-slate-50/50 flex-1 flex flex-col">
                @if (columnasEscrituraKeys.Contains(campoSeleccionandoModal) || (campoSeleccionandoModal != null && campoSeleccionandoModal.StartsWith("ClienteColumna_")))
                {
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección de Columna Maestro</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic <strong>ÚNICAMENTE</strong> sobre una celda de la <strong>Fila 10</strong> para establecer su letra como la columna para "<strong>@GetActiveSelectionLabel()</strong>".</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaWriteColDesdePlantilla(-1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }
                else if (campoSeleccionandoModal == "ColumnaFecha")
                {
                    var titleText = "Columna/Fila Fecha";
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección Activo</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic sobre una celda para establecerla como "<strong>@titleText</strong>".</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaDesdePlantilla(-1, -1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }


                @if (plantillaExcelFilas == null || !plantillaExcelFilas.Any())
                {
                    <div class="py-24 flex flex-col items-center justify-center gap-3">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-600"></div>
                        <span class="text-[10px] font-black text-slate-450 uppercase tracking-[0.2em]">Cargando datos de Excel...</span>
                    </div>
                }
                else
                {
                    var maxColCount = plantillaExcelFilas.Max(r => r.Count);
                    
                    <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white flex-1 flex flex-col">
                        <div id="excelPreviewContainer" class="overflow-auto excel-preview-scrollbar flex-1" style="max-height: calc(90vh - 220px);">
                            <table class="w-full border-collapse text-left excel-preview-table">
                                <thead>
                                    <tr class="bg-slate-100 select-none">
                                        <!-- Corner cell -->
                                        <th class="w-12 bg-slate-100 border-r border-b border-slate-300"></th>
                                        @for (int c = 0; c < maxColCount; c++)
                                        {
                                            var letter = GetExcelColumnName(c);
                                            var widthChar = c < plantillaExcelColumnWidths.Count ? plantillaExcelColumnWidths[c] : 12;
                                            var widthPx = Math.Max(60, (int)(widthChar * 8.5));
                                            <th class="px-3 py-2 text-center text-[10px] font-mono font-black text-slate-600 border-r border-b border-slate-300/80 bg-slate-100 notranslate" style="width: @(widthPx)px; min-width: @(widthPx)px; max-width: @(widthPx)px;" translate="no">
                                                @letter
                                            </th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int r = 0; r < plantillaExcelFilas.Count; r++)
                                    {
                                        var rowData = plantillaExcelFilas[r];
                                        var displayRowNumber = r + 1;
                                        bool isSelectingWriteColTr = columnasEscrituraKeys.Contains(campoSeleccionandoModal) || (campoSeleccionandoModal != null && campoSeleccionandoModal.StartsWith("ClienteColumna_"));
                                        bool isRow10Tr = (r == 9);
                                        string trClass = (isSelectingWriteColTr && isRow10Tr) ? "border-b border-slate-700 bg-black text-white" : "hover:bg-slate-50/40 border-b border-slate-200/70";
                                        string tdNumClass = (isSelectingWriteColTr && isRow10Tr) ? "bg-black text-center text-[10px] font-mono font-black text-white border-r border-slate-700 select-none py-2 px-3 w-12 notranslate" : "bg-slate-100 text-center text-[10px] font-mono font-black text-slate-600 border-r border-slate-300/80 select-none py-2 px-3 w-12 notranslate";
                                        
                                        <tr class="@trClass">
                                            <td class="@tdNumClass" translate="no" style="@((isSelectingWriteColTr && isRow10Tr) ? "background-color: #000000; color: #ffffff;" : "")">
                                                @displayRowNumber
                                            </td>
                                            @for (int c = 0; c < maxColCount; c++)
                                            {
                                                var localCol = c;
                                                var celda = localCol < rowData.Count ? rowData[localCol] : null;
                                                var cellValue = celda?.Valor ?? "";
                                                @if (viendoRegistroVentasModal)
                                                {
                                                    var localRow = r;
                                                    bool isRow10 = localRow == 9;
                                                    string mappedProp = "";
                                                    
                                                    string colLetter = GetExcelColumnName(localCol);

                                                    if (grifoSeleccionado?.RegistroVentasWrite != null && isRow10)
                                                    {
                                                        var rv = grifoSeleccionado.RegistroVentasWrite;
                                                        if (string.Equals(rv.Total_Tarjeta_de_Credito_Liquidos, colLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "Tarjeta Líquidos";
                                                        else if (string.Equals(rv.Total_Tarjeta_de_Credito_GLP, colLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "Tarjeta GLP";
                                                        else if (string.Equals(rv.DescuentoLiquidos, colLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "Desc. Líquidos";
                                                        else if (string.Equals(rv.DescuentoGLP, colLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "Desc. GLP";
                                                    }

                                                    bool tieneMapeo = !string.IsNullOrEmpty(mappedProp);

                                                    if (tieneMapeo)
                                                    {
                                                        string extraClass = (mappedProp == "Tarjeta Líquidos") ? "cell-selected" : "";
                                                        <td class="px-3 py-1.5 text-xs border-r text-center select-none cursor-not-allowed font-medium relative overflow-visible @extraClass"
                                                            style="@GetCeldaStyle(celda, false, tieneMapeo)">
                                                            <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                <span>@cellValue</span>
                                                                <div class="premium-tooltip-vertical-gray premium-tooltip-breath-vertical-gray">
                                                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse shrink-0"></span>
                                                                    <span class="font-mono text-[11px]">(@colLetter)</span>
                                                                    <span class="text-center font-extrabold text-blue-200">ASIGNADO A:</span>
                                                                    <span class="text-center font-black">@mappedProp.ToUpper()</span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td class="px-3 py-1.5 text-xs border-r select-none text-center border-slate-200"
                                                            style="@GetCeldaStyle(celda, false, false)"
                                                            title="@cellValue">
                                                            @cellValue
                                                        </td>
                                                    }
                                                }
                                                else
                                                {
                                                    var localRow = r;
                                                    bool isRow10 = localRow == 9;
                                                    
                                                    string mappedProp = "";
                                                    string currentCellLetter = GetExcelColumnName(localCol);
                                                    
                                                    if (isRow10 && grifoSeleccionado?.RegistroDescuentosWrite != null)
                                                    {
                                                        if (string.Equals(grifoSeleccionado.RegistroDescuentosWrite.ColumnaFecha, currentCellLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "ColumnaFecha";
                                                        else if (string.Equals(grifoSeleccionado.RegistroDescuentosWrite.TarjetaLiquidos, currentCellLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "TarjetaLiquidos";
                                                        else if (string.Equals(grifoSeleccionado.RegistroDescuentosWrite.TarjetaGLP, currentCellLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "TarjetaGLP";
                                                        else if (string.Equals(grifoSeleccionado.RegistroDescuentosWrite.DescLiquidos, currentCellLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "DescLiquidos";
                                                        else if (string.Equals(grifoSeleccionado.RegistroDescuentosWrite.DescGLP, currentCellLetter, StringComparison.OrdinalIgnoreCase)) mappedProp = "DescGLP";
                                                    }
                                                    
                                                    bool tieneMapeo = !string.IsNullOrEmpty(mappedProp);
                                                    string propColLetter = GetWriteConfigValue(campoSeleccionandoModal);
                                                    
                                                    // A cell is "esElMismo" if it is row 10 AND its column letter matches what's currently configured for campoSeleccionandoModal
                                                    bool esElMismo = (isRow10 && !string.IsNullOrEmpty(campoSeleccionandoModal) && string.Equals(propColLetter, currentCellLetter, StringComparison.OrdinalIgnoreCase));
                                                    
                                                    string tooltipText = string.IsNullOrEmpty(campoSeleccionandoModal) ? "" : $"{GetFriendlyWriteLabel(campoSeleccionandoModal)} ({currentCellLetter}{localRow + 1})";
                                                    
                                                    if (esElMismo)
                                                    {
                                                        string extraClass = "cell-selected";
                                                        <td @onclick="() => SeleccionarCeldaWriteColDesdePlantilla(localCol)"
                                                            class="px-3 py-1.5 text-xs border-r border-l border-emerald-500 font-black transition-all select-none cursor-pointer text-center relative overflow-visible shadow-lg scale-[1.02] z-10 @extraClass"
                                                            style="@(GetCeldaStyle(celda, esElMismo, tieneMapeo) + "; background-color: #000000 !important; color: #ffffff !important;")"
                                                            title="Haga clic para deseleccionar o reasignar @tooltipText">
                                                            <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                <span>@cellValue</span>
                                                                <div class="premium-tooltip-vertical premium-tooltip-breath-vertical">
                                                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-450 animate-pulse shrink-0"></span>
                                                                    <span class="font-mono text-[11px]">(@currentCellLetter@(localRow + 1))</span>
                                                                    <span class="text-center font-extrabold text-emerald-350">ASIGNANDO A:</span>
                                                                    <span class="text-center font-black">@GetFriendlyWriteLabel(campoSeleccionandoModal).ToUpper()</span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    }
                                                    else if (tieneMapeo)
                                                    {
                                                        string extraClass = (string.IsNullOrEmpty(campoSeleccionandoModal) && (mappedProp == "TarjetaLiquidos" || mappedProp == "Tarjeta Líquidos")) ? "cell-selected" : "";
                                                        <td class="px-3 py-1.5 text-xs border-r text-center select-none cursor-not-allowed font-medium relative overflow-visible @extraClass"
                                                            style="@(GetCeldaStyle(celda, esElMismo, tieneMapeo) + "; background-color: #000000 !important; color: #94a3b8 !important;")">
                                                            <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                <span>@cellValue</span>
                                                                <div class="premium-tooltip-vertical-gray premium-tooltip-breath-vertical-gray">
                                                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-350 animate-pulse shrink-0"></span>
                                                                    <span class="font-mono text-[11px]">(@currentCellLetter@(localRow + 1))</span>
                                                                    <span class="text-center font-extrabold text-slate-300">OCUPADO POR:</span>
                                                                    <span class="text-center font-black">@GetFriendlyWriteLabel(mappedProp).ToUpper()</span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    }
                                                    else if (isRow10)
                                                    {
                                                        string cursorClass = string.IsNullOrEmpty(campoSeleccionandoModal) ? "cursor-default opacity-80" : "cursor-pointer hover:border-emerald-500 hover:scale-[1.01]";
                                                        <td @onclick="() => SeleccionarCeldaWriteColDesdePlantilla(localCol)"
                                                            class="px-3 py-1.5 text-xs border-r font-black transition-all select-none text-center border border-dashed border-slate-400 @cursorClass"
                                                            style="@(GetCeldaStyle(celda, esElMismo, tieneMapeo) + "; background-color: #000000 !important; color: #ffffff !important;")"
                                                            title="@(string.IsNullOrEmpty(campoSeleccionandoModal) ? "" : "Haga clic para asignar " + tooltipText)">
                                                            @cellValue
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td class="px-3 py-1.5 text-xs border-r select-none text-center font-medium opacity-50 cursor-not-allowed"
                                                            style="@GetCeldaStyle(celda, false, false)"
                                                            title="Solo se permite asignar celdas de la fila 10">
                                                            @cellValue
                                                        </td>
                                                    }
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4.5 border-t border-slate-150 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalVerPlantilla" class="px-5 py-2.5 bg-[#0f172a] hover:bg-slate-800 text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">
                    Cerrar Vista
                </button>
            </div>
            
        </div>
    </div>
}

<!-- 4. MODAL CONFIRMACION MODERN Y MINIMALISTA -->
@if (mostrarModalConfirm)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[1000] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CancelarConfirmacion"></div>
        <div class="bg-white border border-slate-200 w-full max-w-sm rounded-[28px] shadow-2xl overflow-hidden flex flex-col">
            <!-- Modal Header -->
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">@confirmTitulo</h3>
                <button @onclick="CancelarConfirmacion" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            
            <!-- Modal Body -->
            <div class="p-8 flex flex-col items-center text-center gap-5">
                @if (confirmTipo == "danger")
                {
                    <div class="w-16 h-16 bg-rose-50 text-rose-500 rounded-full flex items-center justify-center shadow-sm border border-rose-100">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                    </div>
                }
                else
                {
                    <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center shadow-sm border border-amber-100">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                    </div>
                }
                
                <p class="text-xs font-bold text-slate-600 leading-relaxed max-w-[280px]">
                    @confirmMensaje
                </p>
            </div>
            
            <!-- Modal Footer -->
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CancelarConfirmacion" type="button" class="px-4.5 py-2.5 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">
                    Cancelar
                </button>
                @if (confirmTipo == "danger")
                {
                    <button @onclick="AceptarConfirmacion" type="button" class="px-5 py-2.5 bg-rose-500 hover:bg-rose-600 text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">
                        Confirmar Eliminación
                    </button>
                }
                else
                {
                    <button @onclick="AceptarConfirmacion" type="button" class="px-5 py-2.5 bg-amber-500 hover:bg-amber-600 text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">
                        Confirmar Restablecer
                    </button>
                }
            </div>
        </div>
    </div>
}

<style>
    .config-grid {
        display: grid !important;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)) !important;
        gap: 12px !important;
        width: 100% !important;
    }
    .config-grid .flex-col label {
        font-size: 8px !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-transform: uppercase !important;
        display: block !important;
        max-width: 100% !important;
    }
    .config-grid-7 {
        display: grid !important;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)) !important;
        gap: 12px !important;
        width: 100% !important;
    }
    @@media (min-width: 1400px) {
        .config-grid-7 {
            grid-template-columns: repeat(7, 1fr) !important;
        }
    }
    .config-grid-7 .flex-col label {
        font-size: 8px !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-transform: uppercase !important;
        display: block !important;
        max-width: 100% !important;
    }
    @@keyframes pulse-breath {
        0%, 100% {
            opacity: 0.20;
            transform: translate(-50%, -6px) scale(0.95);
        }
        50% {
            opacity: 1;
            transform: translate(-50%, -20px) scale(1.02);
        }
    }
    .premium-tooltip-breath {
        animation: pulse-breath 2.5s ease-in-out infinite !important;
    }
    
    /* Excel Table Sticky Headers and Columns (Freeze Panes) */
    .excel-preview-table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
    }
    .excel-preview-table tbody tr td {
        font-size: 10px !important;
        border-bottom: 1px solid #cbd5e1 !important; /* horizontal borders */
        border-right: 1px solid #cbd5e1 !important;  /* vertical borders */
        background-clip: padding-box !important;
    }
    
    /* Sticky Top Headers (A, B, C...) */
    .excel-preview-table thead tr th {
        position: sticky !important;
        top: 0 !important;
        z-index: 20 !important;
        background-color: #f1f5f9 !important; /* bg-slate-100 uniform background */
        border-bottom: 2px solid #cbd5e1 !important; /* border-slate-300 */
        border-right: 1px solid #cbd5e1 !important;
