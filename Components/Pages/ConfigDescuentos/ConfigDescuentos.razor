        {
            grifoSeleccionado.Configuracion.ColumnaFecha = colIndex;
            grifoSeleccionado.Configuracion.FilaFecha = rowIndex + 1; // 1-based index
            if (colIndex >= 0 && rowIndex >= 0)
            {
                string colLetter = GetExcelColumnName(colIndex);
                int rowNum = rowIndex + 1;
                ToastService.Success($"Celda de Fecha establecida en {colLetter}{rowNum} (Columna: {colIndex}, Fila: {rowNum}). Recuerda Guardar los cambios.");
            }
            else
            {
                ToastService.Success("Celda de Fecha establecida sin valor. Recuerda Guardar los cambios.");
            }
            CerrarModalVerPlantilla();
        }
    }

    private void ActivarSeleccionWriteCol(string propName)
    {
        if (grifoSeleccionado == null) return;
        if (string.IsNullOrWhiteSpace(grifoSeleccionado.RegistroDescuentosWrite?.Plantilla))
        {
            ToastService.Error("Carga primero la plantilla de destino (Descuentos).");
            return;
        }

        campoSeleccionandoModal = propName;
        AbrirModalVerPlantilla();
    }

    private void SeleccionarCeldaWriteColDesdePlantilla(int colIndex)
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(campoSeleccionandoModal)) return;

        if (campoSeleccionandoModal.StartsWith("ClienteColumna_"))
        {
            string clientName = campoSeleccionandoModal.Substring("ClienteColumna_".Length);
            var cli = grifoSeleccionado.ClientesCredito.FirstOrDefault(c => c.ClienteNombre == clientName);
            if (cli != null)
            {
                if (colIndex >= 0)
                {
                    string colLetter = GetExcelColumnName(colIndex);
                    cli.Columna = colLetter;
                    ToastService.Success($"Columna para cliente '{clientName}' establecida en {colLetter}. Recuerda Guardar los cambios.");
                }
                else
                {
                    cli.Columna = "";
                    ToastService.Success($"Columna para cliente '{clientName}' desasignada. Recuerda Guardar los cambios.");
                }
            }
        }
        else
        {
            if (colIndex >= 0)
            {
                string colLetter = GetExcelColumnName(colIndex);
                SetWriteConfigValue(campoSeleccionandoModal, colLetter);
                ToastService.Success($"Columna para {GetFriendlyLabel(campoSeleccionandoModal)} establecida en {colLetter}. Recuerda Guardar los cambios.");
            }
            else
            {
                SetWriteConfigValue(campoSeleccionandoModal, "");
                ToastService.Success($"Columna para {GetFriendlyLabel(campoSeleccionandoModal)} desasignada. Recuerda Guardar los cambios.");
            }
        }
        CerrarModalVerPlantilla();
    }

    private void SeleccionarCeldaFilaDesdePlantilla(int rowIndex, int colIndex)
    {
        // No-op for removed fields
    }

    private string? GetMappedPropertyNameForCell(int localRow, int localCol)
    {
        if (grifoSeleccionado == null) return null;
        var config = grifoSeleccionado.Configuracion;

        if (localCol == config.ColumnaFecha && localRow == (config.FilaFecha - 1))
        {
            return "Fecha";
        }

        return null;
    }

    private void CerrarModalVerPlantilla()
    {
        mostrarModalVerPlantilla = false;
        plantillaExcelFilas.Clear();
        campoSeleccionandoModal = "";
    }

    private string GetExcelColumnName(int columnNumber)
    {
        int dividend = columnNumber + 1;
        string columnName = String.Empty;
        int modulo;

        while (dividend > 0)
        {
            modulo = (dividend - 1) % 26;
            columnName = Convert.ToChar(65 + modulo).ToString() + columnName;
            dividend = (int)((dividend - modulo) / 26);
        }

        return columnName;
    }

    private string GetFriendlyLabel(string? propName)
    {
        if (propName == null) return string.Empty;
        return propName switch
        {
            "Venta_GPL" => "Venta GLP",
            "Venta_GNV" => "Venta GNV",
            "Total_venta_acumulada" => "Total Acumulado",
            "Total_Tarjeta_de_Credito_Liquidos" => "Tarjeta Líquidos",
            "Total_Tarjeta_de_Credito_GLP" => "Tarjeta GLP",
            "Total_Tarjeta_de_Credito_GNV" => "Tarjeta GNV",
            "ErrorMaquina" => "Error Máquina",
            "Recaudo_Cofide_GNV" => "Cofide GNV",
            "Gastos" => "Gastos",
            "Ventas_con_transferencia" => "Transferencia",
            "EESS" => "EESS",
            "ColumnaFecha" => "Fecha",
            "CreditoNombre" => "Crédito Nombre",
            "CreditoMonto" => "Crédito Monto",
            "HermesBanco" => "Hermes Banco",
            "HermesTipo" => "Hermes Tipo",
            "HermesMonto" => "Hermes Monto",
            "FilaFinal" => "Fila Final",
            "DescuentoLiquidos" => "Desc. Líquidos",
            "DescuentoGLP" => "Desc. GLP",
            "Hermes_monto_liquido" => "Hermes Líquidos",
            "Hermes_monto_GLP" => "Hermes GLP",
            "Hermes_monto_GNV1" => "Hermes GNV 1",
            "Hermes_monto_GNV2" => "Hermes GNV 2",
            "VariaCombusNombre" => "Combustible Var. Nombre",
            "VariaCombusMonto" => "Combustible Var. Monto",
            _ => propName.Replace("_", " ")
