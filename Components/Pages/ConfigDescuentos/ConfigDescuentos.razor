    private string GetActiveSelectionLabel()
    {
        if (string.IsNullOrWhiteSpace(campoSeleccionandoModal)) return "";
        if (campoSeleccionandoModal.StartsWith("ClienteColumna_"))
        {
            return "CLIENTE: " + campoSeleccionandoModal.Substring("ClienteColumna_".Length);
        }
        return GetFriendlyLabel(campoSeleccionandoModal);
    }
