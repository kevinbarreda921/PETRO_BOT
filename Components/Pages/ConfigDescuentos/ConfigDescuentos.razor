    private async Task CargarRegistroVentasArchivo(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                string dir = Path.Combine(ConfiguracionService.ObtenerWebRootPath(env.WebRootPath), "bd", "RegistroVentas", "RegistroVentas");
                if (!Directory.Exists(dir))
                {
                    Directory.CreateDirectory(dir);
                }
                else
                {
                    // Clean directory first to ensure only 1 active sales register Excel
                    var existingFiles = Directory.GetFiles(dir, "*.xlsx");
                    foreach (var oldFile in existingFiles)
                    {
                        try { File.Delete(oldFile); } catch {}
                    }
                }

                string ext = Path.GetExtension(file.Name);
                if (ext.ToLower() != ".xlsx")
                {
                    ToastService.Error("Solo se permiten archivos Excel (.xlsx).");
                    return;
                }

                string fileName = file.Name;
                string filePath = Path.Combine(dir, fileName);

                using (var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024))
                using (var fileStream = new FileStream(filePath, FileMode.Create))
                {
                    await stream.CopyToAsync(fileStream);
                }

                CargarNombreArchivoRegistroVentas();
                ToastService.Success($"Archivo de registro de ventas '{fileName}' cargado exitosamente.");
            }
            catch (Exception ex)
            {
                ToastService.Error("Error al cargar el archivo de registro de ventas: " + ex.Message);
            }
        }
    }

    private async Task CargarPlantillaArchivo(InputFileChangeEventArgs e)
    {
        if (grifoSeleccionado == null) return;
