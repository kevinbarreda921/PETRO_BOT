@page "/ImportarPrecioCompra"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@inject PETRO_BOT.Services.Services.ImportarPrecioCompraService PrecioCompraService
@using PETRO_BOT.Models.PrecioCompra
@using System.IO
@using System.Diagnostics
@using System.Linq

<div class="flex flex-col gap-6 animate-new-row">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

        <!-- Left Column: Control & Upload boxes -->
        <div class="lg:col-span-5 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 overflow-y-auto custom-scrollbar relative animate-fade-in-up" style="height: calc(100vh - 160px);">
            @if (isLoading)
            {
                <LoadingRayo />
            }
            <div class="flex flex-col h-full justify-between">
                <div>
                    <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4">
                        <div>
                            <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest block">Centro de Importación Masiva</h3>
                            <span class="text-[10px] text-slate-400 font-bold block mt-0.5">Importar Precio de Compra (hasta 500 archivos Excel)</span>
                        </div>
                    </div>

                    <!-- Caja de Carga Masiva (Hasta 500 Excel) -->
                    <div class="flex flex-col gap-3 mb-6">
                        @if (archivosAdjuntos.Count == 0)
                        {
                            <div class="border-2 border-dashed border-slate-200 hover:border-slate-400 rounded-3xl p-8 flex flex-col items-center justify-center text-center transition-all bg-slate-50/50 hover:bg-slate-50 group relative cursor-pointer">
                                <label for="file-upload-precio-500" class="cursor-pointer flex flex-col items-center gap-3 w-full">
                                    <div class="w-12 h-12 rounded-2xl bg-white border border-slate-200 shadow-sm flex items-center justify-center group-hover:scale-110 transition-transform text-slate-700">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                    </div>
                                    <div>
                                        <span class="text-xs font-black text-slate-800 uppercase tracking-wider block">Adjuntar archivos Excel</span>
                                        <span class="text-[10px] font-bold text-slate-400 block mt-0.5">Puedes seleccionar hasta 500 archivos simultáneamente (.xlsx, .xls)</span>
                                    </div>
                                </label>
                                <InputFile id="file-upload-precio-500" OnChange="SubirArchivosMasivo" multiple accept=".xlsx,.xls" class="hidden" />
                            </div>
                        }
                        else
                        {
                            <div class="relative w-full group">
                                <label for="file-upload-precio-500-add" class="cursor-pointer block w-full">
                                    <div class="bg-emerald-50 border border-emerald-300 rounded-2xl p-4 flex items-center justify-between shadow-sm">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-xl bg-emerald-500 text-white flex items-center justify-center font-black text-xs">EXCEL</div>
                                            <div>
                                                <span class="text-xs font-black text-emerald-950 uppercase tracking-wider block">@archivosAdjuntos.Count archivos adjuntos</span>
                                                <span class="text-[10px] font-bold text-emerald-700 block">Listos para procesar en SQL Server</span>
                                            </div>
                                        </div>
                                        <span class="text-[10px] font-black text-emerald-800 bg-emerald-100 px-3 py-1.5 rounded-xl border border-emerald-300">+ Agregar más</span>
                                    </div>
                                </label>
                                <InputFile id="file-upload-precio-500-add" OnChange="SubirArchivosMasivo" multiple accept=".xlsx,.xls" class="hidden" />
                            </div>
                        }
                    </div>

                    <!-- Estadísticas en Grid -->
                    @if (listaResumenArchivos.Count > 0)
                    {
                        <div class="grid grid-cols-2 gap-3 mb-6">
                            <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Total Archivos</span>
                                <span class="text-lg font-black text-white">@listaResumenArchivos.Count</span>
                            </div>
                            <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm border-l-2 border-emerald-500">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Insertados SQL</span>
                                <span class="text-lg font-black text-emerald-400">@totalRegistrosInsertados</span>
                            </div>
                            <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm border-l-2 border-amber-500">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Con Observaciones</span>
                                <span class="text-lg font-black text-amber-400">@listaResumenArchivos.Count(a => a.TotalErrores > 0)</span>
                            </div>
                            <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Demora Proceso</span>
                                <span class="text-sm font-black text-white">@(tiempoDemoraMs) ms</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Footer Buttons -->
                <div class="flex flex-col sm:flex-row gap-2.5 mt-4">
                    <button disabled="@(archivosAdjuntos.Count == 0 || isLoading)" 
                            @onclick="() => mostrarModalAdjuntos = true" 
                            class="flex-1 bg-white text-slate-700 border border-slate-200 rounded-xl py-3 text-[10px] font-black uppercase tracking-wider hover:bg-slate-50 transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 shadow-sm">
                        Ver adjuntos (@archivosAdjuntos.Count)
                    </button>
                    <button @onclick="EjecutarProceso"
                            disabled="@(archivosAdjuntos.Count == 0 || isLoading)"
                            class="flex-1 bg-[#0f172a] text-white rounded-xl py-3 text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all flex items-center justify-center gap-1.5 cursor-pointer select-none disabled:opacity-50">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <span>Ejecutar Proceso</span>
                    </button>
                    <button disabled="@(archivosAdjuntos.Count == 0 || isLoading)" 
                            @onclick="LimpiarTodo" 
                            class="px-4 py-3 bg-white border border-slate-200 hover:bg-rose-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 shadow-sm text-rose-600">
                        Limpiar
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Column: Processed Files Table -->
        <div class="lg:col-span-7 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 animate-fade-in-up" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full overflow-hidden">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                    <div class="flex items-center gap-2">
                        <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Resultado de Lectura y Registro en BD (SQL Server)</h3>
                        @if (listaResumenArchivos.Count > 0)
                        {
                            <span class="px-2 py-0.5 bg-slate-100 text-[#0f172a] rounded-full text-[9px] font-black select-none">
                                @listaResumenArchivos.Count archivos
                            </span>
                        }
                    </div>
                </div>

                <div class="overflow-auto custom-scrollbar bg-white border border-slate-200 rounded-2xl shadow-sm flex-1">
                    <table class="w-full text-left border-collapse">
                        <thead class="sticky top-0 z-10" style="background-color: #1e293b !important;">
                            <tr class="text-[10px] font-black uppercase tracking-wider" style="color: #ffffff !important;">
                                <th class="py-3 px-4 w-12 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">#</th>
                                <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Archivo Leído</th>
                                <th class="py-3 px-4 w-28 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">Reg. Insertados</th>
                                <th class="py-3 px-4 w-28 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">Estado</th>
                                <th class="py-3 px-4 text-right w-32" style="background-color: #1e293b !important; color: #ffffff !important;">Acción</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs text-slate-700 divide-y divide-slate-100">
                            @if (listaResumenArchivos.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="py-16 text-center text-slate-400 italic font-bold uppercase tracking-widest bg-white text-xs">
                                        Sin archivos procesados
                                    </td>
                                </tr>
                            }
                            else
                            {
                                int cont = 1;
                                @foreach (var archivo in listaResumenArchivos)
                                {
                                    bool esSuccess = archivo.EstadoGeneral == "Success";
                                    <tr class="hover:bg-slate-50/50 transition-all duration-200">
                                        <td class="py-3 px-4 bg-white text-center font-black text-slate-400 text-[10px]">@(cont++).</td>
                                        <td class="py-3 px-4 bg-white">
                                            <div class="flex flex-col">
                                                <span class="text-xs font-black text-slate-800 uppercase tracking-wide truncate">@archivo.HojasResumen</span>
                                                <span class="text-[9px] text-slate-400 font-mono truncate max-w-[240px]" title="@archivo.NombreOriginal">@archivo.NombreOriginal</span>
                                            </div>
                                        </td>
                                        <td class="py-3 px-4 bg-white text-center font-black text-xs text-slate-700">@archivo.TotalRegistrosLeidos</td>
                                        <td class="py-3 px-4 bg-white text-center">
                                            @if (esSuccess)
                                            {
                                                <span class="text-[9px] bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-1 rounded-md font-black uppercase inline-block">Success</span>
                                            }
                                            else if (archivo.TotalRegistrosLeidos > 0)
                                            {
                                                <span class="text-[9px] bg-amber-50 text-amber-700 border border-amber-200 px-2.5 py-1 rounded-md font-black uppercase inline-block">Parcial</span>
                                            }
                                            else
                                            {
                                                <span class="text-[9px] bg-rose-50 text-rose-700 border border-rose-200 px-2.5 py-1 rounded-md font-black uppercase inline-block">Error</span>
                                            }
                                        </td>
                                        <td class="py-3 px-4 bg-white text-right">
                                            <button @onclick="() => AbrirModalDetalle(archivo)"
                                                    class="bg-[#0f172a] text-white hover:bg-slate-800 px-3.5 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all shadow-sm hover:scale-[1.01] active:scale-[0.98] select-none cursor-pointer">
                                                Detalles
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL: Ver Detalles por Archivo -->
@if (mostrarModalDetalle && archivoResumenSeleccionado != null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[9999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalDetalle"></div>
        
        <div class="bg-white border border-slate-200 rounded-[28px] shadow-2xl w-max max-w-[90vw] max-h-[85vh] flex flex-col overflow-hidden relative z-10"
             @onclick:stopPropagation="true">
            
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50 gap-4">
                <div class="min-w-0 flex-1">
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block mb-0.5">Hojas (Grifos): @archivoResumenSeleccionado.HojasResumen</span>
                    <h3 class="text-xs font-bold text-slate-800 font-mono truncate leading-tight select-all">@archivoResumenSeleccionado.NombreOriginal</h3>
                </div>
                <button @onclick="CerrarModalDetalle" 
                        class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- Dashboard de Conteo / Alertas -->
            <div class="grid grid-cols-2 gap-4 px-6 pt-5">
                <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm cursor-pointer transition-all hover:bg-emerald-100/50 @(filtroModalDetalle == "CORRECTO" ? "ring-2 ring-emerald-400 shadow-md scale-[1.02]" : "opacity-80 hover:opacity-100 hover:scale-[1.01]")"
                     @onclick='() => filtroModalDetalle = (filtroModalDetalle == "CORRECTO" ? "TODOS" : "CORRECTO")'>
                    <div>
                        <span class="text-[9px] font-black text-emerald-600 uppercase tracking-wider block mb-1">Registros OK</span>
                        <span class="text-xl font-black text-emerald-800 line-height-1">
                            @archivoResumenSeleccionado.TotalRegistrosLeidos
                        </span>
                    </div>
                    <div class="bg-emerald-100 rounded-xl p-2 flex items-center justify-center text-emerald-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                </div>

                <div class="bg-rose-50 border border-rose-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm cursor-pointer transition-all hover:bg-rose-100/50 @(filtroModalDetalle == "ERROR" ? "ring-2 ring-rose-400 shadow-md scale-[1.02]" : "opacity-80 hover:opacity-100 hover:scale-[1.01]")"
                     @onclick='() => filtroModalDetalle = (filtroModalDetalle == "ERROR" ? "TODOS" : "ERROR")'>
                    <div>
                        <span class="text-[9px] font-black text-rose-600 uppercase tracking-wider block mb-1">Errores / Alertas</span>
                        <span class="text-xl font-black text-rose-800 line-height-1">
                            @archivoResumenSeleccionado.TotalErrores
                        </span>
                    </div>
                    <div class="bg-rose-100 rounded-xl p-2 flex items-center justify-center text-rose-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                </div>
            </div>

            <!-- Tabla de Detalles / Registros leídos -->
            <div class="p-6 overflow-y-auto flex-1 custom-scrollbar">
                <div class="overflow-hidden bg-white border border-slate-200 rounded-2xl shadow-sm">
                    <table class="w-full text-left border-collapse">
                        <thead style="background-color: #1e293b !important;">
                            <tr class="text-[10px] font-black uppercase tracking-wider" style="color: #ffffff !important;">
                                <th class="py-3 px-4 w-36" style="background-color: #1e293b !important; color: #ffffff !important;">Hoja (Grifo) / Fila</th>
                                <th class="py-3 px-4 w-28 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">Estado</th>
                                <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Detalle / Producto, Galones y Precio</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs text-slate-700 divide-y divide-slate-100">
                        @{
                            var detallesMostrados = archivoResumenSeleccionado.Detalles.Where(d => 
                                filtroModalDetalle == "TODOS" || 
                                (filtroModalDetalle == "CORRECTO" && d.Estado == "Correcto") ||
                                (filtroModalDetalle == "ERROR" && d.Estado != "Correcto")
                            ).ToList();
                        }
                        @if (detallesMostrados.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="py-8 text-center text-slate-400 italic font-medium">
                                    No hay registros para mostrar bajo el filtro seleccionado.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var det in detallesMostrados)
                            {
                                bool ok = det.Estado == "Correcto";
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">
                                        <span class="block text-xs font-black">@det.NombreHoja</span>
                                        @if (det.Fila > 0)
                                        {
                                            <span class="text-[10px] text-slate-400 font-mono">Fila #@det.Fila</span>
                                        }
                                    </td>
                                    <td class="py-3 px-4 text-center whitespace-nowrap">
                                        @if (ok)
                                        {
                                            <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Correcto
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 bg-rose-50 text-rose-700 border border-rose-200 px-2.5 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider">
                                                <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> @det.Estado
                                            </span>
                                        }
                                    </td>
                                    <td class="py-3 px-4 font-mono text-[11px] text-slate-600 break-words">
                                        @if (ok)
                                        {
                                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                                                <span class="font-bold text-slate-800">@det.DescripcionProducto</span>
                                                <div class="flex items-center gap-2">
                                                    <span class="font-bold text-slate-600 bg-slate-100 border border-slate-200 px-2 py-0.5 rounded text-[10px]">Gal: @det.CantidadGalones.ToString("N4")</span>
                                                    <span class="font-black text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded text-[10px]">S/ @det.PrecioGalon.ToString("N4")</span>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            @det.Mensaje
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
                <button @onclick="CerrarModalDetalle"
                        class="px-6 py-2 bg-[#0f172a] text-white hover:bg-slate-800 rounded-xl text-xs font-black uppercase tracking-wider shadow-md transition-all cursor-pointer">
                    Cerrar
                </button>
            </div>
        </div>
    </div>
}

<!-- MODAL: Ver Adjuntos -->
@if (mostrarModalAdjuntos)
{
    <div class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl max-w-2xl w-full p-6 shadow-2xl border border-slate-100 flex flex-col gap-4 animate-scale-up" style="max-height: 80vh;">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                <h3 class="text-sm font-black text-slate-800 uppercase tracking-wider">Archivos Adjuntos (@archivosAdjuntos.Count / 500)</h3>
                <button @onclick="() => mostrarModalAdjuntos = false" class="p-2 bg-slate-100 hover:bg-slate-200 rounded-full text-slate-600 font-bold">✕</button>
            </div>

            <div class="overflow-y-auto custom-scrollbar flex-1 flex flex-col gap-2 pr-1">
                @for (int i = 0; i < archivosAdjuntos.Count; i++)
                {
                    int index = i;
                    string arch = filesNombresOriginales.ContainsKey(archivosAdjuntos[index]) ? filesNombresOriginales[archivosAdjuntos[index]] : Path.GetFileName(archivosAdjuntos[index]);
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-200 flex items-center justify-between text-xs font-bold text-slate-700">
                        <span class="truncate pr-2">@(index + 1). @arch</span>
                        <button @onclick="() => EliminarAdjunto(index)" class="text-rose-600 hover:text-rose-800 font-black px-2 py-1 bg-rose-50 hover:bg-rose-100 rounded-lg text-[10px]">Quitar</button>
                    </div>
                }
            </div>

            <div class="flex justify-end gap-2 pt-2 border-t border-slate-100">
                <button @onclick="LimpiarTodo" class="px-4 py-2 bg-rose-50 text-rose-700 hover:bg-rose-100 rounded-xl text-xs font-bold uppercase">Eliminar Todos</button>
                <button @onclick="() => mostrarModalAdjuntos = false" class="px-5 py-2 bg-[#0f172a] text-white rounded-xl text-xs font-bold uppercase shadow-md">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = false;
    private List<string> archivosAdjuntos = new();
    private Dictionary<string, string> filesNombresOriginales = new();
    private bool mostrarModalAdjuntos = false;
    
    private List<ArchivoProcesadoPrecioCompraLog> logsProcesamiento = new();
    private List<ArchivoPrecioCompraResumen> listaResumenArchivos = new();

    private bool mostrarModalDetalle = false;
    private ArchivoPrecioCompraResumen? archivoResumenSeleccionado = null;
    private string filtroModalDetalle = "TODOS";

    private int totalRegistrosInsertados = 0;
    private long tiempoDemoraMs = 0;

    public class ArchivoPrecioCompraResumen
    {
        public string NombreArchivo { get; set; } = "";
        public string NombreOriginal { get; set; } = "";
        public string HojasResumen { get; set; } = "";
        public int TotalRegistrosLeidos { get; set; }
        public int TotalErrores { get; set; }
        public string EstadoGeneral { get; set; } = "";
        public List<ArchivoProcesadoPrecioCompraLog> Detalles { get; set; } = new();
    }

    private void AbrirModalDetalle(ArchivoPrecioCompraResumen resumen)
    {
        archivoResumenSeleccionado = resumen;
        filtroModalDetalle = "TODOS";
        mostrarModalDetalle = true;
    }

    private void CerrarModalDetalle()
    {
        mostrarModalDetalle = false;
        archivoResumenSeleccionado = null;
    }

    private async Task SubirArchivosMasivo(InputFileChangeEventArgs e)
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            string carpeta = Path.Combine(env.WebRootPath, "uploads", "PrecioCompra");
            if (!Directory.Exists(carpeta)) Directory.CreateDirectory(carpeta);

            foreach (var file in e.GetMultipleFiles(500))
            {
                if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) && 
                    !file.Name.EndsWith(".xls", StringComparison.OrdinalIgnoreCase)) continue;
                    
                string nombreUnico = $"{Guid.NewGuid()}_{file.Name}";
                string rutaCompleta = Path.Combine(carpeta, nombreUnico);

                using var fs = new FileStream(rutaCompleta, FileMode.Create);
                await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(fs);

                archivosAdjuntos.Add(rutaCompleta);
                filesNombresOriginales[rutaCompleta] = file.Name;
            }

            ToastService.Success($"{archivosAdjuntos.Count} archivos Excel adjuntados listos para procesar.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error adjuntando archivos: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void EliminarAdjunto(int index)
    {
        if (index >= 0 && index < archivosAdjuntos.Count)
        {
            string ruta = archivosAdjuntos[index];
            archivosAdjuntos.RemoveAt(index);
            filesNombresOriginales.Remove(ruta);
            try { if (File.Exists(ruta)) File.Delete(ruta); } catch { }
        }
        if (archivosAdjuntos.Count == 0) mostrarModalAdjuntos = false;
    }

    private void LimpiarTodo()
    {
        foreach (var ruta in archivosAdjuntos)
        {
            try { if (File.Exists(ruta)) File.Delete(ruta); } catch { }
        }
        archivosAdjuntos.Clear();
        filesNombresOriginales.Clear();
        logsProcesamiento.Clear();
        listaResumenArchivos.Clear();
        totalRegistrosInsertados = 0;
        tiempoDemoraMs = 0;
        mostrarModalAdjuntos = false;
        mostrarModalDetalle = false;
    }

    private async Task EjecutarProceso()
    {
        if (archivosAdjuntos.Count == 0) return;
        try
        {
            isLoading = true;
            logsProcesamiento.Clear();
            listaResumenArchivos.Clear();
            StateHasChanged();

            var sw = Stopwatch.StartNew();
            var res = await PrecioCompraService.ProcesarArchivosMasivoAsync(archivosAdjuntos);
            sw.Stop();

            logsProcesamiento = res.Logs;
            totalRegistrosInsertados = res.Insertados;
            tiempoDemoraMs = sw.ElapsedMilliseconds;

            var grupos = logsProcesamiento.GroupBy(l => l.NombreArchivo);
            foreach (var g in grupos)
            {
                var logs = g.ToList();
                int regsOk = logs.Count(l => l.Estado == "Correcto");
                int errs = logs.Count(l => l.Estado != "Correcto");
                
                var hojasDistintas = logs.Where(l => !string.IsNullOrEmpty(l.NombreHoja)).Select(l => l.NombreHoja).Distinct().ToList();
                string hojasTxt = hojasDistintas.Count > 0 ? string.Join(", ", hojasDistintas) : "Sin Hojas";

                string orig = g.Key;
                foreach (var kvp in filesNombresOriginales)
                {
                    if (kvp.Key.EndsWith(g.Key) || g.Key.EndsWith(Path.GetFileName(kvp.Key)))
                    {
                        orig = kvp.Value;
                        break;
                    }
                }

                listaResumenArchivos.Add(new ArchivoPrecioCompraResumen
                {
                    NombreArchivo = g.Key,
                    NombreOriginal = orig,
                    HojasResumen = hojasTxt,
                    TotalRegistrosLeidos = regsOk,
                    TotalErrores = errs,
                    EstadoGeneral = regsOk > 0 && errs == 0 ? "Success" : (regsOk > 0 ? "Parcial" : "Error"),
                    Detalles = logs
                });
            }

            ToastService.Success($"Proceso completado. {totalRegistrosInsertados} registros insertados en PETRO.PRECIO_COMPRA.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al ejecutar proceso: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}
