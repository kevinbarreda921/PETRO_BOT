<style>
    .lightning-draw {
        stroke-dasharray: 100;
        stroke-dashoffset: 100;
        animation: drawBolt 1.6s ease-in-out infinite;
    }
    
    @@keyframes drawBolt {
        0% { stroke-dashoffset: 100; fill: transparent; }
        35% { stroke-dashoffset: 0; fill: transparent; }
        50% { fill: #0f172a; filter: drop-shadow(0 0 12px rgba(15, 23, 42, 0.45)); stroke-dashoffset: 0; }
        75% { fill: transparent; stroke-dashoffset: 0; }
        100% { stroke-dashoffset: 100; fill: transparent; }
    }
</style>

<!-- MAIN OVERLAY (Blocks clicks and blurs the background elegantly) -->
<div class="absolute top-0 left-0 w-full h-full bg-white/80 backdrop-blur-[6px] z-[100] flex flex-col items-center justify-center rounded-[28px] cursor-wait outline-none border border-slate-200/30"
     @onclick:stopPropagation="true"
     @onclick:preventDefault="true"
     @onmousedown:stopPropagation="true"
     @onmousedown:preventDefault="true">
    
    <!-- CONTAINER (pointer-events-none) -->
    <div class="pointer-events-none flex flex-col items-center select-none">
        
        <!-- Glowing Lightning Bolt SVG -->
        <div class="mb-5 relative flex items-center justify-center">
            <svg focusable="false" class="w-12 h-12 text-[#0f172a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path class="lightning-draw" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" pathLength="100" 
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
        </div>

        <!-- Sleek glowing bouncing dots -->
        <div class="flex items-center gap-1.5 mb-2.5">
            <div class="w-1.5 h-1.5 rounded-full bg-[#0f172a] animate-bounce" style="animation-delay: -0.3s; box-shadow: 0 0 8px rgba(15, 23, 42, 0.25)"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#0f172a] animate-bounce" style="animation-delay: -0.15s; box-shadow: 0 0 8px rgba(15, 23, 42, 0.25)"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#0f172a] animate-bounce" style="box-shadow: 0 0 8px rgba(15, 23, 42, 0.25)"></div>
        </div>
        <span class="text-[9px] font-black text-slate-800 uppercase tracking-[0.25em] animate-pulse">
            Procesando
        </span>
        
    </div>
    
</div>

