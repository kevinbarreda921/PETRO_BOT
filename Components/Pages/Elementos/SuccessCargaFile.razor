<!-- SECCIÓN CARGA DE ARCHIVO -->
<div class="space-y-2">
    <div class="group relative w-full bg-emerald-50 border-2 border-emerald-200 rounded-2xl px-4 py-2 flex items-center justify-between transition-all">
        <!-- Texto e info del archivo a la izquierda -->
        <div class="flex items-center gap-2">
            <div class="flex flex-col">
                <span class="text-[11px] font-bold text-emerald-700 leading-tight">@File</span>
                <span class="text-[9px] text-emerald-500/80 font-medium">Archivo adjuntado con éxito</span>
            </div>
        </div>
        
        <!-- Icono de éxito a la derecha -->
        <div class="p-1.5 bg-white rounded-lg shadow-sm text-emerald-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string File { get; set; }
}
