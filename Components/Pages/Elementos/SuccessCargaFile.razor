<!-- SECTION SUCCESS FILE ATTACHED (LIGHT MODE CAPSULE) -->
<div class="space-y-2 animate-new-row">
    <div class="group relative w-full bg-emerald-50/65 border border-emerald-300 rounded-2xl px-4 py-3 flex items-center justify-between transition-all hover:border-emerald-400 hover:shadow-md">
        
        <!-- Text and File details -->
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-emerald-600 shrink-0">
                <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </div>
            <div class="flex flex-col">
                <span class="text-[11px] font-black text-emerald-800 leading-tight font-mono truncate max-w-[200px]">@File</span>
                <span class="text-[8px] text-emerald-600 font-bold uppercase tracking-wider mt-0.5">Adjuntado con éxito</span>
            </div>
        </div>
        
        <!-- Success icon badge -->
        <div class="p-1 bg-emerald-500 border border-emerald-400 rounded-lg text-white shadow-sm">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>

    </div>
</div>

@code {
    [Parameter]
    public string File { get; set; }
}
