@using PETRO_BOT.Services.Toast
@inject ToastService ToastService
@implements IDisposable

<div class="fixed bottom-5 right-5 z-[9999] flex flex-col gap-3">
    @if (Visible)
    {
        <div class="
            flex items-center gap-4
            min-w-[320px] max-w-[380px]
            bg-white/95 backdrop-blur-2xl
            border border-slate-200/80
            @GetBorderColor()
            shadow-2xl shadow-slate-900/10
            rounded-2xl
            px-5 py-4
            animate-toast-in">

            <!-- Glowing Icon Badge -->
            <div class="w-9 h-9 rounded-xl @GetIconBg() flex items-center justify-center shrink-0 shadow-sm">
                @if (Type?.ToLower() == "success")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                }
                else if (Type?.ToLower() == "error")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                }
                else if (Type?.ToLower() == "warning")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                }
            </div>

            <!-- Content detail -->
            <div class="flex-1 min-w-0">
                <p class="font-black text-slate-850 text-[13px] uppercase tracking-wider">
                    @Title
                </p>
                <p class="text-slate-500 text-xs mt-1 leading-tight font-medium">
                    @Message
                </p>
            </div>

            <!-- Close cross -->
            <button @onclick="Close"
                    class="text-slate-400 hover:text-slate-700 transition-colors p-1 rounded-lg hover:bg-slate-50 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>

        </div>
    }
</div>

<style>
    @@keyframes toast-pop {
        0% {
            opacity: 0;
            transform: scale(0.9) translateY(15px) translateX(15px);
        }
        100% {
            opacity: 1;
            transform: scale(1) translateY(0) translateX(0);
        }
    }

    .animate-toast-in {
        animation: toast-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
</style>

@code {
    private bool Visible;
    private string Message = "";
    private string Title = "";
    private string Type = "success";

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
    }

    private string GetBorderColor() => Type?.ToLower() switch
    {
        "success" => "border-l-[4px] border-l-emerald-500 shadow-emerald-500/5",
        "error" => "border-l-[4px] border-l-rose-500 shadow-rose-500/5",
        "warning" => "border-l-[4px] border-l-amber-500 shadow-amber-500/5",
        "info" => "border-l-[4px] border-l-blue-500 shadow-blue-500/5",
        _ => "border-l-[4px] border-l-slate-400"
    };

    private string GetIconBg() => Type?.ToLower() switch
    {
        "success" => "bg-emerald-50 border border-emerald-100",
        "error" => "bg-rose-50 border border-rose-100",
        "warning" => "bg-amber-50 border border-amber-100",
        "info" => "bg-blue-50 border border-blue-100",
        _ => "bg-slate-100"
    };

    private string GetTitleEs(string type) => type?.ToLower() switch
    {
        "success" => "Éxito",
        "error" => "Error",
        "warning" => "Advertencia",
        "info" => "Información",
        _ => "Notificación"
    };

    private async void ShowToast(string message, string type)
    {
        Message = message;
        Type = type;
        Title = GetTitleEs(type);

        Visible = true;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(3500);

        if (Visible) await Close();
    }

    private async Task Close()
    {
        Visible = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
    }
}