@page "/"
@using PETRO_BOT.Services.Shared
@using PETRO_BOT.Models.Log
@inject HistorialService HistorialService

<div class="flex flex-col gap-6 animate-fade-in-up">
    <!-- 1. Top 4 Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        
        <!-- Card 1: Total días de ejecución -->
        <div class="bg-white border border-slate-200 rounded-3xl p-6 hover:shadow-lg transition-all duration-300">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">Total días de ejecución</span>
            <div class="flex items-center justify-between">
                <h3 class="text-3xl font-black text-slate-800">@TotalDiasUso <span class="text-sm text-slate-500 font-bold">días</span></h3>
                <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-800">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
            </div>
            <span class="text-xs text-slate-400 font-medium mt-3 block">Total de días con actividad</span>
        </div>

        <!-- Card 2: Racha de uso -->
        <div class="bg-white border border-slate-200 rounded-3xl p-6 hover:shadow-lg transition-all duration-300">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">Racha de uso</span>
            <div class="flex items-center justify-between">
                <h3 class="text-3xl font-black text-slate-800">@RachaUso <span class="text-sm text-slate-500 font-bold">consecutivos</span></h3>
                <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-800">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
            </div>
            <span class="text-xs text-slate-400 font-medium mt-3 block">Mayor cantidad de días seguidos</span>
        </div>

        <!-- Card 3: Tiempo total de ejecución -->
        <div class="bg-white border border-slate-200 rounded-3xl p-6 hover:shadow-lg transition-all duration-300">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">Tiempo de Ejecución</span>
            <div class="flex items-center justify-between">
                <h3 class="text-3xl font-black text-slate-800">@TiempoTotalFormateado</h3>
                <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-800">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
            </div>
            <span class="text-xs text-slate-400 font-medium mt-3 block">Tiempo real consumido por los bots</span>
        </div>

        <!-- Card 4: Tiempo manual ahorrado -->
        <div class="bg-slate-800 border border-slate-700 rounded-3xl p-6 hover:shadow-lg transition-all duration-300 relative overflow-hidden">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-slate-700/50 rounded-full blur-xl"></div>
            <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest block mb-2 relative z-10">Tiempo Manual Ahorrado</span>
            <div class="flex items-center justify-between relative z-10">
                <h3 class="text-2xl font-black text-white">@TiempoAhorradoFormateado</h3>
                <div class="w-10 h-10 rounded-full bg-slate-700/50 border border-slate-600 flex items-center justify-center text-emerald-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
            </div>
            <span class="text-xs text-slate-400 font-medium mt-3 block relative z-10">Equivalente en jornadas laborales</span>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
        <!-- 2. Gráfico Dona -->
        <div class="xl:col-span-4 bg-white border border-slate-200 rounded-3xl p-6 flex flex-col justify-between hover:shadow-lg transition-all duration-300">
            <div>
                <h3 class="text-sm font-black text-slate-800 mb-1">Tiempo de Ejecución vs Ahorro Manual</h3>
                <span class="text-xs text-slate-400 font-medium block mb-6">Proporción de eficiencia generada</span>
            </div>
            <div class="relative flex items-center justify-center py-4">
                <svg viewBox="0 0 36 36" class="w-48 h-48 drop-shadow-xl transform -rotate-90">
                    <!-- Base ring -->
                    <path class="text-slate-100" stroke-width="3.8" stroke="currentColor" fill="none"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    <!-- Time Execution ring (Lighter #1e293b -> #475569) -->
                    <path class="text-slate-500" stroke-width="3.8" stroke-dasharray="@PorcentajeEjecucion, 100" stroke-linecap="round" stroke="currentColor" fill="none"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    <!-- Saved Time ring (Darker #1e293b) -->
                    <path class="text-slate-800" stroke-width="3.8" stroke-dasharray="@PorcentajeAhorro, 100" stroke-dashoffset="-@PorcentajeEjecucion" stroke-linecap="round" stroke="currentColor" fill="none"
                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                </svg>
                <div class="absolute flex flex-col items-center justify-center">
                    <span class="text-3xl font-black text-slate-800">@((int)PorcentajeAhorro)%</span>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mt-1">Eficiencia</span>
                </div>
            </div>
            <div class="flex justify-center gap-6 mt-4 border-t border-slate-100 pt-4">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-slate-800"></span>
                    <span class="text-xs font-bold text-slate-600">Manual Ahorrado</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-slate-500"></span>
                    <span class="text-xs font-bold text-slate-600">Tiempo de Bot</span>
                </div>
            </div>
        </div>

        <!-- 3. Panel Totales -->
        <div class="xl:col-span-4 bg-white border border-slate-200 rounded-3xl p-6 hover:shadow-lg transition-all duration-300">
            <h3 class="text-sm font-black text-slate-800 mb-6">Totales Globales</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-3 rounded-2xl bg-slate-50 border border-slate-100">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Archivos Procesados</span>
                        <span class="text-sm font-bold text-slate-800 mt-1">@TotalArchivosProcesados archivos</span>
                    </div>
                </div>
                <div class="flex items-center justify-between p-3 rounded-2xl bg-slate-50 border border-slate-100">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Tiempo Total de Ejecución</span>
                        <span class="text-sm font-bold text-slate-800 mt-1">@TiempoTotalFormateado</span>
                    </div>
                </div>
                <div class="flex items-center justify-between p-3 rounded-2xl bg-slate-50 border border-slate-100">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Tiempo Manual Ahorrado</span>
                        <span class="text-sm font-bold text-emerald-600 mt-1">@TiempoAhorradoFormateado</span>
                    </div>
                </div>
                <div class="flex items-center justify-between p-3 rounded-2xl bg-slate-50 border border-slate-100">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Robots Ejecutados</span>
                        <span class="text-sm font-bold text-slate-800 mt-1">@TotalRobotsEjecutados ejecuciones</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. Calendario -->
        <div class="xl:col-span-4 bg-white border border-slate-200 rounded-3xl p-6 hover:shadow-lg transition-all duration-300">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-sm font-black text-slate-800">Calendario de Ejecuciones</h3>
                <div class="flex gap-2">
                    <button @onclick="IrMesAnterior" disabled="@(!PuedeIrAtras)" class="w-8 h-8 rounded-full border flex items-center justify-center transition-all @(PuedeIrAtras ? "border-slate-200 text-slate-600 hover:bg-slate-50" : "border-slate-100 text-slate-300 cursor-not-allowed")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <button @onclick="IrMesSiguiente" disabled="@(!PuedeIrAdelante)" class="w-8 h-8 rounded-full border flex items-center justify-center transition-all @(PuedeIrAdelante ? "border-slate-200 text-slate-600 hover:bg-slate-50" : "border-slate-100 text-slate-300 cursor-not-allowed")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>
            
            <div class="text-center mb-4">
                <span class="text-xs font-black text-slate-800 uppercase tracking-widest">@MesVisualizado.ToString("MMMM yyyy").ToUpper()</span>
            </div>

            <div class="grid grid-cols-7 gap-1 text-center mb-2">
                @foreach (var d in new[] {"LU", "MA", "MI", "JU", "VI", "SA", "DO"}) {
                    <span class="text-[9px] font-black text-slate-400">@d</span>
                }
            </div>

            <div class="grid grid-cols-7 gap-1">
                @for (int i = 0; i < ObtenerDesfasePrimerDia(); i++)
                {
                    <div class="h-8"></div>
                }
                @for (int d = 1; d <= DateTime.DaysInMonth(MesVisualizado.Year, MesVisualizado.Month); d++)
                {
                    var fechaActual = new DateTime(MesVisualizado.Year, MesVisualizado.Month, d);
                    bool tieneActividad = DiasConActividad.Contains(fechaActual.Date);
                    
                    <div class="h-8 flex items-center justify-center rounded-lg text-xs font-bold transition-all @(tieneActividad ? "bg-slate-800 text-white shadow-md cursor-pointer hover:bg-slate-700" : "text-slate-500 hover:bg-slate-50")">
                        @d
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 5. Reporte Final (Últimos 30 Procesos) -->
    <div class="bg-white border border-slate-200 rounded-3xl p-6 hover:shadow-lg transition-all duration-300 mb-6">
        <h3 class="text-sm font-black text-slate-800 mb-1">Últimos 30 Procesos</h3>
        <span class="text-xs text-slate-400 font-medium block mb-6">Rendimiento e historial reciente</span>
        
        <div class="w-full h-64 relative flex items-end justify-center gap-2 px-2 pt-10">
            @if (UltimosProcesos.Any())
            {
                var maxArchivos = UltimosProcesos.Max(x => x.TotalArchivos) == 0 ? 1 : UltimosProcesos.Max(x => x.TotalArchivos);
                var maxTiempo = UltimosProcesos.Max(x => x.TiempoEjecucionSegundos) == 0 ? 1 : UltimosProcesos.Max(x => x.TiempoEjecucionSegundos);

                @for (int i = 0; i < UltimosProcesos.Count; i++)
                {
                    var proceso = UltimosProcesos[i];
                    var heightPercentArchivos = (double)proceso.TotalArchivos / maxArchivos * 100;
                    if (heightPercentArchivos < 5) heightPercentArchivos = 5;
                    
                    var heightPercentTiempo = (double)proceso.TiempoEjecucionSegundos / maxTiempo * 100;
                    if (heightPercentTiempo < 5) heightPercentTiempo = 5;

                    <div class="flex-1 max-w-[48px] flex items-end justify-center group relative h-full gap-0.5">
                        <!-- Tooltip Hover -->
                        <div class="absolute bottom-full mb-2 bg-slate-900 text-white text-[10px] p-2 rounded-xl shadow-xl opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50 pointer-events-none">
                            <div class="font-black border-b border-slate-700 pb-1 mb-1">@proceso.FechaHora.ToString("dd/MM/yy HH:mm")</div>
                            <div class="text-slate-300">Archivos: <span class="font-bold text-white">@proceso.TotalArchivos</span></div>
                            <div class="text-slate-300">Tiempo: <span class="font-bold text-white">@proceso.TiempoEjecucionSegundos.ToString("F1")s</span></div>
                            <div class="text-slate-300">Ahorro: <span class="font-bold text-emerald-400">@(proceso.TotalDiasCorrectos * 10) min</span></div>
                        </div>

                        <!-- Barra de Archivos -->
                        <div class="w-1/2 bg-slate-800 rounded-t-sm hover:bg-slate-700 transition-colors" style="height: @(heightPercentArchivos)%;"></div>

                        <!-- Barra de Tiempo -->
                        <div class="w-1/2 bg-slate-400 rounded-t-sm hover:bg-slate-300 transition-colors" style="height: @(heightPercentTiempo)%;"></div>
                    </div>
                }
            }
            else
            {
                <div class="w-full h-full flex items-center justify-center text-slate-400 text-sm font-bold">
                    No hay datos suficientes para mostrar el gráfico.
                </div>
            }
        </div>
        
        <div class="flex justify-center gap-6 mt-6 border-t border-slate-100 pt-4">
            <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-sm bg-slate-800"></span>
                <span class="text-xs font-bold text-slate-600">Cantidad de Archivos</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-sm bg-slate-400"></span>
                <span class="text-xs font-bold text-slate-600">Tiempo de Ejecución</span>
            </div>
        </div>
    </div>
</div>

@code {
    private List<HistorialEjecucion> historial = new();
    
    // 1. Indicadores
    private int TotalDiasUso = 0;
    private int RachaUso = 0;
    private string TiempoTotalFormateado = "0s";
    private string TiempoAhorradoFormateado = "0 h";
    
    // 2. Gráficos
    private double PorcentajeEjecucion = 0;
    private double PorcentajeAhorro = 0;
    
    // 3. Totales
    private int TotalArchivosProcesados = 0;
    private int TotalRobotsEjecutados = 0;
    
    // 4. Calendario
    private DateTime MesVisualizado;
    private HashSet<DateTime> DiasConActividad = new();
    private bool PuedeIrAtras => MesVisualizado.Month == DateTime.Today.Month; // Solo permite ir 1 mes atrás (si está en actual)
    private bool PuedeIrAdelante => MesVisualizado.Month < DateTime.Today.Month; // Solo permite ir a actual (si está 1 mes atrás)
    
    // 5. Últimos 30
    private List<HistorialEjecucion> UltimosProcesos = new();

    protected override void OnInitialized()
    {
        MesVisualizado = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        CargarDatos();
    }

    private void CargarDatos()
    {
        historial = HistorialService.ObtenerHistorial();

        if (historial.Any())
        {
            // --- 1. Top Indicadores ---
            var diasDistintos = historial.Select(h => h.FechaHora.Date).Distinct().OrderBy(d => d).ToList();
            TotalDiasUso = diasDistintos.Count;
            RachaUso = CalcularRacha(diasDistintos);

            double segundosTotales = historial.Sum(h => h.TiempoEjecucionSegundos);
            TiempoTotalFormateado = FormatearTiempo(segundosTotales);

            int minutosAhorrados = historial.Sum(h => h.TotalDiasCorrectos) * 10;
            TiempoAhorradoFormateado = FormatearAhorroManual(minutosAhorrados);

            // --- 2. Dona ---
            double totalSumaMins = (segundosTotales / 60) + minutosAhorrados;
            if (totalSumaMins > 0)
            {
                PorcentajeEjecucion = ((segundosTotales / 60) / totalSumaMins) * 100;
                PorcentajeAhorro = 100 - PorcentajeEjecucion;
            }

            // --- 3. Panel Totales ---
            TotalArchivosProcesados = historial.Sum(h => h.TotalArchivos);
            TotalRobotsEjecutados = historial.Count;

            // --- 4. Calendario ---
            DiasConActividad = new HashSet<DateTime>(diasDistintos);

            // --- 5. Últimos 30 Procesos ---
            // Tomamos los últimos 30 procesos (los más recientes), pero los ordenamos cronológicamente para el gráfico de izq a der.
            UltimosProcesos = historial.OrderByDescending(h => h.FechaHora).Take(30).OrderBy(h => h.FechaHora).ToList();
        }
    }

    private int CalcularRacha(List<DateTime> dias)
    {
        if (!dias.Any()) return 0;
        int maxRacha = 1;
        int rachaActual = 1;

        for (int i = 1; i < dias.Count; i++)
        {
            if ((dias[i] - dias[i - 1]).TotalDays == 1)
            {
                rachaActual++;
                if (rachaActual > maxRacha) maxRacha = rachaActual;
            }
            else
            {
                rachaActual = 1;
            }
        }
        return maxRacha;
    }

    private string FormatearTiempo(double segundosTotales)
    {
        TimeSpan t = TimeSpan.FromSeconds(segundosTotales);
        if (t.TotalHours >= 1) return $"{(int)t.TotalHours}h {t.Minutes}m";
        if (t.TotalMinutes >= 1) return $"{t.Minutes}m {t.Seconds}s";
        return $"{t.Seconds:F1}s";
    }

    private string FormatearAhorroManual(int minutosAhorrados)
    {
        int totalHoras = minutosAhorrados / 60;
        int minutosRestantes = minutosAhorrados % 60;
        int diasLaborables = totalHoras / 8;
        int horasRestantes = totalHoras % 8;

        if (diasLaborables > 0)
        {
            string strDias = diasLaborables == 1 ? "1 día lab." : $"{diasLaborables} días lab.";
            if (horasRestantes > 0) return $"{strDias} {horasRestantes} h";
            if (minutosRestantes > 0) return $"{strDias} {minutosRestantes} min";
            return strDias;
        }
        if (totalHoras > 0) return $"{totalHoras} h {minutosRestantes} min";
        return $"{minutosRestantes} min";
    }

    // Calendario Helpers
    private int ObtenerDesfasePrimerDia()
    {
        int desfase = (int)MesVisualizado.DayOfWeek - 1;
        if (desfase < 0) desfase = 6; // Lunes = 0, Domingo = 6
        return desfase;
    }

    private void IrMesAnterior()
    {
        if (PuedeIrAtras) MesVisualizado = MesVisualizado.AddMonths(-1);
    }

    private void IrMesSiguiente()
    {
        if (PuedeIrAdelante) MesVisualizado = MesVisualizado.AddMonths(1);
    }
}