@page "/"

@using PETRO_BOT.Services.Toast
@inject ToastService ToastService

<div class="flex flex-col lg:flex-row gap-6 items-start">
    <div class="w-full bg-white rounded-[35px] p-8 shadow-sm flex flex-col gap-6 relative z-30 border border-slate-50">
        <h2 class="text-xs font-black text-slate-800 uppercase tracking-widest border-b border-slate-50 pb-4">Inicio</h2>

        <div class="flex gap-3 p-10">

       

        </div>
    </div>
</div>

@code {

private void ShowSuccess()
{
ToastService.Success("Registro guardado correctamente.");
}

private void ShowError()
{
ToastService.Error("Ocurrió un error inesperado.");
}

private void ShowWarning()
{
ToastService.Warning("Debes completar los campos.");
}

private void ShowInfo()
{
ToastService.Info("Nueva actualización disponible.");
}

}