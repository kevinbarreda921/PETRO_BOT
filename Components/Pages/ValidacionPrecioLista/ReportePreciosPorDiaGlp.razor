@page "/ReportePreciosPorDiaGlp"
@using System.Data
@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using PETRO_BOT.Services.Services
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject ValidacionPrecioService ValidacionPrecioService
@inject ToastService ToastService
@inject IJSRuntime JSRuntime

<PageTitle>Validación precio lista - Reporte de Precios por Día GLP</PageTitle>

<div class="w-full flex flex-col gap-6 animate-fade-in-up h-[calc(100vh-135px)] min-h-[600px] overflow-hidden select-none" @onclick="CerrarMenus" @onmouseup="FinalizarSeleccion">

    @if (cargandoInicial)
    {
        <LoadingRayo />
    }
    else if (!hayRegistrosBD)
    {
        <div class="bg-white border border-slate-200/60 rounded-[30px] p-16 max-w-xl mx-auto text-center shadow-xs my-auto flex flex-col items-center justify-center" @onclick:stopPropagation="true">
            <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-amber-200 shadow-2xs">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-base font-black text-slate-800 uppercase tracking-wider mb-2">Reporte de Precios por Día GLP</h3>
            <p class="text-xs text-slate-500 font-medium">Importar ventas para poder generar reporte</p>
        </div>
    }
    else
    {
        <!-- CAJA 1: SELECTORES MINIMALISTAS Y BOTÓN DESCARGA (AL CENTRO) -->
        <div class="bg-white border border-slate-200/60 rounded-[30px] p-6 shrink-0 shadow-xs flex flex-col items-center justify-center w-full relative z-40" @onclick:stopPropagation="true">
            <div class="flex flex-col md:flex-row items-center justify-center gap-6 w-full max-w-4xl mx-auto">
                
                <!-- SELECT 1 CUSTOM: GRIFO -->
                <div class="relative w-full md:w-80">
                    <label class="text-[10px] font-black uppercase tracking-wider text-slate-500 flex items-center gap-1.5 mb-1.5">
                        <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                        <span>Grifo (Local)</span>
                    </label>
                    <div class="relative">
                        <button type="button" 
                                @onclick="ToggleGrifo"
                                class="w-full bg-slate-50 border @(menuGrifoAbierto ? "border-[#0f172a] ring-2 ring-slate-900/10 bg-white" : "border-slate-200 hover:border-slate-300") rounded-2xl px-4 py-3.5 text-xs font-bold text-slate-800 flex items-center justify-between transition-all cursor-pointer text-left shadow-2xs">
                            <span class="truncate">@(string.IsNullOrEmpty(localSeleccionado) ? "-- Seleccione Grifo --" : localSeleccionado)</span>
                            <svg class="w-4 h-4 text-slate-400 shrink-0 transition-transform @(menuGrifoAbierto ? "rotate-180 text-slate-800" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>

                        @if (menuGrifoAbierto)
                        {
                            <div class="absolute z-50 top-full mt-2 w-full bg-white border border-slate-200 rounded-2xl shadow-2xl max-h-60 overflow-y-auto custom-scrollbar p-1.5 animate-fade-in-down">
                                @foreach (var loc in listaLocales)
                                {
                                    <div @onclick="() => SeleccionarLocal(loc)"
                                         class="px-3.5 py-2.5 rounded-xl text-xs font-bold cursor-pointer transition-all flex items-center justify-between @(loc == localSeleccionado ? "bg-[#0f172a] text-white shadow-sm" : "text-slate-700 hover:bg-slate-100")">
                                        <span class="truncate">@loc</span>
                                        @if (loc == localSeleccionado)
                                        {
                                            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- SELECT 2 CUSTOM: PERIODO -->
                <div class="relative w-full md:w-64">
                    <label class="text-[10px] font-black uppercase tracking-wider text-slate-500 flex items-center gap-1.5 mb-1.5">
                        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span>Periodo (Mes)</span>
                    </label>
                    <div class="relative">
                        <button type="button" 
                                disabled="@(string.IsNullOrEmpty(localSeleccionado) || !listaPeriodos.Any())"
                                @onclick="TogglePeriodo"
                                class="w-full bg-slate-50 border @(menuPeriodoAbierto ? "border-[#0f172a] ring-2 ring-slate-900/10 bg-white" : "border-slate-200 hover:border-slate-300") rounded-2xl px-4 py-3.5 text-xs font-bold text-slate-800 flex items-center justify-between transition-all cursor-pointer text-left shadow-2xs disabled:opacity-40 disabled:cursor-not-allowed">
                            <span class="truncate">@(string.IsNullOrEmpty(periodoSeleccionado) ? "-- Seleccione Periodo --" : periodoSeleccionado)</span>
                            <svg class="w-4 h-4 text-slate-400 shrink-0 transition-transform @(menuPeriodoAbierto ? "rotate-180 text-slate-800" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>

                        @if (menuPeriodoAbierto)
                        {
                            <div class="absolute z-50 top-full mt-2 w-full bg-white border border-slate-200 rounded-2xl shadow-2xl max-h-60 overflow-y-auto custom-scrollbar p-1.5 animate-fade-in-down">
                                @foreach (var per in listaPeriodos)
                                {
                                    <div @onclick="() => SeleccionarPeriodo(per)"
                                         class="px-3.5 py-2.5 rounded-xl text-xs font-bold cursor-pointer transition-all flex items-center justify-between @(per == periodoSeleccionado ? "bg-[#0f172a] text-white shadow-sm" : "text-slate-700 hover:bg-slate-100")">
                                        <span class="truncate">@per</span>
                                        @if (per == periodoSeleccionado)
                                        {
                                            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- BOTONES DESCARGAR -->
                <div class="flex flex-col sm:flex-row gap-2 w-full md:w-auto self-end pt-5 md:pt-0">
                    <button type="button"
                            disabled="@(dtSP == null || dtSP.Rows.Count == 0 || cargandoSP || estaProcesando)"
                            @onclick="DescargarExcel"
                            class="bg-emerald-600 hover:bg-emerald-700 active:scale-[0.98] text-white font-black text-[10px] uppercase tracking-wider px-5 py-3.5 rounded-2xl transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed h-[44px]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        <span>Descargar Excel</span>
                    </button>
                    <button type="button"
                            disabled="@(!hayRegistrosBD || estaProcesando || cargandoSP)"
                            @onclick="AbrirModalMasivoAsync"
                            class="bg-blue-600 hover:bg-blue-700 active:scale-[0.98] text-white font-black text-[10px] uppercase tracking-wider px-5 py-3.5 rounded-2xl transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed h-[44px]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                        <span>Descargar Masivo</span>
                    </button>
                </div>

            </div>
        </div>

        <!-- CAJA 2: RESULTADOS SP (VISTA CELDAS EXCEL CON SCROLL Y SELECCIÓN) -->
        <div class="bg-white border border-slate-200/60 rounded-[30px] p-6 flex-1 flex flex-col min-h-0 overflow-hidden relative shadow-xs z-10" @onclick:stopPropagation="true">
            <div class="flex items-center justify-between pb-4 mb-4 border-b border-slate-100 shrink-0 select-none">
                <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest flex items-center gap-1.5">
                    <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span>Resultados Reporte SP GLP</span>
                    @if (dtSP != null && dtSP.Rows.Count > 0)
                    {
                        <span class="ml-2 bg-slate-100 text-slate-700 font-mono text-[10px] px-2.5 py-0.5 rounded-full font-bold">@dtSP.Rows.Count filas</span>
                    }
                </h3>

                <div class="flex items-center gap-4">
                    <button type="button"
                            @onclick="QuitarSeleccion"
                            class="@(haySeleccionFirme ? "bg-slate-900 hover:bg-black text-white border-slate-700 shadow-md" : "bg-slate-200 hover:bg-slate-300 text-slate-700 border-slate-300") font-black text-[10px] uppercase tracking-wider px-4 py-2 rounded-xl transition-all flex items-center gap-2 cursor-pointer border active:scale-95">
                        <svg class="w-3.5 h-3.5 @(haySeleccionFirme ? "text-rose-400" : "text-slate-500")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                        <span>Quitar Selección@(haySeleccionFirme ? $" ({ObtenerTextoConteoSeleccion()})" : "")</span>
                    </button>
                    @if (cargandoSP)
                    {
                        <span class="text-xs text-blue-500 font-bold animate-pulse flex items-center gap-2 font-mono">
                            <svg class="animate-spin h-4 w-4 text-blue-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            Consumiendo SP GLP...
                        </span>
                    }
                </div>
            </div>

            <!-- TABLA EXCEL CON SCROLL VERTICAL Y HORIZONTAL -->
            <div class="flex-1 overflow-auto min-h-0 border border-slate-300 bg-slate-50 rounded-xl custom-scrollbar relative select-none" @onmouseleave="FinalizarSeleccion" @onmouseup="FinalizarSeleccion">
                @if (string.IsNullOrEmpty(localSeleccionado) || string.IsNullOrEmpty(periodoSeleccionado))
                {
                    <div class="h-full flex items-center justify-center text-slate-400 font-mono text-xs italic">
                        Seleccione un grifo y un periodo en la parte superior para generar el reporte GLP.
                    </div>
                }
                else if (dtSP == null || dtSP.Rows.Count == 0)
                {
                    <div class="h-full flex items-center justify-center text-slate-400 font-mono text-xs italic">
                        @(cargandoSP ? "" : "No hay registros devueltos por el procedimiento almacenado para el grifo y periodo seleccionados.")
                    </div>
                }
                else
                {
                    <table class="w-full text-left border-collapse font-mono text-xs bg-white select-none">
                        <thead class="sticky top-0 z-20 font-bold tracking-wider text-[11px] shadow-sm select-none text-slate-900 border-b border-slate-300">
                            @if (dtSP.Columns.Count >= 4 && dtSP.Columns[1].ColumnName.Equals("DIAS", StringComparison.OrdinalIgnoreCase))
                            {
                                <tr>
                                    <th rowspan="2" class="py-2.5 px-3 border-b border-r border-slate-700 bg-[#0f172a] text-white text-center w-12 shrink-0 align-middle">#</th>
                                    <th rowspan="2" class="py-2.5 px-3 border-b border-r border-slate-300 bg-[#ffff99] text-slate-900 text-center uppercase whitespace-nowrap align-middle font-black">FECHA</th>
                                    <th rowspan="2" class="py-2.5 px-3 border-b border-r border-slate-300 bg-[#ffff99] text-slate-900 text-center uppercase whitespace-nowrap align-middle font-black">DIAS</th>
                                    <th colspan="2" class="py-2 px-3 border-b border-r border-slate-300 bg-[#d9d9d9] text-slate-900 text-center uppercase whitespace-nowrap font-black">G-84</th>
                                </tr>
                                <tr>
                                    <th class="py-2 px-3 border-b border-r border-slate-300 bg-[#ffff99] text-slate-900 text-center uppercase whitespace-nowrap font-bold">VENTA GALONES</th>
                                    <th class="py-2 px-3 border-b border-r border-slate-300 bg-[#ffff99] text-slate-900 text-center uppercase whitespace-nowrap font-bold">PRECIO VENTA</th>
                                </tr>
                            }
                            else
                            {
                                <tr class="bg-[#0f172a] text-white">
                                    <th class="py-2.5 px-3 border-b border-r border-slate-700 bg-[#0f172a] text-center w-12 shrink-0">#</th>
                                    @foreach (DataColumn col in dtSP.Columns)
                                    {
                                        <th class="py-2.5 px-3 border-b border-r border-slate-700 bg-[#0f172a] uppercase whitespace-nowrap">@col.ColumnName</th>
                                    }
                                </tr>
                            }
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            @for (int r = 0; r < dtSP.Rows.Count; r++)
                            {
                                int rowIdx = r;
                                var row = dtSP.Rows[r];
                                string? valFecha = ObtenerValorFechaTurno(row);
                                bool repetida = valFecha != null && fechasRepetidas.Contains(valFecha);
                                string diaStr = row.Table.Columns.Contains("DIAS") ? (row["DIAS"]?.ToString() ?? "") : "";
                                bool esDomingo = diaStr.Equals("DOMINGO", StringComparison.OrdinalIgnoreCase);

                                <tr class="select-none @(haySeleccionFirme ? "bg-transparent" : (esDomingo ? "bg-[#80ff80]" : "bg-white"))">
                                    <td @onmousedown="QuitarSeleccion" class="py-1.5 px-3 border-r border-b border-slate-200 text-center text-slate-400 bg-slate-100 font-bold select-none cursor-pointer">@(r + 1)</td>
                                    @for (int c = 0; c < dtSP.Columns.Count; c++)
                                    {
                                        int colIdx = c;
                                        string colName = dtSP.Columns[c].ColumnName;
                                        string valStr = FormatearCelda(row[c], colName);
                                        bool esCero = EsValorCero(valStr);
                                        bool esColFechaODia = colName.Equals("FECHA_TURNO", StringComparison.OrdinalIgnoreCase) || colName.Equals("DIAS", StringComparison.OrdinalIgnoreCase);

                                        bool enRango = EstaCeldaEnRango(rowIdx, colIdx);

                                        string claseCelda = "";
                                        if (haySeleccionFirme)
                                        {
                                            if (enRango)
                                            {
                                                claseCelda = "bg-[#0f172a] border-slate-800 shadow-sm z-10 text-white font-bold";
                                                if (esCero) claseCelda += " opacity-40 font-normal";
                                            }
                                            else
                                            {
                                                claseCelda = esDomingo ? "bg-[#80ff80] text-slate-900 border-slate-300 opacity-60 font-bold" : (repetida && esColFechaODia ? "bg-[#ffe699] text-slate-900 border-slate-300 opacity-60 font-bold" : "bg-slate-100 text-slate-400 border-slate-300 opacity-45");
                                            }
                                        }
                                        else if (estaArrastrando && enRango)
                                        {
                                            claseCelda = "bg-blue-100 border-blue-300 text-blue-950 font-bold";
                                        }
                                        else
                                        {
                                            if (esDomingo)
                                            {
                                                claseCelda = "bg-[#80ff80] border-slate-300 text-slate-950 font-bold hover:brightness-95 transition-all";
                                            }
                                            else if (repetida && esColFechaODia)
                                            {
                                                claseCelda = "bg-[#ffe699] border-slate-300 text-slate-950 font-bold hover:brightness-95 transition-all";
                                            }
                                            else
                                            {
                                                claseCelda = "bg-white border-slate-200 text-slate-800 hover:bg-blue-100 hover:ring-2 hover:ring-blue-400 hover:z-20 hover:text-slate-900 transition-all";
                                            }
                                            if (esCero && !esDomingo) claseCelda += " opacity-30 text-slate-400 font-normal";
                                        }

                                        <td @onmousedown="() => IniciarSeleccion(rowIdx, colIdx)"
                                            @onmouseenter="() => ActualizarSeleccion(rowIdx, colIdx)"
                                            class="py-1.5 px-3 border-r border-b whitespace-nowrap cursor-cell select-none @claseCelda @(c >= 2 ? "text-right" : "text-center")">
                                            @valStr
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                        <tfoot class="sticky bottom-0 z-20 bg-slate-100 text-slate-900 font-bold tracking-wider text-xs shadow-lg select-none border-t-2 border-slate-400">
                            <tr>
                                <td class="py-2.5 px-3 border-r border-slate-300 text-center bg-slate-200 text-slate-600 font-black">∑</td>
                                @{
                                    int numDias = dtSP.AsEnumerable().Select(r => ObtenerValorFechaTurno(r)).Where(f => !string.IsNullOrEmpty(f)).Distinct().Count();
                                }
                                @for (int c = 0; c < dtSP.Columns.Count; c++)
                                {
                                    string colName = dtSP.Columns[c].ColumnName;
                                    if (c == 0)
                                    {
                                        <td colspan="2" class="py-2.5 px-3 border-r border-t border-slate-300 bg-white text-slate-900 font-black text-center uppercase whitespace-nowrap">
                                            @($"{numDias} DÍAS")
                                        </td>
                                    }
                                    else if (c == 1)
                                    {
                                        <!-- Cubierto por colspan=2 -->
                                    }
                                    else if (EsColumnaDeTotal(colName))
                                    {
                                        decimal total = CalcularTotalTabla(dtSP, colName);
                                        <td class="py-2.5 px-3 border-r border-t border-slate-300 bg-[#99ff99] text-slate-950 font-black italic text-right whitespace-nowrap shadow-inner">
                                            @total.ToString("N2")
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="py-2.5 px-3 border-r border-t border-slate-300 bg-white whitespace-nowrap"></td>
                                    }
                                }
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    }

</div>

@if (mostrarModalMasivo)
{
    <div class="fixed inset-0 z-[9999] flex items-center justify-center bg-slate-950/75 backdrop-blur-md animate-fade-in p-4 sm:p-6 lg:p-10" @onclick="() => mostrarModalMasivo = false">
        <div class="bg-white border border-slate-200 rounded-[32px] p-6 sm:p-8 lg:p-10 max-w-6xl w-full h-[85vh] max-h-[850px] min-h-[500px] shadow-2xl flex flex-col gap-6 overflow-hidden cursor-default animate-scale-up" @onclick:stopPropagation="true">
            <!-- Header -->
            <div class="flex items-center justify-between border-b border-slate-100 pb-4 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 shadow-inner">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 012-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-black text-slate-800 uppercase tracking-wide">Descarga Masiva Consolidada GLP</h3>
                        <p class="text-xs text-slate-400 font-mono">Seleccione los grifos y periodos a consolidar en un solo Excel multigrifo GLP</p>
                    </div>
                </div>
                <button type="button" @onclick="() => mostrarModalMasivo = false" class="text-slate-400 hover:text-slate-600 p-2 rounded-xl hover:bg-slate-100 transition-all cursor-pointer">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Body (2 Columnas Grandes Responsive) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 overflow-hidden flex-1 min-h-0">
                <!-- Caja Grifos -->
                <div class="border border-slate-200 bg-slate-50 rounded-2xl p-4 sm:p-5 flex flex-col gap-3 overflow-hidden h-full shadow-xs">
                    <div class="flex items-center justify-between border-b border-slate-200 pb-3 shrink-0">
                        <label class="flex items-center gap-2.5 text-xs font-black text-slate-700 cursor-pointer select-none">
                            <input type="checkbox" checked="@(localesSeleccionadosMasivo.Count == localesMasivo.Count && localesMasivo.Count > 0)" @onchange="ToggleSeleccionarTodosLocales" class="rounded text-blue-600 focus:ring-blue-500 w-4 h-4 cursor-pointer" />
                            <span>TODOS LOS GRIFOS (@localesSeleccionadosMasivo.Count/@localesMasivo.Count)</span>
                        </label>
                    </div>
                    <div class="overflow-y-auto custom-scrollbar flex-1 flex flex-col gap-1.5 pr-1 min-h-0">
                        @foreach (var loc in localesMasivo)
                        {
                            <label class="flex items-center gap-2.5 text-xs font-mono text-slate-600 hover:bg-slate-200/60 p-2 rounded-xl cursor-pointer transition-all select-none shrink-0">
                                <input type="checkbox" checked="@localesSeleccionadosMasivo.Contains(loc)" @onchange="e => ToggleLocalMasivo(loc, e)" class="rounded text-blue-600 focus:ring-blue-500 w-4 h-4 cursor-pointer shrink-0" />
                                <span class="truncate font-medium">@loc</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- Caja Periodos -->
                <div class="border border-slate-200 bg-slate-50 rounded-2xl p-4 sm:p-5 flex flex-col gap-3 overflow-hidden h-full shadow-xs">
                    <div class="flex items-center justify-between border-b border-slate-200 pb-3 shrink-0">
                        <label class="flex items-center gap-2.5 text-xs font-black text-slate-700 cursor-pointer select-none">
                            <input type="checkbox" checked="@(periodosSeleccionadosMasivo.Count == periodosMasivo.Count && periodosMasivo.Count > 0)" @onchange="ToggleSeleccionarTodosPeriodos" class="rounded text-blue-600 focus:ring-blue-500 w-4 h-4 cursor-pointer" />
                            <span>TODOS LOS PERIODOS (@periodosSeleccionadosMasivo.Count/@periodosMasivo.Count)</span>
                        </label>
                    </div>
                    <div class="overflow-y-auto custom-scrollbar flex-1 flex flex-col gap-1.5 pr-1 min-h-0">
                        @foreach (var per in periodosMasivo)
                        {
                            <label class="flex items-center gap-2.5 text-xs font-mono text-slate-600 hover:bg-slate-200/60 p-2 rounded-xl cursor-pointer transition-all select-none shrink-0">
                                <input type="checkbox" checked="@periodosSeleccionadosMasivo.Contains(per)" @onchange="e => TogglePeriodoMasivo(per, e)" class="rounded text-blue-600 focus:ring-blue-500 w-4 h-4 cursor-pointer shrink-0" />
                                <span class="font-medium">@per</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-slate-100 pt-4 shrink-0">
                <div class="text-xs font-mono text-slate-500">
                    Total a consultar: <span class="font-bold text-blue-600 text-sm">@(localesSeleccionadosMasivo.Count * periodosSeleccionadosMasivo.Count) reportes SP GLP</span>
                </div>
                <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
                    <button type="button" @onclick="() => mostrarModalMasivo = false" class="px-6 py-3 rounded-2xl border border-slate-200 text-xs font-bold text-slate-600 hover:bg-slate-100 transition-all cursor-pointer h-[44px]">
                        Cancelar
                    </button>
                    <button type="button"
                            disabled="@(localesSeleccionadosMasivo.Count == 0 || periodosSeleccionadosMasivo.Count == 0 || descargandoMasivo)"
                            @onclick="DescargarConsolidadoMasivoAsync"
                            class="bg-blue-600 hover:bg-blue-700 active:scale-95 text-white font-black text-xs uppercase tracking-wider px-8 py-3 rounded-2xl transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed h-[44px]">
                        @if (descargandoMasivo)
                        {
                            <svg class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            <span>Consolidando GLP...</span>
                        }
                        else
                        {
                            <span>Descargar Consolidado</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool cargandoInicial = true;
    private bool hayRegistrosBD = false;
    private bool cargandoSP = false;
    private bool estaProcesando = false;

    private bool menuGrifoAbierto = false;
    private bool menuPeriodoAbierto = false;

    private List<string> listaLocales = new();
    private List<string> listaPeriodos = new();

    private string localSeleccionado = "";
    private string periodoSeleccionado = "";

    private DataTable? dtSP = null;
    private int colFechaIdx = -1;
    private HashSet<string> fechasRepetidas = new();

    // Variables de selección estilo Excel
    private int selStartRow = -1;
    private int selStartCol = -1;
    private int tempEndRow = -1;
    private int tempEndCol = -1;
    private bool estaArrastrando = false;
    private bool haySeleccionFirme = false;

    protected override async Task OnInitializedAsync()
    {
        cargandoInicial = true;
        hayRegistrosBD = await ValidacionPrecioService.ExisteAlgunRegistroAsync();

        if (hayRegistrosBD)
        {
            listaLocales = await ValidacionPrecioService.ObtenerLocalesDisponiblesAsync();
            localSeleccionado = "";
            periodoSeleccionado = "";
            dtSP = null;
        }
        cargandoInicial = false;
    }

    private void ToggleGrifo()
    {
        menuGrifoAbierto = !menuGrifoAbierto;
        menuPeriodoAbierto = false;
    }

    private void TogglePeriodo()
    {
        if (string.IsNullOrEmpty(localSeleccionado) || !listaPeriodos.Any()) return;
        menuPeriodoAbierto = !menuPeriodoAbierto;
        menuGrifoAbierto = false;
    }

    private void CerrarMenus()
    {
        menuGrifoAbierto = false;
        menuPeriodoAbierto = false;
    }

    private async Task SeleccionarLocal(string loc)
    {
        localSeleccionado = loc;
        menuGrifoAbierto = false;
        listaPeriodos.Clear();
        periodoSeleccionado = "";
        dtSP = null;
        QuitarSeleccion();
        StateHasChanged();

        if (!string.IsNullOrEmpty(localSeleccionado))
        {
            listaPeriodos = await ValidacionPrecioService.ObtenerPeriodosPorLocalAsync(localSeleccionado);
            StateHasChanged();
        }
    }

    private async Task SeleccionarPeriodo(string per)
    {
        periodoSeleccionado = per;
        menuPeriodoAbierto = false;
        dtSP = null;
        QuitarSeleccion();
        StateHasChanged();

        if (!string.IsNullOrEmpty(localSeleccionado) && !string.IsNullOrEmpty(periodoSeleccionado))
        {
            await CargarReporteSP();
        }
    }

    private async Task CargarReporteSP()
    {
        cargandoSP = true;
        QuitarSeleccion();
        StateHasChanged();

        dtSP = await ValidacionPrecioService.EjecutarSPReportePrecioListaGlpAsync(localSeleccionado, periodoSeleccionado);
        CalcularFechasRepetidas();

        cargandoSP = false;
        StateHasChanged();
    }

    private void IniciarSeleccion(int r, int c)
    {
        if (haySeleccionFirme)
        {
            QuitarSeleccion();
            return;
        }

        selStartRow = r;
        selStartCol = c;
        tempEndRow = r;
        tempEndCol = c;
        estaArrastrando = true;
        haySeleccionFirme = false;
    }

    private void ActualizarSeleccion(int r, int c)
    {
        if (estaArrastrando)
        {
            if (tempEndRow != r || tempEndCol != c)
            {
                tempEndRow = r;
                tempEndCol = c;
            }
        }
    }

    private void FinalizarSeleccion()
    {
        if (estaArrastrando)
        {
            estaArrastrando = false;
            bool esMismaCelda = (selStartRow == tempEndRow && selStartCol == tempEndCol);

            if (esMismaCelda)
            {
                QuitarSeleccion();
            }
            else if (selStartRow != -1 && selStartCol != -1 && tempEndRow != -1 && tempEndCol != -1)
            {
                haySeleccionFirme = true;
            }
        }
    }

    private void QuitarSeleccion()
    {
        selStartRow = -1;
        selStartCol = -1;
        tempEndRow = -1;
        tempEndCol = -1;
        estaArrastrando = false;
        haySeleccionFirme = false;
        _ = LimpiarSeleccionJSAsync();
    }

    private async Task LimpiarSeleccionJSAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "window.getSelection()?.removeAllRanges()");
        }
        catch { }
    }

    private bool EstaCeldaEnRango(int r, int c)
    {
        if (selStartRow == -1 || tempEndRow == -1) return false;
        int minR = Math.Min(selStartRow, tempEndRow);
        int maxR = Math.Max(selStartRow, tempEndRow);
        int minC = Math.Min(selStartCol, tempEndCol);
        int maxC = Math.Max(selStartCol, tempEndCol);

        return r >= minR && r <= maxR && c >= minC && c <= maxC;
    }

    private string ObtenerTextoConteoSeleccion()
    {
        if (!haySeleccionFirme) return "";
        int filas = Math.Abs(tempEndRow - selStartRow) + 1;
        int cols = Math.Abs(tempEndCol - selStartCol) + 1;
        int total = filas * cols;
        return total == 1 ? "1 celda" : $"{total} celdas";
    }

    private void CalcularFechasRepetidas()
    {
        fechasRepetidas.Clear();
        colFechaIdx = -1;
        if (dtSP == null) return;

        for (int c = 0; c < dtSP.Columns.Count; c++)
        {
            string colName = dtSP.Columns[c].ColumnName;
            if (colName.Equals("FECHA_TURNO", StringComparison.OrdinalIgnoreCase) ||
                colName.Equals("FECHA", StringComparison.OrdinalIgnoreCase) ||
                colName.Equals("DIA", StringComparison.OrdinalIgnoreCase))
            {
                colFechaIdx = c;
                break;
            }
        }

        if (colFechaIdx != -1)
        {
            var conteos = new Dictionary<string, int>();
            foreach (DataRow r in dtSP.Rows)
            {
                string v = FormatearCelda(r[colFechaIdx], dtSP.Columns[colFechaIdx].ColumnName);
                if (!string.IsNullOrEmpty(v))
                {
                    conteos[v] = conteos.GetValueOrDefault(v) + 1;
                }
            }
            foreach (var kvp in conteos)
            {
                if (kvp.Value > 1) fechasRepetidas.Add(kvp.Key);
            }
        }
    }

    private string? ObtenerValorFechaTurno(DataRow row)
    {
        if (colFechaIdx != -1 && colFechaIdx < row.Table.Columns.Count)
        {
            return FormatearCelda(row[colFechaIdx], row.Table.Columns[colFechaIdx].ColumnName);
        }
        return null;
    }

    private string FormatearCelda(object? valObj, string colName)
    {
        if (valObj == null || valObj is DBNull) return "";
        string raw = valObj.ToString()?.Trim() ?? "";

        if (colName.Equals("FECHA_TURNO", StringComparison.OrdinalIgnoreCase) ||
            colName.Equals("FECHA", StringComparison.OrdinalIgnoreCase) ||
            colName.Equals("DIA", StringComparison.OrdinalIgnoreCase))
        {
            if (valObj is DateTime dt) return dt.ToString("dd/MM/yyyy");
            if (DateTime.TryParse(raw, out DateTime dt2)) return dt2.ToString("dd/MM/yyyy");
            if (raw.Contains(" ")) return raw.Split(' ')[0];
        }
        return raw;
    }

    private bool EsValorCero(string val)
    {
        if (string.IsNullOrEmpty(val)) return false;
        if (val == "0" || val == "0.0" || val == "0.00" || val == "0.000" || val == "0.0000") return true;
        if (decimal.TryParse(val, NumberStyles.Any, CultureInfo.InvariantCulture, out decimal dec) && dec == 0) return true;
        return false;
    }

    private bool EsColumnaDeTotal(string colName)
    {
        return colName.Equals("GLP_CANTIDAD_TOTAL", StringComparison.OrdinalIgnoreCase);
    }

    private decimal CalcularTotalTabla(DataTable? dt, string nombreColumna)
    {
        if (dt == null) return 0m;
        decimal suma = 0m;
        foreach (DataRow row in dt.Rows)
        {
            if (dt.Columns.Contains(nombreColumna) && row[nombreColumna] != DBNull.Value)
            {
                string valStr = row[nombreColumna]?.ToString() ?? "";
                if (decimal.TryParse(valStr, NumberStyles.Any, CultureInfo.InvariantCulture, out decimal decInv))
                {
                    suma += decInv;
                }
                else if (decimal.TryParse(valStr, NumberStyles.Any, CultureInfo.CurrentCulture, out decimal decCur))
                {
                    suma += decCur;
                }
            }
        }
        return suma;
    }

    private void GenerarHojaReporteExcel(IXLWorksheet ws, DataTable dt)
    {
        // Fila 1: Cabeceras de grupo
        ws.Cell(1, 1).Value = "FECHA";
        ws.Range(1, 1, 2, 1).Merge();
        ws.Cell(1, 2).Value = "DIAS";
        ws.Range(1, 2, 2, 2).Merge();

        ws.Cell(1, 3).Value = "G-84";
        ws.Range(1, 3, 1, 4).Merge();
        ws.Range(1, 3, 1, 4).Style.Fill.BackgroundColor = XLColor.FromHtml("#D9D9D9");

        ws.Range(1, 1, 2, 2).Style.Fill.BackgroundColor = XLColor.FromHtml("#FFFF99");

        // Fila 2: Subcabeceras
        ws.Cell(2, 3).Value = "VENTA GALONES";
        ws.Cell(2, 4).Value = "PRECIO VENTA";
        ws.Range(2, 3, 2, 4).Style.Fill.BackgroundColor = XLColor.FromHtml("#FFFF99");

        var headerRange = ws.Range(1, 1, 2, 4);
        headerRange.Style.Font.Bold = true;
        headerRange.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
        headerRange.Style.Alignment.Vertical = XLAlignmentVerticalValues.Center;
        headerRange.Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
        headerRange.Style.Border.InsideBorder = XLBorderStyleValues.Thin;

        // Calcular fechas repetidas para esta hoja
        var repFechas = new HashSet<string>();
        var conteos = new Dictionary<string, int>();
        foreach (DataRow r in dt.Rows)
        {
            string v = FormatearCelda(r[0], "FECHA_TURNO");
            if (!string.IsNullOrEmpty(v)) conteos[v] = conteos.GetValueOrDefault(v) + 1;
        }
        foreach (var kvp in conteos)
        {
            if (kvp.Value > 1) repFechas.Add(kvp.Key);
        }

        // Datos
        for (int r = 0; r < dt.Rows.Count; r++)
        {
            int rowIdx = r + 3;
            var row = dt.Rows[r];
            string fechaStr = FormatearCelda(row[0], "FECHA_TURNO");
            string diaStr = row[1]?.ToString() ?? "";
            bool esDomingo = diaStr.Equals("DOMINGO", StringComparison.OrdinalIgnoreCase);
            bool esRepetida = !string.IsNullOrEmpty(fechaStr) && repFechas.Contains(fechaStr);

            ws.Cell(rowIdx, 1).Value = fechaStr;
            ws.Cell(rowIdx, 2).Value = diaStr;
            ws.Cell(rowIdx, 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            ws.Cell(rowIdx, 2).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

            for (int c = 2; c < dt.Columns.Count; c++)
            {
                int colIdx = c + 1;
                var valObj = row[c];
                if (valObj != null && valObj != DBNull.Value && decimal.TryParse(valObj.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out decimal decInv))
                {
                    ws.Cell(rowIdx, colIdx).Value = decInv;
                }
                else if (valObj != null && valObj != DBNull.Value && decimal.TryParse(valObj.ToString(), NumberStyles.Any, CultureInfo.CurrentCulture, out decimal decCur))
                {
                    ws.Cell(rowIdx, colIdx).Value = decCur;
                }
                else
                {
                    ws.Cell(rowIdx, colIdx).Value = valObj?.ToString() ?? "";
                }
                ws.Cell(rowIdx, colIdx).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(rowIdx, colIdx).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Right;
            }

            var rowRange = ws.Range(rowIdx, 1, rowIdx, dt.Columns.Count);
            rowRange.Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
            rowRange.Style.Border.InsideBorder = XLBorderStyleValues.Thin;

            if (esDomingo)
            {
                rowRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#80FF80");
            }
            else if (esRepetida)
            {
                ws.Range(rowIdx, 1, rowIdx, 2).Style.Fill.BackgroundColor = XLColor.FromHtml("#FFE699");
            }
        }

        // Fila de Totales
        int totalRowIdx = dt.Rows.Count + 3;
        int numDias = dt.AsEnumerable().Select(r => FormatearCelda(r[0], "FECHA_TURNO")).Where(f => !string.IsNullOrEmpty(f)).Distinct().Count();
        ws.Cell(totalRowIdx, 1).Value = $"{numDias} DÍAS";
        ws.Range(totalRowIdx, 1, totalRowIdx, 2).Merge();
        ws.Range(totalRowIdx, 1, totalRowIdx, 2).Style.Font.Bold = true;
        ws.Range(totalRowIdx, 1, totalRowIdx, 2).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

        for (int c = 2; c < dt.Columns.Count; c++)
        {
            int colIdx = c + 1;
            string colName = dt.Columns[c].ColumnName;
            if (EsColumnaDeTotal(colName))
            {
                decimal tot = CalcularTotalTabla(dt, colName);
                var celda = ws.Cell(totalRowIdx, colIdx);
                celda.Value = tot;
                celda.Style.Font.Bold = true;
                celda.Style.Font.Italic = true;
                celda.Style.Fill.BackgroundColor = XLColor.FromHtml("#99FF99");
                celda.Style.NumberFormat.Format = "#,##0.00";
                celda.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Right;
            }
        }

        var totalRange = ws.Range(totalRowIdx, 1, totalRowIdx, dt.Columns.Count);
        totalRange.Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
        totalRange.Style.Border.InsideBorder = XLBorderStyleValues.Thin;

        ws.Columns().AdjustToContents();
    }

    private async Task DescargarExcel()
    {
        if (dtSP == null || dtSP.Rows.Count == 0) return;

        estaProcesando = true;
        StateHasChanged();

        try
        {
            string downloadFolder = Path.Combine("wwwroot", "uploads", "DescargasSP");
            if (Directory.Exists(downloadFolder))
            {
                try { Directory.Delete(downloadFolder, true); } catch { }
            }

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("ReporteDiaGLP");
            GenerarHojaReporteExcel(ws, dtSP);

            string nombreArchivo = $"ReporteGLP_{localSeleccionado}_{periodoSeleccionado}.xlsx";

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            string base64 = Convert.ToBase64String(ms.ToArray());

            await JSRuntime.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}'; a.download = '{nombreArchivo}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);");
            ToastService.Success($"Reporte GLP {nombreArchivo} descargado.");
        }
        catch (Exception ex)
        {
            ToastService.Error($"Error al exportar Excel: {ex.Message}");
        }
        finally
        {
            estaProcesando = false;
        }
    }

    private bool mostrarModalMasivo = false;
    private bool descargandoMasivo = false;
    private List<string> localesMasivo = new();
    private List<string> periodosMasivo = new();
    private HashSet<string> localesSeleccionadosMasivo = new();
    private HashSet<string> periodosSeleccionadosMasivo = new();

    private async Task AbrirModalMasivoAsync()
    {
        localesMasivo = await ValidacionPrecioService.ObtenerLocalesDisponiblesAsync();
        periodosMasivo = await ValidacionPrecioService.ObtenerTodosPeriodosDisponiblesAsync();
        localesSeleccionadosMasivo = new HashSet<string>(localesMasivo);
        periodosSeleccionadosMasivo = new HashSet<string>(periodosMasivo);
        mostrarModalMasivo = true;
    }

    private void ToggleSeleccionarTodosLocales(ChangeEventArgs e)
    {
        bool check = (bool)(e.Value ?? false);
        if (check) localesSeleccionadosMasivo = new HashSet<string>(localesMasivo);
        else localesSeleccionadosMasivo.Clear();
    }

    private void ToggleLocalMasivo(string loc, ChangeEventArgs e)
    {
        bool check = (bool)(e.Value ?? false);
        if (check) localesSeleccionadosMasivo.Add(loc);
        else localesSeleccionadosMasivo.Remove(loc);
    }

    private void ToggleSeleccionarTodosPeriodos(ChangeEventArgs e)
    {
        bool check = (bool)(e.Value ?? false);
        if (check) periodosSeleccionadosMasivo = new HashSet<string>(periodosMasivo);
        else periodosSeleccionadosMasivo.Clear();
    }

    private void TogglePeriodoMasivo(string per, ChangeEventArgs e)
    {
        bool check = (bool)(e.Value ?? false);
        if (check) periodosSeleccionadosMasivo.Add(per);
        else periodosSeleccionadosMasivo.Remove(per);
    }

    private async Task DescargarConsolidadoMasivoAsync()
    {
        if (localesSeleccionadosMasivo.Count == 0 || periodosSeleccionadosMasivo.Count == 0) return;

        descargandoMasivo = true;
        StateHasChanged();

        try
        {
            string downloadFolder = Path.Combine("wwwroot", "uploads", "DescargasSP");
            if (Directory.Exists(downloadFolder))
            {
                try { Directory.Delete(downloadFolder, true); } catch { }
            }

            using var wb = new XLWorkbook();
            int hojasCreadas = 0;

            foreach (var loc in localesMasivo.Where(l => localesSeleccionadosMasivo.Contains(l)))
            {
                foreach (var per in periodosMasivo.Where(p => periodosSeleccionadosMasivo.Contains(p)))
                {
                    var dt = await ValidacionPrecioService.EjecutarSPReportePrecioListaGlpAsync(loc, per);
                    if (dt != null && dt.Rows.Count > 0)
                    {
                        string cleanLoc = loc.Replace("EESS-", "").Replace(" ", "_");
                        string nombreHoja = $"{cleanLoc}_{per}";
                        if (nombreHoja.Length > 31) nombreHoja = nombreHoja.Substring(0, 31);

                        int sufijo = 1;
                        string hojaBase = nombreHoja;
                        while (wb.Worksheets.Any(ws => ws.Name.Equals(nombreHoja, StringComparison.OrdinalIgnoreCase)))
                        {
                            string s = sufijo.ToString();
                            nombreHoja = hojaBase.Substring(0, Math.Min(hojaBase.Length, 31 - s.Length)) + s;
                            sufijo++;
                        }

                        var ws = wb.Worksheets.Add(nombreHoja);
                        GenerarHojaReporteExcel(ws, dt);
                        hojasCreadas++;
                    }
                }
            }

            if (hojasCreadas == 0)
            {
                ToastService.Warning("No se encontraron datos devueltos por el SP GLP para los grifos y periodos seleccionados.");
                descargandoMasivo = false;
                return;
            }

            string nombreArchivo = $"Consolidado_PreciosMasivoGLP_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            string base64 = Convert.ToBase64String(ms.ToArray());

            await JSRuntime.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}'; a.download = '{nombreArchivo}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);");
            ToastService.Success($"Consolidado GLP {nombreArchivo} descargado con {hojasCreadas} pestañas.");
            mostrarModalMasivo = false;
        }
        catch (Exception ex)
        {
            ToastService.Error($"Error en descarga masiva GLP: {ex.Message}");
        }
        finally
        {
            descargandoMasivo = false;
        }
    }
}
