@page "/ValidacionPrecioLista"
@using PETRO_BOT.Models.ValidacionPrecio
@using PETRO_BOT.Services.Services
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@using System.IO
@rendermode InteractiveServer
@inject ValidacionPrecioService ValidacionPrecioService
@inject ToastService ToastService

<PageTitle>Validación precio lista - Importar Venta</PageTitle>

<div class="w-full flex flex-col gap-6 animate-fade-in-up h-[calc(100vh-135px)] min-h-[600px] overflow-hidden">

    <!-- SECCIÓN SUPERIOR: GRID DE 2 COLUMNAS (MÓDULO DE IMPORTACIÓN + RESUMEN DE EJECUCIÓN) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch shrink-0">
        
        <!-- IZQUIERDA: CAJA DE IMPORTACIÓN (lg:col-span-8) -->
        <div class="lg:col-span-8 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col relative shadow-xs justify-between">
            @if (estaProcesando)
            {
                <LoadingRayo />
            }
            
            <div class="flex flex-col flex-1">
                <div class="border-b border-slate-100 pb-4 mb-5">
                    <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest block">Módulo de Importación</h3>
                    <span class="text-[10px] text-slate-400 font-bold block mt-0.5">Carga masiva y validación automática de reportes de ventas detalladas</span>
                </div>

                <!-- Zona de carga ocupando todo el ancho -->
                <div class="flex flex-col gap-3 my-auto w-full py-4">
                    @if (!archivosNombres.Any())
                    {
                        <div class="group relative w-full">
                            <label for="file-upload_ventas" class="w-full bg-slate-50 border-2 border-dashed border-slate-200 hover:border-slate-400 hover:bg-slate-100/50 rounded-2xl px-6 py-8 flex items-center justify-between transition-all duration-300 cursor-pointer select-none shadow-2xs">
                                <span class="flex flex-col">
                                    <span class="text-sm font-black text-slate-800">Reporte de Ventas Detalladas</span>
                                    <span class="text-[10px] text-slate-500 font-bold uppercase tracking-wider mt-1">Se pueden adjuntar múltiples planillas Excel (.xlsx)</span>
                                </span>
                                <span class="p-3 bg-white border border-slate-200 rounded-xl group-hover:bg-[#0f172a] group-hover:text-white group-hover:border-[#0f172a] text-slate-600 transition-all shrink-0 shadow-2xs">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                </span>
                            </label>
                            <InputFile id="file-upload_ventas" OnChange="SubirArchivos" multiple accept=".xlsx" class="hidden" />
                        </div>
                    }
                    else
                    {
                        <div class="relative w-full group">
                            <label for="file-upload_ventas_add" class="cursor-pointer block w-full">
                                <SuccessCargaFile File="@($"{archivosNombres.Count} reportes de ventas listos para procesar")" />
                                <div class="absolute inset-0 bg-emerald-500/0 group-hover:bg-emerald-500/10 rounded-2xl transition-all flex items-center justify-end px-4 pointer-events-none">
                                    <span class="text-[10px] font-black text-emerald-800 bg-emerald-100 px-3 py-1.5 rounded-lg shadow-sm border border-emerald-300 opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
                                        + Adjuntar más planillas
                                    </span>
                                </div>
                            </label>
                            <InputFile id="file-upload_ventas_add" OnChange="SubirArchivos" multiple accept=".xlsx" class="hidden" />
                        </div>
                    }
                </div>
            </div>

            <!-- ESTOS 3 BOTONES OCUPANDO TODO EL ANCHO DE LA CAJA -->
            <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-slate-100/80 w-full">
                <button disabled="@(estaProcesando || !archivosNombres.Any())" 
                        @onclick="AbrirModalAdjuntos" 
                        type="button"
                        class="flex-1 bg-white text-slate-700 border border-slate-200 rounded-xl py-3.5 text-[10px] font-black uppercase tracking-wider hover:bg-slate-50 transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 disabled:cursor-not-allowed shadow-2xs text-center">
                    Ver adjuntos
                </button>
                <button @onclick="EjecutarProceso"
                        type="button"
                        disabled="@(estaProcesando || !archivosNombres.Any())"
                        class="flex-1 bg-[#0f172a] text-white rounded-xl py-3.5 text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer select-none disabled:opacity-40 disabled:cursor-not-allowed">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    <span>Ejecutar Proceso</span>
                </button>
                <button disabled="@estaProcesando" 
                        @onclick="Limpiar" 
                        type="button"
                        class="flex-1 px-4 py-3.5 bg-white border border-slate-200 hover:bg-rose-50 hover:text-rose-600 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 shadow-2xs text-center">
                    Limpiar
                </button>
            </div>
        </div>

        <!-- DERECHA: RESUMEN DE EJECUCIÓN (lg:col-span-4) -->
        <div class="lg:col-span-4 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col relative shadow-xs justify-between">
            <div class="border-b border-slate-100 pb-4 mb-4">
                <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest flex items-center gap-1.5">
                    <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Resumen de Ejecución
                </h3>
                <span class="text-[10px] text-slate-400 font-bold block mt-0.5">Indicadores de estado del último proceso</span>
            </div>

            <div class="flex flex-col gap-3.5 my-auto">
                <!-- 2 Cajas superiores lado a lado -->
                <div class="grid grid-cols-2 gap-3">
                    <!-- Correctos -->
                    <div class="bg-emerald-50/70 border border-emerald-100 rounded-2xl p-4 flex flex-col justify-center shadow-2xs relative overflow-hidden">
                        <div class="absolute right-2 top-1/2 -translate-y-1/2 opacity-25 text-emerald-600 pointer-events-none">
                            <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <span class="text-[9px] font-black text-emerald-700 uppercase tracking-wider block mb-1">Correctos</span>
                        <span class="text-2xl font-black text-emerald-900 font-mono">
                            @archivosImportados.Count(a => a.Estado == 1)
                        </span>
                    </div>

                    <!-- Errores -->
                    <div class="bg-rose-50/70 border border-rose-100 rounded-2xl p-4 flex flex-col justify-center shadow-2xs relative overflow-hidden">
                        <div class="absolute right-2 top-1/2 -translate-y-1/2 opacity-25 text-rose-600 pointer-events-none">
                            <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <span class="text-[9px] font-black text-rose-700 uppercase tracking-wider block mb-1">Con Error</span>
                        <span class="text-2xl font-black text-rose-900 font-mono">
                            @archivosImportados.Count(a => a.Estado == 0)
                        </span>
                    </div>
                </div>

                <!-- Caja inferior: Tiempo de ejecución -->
                <div class="bg-slate-900 text-white rounded-2xl p-4 flex items-center justify-between shadow-sm relative overflow-hidden">
                    <div class="flex flex-col z-10">
                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider block mb-1">Tiempo de Ejecución</span>
                        <span class="text-xl font-black text-emerald-400 font-mono">
                            @(tiempoTotalEjecucionMs > 1000 ? $"{(tiempoTotalEjecucionMs / 1000.0):F2} s" : $"{tiempoTotalEjecucionMs} ms")
                        </span>
                    </div>
                    <div class="p-2.5 bg-slate-800 rounded-xl text-slate-300 border border-slate-700 shrink-0 z-10">
                        <svg class="w-5.5 h-5.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-blue-500/10 rounded-full blur-xl pointer-events-none"></div>
                </div>
            </div>

            <!-- Indicador inferior de estado -->
            <div class="pt-3 border-t border-slate-100 flex items-center justify-between text-[10px] text-slate-400 font-medium mt-3">
                <span>Estado en Sistema</span>
                <span class="flex items-center gap-1.5 font-bold @(estaProcesando ? "text-amber-500" : "text-emerald-600")">
                    <span class="w-2 h-2 rounded-full @(estaProcesando ? "bg-amber-500 animate-ping" : "bg-emerald-500")"></span>
                    @(estaProcesando ? "Procesando lote..." : "Listo")
                </span>
            </div>
        </div>

    </div>

    <!-- SEGUNDA CAJA: LISTA DE ARCHIVOS IMPORTADOS DINÁMICA MANTENIENDO EL ALTO EXACTO -->
    <div class="bg-white border border-slate-200/60 rounded-[30px] p-6 flex-1 flex flex-col min-h-0 overflow-hidden relative shadow-xs">
        <div class="border-b border-slate-100 pb-4 mb-4 flex items-center justify-between shrink-0">
            <div>
                <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest block">Archivos Procesados</h3>
                <span class="text-[10px] text-slate-400 font-bold block mt-0.5">contador, archivo importado, cantidad de registros importados, estado, descripción de estado</span>
            </div>
            @if (archivosImportados.Any())
            {
                <span class="text-[10px] font-black bg-slate-100 text-slate-700 px-3 py-1 rounded-full border border-slate-200">
                    Total procesados: @archivosImportados.Count
                </span>
            }
        </div>

        <!-- Tabla 100% Flex (flex-1 overflow-y-auto min-h-0) -->
        <div class="flex-1 overflow-y-auto overflow-x-auto rounded-2xl border border-slate-200 custom-scrollbar min-h-0 relative">
            <table class="w-full text-left border-collapse relative">
                <thead class="sticky top-0 z-20">
                    <tr class="border-b border-slate-200 font-black text-[10px] uppercase tracking-wider" style="background-color: #1e293b !important; color: #ffffff !important;">
                        <th class="py-3.5 px-4 text-center w-16" style="background-color: #1e293b !important; color: #ffffff !important;">#</th>
                        <th class="py-3.5 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Archivo Importado</th>
                        <th class="py-3.5 px-4 text-center w-44" style="background-color: #1e293b !important; color: #ffffff !important;">Registros Importados</th>
                        <th class="py-3.5 px-4 text-center w-36" style="background-color: #1e293b !important; color: #ffffff !important;">Estado</th>
                        <th class="py-3.5 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Descripción de Estado</th>
                    </tr>
                </thead>
                <tbody class="text-xs text-slate-700 divide-y divide-slate-100">
                    @if (!archivosImportados.Any())
                    {
                        @if (!estaProcesando)
                        {
                            <tr>
                                <td colspan="5" class="py-14 text-center text-slate-400 italic font-bold uppercase tracking-widest bg-white text-xs">
                                    Sin archivos procesados aún
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        @foreach (var archivo in archivosImportados)
                        {
                            <tr class="hover:bg-slate-50/60 transition-all duration-150">
                                <td class="py-3 px-4 bg-white text-center font-black text-slate-400 text-[11px]">
                                    @archivo.Contador.
                                </td>
                                <td class="py-3 px-4 bg-white font-black text-slate-800 text-xs">
                                    @archivo.ArchivoImportado
                                </td>
                                <td class="py-3 px-4 bg-white text-center font-mono font-bold text-slate-700 text-xs">
                                    @archivo.CantidadRegistros.ToString("N0")
                                </td>
                                <td class="py-3 px-4 bg-white text-center">
                                    @if (archivo.Estado == 1)
                                    {
                                        <span class="text-[9px] bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-1 rounded-md font-black uppercase inline-block shadow-2xs">Success</span>
                                    }
                                    else
                                    {
                                        <span class="text-[9px] bg-rose-50 text-rose-700 border border-rose-200 px-2.5 py-1 rounded-md font-black uppercase inline-block shadow-2xs">Error</span>
                                    }
                                </td>
                                <td class="py-3 px-4 bg-white text-xs @(archivo.Estado == 1 ? "text-slate-600 font-medium" : "text-rose-600 font-bold")">
                                    @archivo.DescripcionEstado
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- MODAL VER ADJUNTOS -->
@if (mostrarModalAdjuntos)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[9998] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAdjuntos"></div>
        
        <div class="bg-white border border-slate-200 rounded-[28px] shadow-2xl w-full max-w-xl max-h-[85vh] flex flex-col overflow-hidden relative z-10"
             @onclick:stopPropagation="true">
            
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <div>
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block mb-0.5">Archivos en Cola</span>
                    <h3 class="text-xs font-black text-slate-800 uppercase tracking-wider">Documentos Adjuntados</h3>
                </div>
                <button @onclick="CerrarModalAdjuntos" 
                        type="button"
                        class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="p-6 overflow-y-auto flex-1 flex flex-col gap-3 custom-scrollbar">
                @if (!archivosNombres.Any())
                {
                    <span class="text-xs text-slate-400 italic block py-6 text-center">Ningún archivo adjuntado en cola.</span>
                }
                else
                {
                    <ul class="flex flex-col gap-2.5">
                        @for (int i = 0; i < archivosNombres.Count; i++)
                        {
                            int idx = i;
                            string nombreArchivo = archivosNombres[i];
                            <li class="bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 flex items-center justify-between font-mono text-xs text-slate-700 shadow-2xs">
                                <span class="truncate pr-3 font-bold text-slate-800 flex items-center gap-2">
                                    <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                    @nombreArchivo
                                </span>
                                <button type="button" @onclick="() => EliminarAdjunto(idx)" class="p-1.5 hover:bg-rose-100 rounded-lg text-rose-500 hover:text-rose-700 transition-all cursor-pointer shrink-0" title="Eliminar">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
                <button @onclick="CerrarModalAdjuntos" type="button" class="px-5 py-2.5 bg-[#0f172a] text-white rounded-xl text-[10px] font-black uppercase tracking-wider hover:bg-slate-800 transition-all shadow-sm cursor-pointer">
                    Cerrar
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool estaProcesando = false;
    private bool mostrarModalAdjuntos = false;
    private long tiempoTotalEjecucionMs = 0;
    private List<string> archivosNombres = new();
    private List<string> archivosRutasTemporales = new();
    private List<ArchivoImportadoVenta> archivosImportados = new();

    private string carpetaRegistro => Path.Combine("wwwroot", "uploads", "RegistroPrecioLista");

    protected override void OnInitialized()
    {
        LimpiarCarpetaFisica();
    }

    private void LimpiarCarpetaFisica()
    {
        if (Directory.Exists(carpetaRegistro))
        {
            try
            {
                var files = Directory.GetFiles(carpetaRegistro);
                foreach (var f in files)
                {
                    try { File.Delete(f); } catch { }
                }
            }
            catch { }
        }
    }

    private void AbrirModalAdjuntos() => mostrarModalAdjuntos = true;
    private void CerrarModalAdjuntos() => mostrarModalAdjuntos = false;

    private async Task SubirArchivos(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(1000);
        Directory.CreateDirectory(carpetaRegistro);

        foreach (var file in files)
        {
            if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
                continue;

            string uniqueName = $"{Guid.NewGuid()}_{file.Name}";
            string fullPath = Path.Combine(carpetaRegistro, uniqueName);

            using var stream = new FileStream(fullPath, FileMode.Create);
            await file.OpenReadStream(1024 * 1024 * 100).CopyToAsync(stream);

            archivosNombres.Add(file.Name);
            archivosRutasTemporales.Add(fullPath);
        }

        ToastService.Success($"{files.Count} archivo(s) adjuntado(s) correctamente.");
    }

    private void EliminarAdjunto(int index)
    {
        if (index >= 0 && index < archivosNombres.Count)
        {
            string ruta = archivosRutasTemporales[index];
            if (File.Exists(ruta))
            {
                try { File.Delete(ruta); } catch { }
            }
            archivosNombres.RemoveAt(index);
            archivosRutasTemporales.RemoveAt(index);
            ToastService.Warning("Archivo removido de la cola.");
        }
    }

    private async Task EjecutarProceso()
    {
        if (!archivosRutasTemporales.Any()) return;

        estaProcesando = true;
        archivosImportados.Clear();
        tiempoTotalEjecucionMs = 0;
        StateHasChanged();

        var cronoGeneral = System.Diagnostics.Stopwatch.StartNew();

        for (int i = 0; i < archivosRutasTemporales.Count; i++)
        {
            string ruta = archivosRutasTemporales[i];
            string nombre = archivosNombres[i];

            var resultado = await ValidacionPrecioService.ProcesarArchivoVentaAsync(ruta, nombre);

            archivosImportados.Add(new ArchivoImportadoVenta
            {
                Contador = archivosImportados.Count + 1,
                ArchivoImportado = nombre,
                CantidadRegistros = resultado.RegistrosInsertados,
                Estado = resultado.Exito ? 1 : 0,
                DescripcionEstado = resultado.Mensaje,
                DemoraMs = resultado.DemoraMs,
                RutaCompleta = ruta
            });
        }

        cronoGeneral.Stop();
        tiempoTotalEjecucionMs = cronoGeneral.ElapsedMilliseconds;

        LimpiarCarpetaFisica();
        archivosNombres.Clear();
        archivosRutasTemporales.Clear();

        estaProcesando = false;
        ToastService.Success("Procesamiento masivo finalizado.");
    }

    private void Limpiar()
    {
        LimpiarCarpetaFisica();
        archivosNombres.Clear();
        archivosRutasTemporales.Clear();
        archivosImportados.Clear();
        tiempoTotalEjecucionMs = 0;
        ToastService.Info("Módulo limpio.");
    }
}
