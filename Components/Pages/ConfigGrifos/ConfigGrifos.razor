                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaDesdePlantilla(-1, -1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }
                else if (campoSeleccionandoModal == "FilaFinal")
                {
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección de Fila Final</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic sobre cualquier celda de una fila para establecerla como la <strong>Fila Final</strong> (ej. para detener la lectura).</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarFilaFinalDesdePlantilla(-1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Restablecer por Defecto (129)
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }
                else if (mapeoFilasKeys.Contains(campoSeleccionandoModal))
                {
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección de Fila Activo</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic sobre cualquier celda de la fila deseada para establecerla como Fila de <strong>@campoSeleccionandoModal</strong>.</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaFilaDesdePlantilla(-1, -1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }

                @if (plantillaExcelFilas == null || !plantillaExcelFilas.Any())
                {
                    <div class="py-24 flex flex-col items-center justify-center gap-3">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-600"></div>
                        <span class="text-[10px] font-black text-slate-450 uppercase tracking-[0.2em]">Cargando datos de Excel...</span>
                    </div>
                }
                else
                {
                    var maxColCount = plantillaExcelFilas.Max(r => r.Count);
                    
                    <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white flex-1 flex flex-col">
                        <div id="excelPreviewContainer" class="overflow-auto excel-preview-scrollbar flex-1" style="max-height: calc(90vh - 220px);">
                            <table class="w-full border-collapse text-left excel-preview-table">
                                <thead>
                                    <tr class="bg-slate-100 select-none">
                                        <!-- Corner cell -->
                                        <th class="w-12 bg-slate-100 border-r border-b border-slate-300"></th>
                                        @for (int c = 0; c < maxColCount; c++)
                                        {
                                            var letter = GetExcelColumnName(c);
                                            var widthChar = c < plantillaExcelColumnWidths.Count ? plantillaExcelColumnWidths[c] : 12;
                                            var widthPx = Math.Max(60, (int)(widthChar * 8.5));
                                            <th class="px-3 py-2 text-center text-[10px] font-mono font-black text-slate-600 border-r border-b border-slate-300/80 bg-slate-100 notranslate" style="width: @(widthPx)px; min-width: @(widthPx)px; max-width: @(widthPx)px;" translate="no">
                                                @letter
                                            </th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int r = 0; r < plantillaExcelFilas.Count; r++)
                                    {
                                        var rowData = plantillaExcelFilas[r];
                                        var displayRowNumber = r + 1;
                                        <tr class="hover:bg-slate-50/40 border-b border-slate-200/70">
                                            <td class="bg-slate-100 text-center text-[10px] font-mono font-black text-slate-600 border-r border-slate-300/80 select-none py-2 px-3 w-12 notranslate" translate="no">
                                                @displayRowNumber
                                            </td>
                                            @for (int c = 0; c < maxColCount; c++)
                                            {
                                                var localCol = c;
                                                var celda = localCol < rowData.Count ? rowData[localCol] : null;
                                                var cellValue = celda?.Valor ?? "";
                                                @if (viendoRegistroVentasModal)
                                                {
                                                    var localRow = r;
                                                    bool isRow10 = localRow == 9;
                                                    string mappedProp = "";
                                                    
                                                    string colLetter = GetExcelColumnName(localCol);
                                                    foreach (var key in columnasEscrituraKeys)
                                                    {
                                                        if (string.Equals(GetWriteConfigValue(key), colLetter, StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            mappedProp = key;
                                                            break;
                                                        }
                                                    }

                                                    RegistroVentasClienteCredito? mappedClient = null;
                                                    if (grifoSeleccionado.ClientesCredito != null)
                                                    {
                                                        mappedClient = grifoSeleccionado.ClientesCredito.FirstOrDefault(cli => string.Equals(cli.Columna, colLetter, StringComparison.OrdinalIgnoreCase));
                                                    }

                                                    bool tieneMapeo = !string.IsNullOrEmpty(mappedProp) || mappedClient != null;

                                                    bool esElMismo = false;
                                                    if (campoSeleccionandoModal != null && campoSeleccionandoModal.StartsWith("ClienteColumna_"))
                                                    {
                                                        string clientName = campoSeleccionandoModal.Substring("ClienteColumna_".Length);
                                                        esElMismo = (mappedClient != null && string.Equals(mappedClient.ClienteNombre, clientName, StringComparison.OrdinalIgnoreCase));
                                                    }
                                                    else
                                                    {
                                                        esElMismo = (campoSeleccionandoModal == mappedProp);
                                                    }

                                                    bool isSelectingWriteCol = columnasEscrituraKeys.Contains(campoSeleccionandoModal) || (campoSeleccionandoModal != null && campoSeleccionandoModal.StartsWith("ClienteColumna_"));

                                                    if (isSelectingWriteCol)
                                                    {
                                                        if (isRow10)
                                                        {
                                                            if (esElMismo)
                                                            {
                                                                <td @onclick="() => SeleccionarCeldaWriteColDesdePlantilla(localCol)"
                                                                    class="px-3 py-1.5 text-xs border-r border-l border-emerald-500 font-black transition-all select-none cursor-pointer text-center relative overflow-visible shadow-lg scale-[1.02] z-10 cell-selected"
                                                                    style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)"
                                                                    title="Haga clic para deseleccionar o reasignar la columna @colLetter">
                                                                    <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                        <span>@cellValue</span>
                                                                        <div class="premium-tooltip-vertical premium-tooltip-breath-vertical">
                                                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-450 animate-pulse shrink-0"></span>
                                                                            <span class="font-mono text-[11px]">(@colLetter)</span>
                                                                            <span class="text-center font-extrabold text-emerald-350">ASIGNANDO A:</span>
                                                                            <span class="text-center font-black">@GetActiveSelectionLabel()</span>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                            }
                                                            else if (tieneMapeo)
                                                            {
                                                                string occupiedBy = !string.IsNullOrEmpty(mappedProp) ? GetFriendlyLabel(mappedProp) : (mappedClient != null ? "Cliente: " + mappedClient.ClienteNombre : "");
                                                                <td class="px-3 py-1.5 text-xs border-r text-center select-none border-slate-200 cursor-not-allowed font-medium relative overflow-visible"
                                                                    style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)">
                                                                    <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                        <span>@cellValue</span>
                                                                        <div class="premium-tooltip-vertical-gray premium-tooltip-breath-vertical-gray">
                                                                            <span class="w-1.5 h-1.5 rounded-full bg-slate-350 animate-pulse shrink-0"></span>
                                                                            <span class="font-mono text-[11px]">(@colLetter)</span>
                                                                            <span class="text-center font-extrabold text-slate-300">OCUPADO POR:</span>
                                                                            <span class="text-center font-black">@occupiedBy.ToUpper()</span>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                            }
                                                            else
                                                            {
                                                                <td @onclick="() => SeleccionarCeldaWriteColDesdePlantilla(localCol)"
                                                                    class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center border border-dashed border-slate-200 hover:border-emerald-500 hover:scale-[1.01]"
                                                                    style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)"
                                                                    title="Haga clic para asignar la columna @colLetter para @GetActiveSelectionLabel()">
                                                                    @cellValue
                                                                </td>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <td class="px-3 py-1.5 text-xs border-r select-none text-center border-slate-200 text-slate-400 font-normal" 
                                                                style="@GetCeldaStyle(celda, false, false)"
                                                                title="Solo se puede seleccionar celdas en la Fila 10">
                                                                @cellValue
                                                            </td>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        if (isRow10 && tieneMapeo)
                                                        {
                                                            <td class="px-3 py-1.5 text-xs border-r border-l border-slate-600 font-black transition-all select-none text-center relative overflow-visible shadow-lg z-10 cell-selected"
                                                                style="@GetCeldaStyle(celda, true, false)">
                                                                <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                    <span>@cellValue</span>
                                                                    <div class="premium-tooltip-vertical premium-tooltip-breath-vertical">
                                                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-450 animate-pulse shrink-0"></span>
                                                                        <span class="font-mono text-[11px]">(@colLetter)</span>
                                                                        @if (!string.IsNullOrEmpty(mappedProp))
                                                                        {
                                                                            <span class="text-center font-extrabold text-emerald-400">@GetFriendlyLabel(mappedProp)</span>
                                                                        }
                                                                        @if (mappedClient != null)
                                                                        {
                                                                            <span class="text-center font-extrabold text-sky-400">CLI: @mappedClient.ClienteNombre</span>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td class="px-3 py-1.5 text-xs border-r select-none text-center border-slate-200"
                                                                style="@GetCeldaStyle(celda, false, false)"
                                                                title="@cellValue">
                                                                @cellValue
                                                            </td>
                                                        }
                                                    }
                                                }
                                                else
                                                {
                                                    if (campoSeleccionandoModal == "ColumnaFecha" || campoSeleccionandoModal == "CreditoNombre" || campoSeleccionandoModal == "CreditoMonto" || campoSeleccionandoModal == "HermesBanco" || campoSeleccionandoModal == "HermesTipo" || campoSeleccionandoModal == "HermesMonto" || campoSeleccionandoModal == "VariaCombusNombre" || campoSeleccionandoModal == "VariaCombusMonto" || campoSeleccionandoModal == "EESS")
                                                    {
                                                        var localRow = r;
                                                        var mappedProp = GetMappedPropertyNameForCell(localRow, localCol);
                                                        bool tieneMapeo = !string.IsNullOrEmpty(mappedProp);
                                                        bool esElMismo = false;
                                                        string tooltipText = "";
                                                        
                                                        if (campoSeleccionandoModal == "EESS")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaEESS && localRow == (grifoSeleccionado?.Configuracion.FilaEESS - 1));
                                                            tooltipText = $"EESS ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "ColumnaFecha")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaFecha && localRow == (grifoSeleccionado?.Configuracion.FilaFecha - 1));
                                                            tooltipText = $"Celda Fecha ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "CreditoNombre")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaCreditoNombre && localRow == (grifoSeleccionado?.Configuracion.FilaCreditosNombre - 1));
                                                            tooltipText = $"Crédito Nombre ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "CreditoMonto")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaCreditoMonto && localRow == (grifoSeleccionado?.Configuracion.FilaCreditosMonto - 1));
                                                            tooltipText = $"Crédito Monto ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "HermesBanco")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaHermesBanco && localRow == (grifoSeleccionado?.Configuracion.FilaHermesBanco - 1));
                                                            tooltipText = $"Hermes Banco ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "HermesTipo")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaHermesTipo && localRow == (grifoSeleccionado?.Configuracion.FilaHermesTipo - 1));
                                                            tooltipText = $"Hermes Tipo ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "HermesMonto")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaHermesMonto && localRow == (grifoSeleccionado?.Configuracion.FilaHermesMonto - 1));
                                                            tooltipText = $"Hermes Monto ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "VariaCombusNombre")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaVariaCombusNombre && localRow == (grifoSeleccionado?.Configuracion.FilaVariaCombusNombre - 1));
                                                            tooltipText = $"Combustible Nombre ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        else if (campoSeleccionandoModal == "VariaCombusMonto")
                                                        {
                                                            esElMismo = (localCol == grifoSeleccionado?.Configuracion.ColumnaVariaCombusMonto && localRow == (grifoSeleccionado?.Configuracion.FilaVariaCombusMonto - 1));
                                                            tooltipText = $"Combustible Monto ({GetExcelColumnName(localCol)}{localRow + 1})";
                                                        }
                                                        
                                                        if (esElMismo)
                                                        {
                                                            <td @onclick="() => SeleccionarCeldaDesdePlantilla(localRow, localCol)"
                                                                class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center relative overflow-visible shadow-lg scale-[1.02] z-10 cell-selected"
                                                                style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)"
                                                                title="Haga clic para deseleccionar o cambiar la celda para @GetFriendlyLabel(campoSeleccionandoModal)">
                                                                <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                    <span>@cellValue</span>
                                                                    <div class="absolute bottom-full left-1/2 px-2.5 py-1 bg-[#0f172a] text-white text-[9px] font-black uppercase tracking-wider rounded-lg shadow-xl z-[9999] whitespace-nowrap pointer-events-none select-none flex items-center gap-1 border border-slate-700 premium-tooltip-breath">
                                                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                                                        <span>@tooltipText</span>
                                                                        <!-- Down Arrow -->
                                                                        <div class="absolute top-full left-1/2 transform -translate-x-1/2 border-[5px] border-solid border-transparent border-t-[#0f172a]"></div>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                        }
                                                        else if (!string.IsNullOrEmpty(mappedProp))
                                                        {
                                                            <td class="px-3 py-1.5 text-xs border-r text-center select-none border-slate-200 cursor-not-allowed font-medium relative overflow-visible"
                                                                style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)">
                                                                <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                    <span>@cellValue</span>
                                                                    <div class="absolute bottom-full left-1/2 px-2.5 py-1 bg-[#7f8c8d] text-white text-[9px] font-black uppercase tracking-wider rounded-lg shadow-xl z-[9999] whitespace-nowrap pointer-events-none select-none flex items-center gap-1 border border-slate-400 premium-tooltip-breath-gray">
                                                                        <span class="w-1.5 h-1.5 rounded-full bg-slate-350 animate-pulse"></span>
                                                                        <span>En Uso: @GetFriendlyLabel(mappedProp)</span>
                                                                        <!-- Down Arrow -->
                                                                        <div class="absolute top-full left-1/2 transform -translate-x-1/2 border-[5px] border-solid border-transparent border-t-[#7f8c8d]"></div>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td @onclick="() => SeleccionarCeldaDesdePlantilla(localRow, localCol)"
                                                                class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center border border-dashed border-slate-200 hover:border-emerald-500 hover:scale-[1.01]"
                                                                style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)"
                                                                title="Haga clic para seleccionar esta celda para @GetFriendlyLabel(campoSeleccionandoModal)">
                                                                @cellValue
                                                            </td>
                                                        }
                                                    }
                                                    else if (campoSeleccionandoModal == "FilaFinal")
                                                    {
                                                        var localRow = r;
                                                        bool esSeleccionado = (localRow == (grifoSeleccionado?.Configuracion.FilaFinal - 1));
                                                        <td @onclick="() => SeleccionarFilaFinalDesdePlantilla(localRow)"
                                                            class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center relative overflow-visible hover:scale-[1.01]"
                                                            style="@GetCeldaStyle(celda, esSeleccionado, false)"
                                                            title="Haga clic para seleccionar esta fila como Fila Final">
                                                            @if (esSeleccionado)
                                                            {
                                                                <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                    <span>@cellValue</span>
                                                                    @if (localCol == 0)
                                                                    {
                                                                        <div class="absolute bottom-full left-1/2 px-2.5 py-1 bg-[#0f172a] text-white text-[9px] font-black uppercase tracking-wider rounded-lg shadow-xl z-[9999] whitespace-nowrap pointer-events-none select-none flex items-center gap-1 border border-slate-700 premium-tooltip-breath">
                                                                            <span class="w-1.5 h-1.5 rounded-full bg-rose-400 animate-pulse"></span>
                                                                            <span>Fila Final (Fila @(localRow + 1))</span>
                                                                            <!-- Down Arrow -->
                                                                            <div class="absolute top-full left-1/2 transform -translate-x-1/2 border-[5px] border-solid border-transparent border-t-[#0f172a]"></div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                @cellValue
                                                            }
                                                        </td>
                                                    }
                                                    else if (mapeoFilasKeys.Contains(campoSeleccionandoModal))
                                                    {
                                                        var localRow = r;
                                                        var mappedProp = GetMappedPropertyNameForCell(localRow, localCol);
                                                        bool tieneMapeo = !string.IsNullOrEmpty(mappedProp);
                                                         bool esElMismo = (mappedProp == campoSeleccionandoModal);
                                                        
                                                        if (esElMismo)
                                                        {
                                                            <td @onclick="() => SeleccionarCeldaFilaDesdePlantilla(localRow, localCol)"
                                                                class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center relative overflow-visible shadow-lg scale-[1.02] z-10 cell-selected"
                                                                style="@GetCeldaStyle(celda, esElMismo, tieneMapeo)"
