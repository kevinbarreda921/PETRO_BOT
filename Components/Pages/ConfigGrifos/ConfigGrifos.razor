@page "/ConfigGrifos"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using PETRO_BOT.Services.Services
@using PETRO_BOT.Models.Configuracion
@using System.IO
@using System.Text.Json

<div class="flex flex-col gap-6 animate-new-row">

    <!-- ============================================== -->
    <!-- MAIN GRID: THE SYSTEM CONTROL & CONFIGURATION -->
    <!-- ============================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

        <!-- Left Column (col-span-4): Fuel stations selector list, styled like mockup breakdown -->
        <div class="lg:col-span-4 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full overflow-hidden">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                    <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Lista de Grifos</h3>
                    <button @onclick="AbrirModalAgregarGrifo" class="bg-[#0f172a] hover:bg-slate-800 text-white text-[9px] font-black uppercase tracking-wider rounded-xl px-3.5 py-2 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-1.5 cursor-pointer">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                        <span>Agregar nuevo grifo</span>
                    </button>
                </div>

                <!-- Custom station rows in Mockup style -->
                <div class="flex flex-col gap-3 overflow-y-auto custom-scrollbar flex-1 pr-1">
                    @{ int idx = 1; }
                    @foreach (var grifo in grifosConfig)
                    {
                        var gName = grifo.Key;
                        var esSeleccionado = gName == grifoSeleccionadoName;
                        var currentIdx = idx++;
                        <div @onclick="() => SeleccionarGrifo(gName)" 
                             class="flex items-center justify-between group/ch p-3 rounded-2xl border transition-all cursor-pointer @(esSeleccionado ? "bg-[#0f172a] border-[#0f172a] text-white shadow-lg scale-[1.01]" : "bg-transparent border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900")">
                            
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 @(esSeleccionado ? "bg-slate-800 border border-slate-700" : "bg-slate-100 border border-slate-200")">
                                    <span class="text-xs font-black @(esSeleccionado ? "text-slate-200" : "text-slate-500")">#@currentIdx</span>
                                </div>
                                <div>
                                    <span class="text-xs font-black block uppercase tracking-wide">@gName</span>
                                    <span class="text-[8px] text-slate-400 font-bold block mt-0.5">Configurado</span>
                                </div>
                            </div>

                            <button class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer @(esSeleccionado ? "bg-slate-800 border border-slate-750 text-white hover:text-slate-100" : "bg-white border border-slate-200 text-slate-700 hover:text-slate-900 hover:border-slate-350")">
                                Config
                            </button>

                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column (col-span-8): Form and active mapping editors, styled like Transaction Perf -->
        <div class="lg:col-span-8 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 overflow-y-auto custom-scrollbar" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full">
                
                @if (string.IsNullOrEmpty(grifoSeleccionadoName))
                {
                    <div class="py-24 flex flex-col items-center justify-center gap-4">
                        <div class="bg-slate-50 p-6 rounded-full border border-slate-200 text-slate-400 shadow-sm">
                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                        </div>
                        <span class="text-[10px] font-black text-slate-450 uppercase tracking-[0.25em]">Selecciona un grifo para editar su mapeo</span>
                    </div>
                }
                else
                {
                    <!-- Active Edit Board form -->
                    <div class="flex flex-col gap-6">
                        
                        <!-- Header and action bar -->
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between border-b border-slate-150 pb-4 gap-4">
                            <div>
                                <h3 class="text-sm font-black text-slate-900 uppercase tracking-wider">@grifoSeleccionadoName</h3>
                                <p class="text-[10px] text-slate-500 font-bold uppercase mt-0.5">Modifica coordenadas y límites</p>
                            </div>
                            <div class="flex items-center gap-2">
                                <button @onclick="ConfirmarEliminarGrifo" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Eliminar</button>
                                <button @onclick="CancelarEdicion" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 hover:text-slate-950 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cancelar</button>
                                <button @onclick="GuardarConfiguracion" class="px-4.5 py-2 bg-[#0f172a] text-white hover:bg-slate-800 rounded-xl text-[9px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">Guardar</button>
                            </div>
                        </div>

                        <!-- Panel: Lectura -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm">
                            <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                                <span class="w-1.5 h-3 bg-[#0f172a] rounded-full"></span> Coordenadas de Lectura
                            </h4>
                            <div class="config-grid">
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Fecha</label>
                                    <input type="text" @bind="lecturaConfig.ColumnaFecha" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(lecturaConfig.ColumnaFecha >= 0  ? "background-color: rgba(16, 185, 129, 0.08) !important; border-color: rgba(16, 185, 129, 0.25) !important; color: #10b981 !important;" : "background-color: rgba(244, 63, 94, 0.08) !important; border-color: rgba(244, 63, 94, 0.25) !important; color: #f43f5e !important;")" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Totales</label>
                                    <input type="text" @bind="lecturaConfig.ColumnaTotales" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(lecturaConfig.ColumnaTotales >= 0  ? "background-color: rgba(16, 185, 129, 0.08) !important; border-color: rgba(16, 185, 129, 0.25) !important; color: #10b981 !important;" : "background-color: rgba(244, 63, 94, 0.08) !important; border-color: rgba(244, 63, 94, 0.25) !important; color: #f43f5e !important;")" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Crédito Nombre</label>
                                    <input type="text" @bind="lecturaConfig.ColumnaCreditoNombre" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(lecturaConfig.ColumnaCreditoNombre >= 0  ? "background-color: rgba(16, 185, 129, 0.08) !important; border-color: rgba(16, 185, 129, 0.25) !important; color: #10b981 !important;" : "background-color: rgba(244, 63, 94, 0.08) !important; border-color: rgba(244, 63, 94, 0.25) !important; color: #f43f5e !important;")" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Crédito Monto</label>
                                    <input type="text" @bind="lecturaConfig.ColumnaCreditoMonto" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(lecturaConfig.ColumnaCreditoMonto >= 0  ? "background-color: rgba(16, 185, 129, 0.08) !important; border-color: rgba(16, 185, 129, 0.25) !important; color: #10b981 !important;" : "background-color: rgba(244, 63, 94, 0.08) !important; border-color: rgba(244, 63, 94, 0.25) !important; color: #f43f5e !important;")" />
                                </div>
                            </div>

                            <!-- Row maps -->
                            <h5 class="text-[8px] font-black text-slate-500 uppercase tracking-widest border-t border-slate-200 pt-4 mt-4 mb-2.5">Mapeo de Filas (Excel)</h5>
                            <div class="config-grid">
                                @foreach (var prop in mapeoFilasKeys)
                                {
                                    <div class="flex flex-col gap-1">
                                        <label class="text-[8px] font-black text-slate-500 uppercase truncate" title="@prop">@prop</label>
                                        <input type="text" @bind="mapeoFilasTemp[prop]" class="w-full rounded-xl px-2.5 py-1.5 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(string.IsNullOrWhiteSpace(mapeoFilasTemp[prop]) ? "background-color: rgba(244, 63, 94, 0.08) !important; border-color: rgba(244, 63, 94, 0.25) !important; color: #f43f5e !important;" : "background-color: rgba(16, 185, 129, 0.08) !important; border-color: rgba(16, 185, 129, 0.25) !important; color: #10b981 !important;")" placeholder="N/A" />
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Panel: Escritura -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm">
                            <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                                <span class="w-1.5 h-3 bg-slate-500 rounded-full"></span> Columnas Excel Maestro
                            </h4>
                            <div class="config-grid">
                                @foreach (var col in columnasEscrituraKeys)
                                {
                                    <div class="flex flex-col gap-1">
                                        <label class="text-[8px] font-black text-slate-500 uppercase truncate" title="@col">@col</label>
                                        <input type="text" @bind="columnasEscrituraTemp[col]" class="w-full rounded-xl px-2.5 py-1.5 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(string.IsNullOrWhiteSpace(columnasEscrituraTemp[col]) ? "background-color: rgba(244, 63, 94, 0.08) !important; border-color: rgba(244, 63, 94, 0.25) !important; color: #f43f5e !important;" : "background-color: rgba(16, 185, 129, 0.08) !important; border-color: rgba(16, 185, 129, 0.25) !important; color: #10b981 !important;")" placeholder="Columna" />
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Panel: Authorized clients -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm mb-6">
                            <div class="flex items-center justify-between border-b border-slate-200 pb-3 mb-3.5">
                                <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] flex items-center gap-2">
                                    <span class="w-1.5 h-3 bg-[#0f172a] rounded-full"></span> Clientes Autorizados
                                </h4>
                                <button @onclick="AbrirModalAgregarCliente" class="bg-[#0f172a] text-white hover:bg-slate-800 px-3.5 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Agregar</button>
                            </div>
                            <div class="overflow-y-auto custom-scrollbar" style="max-height: 220px; padding-right: 4px;">
                                <table class="w-full text-left">
                                    <thead>
                                        <tr class="text-slate-500 text-[8px] uppercase tracking-wider border-b border-slate-200">
                                            <th class="pb-2 font-black">Columna</th>
                                            <th class="pb-2 font-black">Cliente / Razon Social</th>
                                            <th class="pb-2 font-black text-right pr-4">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-xs">
                                        @if (clientesCreditoTemp == null || !clientesCreditoTemp.Any())
                                        {
                                            <tr>
                                                <td colspan="3" class="py-6 text-center text-slate-500 italic font-semibold">Sin clientes registrados.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var cliente in clientesCreditoTemp)
                                            {
                                                var col = cliente.Key;
                                                var name = cliente.Value;
                                                <tr class="border-b border-slate-200/60 hover:bg-slate-100/60">
                                                    <td class="py-3 font-bold text-slate-850 font-mono font-black">@col</td>
                                                    <td class="py-3 text-slate-700 font-bold">@name</td>
                                                    <td class="py-3 text-right flex items-center justify-end gap-2 pr-4">
                                                        <button @onclick="() => AbrirModalEditarCliente(col, name)" class="px-2.5 py-1 rounded-lg bg-white border border-slate-200 text-slate-700 hover:text-slate-900 hover:border-slate-350 font-black text-[9px] uppercase select-none cursor-pointer">Editar</button>
                                                        <button @onclick="() => EliminarCliente(col)" class="px-2.5 py-1 rounded-lg bg-rose-50 hover:bg-rose-100 text-rose-750 border border-rose-200 font-black text-[9px] uppercase select-none cursor-pointer">Eliminar</button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- ELASIC DIALOG MODALS IN DARK GLASSMORPHISM -->
<!-- ============================================== -->

<!-- 1. MODAL NUEVO GRIFO -->
@if (mostrarModalNuevoGrifo)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAgregarGrifo"></div>
        <div class="bg-white border border-slate-200 w-full max-w-md rounded-[28px] shadow-2xl overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Agregar Nuevo Grifo</h3>
                <button @onclick="CerrarModalAgregarGrifo" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-55 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Nombre del Grifo</label>
                    <input type="text" @bind="nuevoGrifoNombre" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-800 placeholder-slate-400 outline-none focus:border-slate-450 transition-all text-center uppercase font-bold" placeholder="EJ: BRASIL" />
                </div>
            </div>
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalAgregarGrifo" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cancelar</button>
                <button @onclick="AgregarNuevoGrifo" class="px-5 py-2.5 bg-[#0f172a] text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">Crear Grifo</button>
            </div>
        </div>
    </div>
}

<!-- 2. MODAL CLIENTE CRÉDITO -->
@if (mostrarModalCliente)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAgregarCliente"></div>
        <div class="bg-white border border-slate-200 w-full max-w-md rounded-[28px] shadow-2xl overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">
                    @(isEditingClient ? "Editar Cliente de Crédito" : "Agregar Cliente de Crédito")
                </h3>
                <button @onclick="CerrarModalAgregarCliente" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-55 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Columna Excel</label>
                    <input type="text" @bind="nuevoClienteColumna" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-800 placeholder-slate-400 outline-none focus:border-slate-450 transition-all text-center uppercase font-bold" placeholder="EJ: H" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Nombre Completo / Razón Social</label>
                    <input type="text" @bind="nuevoClienteNombre" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-800 placeholder-slate-400 outline-none focus:border-slate-450 transition-all text-center font-bold" placeholder="EJ: REDCOL SAC" />
                </div>
            </div>
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalAgregarCliente" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cancelar</button>
                <button @onclick="GuardarCliente" class="px-5 py-2.5 bg-[#0f172a] text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">
                    @(isEditingClient ? "Guardar Cambios" : "Agregar Cliente")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .config-grid {
        display: grid !important;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)) !important;
        gap: 12px !important;
        width: 100% !important;
    }
    .config-grid .flex-col label {
        font-size: 8px !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-transform: uppercase !important;
        display: block !important;
        max-width: 100% !important;
    }
</style>

@code {
    private Dictionary<string, GrifoConfig> grifosConfig = new();
    private string grifoSeleccionadoName = "";
    
    private LecturaConfig lecturaConfig = new();
    private Dictionary<string, string> mapeoFilasTemp = new();
    private Dictionary<string, string> columnasEscrituraTemp = new();
    private Dictionary<string, string> clientesCreditoTemp = new();

    private readonly string[] mapeoFilasKeys = {
        "Venta_GLP", "Venta_GNV", "Total_venta_acumulada", "Total_Tarjeta_de_Credito_Liquidos",
        "Total_Tarjeta_de_Credito_GLP", "Total_Tarjeta_de_Credito_GNV", "ErrorMaquina",
        "Recaudo_Cofide_GNV", "Gastos", "Ventas_con_transferencia"
    };

    private readonly string[] columnasEscrituraKeys = {
        "Venta_GLP", "Venta_GNV", "Total_venta_acumulada", "Total_Tarjeta_de_Credito_Liquidos",
        "Total_Tarjeta_de_Credito_GLP", "Total_Tarjeta_de_Credito_GNV", "ErrorMaquina",
        "Recaudo_Cofide_GNV", "Gastos", "Ventas_con_transferencia", "DescuentoLiquidos",
        "DescuentoGLP", "Hermes_monto_liquido", "Hermes_monto_GLP", "Hermes_monto_GNV1", "Hermes_monto_GNV2"
    };

    private bool mostrarModalNuevoGrifo = false;
    private string nuevoGrifoNombre = "";

    private bool mostrarModalCliente = false;
    private bool isEditingClient = false;
    private string oldClienteColumna = "";
    private string nuevoClienteColumna = "";
    private string nuevoClienteNombre = "";

    protected override void OnInitialized()
    {
        CargarConfiguracion();
    }

    private void CargarConfiguracion()
    {
        grifosConfig = new Dictionary<string, GrifoConfig>(ConfiguracionService.ConfigGlobal.Grifos);
    }

    private void CancelarEdicion()
    {
        grifoSeleccionadoName = "";
        ToastService.Success("Edición cancelada.");
    }

    private void SeleccionarGrifo(string name)
    {
        grifoSeleccionadoName = name;
        var config = grifosConfig[name];
        
        lecturaConfig = new LecturaConfig
        {
            ColumnaFecha = config.Lectura?.ColumnaFecha ?? 14,
            ColumnaTotales = config.Lectura?.ColumnaTotales ?? 15,
            ColumnaCreditoNombre = config.Lectura?.ColumnaCreditoNombre ?? 0,
            ColumnaCreditoMonto = config.Lectura?.ColumnaCreditoMonto ?? 6,
            ColumnaVariaCombusNombre = config.Lectura?.ColumnaVariaCombusNombre ?? 16,
            ColumnaVariaCombusMonto = config.Lectura?.ColumnaVariaCombusMonto ?? 18,
            ColumnaTablaHermes = config.Lectura?.ColumnaTablaHermes ?? 14
        };

        mapeoFilasTemp = new Dictionary<string, string>();
        foreach (var key in mapeoFilasKeys)
        {
            mapeoFilasTemp[key] = "";
        }

        if (config.Lectura?.MapeoFilas != null)
        {
            foreach (var kvp in config.Lectura.MapeoFilas)
            {
                string rowNumber = kvp.Key.Trim();
                string propName = kvp.Value;
                if (!string.IsNullOrEmpty(rowNumber) && mapeoFilasTemp.ContainsKey(propName))
                {
                    mapeoFilasTemp[propName] = rowNumber;
                }
            }
        }

        columnasEscrituraTemp = new Dictionary<string, string>();
        foreach (var key in columnasEscrituraKeys)
        {
            columnasEscrituraTemp[key] = "";
        }

        if (config.Escritura?.Columnas != null)
        {
            foreach (var kvp in config.Escritura.Columnas)
            {
                if (columnasEscrituraTemp.ContainsKey(kvp.Key))
                {
                    columnasEscrituraTemp[kvp.Key] = kvp.Value;
                }
            }
        }

        clientesCreditoTemp = config.FilasClientesCreditos != null 
            ? new Dictionary<string, string>(config.FilasClientesCreditos) 
            : new Dictionary<string, string>();
    }

    private void GuardarConfiguracion()
    {
        if (string.IsNullOrEmpty(grifoSeleccionadoName)) return;

        var grifo = grifosConfig[grifoSeleccionadoName];
        
        var mapeoFilasOutput = new Dictionary<string, string>();
        int spaceCount = 0;
        foreach (var kvp in mapeoFilasTemp)
        {
            string rowNumber = kvp.Value?.Trim() ?? "";
            string propName = kvp.Key;
            if (!string.IsNullOrEmpty(rowNumber))
            {
                mapeoFilasOutput[rowNumber] = propName;
            }
            else
            {
                string emptyKey = new string(' ', spaceCount);
                mapeoFilasOutput[emptyKey] = propName;
                spaceCount++;
            }
        }

        lecturaConfig.MapeoFilas = mapeoFilasOutput;
        grifo.Lectura = lecturaConfig;

        grifo.Escritura ??= new EscrituraConfig();
        grifo.Escritura.Columnas = new Dictionary<string, string>(columnasEscrituraTemp);

        grifo.FilasClientesCreditos = new Dictionary<string, string>(clientesCreditoTemp);

        try
        {
            string baseDir = AppDomain.CurrentDomain.BaseDirectory;
            string pathJson = Path.GetFullPath(Path.Combine(baseDir, @"..\..\..\Json\JsonRegistroVentas\", "config_grifos.json"));
            
            var options = new JsonSerializerOptions { WriteIndented = true };
            string jsonText = JsonSerializer.Serialize(new { Grifos = grifosConfig }, options);
            File.WriteAllText(pathJson, jsonText);
            
            ConfiguracionService.ConfigGlobal.Grifos = grifosConfig;
            ToastService.Success($"Configuración de {grifoSeleccionadoName} guardada correctamente.");
            grifoSeleccionadoName = "";
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar la configuración: " + ex.Message);
        }
    }

    private void AbrirModalAgregarGrifo()
    {
        nuevoGrifoNombre = "";
        mostrarModalNuevoGrifo = true;
    }

    private void CerrarModalAgregarGrifo()
    {
        mostrarModalNuevoGrifo = false;
    }

    private void AgregarNuevoGrifo()
    {
        if (string.IsNullOrWhiteSpace(nuevoGrifoNombre))
        {
            ToastService.Error("Ingresa el nombre del nuevo grifo.");
            return;
        }

        string grifoNameUpper = nuevoGrifoNombre.Trim().ToUpper();
        if (grifosConfig.ContainsKey(grifoNameUpper))
        {
            ToastService.Error("Este grifo ya existe en la configuración.");
            return;
        }

        var nuevoGrifo = new GrifoConfig
        {
            Lectura = new LecturaConfig
            {
                ColumnaFecha = 14,
                ColumnaTotales = 15,
                ColumnaCreditoNombre = 0,
                ColumnaCreditoMonto = 6,
                ColumnaVariaCombusNombre = 16,
                ColumnaVariaCombusMonto = 18,
                ColumnaTablaHermes = 14,
                MapeoFilas = new Dictionary<string, string>()
            },
            Escritura = new EscrituraConfig
            {
                Columnas = new Dictionary<string, string>()
            },
            FilasClientesCreditos = new Dictionary<string, string>()
        };

        for (int i = 0; i < mapeoFilasKeys.Length; i++)
        {
            nuevoGrifo.Lectura.MapeoFilas[new string(' ', i)] = mapeoFilasKeys[i];
        }

        foreach (var key in columnasEscrituraKeys)
        {
            nuevoGrifo.Escritura.Columnas[key] = "";
        }

        grifosConfig[grifoNameUpper] = nuevoGrifo;
        mostrarModalNuevoGrifo = false;
        
        SeleccionarGrifo(grifoNameUpper);
        ToastService.Success($"Grifo {grifoNameUpper} creado correctamente.");
    }

    private async Task ConfirmarEliminarGrifo()
    {
        if (string.IsNullOrEmpty(grifoSeleccionadoName)) return;

        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"¿Estás seguro de que deseas eliminar permanentemente el grifo {grifoSeleccionadoName}?");
        if (confirm)
        {
            EliminarGrifoActual();
        }
    }

    private void EliminarGrifoActual()
    {
        string name = grifoSeleccionadoName;
        try
        {
            grifosConfig.Remove(name);
            grifoSeleccionadoName = "";

            string baseDir = AppDomain.CurrentDomain.BaseDirectory;
            string pathJson = Path.GetFullPath(Path.Combine(baseDir, @"..\..\..\Json\JsonRegistroVentas\", "config_grifos.json"));
            
            var options = new JsonSerializerOptions { WriteIndented = true };
            string jsonText = JsonSerializer.Serialize(new { Grifos = grifosConfig }, options);
            File.WriteAllText(pathJson, jsonText);
            
            ConfiguracionService.ConfigGlobal.Grifos = grifosConfig;
            ToastService.Success($"El grifo {name} ha sido eliminado.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al eliminar: " + ex.Message);
        }
    }

    private void AbrirModalAgregarCliente()
    {
        isEditingClient = false;
        nuevoClienteColumna = "";
        nuevoClienteNombre = "";
        mostrarModalCliente = true;
    }

    private void AbrirModalEditarCliente(string col, string name)
    {
        isEditingClient = true;
        oldClienteColumna = col;
        nuevoClienteColumna = col;
        nuevoClienteNombre = name;
        mostrarModalCliente = true;
    }

    private void CerrarModalAgregarCliente()
    {
        mostrarModalCliente = false;
    }

    private void GuardarCliente()
    {
        if (string.IsNullOrWhiteSpace(nuevoClienteColumna) || string.IsNullOrWhiteSpace(nuevoClienteNombre))
        {
            ToastService.Error("Completa todos los campos obligatorios.");
            return;
        }

        string colUpper = nuevoClienteColumna.Trim().ToUpper();
        string nameTrim = nuevoClienteNombre.Trim();

        if (isEditingClient)
        {
            if (colUpper != oldClienteColumna)
            {
                clientesCreditoTemp.Remove(oldClienteColumna);
            }
            clientesCreditoTemp[colUpper] = nameTrim;
            ToastService.Success("Cliente editado temporalmente.");
        }
        else
        {
            if (clientesCreditoTemp.ContainsKey(colUpper))
            {
                ToastService.Error($"La columna {colUpper} ya está asignada a un cliente.");
                return;
            }
            clientesCreditoTemp[colUpper] = nameTrim;
            ToastService.Success("Cliente agregado temporalmente.");
        }

        mostrarModalCliente = false;
    }

    private void EliminarCliente(string col)
    {
        clientesCreditoTemp.Remove(col);
        ToastService.Success($"Cliente de la columna {col} removido.");
    }
}
