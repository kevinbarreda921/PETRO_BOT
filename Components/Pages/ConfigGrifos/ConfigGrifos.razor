        ToastService.Success($"Fila y Columna para {propName} removidas. Recuerda Guardar los cambios.");
    }

    private void SeleccionarCeldaFilaDesdePlantilla(int rowIndex, int colIndex)
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(campoSeleccionandoModal)) return;

        if (mapeoFilasKeys.Contains(campoSeleccionandoModal))
        {
            if (rowIndex >= 0 && colIndex >= 0)
            {
                int rowNum = rowIndex + 1;
                string colLetter = GetExcelColumnName(colIndex);
                SetConfigValue(campoSeleccionandoModal, true, colLetter);
                SetConfigValue(campoSeleccionandoModal, false, rowNum.ToString());
                ToastService.Success($"Fila y Columna para {campoSeleccionandoModal} establecidas en {colLetter}{rowNum}. Recuerda Guardar los cambios.");
            }
            else
            {
                SetConfigValue(campoSeleccionandoModal, true, "");
                SetConfigValue(campoSeleccionandoModal, false, "");
                ToastService.Success($"Fila para {campoSeleccionandoModal} desasignada. Recuerda Guardar los cambios.");
            }
            CerrarModalVerPlantilla();
        }
    }

    private string GetMappedPropertyNameForCell(int localRow, int localCol)
    {
        if (grifoSeleccionado == null) return null;
        var config = grifoSeleccionado.Configuracion;

        // 0. Check EESS
        if (localCol == config.ColumnaEESS && localRow == (config.FilaEESS - 1))
        {
            return "EESS";
        }

        // 1. Check Fecha
        if (localCol == config.ColumnaFecha && localRow == (config.FilaFecha - 1))
        {
            return "Fecha";
        }

        // 2. Check Crédito Nombre
        if (localCol == config.ColumnaCreditoNombre && localRow == (config.FilaCreditosNombre - 1))
        {
            return "Crédito Nombre";
        }

        // 3. Check Crédito Monto
        if (localCol == config.ColumnaCreditoMonto && localRow == (config.FilaCreditosMonto - 1))
        {
            return "Crédito Monto";
        }

        // Check Hermes Banco
        if (localCol == config.ColumnaHermesBanco && localRow == (config.FilaHermesBanco - 1))
        {
            return "HermesBanco";
        }

        // Check Hermes Tipo
        if (localCol == config.ColumnaHermesTipo && localRow == (config.FilaHermesTipo - 1))
        {
            return "HermesTipo";
        }

        // Check Hermes Monto
        if (localCol == config.ColumnaHermesMonto && localRow == (config.FilaHermesMonto - 1))
        {
            return "HermesMonto";
        }

        // Check Combustible Var. Nombre
        if (localCol == config.ColumnaVariaCombusNombre && localRow == (config.FilaVariaCombusNombre - 1))
        {
            return "VariaCombusNombre";
        }

        // Check Combustible Var. Monto
        if (localCol == config.ColumnaVariaCombusMonto && localRow == (config.FilaVariaCombusMonto - 1))
        {
            return "VariaCombusMonto";
        }

        // 4. Check sequential fields
        foreach (var propName in mapeoFilasKeys)
        {
            string val = GetConfigValue(propName, false); // row value
            if (string.IsNullOrWhiteSpace(val)) continue;

            int colIndex = -1;
            int rowIndex = -1;

            if (val.Contains(","))
            {
                var parts = val.Split(',');
                if (parts.Length == 2 && int.TryParse(parts[0], out int c) && int.TryParse(parts[1], out int r))
                {
                    colIndex = c;
                    rowIndex = r;
                }
            }
            else if (int.TryParse(val, out int r))
            {
                rowIndex = r;
                string customCol = GetConfigValue(propName, true); // col letter
                if (!string.IsNullOrWhiteSpace(customCol))
                {
                    int parsedCol = ConfiguracionService.GetExcelColumnIndex(customCol);
                    if (parsedCol >= 0)
                    {
                        colIndex = parsedCol;
                    }
                }
            }

            if (colIndex == localCol && rowIndex == (localRow + 1))
            {
                return propName;
            }
        }

        return null;
    }

    private void CerrarModalVerPlantilla()
    {
        mostrarModalVerPlantilla = false;
        plantillaExcelFilas.Clear();
        campoSeleccionandoModal = "";
    }

    private string GetExcelColumnName(int columnNumber)
    {
        int dividend = columnNumber + 1;
        string columnName = String.Empty;
        int modulo;

        while (dividend > 0)
        {
            modulo = (dividend - 1) % 26;
            columnName = Convert.ToChar(65 + modulo).ToString() + columnName;
            dividend = (int)((dividend - modulo) / 26);
        }

        return columnName;
    }

