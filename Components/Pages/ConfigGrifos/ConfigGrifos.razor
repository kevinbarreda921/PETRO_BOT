                                                <svg class="w-3 h-3 ml-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            </button>
                                            @if (!string.IsNullOrWhiteSpace(GetWriteConfigValue(col)))
                                            {
                                                <button @onclick="() => SetWriteConfigValue(col, null)" type="button" class="absolute right-1 p-1 bg-white hover:bg-rose-50 border border-slate-200 hover:border-rose-200 rounded-lg text-slate-450 hover:text-rose-600 transition-all cursor-pointer shadow-sm select-none font-bold" title="Limpiar valor">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Panel: Authorized clients -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm flex flex-col flex-grow flex-1 min-h-[220px] mb-2">
                            <div class="flex items-center justify-between border-b border-slate-200 pb-3 mb-3.5">
                                <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] flex items-center gap-2">
                                    <span class="w-1.5 h-3 bg-[#0f172a] rounded-full"></span> Clientes Autorizados
                                </h4>
                                <button @onclick="AbrirModalAgregarCliente" 
                                        disabled="@(grifoSeleccionado.Configuracion.ColumnaCreditoNombre < 0 || grifoSeleccionado.Configuracion.FilaCreditosNombre < 1)" 
                                        class="bg-[#0f172a] hover:bg-slate-800 text-white disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed px-3.5 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shadow-sm hover:scale-[1.01] active:scale-[0.98]"
                                        title="@(grifoSeleccionado.Configuracion.ColumnaCreditoNombre < 0 || grifoSeleccionado.Configuracion.FilaCreditosNombre < 1 ? "Configura primero 'Crédito Nombre' en Coordenadas de Lectura" : "Agregar Clientes")">
                                    Agregar
                                </button>
                            </div>
                            <div class="overflow-auto custom-scrollbar bg-white border border-slate-200 rounded-2xl shadow-sm" style="flex: 1; min-height: 150px;">
                                <table class="w-full text-left border-collapse">
                                    <thead class="sticky top-0 z-10" style="background-color: #1e293b !important;">
                                        <tr class="text-[10px] font-black uppercase tracking-wider" style="color: #ffffff !important;">
                                            <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Columna</th>
                                            <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Cliente / Razón Social</th>
                                            <th class="py-3 px-4 text-right" style="background-color: #1e293b !important; color: #ffffff !important;">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-xs text-slate-700 divide-y divide-slate-100">
                                        @if (grifoSeleccionado.ClientesCredito == null || !grifoSeleccionado.ClientesCredito.Any())
                                        {
                                            <tr>
                                                <td colspan="3" class="py-8 text-center text-slate-450 italic font-semibold bg-white">Sin clientes registrados.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var cliente in grifoSeleccionado.ClientesCredito)
                                            {
                                                var col = cliente.Columna;
                                                var name = cliente.ClienteNombre;
                                                <tr class="hover:bg-slate-50/50 transition-all duration-205">
                                                    <td class="py-2.5 px-4 bg-white">
                                                        <div class="relative flex items-center w-24">
                                                            <button @onclick="() => ActivarSeleccionClienteCol(cliente)" type="button" class="w-full rounded-xl px-2.5 py-1.5 text-xs font-bold outline-none transition-all duration-300 border text-center select-none cursor-pointer flex items-center justify-center gap-1 min-h-[30px]" style="@(!string.IsNullOrWhiteSpace(cliente.Columna) ? "background-color: #0f172a !important; border-color: #0f172a !important; color: #ffffff !important;" : "background-color: #dc2626 !important; border-color: #dc2626 !important; color: #ffffff !important;")" title="@(string.IsNullOrWhiteSpace(cliente.Columna) ? "Sin Asignar" : $"Columna {cliente.Columna}")">
                                                                <span>@(!string.IsNullOrWhiteSpace(cliente.Columna) ? cliente.Columna : "Sin Valor")</span>
                                                                <svg class="w-3 h-3 ml-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                                            </button>
                                                            @if (!string.IsNullOrWhiteSpace(cliente.Columna))
                                                            {
                                                                <button @onclick="() => LimpiarClienteColumna(cliente)" type="button" class="absolute right-1 p-0.5 bg-white hover:bg-rose-50 border border-slate-200 hover:border-rose-200 rounded text-slate-450 hover:text-rose-600 transition-all cursor-pointer shadow-sm select-none font-bold" title="Limpiar valor">
                                                                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td class="py-2.5 px-4 bg-white font-bold text-slate-800">@name</td>
                                                    <td class="py-2.5 px-4 bg-white text-right">
                                                        <div class="flex items-center justify-end gap-2">
                                                            <button @onclick="() => EliminarCliente(cliente.Id)" class="bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-200/80 text-[10px] font-black uppercase tracking-wider rounded-xl px-3.5 py-1.5 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-1.5 cursor-pointer">
                                                                <svg class="w-3 h-3 text-rose-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                                <span>Eliminar</span>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- ELASIC DIALOG MODALS IN DARK GLASSMORPHISM -->
<!-- ============================================== -->

<!-- 1. MODAL NUEVO GRIFO -->
@if (mostrarModalNuevoGrifo)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAgregarGrifo"></div>
        <div class="bg-white border border-slate-200 w-full max-w-md rounded-[28px] shadow-2xl overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Agregar Nuevo Grifo</h3>
                <button @onclick="CerrarModalAgregarGrifo" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-55 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Nombre del Grifo</label>
                    <input type="text" @bind="nuevoGrifoNombre" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-800 placeholder-slate-400 outline-none focus:border-slate-450 transition-all text-center uppercase font-bold" placeholder="EJ: BRASIL" />
                </div>
            </div>
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalAgregarGrifo" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cancelar</button>
                <button @onclick="AgregarNuevoGrifo" class="px-5 py-2.5 bg-[#0f172a] text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">Crear Grifo</button>
            </div>
        </div>
    </div>
}

<!-- 2. MODAL CLIENTE CRÉDITO -->
@if (mostrarModalCliente)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAgregarCliente"></div>
        <div class="bg-white border border-slate-200 w-fit min-w-[520px] max-w-[95vw] rounded-[28px] shadow-2xl overflow-hidden flex flex-col transition-all duration-300 animate-modal-in" style="max-height: 85vh;">
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Importador de Clientes de Crédito</h3>
                <button @onclick="CerrarModalAgregarCliente" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-55 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-4 overflow-hidden flex-1">
                
                <!-- Zone: File Upload (Minimalist) -->
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Cargar Partes Diarios</label>
                    <div class="flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-2xl p-3">
                        <div class="relative overflow-hidden inline-block shrink-0">
                            <button class="bg-[#0f172a] hover:bg-slate-800 text-white px-3.5 py-2 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shadow-sm hover:scale-[1.01] active:scale-[0.98] flex items-center gap-1.5">
                                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                <span>Cargar Varios Excel</span>
                            </button>
                            <InputFile OnChange="CargarArchivosClientes" multiple class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept=".xlsx" />
                        </div>
                        <span class="text-[8px] text-slate-450 font-bold uppercase">Solo formato .xlsx (Máx. 10MB c/u)</span>
                    </div>
                </div>

                <!-- Table: Clientes Leídos -->
                <div class="flex-1 flex flex-col overflow-hidden min-h-[250px]">
                    <div class="flex items-center justify-between pb-2 mb-2 border-b border-slate-150 border-solid">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Clientes Encontrados en Excel</label>
                        <span class="bg-slate-100 text-slate-600 text-[8px] font-black uppercase px-2 py-0.5 rounded-full border border-slate-200">@clientesLeidosModal.Count Clientes</span>
                    </div>
                    <div class="overflow-auto custom-scrollbar flex-1 border border-slate-200 rounded-2xl bg-white">
                        <table class="w-full text-left">
                            <thead class="sticky top-0 bg-slate-50 border-b border-slate-200 z-10">
                                <tr class="text-[9px] font-black uppercase tracking-wider text-slate-500">
                                    <th class="py-2.5 px-4">Contador</th>
                                    <th class="py-2.5 px-2">Cliente</th>
                                    <th class="py-2.5 px-2">Estado</th>
                                    <th class="py-2.5 px-4 text-right">Acción</th>
                                </tr>
                            </thead>
                            <tbody class="text-xs">
                                @if (clientesLeidosModal == null || !clientesLeidosModal.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="py-8 text-center text-slate-400 italic font-semibold">Suba archivos Excel de partes diarios para escanear clientes de crédito.</td>
                                    </tr>
                                }
                                else
                                {
                                    @for (int i = 0; i < clientesLeidosModal.Count; i++)
                                    {
                                        var importadorIdx = i + 1;
                                        var clientName = clientesLeidosModal[i];
                                        bool yaExiste = grifoSeleccionado.ClientesCredito?.Any(c => string.Equals(c.ClienteNombre, clientName, StringComparison.OrdinalIgnoreCase)) ?? false;
                                        
                                        <tr class="border-b border-slate-100 hover:bg-slate-50/50 transition-all">
                                            <td class="py-2 px-4 font-mono text-slate-400 font-bold">@importadorIdx</td>
                                            <td class="py-2 px-2 text-slate-800 font-bold uppercase whitespace-nowrap" title="@clientName">@clientName</td>
                                            <td class="py-2 px-2">
                                                @if (yaExiste)
                                                {
                                                    <span class="inline-flex items-center gap-1 text-[8px] font-black uppercase tracking-wider px-2 py-0.5 rounded-lg border bg-emerald-50 text-emerald-700 border-emerald-250">
                                                        <span class="w-1 h-1 rounded-full bg-emerald-500 animate-pulse"></span>
                                                        Cliente Creado
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="inline-flex items-center gap-1 text-[8px] font-black uppercase tracking-wider px-2 py-0.5 rounded-lg border bg-rose-50 text-rose-700 border-rose-250">
                                                        <span class="w-1 h-1 rounded-full bg-rose-500 animate-pulse"></span>
                                                        Cliente Faltante
                                                    </span>
                                                }
                                            </td>
                                            <td class="py-2 px-4 text-right">
                                                @if (!yaExiste)
                                                {
                                                    <button @onclick="() => AgregarClienteDesdeModal(clientName)" class="bg-[#0f172a] hover:bg-slate-800 text-white text-[9px] font-black uppercase tracking-wider rounded-lg px-2.5 py-1.5 shadow-sm transition-all active:scale-[0.98] select-none cursor-pointer">
                                                        Agregar Cliente
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalAgregarCliente" class="px-5 py-2.5 bg-slate-200 text-slate-700 hover:bg-slate-300 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cerrar Importer</button>
                @if (clientesLeidosModal != null && clientesLeidosModal.Any(name => !(grifoSeleccionado?.ClientesCredito?.Any(c => string.Equals(c.ClienteNombre, name, StringComparison.OrdinalIgnoreCase)) ?? false)))
                {
                    <button @onclick="ImportarTodosLosClientes" class="px-5 py-2.5 bg-[#0f172a] hover:bg-slate-800 text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">
                        Importar Todos
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- 3. MODAL VER PLANTILLA EXCEL -->
@if (mostrarModalVerPlantilla)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalVerPlantilla"></div>
        <div class="bg-white border border-slate-200 w-full max-w-[96vw] rounded-[28px] shadow-2xl overflow-hidden flex flex-col hover:border-slate-350 transition-all duration-300 animate-modal-in" style="max-height: 90vh;">
            
            <!-- Modal Header -->
            <div class="px-6 py-5 border-b border-slate-150 flex items-center justify-between bg-slate-50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center border border-emerald-200">
                        <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Previsualización de Plantilla</h3>
                        <span class="text-[9px] text-slate-450 font-bold block uppercase mt-0.5">Archivo: @plantillaExcelNombre</span>
                    </div>
                </div>
                <button @onclick="CerrarModalVerPlantilla" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <!-- Sheet Selector Tabs -->
            @if (!viendoRegistroVentasModal)
            {
                <div class="px-6 py-3 border-b border-slate-100 bg-white flex items-center gap-3 overflow-hidden">
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider shrink-0">Hojas de Trabajo:</span>
                    <div class="flex items-center gap-2 overflow-x-auto pb-1.5 custom-scrollbar flex-1 whitespace-nowrap scroll-smooth">
                        @foreach (var sheet in plantillaExcelHojas)
                        {
                            var esHojaActiva = string.Equals(sheet, plantillaExcelHojaSeleccionada, StringComparison.OrdinalIgnoreCase);
                            <button @onclick="() => CargarDatosHojaExcel(sheet)" 
                                    class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center gap-1.5 shrink-0 @(esHojaActiva ? "bg-emerald-600 text-white shadow-md scale-[1.01]" : "bg-slate-100 hover:bg-slate-200 text-slate-600 hover:text-slate-800 border border-transparent")">
                                <span class="w-1.5 h-1.5 rounded-full @(esHojaActiva ? "bg-white animate-pulse" : "bg-slate-400")"></span>
                                <span>@sheet</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- Modal Body (Excel-like Grid) -->
            <div class="p-6 overflow-hidden bg-slate-50/50 flex-1 flex flex-col">
                @if (columnasEscrituraKeys.Contains(campoSeleccionandoModal) || (campoSeleccionandoModal != null && campoSeleccionandoModal.StartsWith("ClienteColumna_")))
                {
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección de Columna Maestro</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic sobre cualquier celda de la <strong>Fila 10</strong> para establecer su letra como la columna para "<strong>@GetActiveSelectionLabel()</strong>".</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaWriteColDesdePlantilla(-1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }
                else if (campoSeleccionandoModal == "ColumnaFecha" || campoSeleccionandoModal == "CreditoNombre" || campoSeleccionandoModal == "CreditoMonto" || campoSeleccionandoModal == "HermesBanco" || campoSeleccionandoModal == "HermesTipo" || campoSeleccionandoModal == "HermesMonto" || campoSeleccionandoModal == "VariaCombusNombre" || campoSeleccionandoModal == "VariaCombusMonto" || campoSeleccionandoModal == "EESS")
                {
                    var titleText = campoSeleccionandoModal == "ColumnaFecha" ? "Columna/Fila Fecha" :
                                    campoSeleccionandoModal == "EESS" ? "Columna/Fila EESS" :
                                    campoSeleccionandoModal == "CreditoNombre" ? "Columna/Fila de Crédito Nombre" :
                                    campoSeleccionandoModal == "CreditoMonto" ? "Columna/Fila de Crédito Monto" :
                                    campoSeleccionandoModal == "HermesBanco" ? "Columna/Fila de Hermes Banco" :
                                    campoSeleccionandoModal == "HermesTipo" ? "Columna/Fila de Hermes Tipo" :
                                    campoSeleccionandoModal == "HermesMonto" ? "Columna/Fila de Hermes Monto" :
                                    campoSeleccionandoModal == "VariaCombusNombre" ? "Columna/Fila de Combustible Var. Nombre" :
