@page "/ConfigGrifos"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using PETRO_BOT.Services.Services
@using PETRO_BOT.Models.Configuracion
@using System.IO
@using System.Text.Json
@using ExcelDataReader

<div class="flex flex-col gap-6 animate-new-row">

    <!-- ============================================== -->
    <!-- MAIN GRID: THE SYSTEM CONTROL & CONFIGURATION -->
    <!-- ============================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

        <!-- Left Column (col-span-4): Fuel stations selector list, styled like mockup breakdown -->
        <div class="lg:col-span-4 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full overflow-hidden">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                    <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Lista de Grifos</h3>
                    <button @onclick="AbrirModalAgregarGrifo" class="bg-[#0f172a] hover:bg-slate-800 text-white text-[9px] font-black uppercase tracking-wider rounded-xl px-3.5 py-2 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-1.5 cursor-pointer">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                        <span>Agregar nuevo grifo</span>
                    </button>
                </div>

                <!-- Custom station rows in Mockup style -->
                <div class="flex flex-col gap-3 overflow-y-auto custom-scrollbar flex-1 pr-1">
                    @{ int idx = 1; }
                    @foreach (var grifo in grifosList)
                    {
                        var gName = grifo.Nombre;
                        var esSeleccionado = grifoSeleccionado != null && grifo.Id == grifoSeleccionado.Id;
                        var currentIdx = idx++;
                        <div @onclick="() => SeleccionarGrifo(grifo.Id)" 
                             class="flex items-center justify-between group/ch p-3 rounded-2xl border transition-all cursor-pointer @(esSeleccionado ? "bg-[#0f172a] border-[#0f172a] text-white shadow-lg scale-[1.01]" : "bg-transparent border-transparent text-slate-600 hover:bg-slate-50 hover:text-slate-900")">
                            
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 @(esSeleccionado ? "bg-slate-800 border border-slate-700" : "bg-slate-100 border border-slate-200")">
                                    <span class="text-xs font-black @(esSeleccionado ? "text-slate-200" : "text-slate-500")">#@currentIdx</span>
                                </div>
                                <div>
                                    <span class="text-xs font-black block uppercase tracking-wide">@gName</span>
                                    <span class="text-[8px] text-slate-400 font-bold block mt-0.5">Configurado</span>
                                </div>
                            </div>

                            <button class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer @(esSeleccionado ? "bg-slate-800 border border-slate-750 text-white hover:text-slate-100" : "bg-white border border-slate-200 text-slate-700 hover:text-slate-900 hover:border-slate-350")">
                                Config
                            </button>

                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column (col-span-8): Form and active mapping editors, styled like Transaction Perf -->
        <div class="lg:col-span-8 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 overflow-y-auto custom-scrollbar" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full">
                
                @if (grifoSeleccionado == null)
                {
                    <div class="py-24 flex flex-col items-center justify-center gap-4">
                        <div class="bg-slate-50 p-6 rounded-full border border-slate-200 text-slate-400 shadow-sm">
                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                        </div>
                        <span class="text-[10px] font-black text-slate-450 uppercase tracking-[0.25em]">Selecciona un grifo para editar su mapeo</span>
                    </div>
                }
                else
                {
                    <!-- Active Edit Board form -->
                    <div class="flex flex-col gap-6 flex-1 min-h-0">
                        
                                        <!-- Header and action bar in ONE row -->
                        <div class="flex flex-col md:flex-row flex-wrap md:items-center justify-between border-b border-slate-150 pb-4 gap-3 w-full">
                            <!-- Left: Nombre del Grifo Inline -->
                            <div class="flex items-center gap-2 shrink-0 justify-center md:justify-start w-full md:w-auto">
                                <label class="text-[8px] font-black text-slate-400 uppercase tracking-widest shrink-0">Grifo:</label>
                                <input type="text" @bind="grifoSeleccionado.Nombre" class="text-xs font-black text-slate-900 uppercase tracking-wider border border-slate-200 rounded-xl px-3 py-1.5 outline-none focus:border-slate-450 focus:bg-white bg-slate-50 w-32 sm:w-40 transition-all font-bold shrink-0" />
                            </div>

                            <!-- Middle: Plantilla compact pill -->
                            <div class="flex flex-row items-center gap-2 bg-slate-50 border border-slate-200 rounded-xl p-1 px-3 shadow-sm min-w-0 max-w-full sm:max-w-md w-full md:w-auto justify-center md:justify-start md:ml-auto">
                                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full shrink-0"></span>
                                <span class="text-[10px] font-bold text-slate-700 truncate max-w-[80px] sm:max-w-[200px]" title="@grifoSeleccionado.Plantilla">
                                    @(string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla) ? "Ninguna cargada" : grifoSeleccionado.Plantilla)
                                </span>
                                <div class="flex items-center gap-1 shrink-0 ml-1">
                                    <InputFile id="fileUpload" OnChange="CargarPlantillaArchivo" accept=".xlsx" class="hidden" />
                                    <label for="fileUpload" class="px-3 py-1.5 bg-[#0f172a] hover:bg-slate-800 text-white rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center justify-center gap-1.5 shadow-sm shrink-0">
                                        <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                        <span>Cargar</span>
                                    </label>
                                    <button @onclick="AbrirModalVerPlantilla" disabled="@(string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla))" class="px-3 py-1.5 bg-[#0f172a] hover:bg-slate-800 text-white disabled:bg-slate-250 disabled:text-slate-400 disabled:cursor-not-allowed rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center justify-center gap-1.5 shadow-sm shrink-0">
                                        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        <span>Ver</span>
                                    </button>
                                </div>
                            </div>

                            <!-- Right: General buttons -->
                            <div class="flex flex-row flex-wrap items-center gap-1.5 shrink-0 justify-center w-full md:w-auto">
                                <button @onclick="ConfirmarEliminarGrifo" class="px-3 py-1.5 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shrink-0">Eliminar</button>
                                <button @onclick="CancelarEdicion" class="px-3 py-1.5 bg-white border border-slate-200 text-slate-700 hover:bg-slate-55 hover:text-slate-950 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shrink-0">Cancelar</button>
                                <button @onclick="GuardarConfiguracion" class="px-4 py-1.5 bg-[#0f172a] text-white hover:bg-slate-800 rounded-xl text-[9px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer shrink-0">Guardar</button>
                            </div>
                        </div>

                        <!-- Panel: Lectura -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm">
                            <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                                <span class="w-1.5 h-3 bg-[#0f172a] rounded-full"></span> Coordenadas de Lectura
                            </h4>
                            <div class="config-grid">
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Fecha</label>
                                    <div class="relative flex items-center">
                                        <button @onclick="ActivarSeleccionColumnaFecha" type="button" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300 border text-center select-none cursor-pointer flex items-center justify-center gap-1 min-h-[34px]" style="@(grifoSeleccionado.Configuracion.ColumnaFecha >= 0 && grifoSeleccionado.Configuracion.FilaFecha >= 1 ? "background-color: #0f172a !important; border-color: #0f172a !important; color: #ffffff !important;" : "background-color: #dc2626 !important; border-color: #dc2626 !important; color: #ffffff !important;")" title="@(grifoSeleccionado.Configuracion.ColumnaFecha >= 0 && grifoSeleccionado.Configuracion.FilaFecha >= 1 ? GetExcelColumnName(grifoSeleccionado.Configuracion.ColumnaFecha) + grifoSeleccionado.Configuracion.FilaFecha + " (Columna: " + grifoSeleccionado.Configuracion.ColumnaFecha + ", Fila: " + grifoSeleccionado.Configuracion.FilaFecha + ")" : "Sin Asignar")">
                                            <span>@(grifoSeleccionado.Configuracion.ColumnaFecha >= 0 && grifoSeleccionado.Configuracion.FilaFecha >= 1 ? GetExcelColumnName(grifoSeleccionado.Configuracion.ColumnaFecha) + grifoSeleccionado.Configuracion.FilaFecha : "Sin Valor")</span>
                                            <svg class="w-3 h-3 ml-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        </button>
                                        @if (grifoSeleccionado.Configuracion.ColumnaFecha >= 0 && grifoSeleccionado.Configuracion.FilaFecha >= 1)
                                        {
                                            <button @onclick="LimpiarColumnaFecha" type="button" class="absolute right-1 p-1 bg-white hover:bg-rose-50 border border-slate-200 hover:border-rose-200 rounded-lg text-slate-450 hover:text-rose-600 transition-all cursor-pointer shadow-sm select-none font-bold" title="Limpiar valor">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Crédito Nombre</label>
                                    <input type="number" @bind="grifoSeleccionado.Configuracion.ColumnaCreditoNombre" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(grifoSeleccionado.Configuracion.ColumnaCreditoNombre >= 0  ? "background-color: #0f172a !important; border-color: #0f172a !important; color: #ffffff !important;" : "background-color: #dc2626 !important; border-color: #dc2626 !important; color: #ffffff !important;")" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[8px] font-black text-slate-500 uppercase">Columna Crédito Monto</label>
                                    <input type="number" @bind="grifoSeleccionado.Configuracion.ColumnaCreditoMonto" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300" style="text-align: center; border-width: 1px; border-style: solid; @(grifoSeleccionado.Configuracion.ColumnaCreditoMonto >= 0  ? "background-color: #0f172a !important; border-color: #0f172a !important; color: #ffffff !important;" : "background-color: #dc2626 !important; border-color: #dc2626 !important; color: #ffffff !important;")" />
                                </div>
                            </div>

                            <!-- Row maps -->
                            <div class="config-grid-4">
                                @foreach (var prop in mapeoFilasKeys)
                                {
                                    <div class="flex flex-col gap-1">
                                        <label class="text-[8px] font-black text-slate-500 uppercase truncate" title="@prop">@prop</label>
                                        <div class="relative flex items-center">
                                            <button @onclick="() => ActivarSeleccionFila(prop)" type="button" class="w-full rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all duration-300 border text-center select-none cursor-pointer flex items-center justify-center gap-1 min-h-[34px]" style="@(!string.IsNullOrWhiteSpace(GetConfigValue(prop, false)) ? "background-color: #0f172a !important; border-color: #0f172a !important; color: #ffffff !important;" : "background-color: #dc2626 !important; border-color: #dc2626 !important; color: #ffffff !important;")" title="@GetConfigLabelFull(prop)">
                                                <span>@GetConfigLabel(prop, false)</span>
                                                <svg class="w-3 h-3 ml-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                            </button>
                                            @if (!string.IsNullOrWhiteSpace(GetConfigValue(prop, false)))
                                            {
                                                <button @onclick="() => LimpiarFila(prop)" type="button" class="absolute right-1 p-1 bg-white hover:bg-rose-50 border border-slate-200 hover:border-rose-200 rounded-lg text-slate-450 hover:text-rose-600 transition-all cursor-pointer shadow-sm select-none font-bold" title="Limpiar valor">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Panel: Escritura -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm">
                            <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] border-b border-slate-200 pb-2 mb-4 flex items-center gap-2">
                                <span class="w-1.5 h-3 bg-slate-500 rounded-full"></span> Columnas Excel Maestro
                            </h4>
                            <div class="config-grid">
                                @foreach (var col in columnasEscrituraKeys)
                                {
                                    <div class="flex flex-col gap-1">
                                        <label class="text-[8px] font-black text-slate-500 uppercase truncate" title="@col">@col</label>
                                        <input type="text" 
                                               value="@GetConfigValue(col, true)" 
                                               @onchange="@(e => SetConfigValue(col, true, e.Value?.ToString() ?? ""))" 
                                               class="w-full rounded-xl px-2.5 py-1.5 text-xs font-bold outline-none transition-all duration-300" 
                                               style="text-align: center; border-width: 1px; border-style: solid; @(string.IsNullOrWhiteSpace(GetConfigValue(col, true)) ? "background-color: #dc2626 !important; border-color: #dc2626 !important; color: #ffffff !important;" : "background-color: #0f172a !important; border-color: #0f172a !important; color: #ffffff !important;")" 
                                               placeholder="Columna" />
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Panel: Authorized clients -->
                        <div class="bg-slate-50 border border-slate-200 rounded-[20px] p-5 shadow-sm flex flex-col flex-grow flex-1 min-h-[220px] mb-2">
                            <div class="flex items-center justify-between border-b border-slate-200 pb-3 mb-3.5">
                                <h4 class="text-[9px] font-black text-slate-800 uppercase tracking-[0.15em] flex items-center gap-2">
                                    <span class="w-1.5 h-3 bg-[#0f172a] rounded-full"></span> Clientes Autorizados
                                </h4>
                                <button @onclick="AbrirModalAgregarCliente" class="bg-[#0f172a] hover:bg-slate-800 text-white px-3.5 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer shadow-sm hover:scale-[1.01] active:scale-[0.98]">Agregar</button>
                            </div>
                            <div class="overflow-auto custom-scrollbar bg-[#0f172a] border border-slate-800 rounded-2xl px-4 pb-4 pt-0 shadow-lg" style="flex: 1; min-height: 150px; padding-right: 4px;">
                                <table class="w-full text-left">
                                    <thead class="sticky top-0 bg-[#0f172a] z-10">
                                        <tr class="text-xs font-black uppercase tracking-wider border-b border-slate-800" style="color: #ffffff !important;">
                                            <th class="py-3 bg-[#0f172a]" style="color: #ffffff !important;">Columna</th>
                                            <th class="py-3 bg-[#0f172a]" style="color: #ffffff !important;">Cliente / Razon Social</th>
                                            <th class="py-3 text-right pr-4 bg-[#0f172a]" style="color: #ffffff !important;">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-xs">
                                        @if (grifoSeleccionado.ClientesCredito == null || !grifoSeleccionado.ClientesCredito.Any())
                                        {
                                            <tr>
                                                <td colspan="3" class="py-6 text-center text-slate-400 italic font-semibold">Sin clientes registrados.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var cliente in grifoSeleccionado.ClientesCredito)
                                            {
                                                var col = cliente.Columna;
                                                var name = cliente.ClienteNombre;
                                                <tr class="border-b border-slate-850 hover:bg-slate-900/40 transition-all duration-200">
                                                    <td class="py-3 font-bold text-white font-mono font-black">@col</td>
                                                    <td class="py-3 text-slate-200 font-bold">@name</td>
                                                    <td class="py-3 text-right flex items-center justify-end gap-2 pr-4">
                                                        <button @onclick="() => AbrirModalEditarCliente(cliente.Id, col, name)" class="bg-white hover:bg-slate-100 text-slate-900 text-[9px] font-black uppercase tracking-wider rounded-xl px-2.5 py-1.5 border border-slate-200 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-1.5 cursor-pointer">
                                                            <svg class="w-3 h-3 text-slate-800" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                                            <span>Editar</span>
                                                        </button>
                                                        <button @onclick="() => EliminarCliente(cliente.Id)" class="bg-rose-600 hover:bg-rose-700 text-white text-[9px] font-black uppercase tracking-wider rounded-xl px-2.5 py-1.5 shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-1.5 cursor-pointer">
                                                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                            <span>Eliminar</span>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- ELASIC DIALOG MODALS IN DARK GLASSMORPHISM -->
<!-- ============================================== -->

<!-- 1. MODAL NUEVO GRIFO -->
@if (mostrarModalNuevoGrifo)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAgregarGrifo"></div>
        <div class="bg-white border border-slate-200 w-full max-w-md rounded-[28px] shadow-2xl overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Agregar Nuevo Grifo</h3>
                <button @onclick="CerrarModalAgregarGrifo" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-55 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-wider ml-1">Nombre del Grifo</label>
                    <input type="text" @bind="nuevoGrifoNombre" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-800 placeholder-slate-400 outline-none focus:border-slate-450 transition-all text-center uppercase font-bold" placeholder="EJ: BRASIL" />
                </div>
            </div>
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalAgregarGrifo" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all select-none cursor-pointer">Cancelar</button>
