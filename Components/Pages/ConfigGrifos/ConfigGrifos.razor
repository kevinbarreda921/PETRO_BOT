    private async Task CargarArchivosClientes(InputFileChangeEventArgs e)
    {
        if (grifoSeleccionado == null) return;
        
        try
        {
            string uploadDir = Path.Combine(ConfiguracionService.ObtenerWebRootPath(env.WebRootPath), "uploads", "ClientesCredito");
            if (!Directory.Exists(uploadDir))
            {
                Directory.CreateDirectory(uploadDir);
            }

            var loadedPaths = new List<string>();
            foreach (var file in e.GetMultipleFiles())
            {
                string uniqueName = $"{Guid.NewGuid()}_{file.Name}";
                string filePath = Path.Combine(uploadDir, uniqueName);
                
                using (var stream = new FileStream(filePath, FileMode.Create))
                {
                    await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
                }
                loadedPaths.Add(filePath);
            }

            var lector = new LectorClientesCreditos();
            var list = lector.ObtenerClientes(loadedPaths, grifoSeleccionado);
            
            clientesLeidosModal = list;
            
            ToastService.Success($"Se leyeron {clientesLeidosModal.Count} clientes de los archivos subidos.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar archivos de clientes: " + ex.Message);
        }
    }

    private void AgregarClienteDesdeModal(string name)
    {
        if (grifoSeleccionado == null) return;
        
        if (!grifoSeleccionado.ClientesCredito.Any(c => string.Equals(c.ClienteNombre, name, StringComparison.OrdinalIgnoreCase)))
        {
            int tempId = -1;
            if (grifoSeleccionado.ClientesCredito.Any())
            {
                int minId = grifoSeleccionado.ClientesCredito.Min(c => c.Id);
                if (minId < 0)
                {
                    tempId = minId - 1;
                }
            }
            
            grifoSeleccionado.ClientesCredito.Add(new RegistroVentasClienteCredito
            {
                Id = tempId,
                GrifoId = grifoSeleccionado.Id,
                Columna = "",
                ClienteNombre = name
            });
            
            ToastService.Success($"Cliente '{name}' agregado.");
        }
        
        clientesLeidosModal.Remove(name);
        StateHasChanged();
    }

    private void ImportarTodosLosClientes()
    {
        if (grifoSeleccionado == null || clientesLeidosModal == null || !clientesLeidosModal.Any()) return;
        
        int agregadosCount = 0;
        var listCopy = clientesLeidosModal.ToList();
        
        foreach (var name in listCopy)
        {
            bool yaExiste = grifoSeleccionado.ClientesCredito?.Any(c => string.Equals(c.ClienteNombre, name, StringComparison.OrdinalIgnoreCase)) ?? false;
            if (!yaExiste)
            {
                int tempId = -1;
                if (grifoSeleccionado.ClientesCredito.Any())
                {
                    int minId = grifoSeleccionado.ClientesCredito.Min(c => c.Id);
                    if (minId < 0)
                    {
                        tempId = minId - 1;
                    }
                }
                
                grifoSeleccionado.ClientesCredito.Add(new RegistroVentasClienteCredito
                {
                    Id = tempId,
                    GrifoId = grifoSeleccionado.Id,
                    Columna = "",
                    ClienteNombre = name
                });
                
                agregadosCount++;
                clientesLeidosModal.Remove(name);
            }
        }
        
        if (agregadosCount > 0)
        {
            ToastService.Success($"Se agregaron {agregadosCount} clientes correctamente. Recuerda guardar los cambios.");
        }
        else
        {
            ToastService.Info("No hay nuevos clientes para agregar.");
        }
        
        StateHasChanged();
    }

