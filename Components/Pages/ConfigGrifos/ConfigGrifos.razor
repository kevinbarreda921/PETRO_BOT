<!-- 3. MODAL VER PLANTILLA EXCEL -->
@if (mostrarModalVerPlantilla)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalVerPlantilla"></div>
        <div class="bg-white border border-slate-200 w-full max-w-[96vw] rounded-[28px] shadow-2xl overflow-hidden flex flex-col hover:border-slate-350 transition-all duration-300 animate-modal-in" style="max-height: 90vh;">
            
            <!-- Modal Header -->
            <div class="px-6 py-5 border-b border-slate-150 flex items-center justify-between bg-slate-50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center border border-emerald-200">
                        <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-xs font-black text-slate-800 uppercase tracking-widest">Previsualización de Plantilla</h3>
                        <span class="text-[9px] text-slate-450 font-bold block uppercase mt-0.5">Archivo: @plantillaExcelNombre</span>
                    </div>
                </div>
                <button @onclick="CerrarModalVerPlantilla" class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <!-- Sheet Selector Tabs -->
            <div class="px-6 py-3 border-b border-slate-100 bg-white flex items-center gap-3 overflow-hidden">
                <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider shrink-0">Hojas de Trabajo:</span>
                <div class="flex items-center gap-2 overflow-x-auto pb-1.5 custom-scrollbar flex-1 whitespace-nowrap scroll-smooth">
                    @foreach (var sheet in plantillaExcelHojas)
                    {
                        var esHojaActiva = string.Equals(sheet, plantillaExcelHojaSeleccionada, StringComparison.OrdinalIgnoreCase);
                        <button @onclick="() => CargarDatosHojaExcel(sheet)" 
                                class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all select-none cursor-pointer flex items-center gap-1.5 shrink-0 @(esHojaActiva ? "bg-emerald-600 text-white shadow-md scale-[1.01]" : "bg-slate-100 hover:bg-slate-200 text-slate-600 hover:text-slate-800 border border-transparent")">
                            <span class="w-1.5 h-1.5 rounded-full @(esHojaActiva ? "bg-white animate-pulse" : "bg-slate-400")"></span>
                            <span>@sheet</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Modal Body (Excel-like Grid) -->
            <div class="p-6 overflow-hidden bg-slate-50/50 flex-1 flex flex-col">
                @if (campoSeleccionandoModal == "ColumnaFecha")
                {
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección Activo</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic sobre una celda para establecerla como "Columna/Fila Fecha".</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaDesdePlantilla(-1, -1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }
                else if (mapeoFilasKeys.Contains(campoSeleccionandoModal))
                {
                    <div class="mb-4 bg-emerald-55 border border-emerald-200/80 rounded-2xl p-4 flex items-center justify-between shadow-sm animate-modal-in" style="background-color: #f0fdf4;">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 border border-emerald-200 animate-pulse">
                                <span class="text-emerald-755 text-xs font-black">●</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-black text-emerald-800 uppercase tracking-widest block">Modo Selección de Fila Activo</span>
                                <span class="text-[10px] text-emerald-650 font-bold block mt-0.5">Haga clic sobre cualquier celda de la fila deseada para establecerla como Fila de <strong>@campoSeleccionandoModal</strong>.</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="() => SeleccionarCeldaFilaDesdePlantilla(-1, -1)" type="button" class="px-3.5 py-2 bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Eliminar Valor / Sin Asignar
                            </button>
                            <button @onclick="CerrarModalVerPlantilla" type="button" class="px-3.5 py-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all cursor-pointer shadow-sm select-none">
                                Cancelar
                            </button>
                        </div>
                    </div>
                }

                @if (plantillaExcelFilas == null || !plantillaExcelFilas.Any())
                {
                    <div class="py-24 flex flex-col items-center justify-center gap-3">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-emerald-600"></div>
                        <span class="text-[10px] font-black text-slate-450 uppercase tracking-[0.2em]">Cargando datos de Excel...</span>
                    </div>
                }
                else
                {
                    var maxColCount = plantillaExcelFilas.Max(r => r.Count);
                    
                    <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white flex-1 flex flex-col">
                        <div id="excelPreviewContainer" class="overflow-auto custom-scrollbar flex-1" style="max-height: calc(90vh - 220px);">
                            <table class="w-full border-collapse text-left excel-preview-table">
                                <thead>
                                    <tr class="bg-slate-100 select-none">
                                        <!-- Corner cell -->
                                        <th class="w-10 bg-slate-200 border-r border-b border-slate-300"></th>
                                        @for (int c = 0; c < maxColCount; c++)
                                        {
                                            var letter = GetExcelColumnName(c);
                                            <th class="px-3 py-1.5 text-center text-[9px] font-mono font-black text-slate-500 border-r border-b border-slate-300/80 min-w-[120px] bg-slate-100">
                                                @letter
                                            </th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int r = 0; r < plantillaExcelFilas.Count; r++)
                                    {
                                        var rowData = plantillaExcelFilas[r];
                                        var displayRowNumber = r + 1;
                                        <tr class="hover:bg-slate-50/40 border-b border-slate-200/70">
                                            <td class="bg-slate-100 text-center text-[9px] font-mono font-black text-slate-450 border-r border-slate-300/80 select-none py-1.5 w-10">
                                                @displayRowNumber
                                            </td>
                                            @for (int c = 0; c < maxColCount; c++)
                                            {
                                                var localCol = c;
                                                var cellValue = localCol < rowData.Count ? rowData[localCol] : "";
                                                if (campoSeleccionandoModal == "ColumnaFecha")
                                                {
                                                    var localRow = r;
                                                    var esSeleccionado = (localCol == grifoSeleccionado?.Configuracion.ColumnaFecha && localRow == (grifoSeleccionado?.Configuracion.FilaFecha - 1));
                                                    <td @onclick="() => SeleccionarCeldaDesdePlantilla(localRow, localCol)"
                                                        class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center relative overflow-visible @(esSeleccionado ? "bg-[#0f172a] text-white border border-solid border-[#0f172a] shadow-lg scale-[1.02] z-10 cell-selected" : "bg-emerald-50/45 text-emerald-800 hover:bg-emerald-100/70 border border-dashed border-emerald-200/50 hover:border-emerald-500 hover:scale-[1.01]")"
                                                        title="Haga clic para seleccionar esta celda como Fecha (Fila y Columna)">
                                                        @if (esSeleccionado)
                                                        {
                                                            <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                <span>@cellValue</span>
                                                                <div class="absolute bottom-full left-1/2 px-2.5 py-1 bg-[#0f172a] text-white text-[9px] font-black uppercase tracking-wider rounded-lg shadow-xl z-[9999] whitespace-nowrap pointer-events-none select-none flex items-center gap-1 border border-slate-700 premium-tooltip-breath">
                                                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                                                    <span>Celda Fecha (@(GetExcelColumnName(localCol))@(localRow + 1))</span>
                                                                    <!-- Down Arrow -->
                                                                    <div class="absolute top-full left-1/2 transform -translate-x-1/2 border-[5px] border-solid border-transparent border-t-[#0f172a]"></div>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            @cellValue
                                                        }
                                                    </td>
                                                }
                                                else if (mapeoFilasKeys.Contains(campoSeleccionandoModal))
                                                {
                                                    var localRow = r;
                                                    bool esSeleccionado = false;
                                                    string currentVal = GetConfigValue(campoSeleccionandoModal, false);
                                                    string currentCol = GetConfigValue(campoSeleccionandoModal, true);
                                                    
                                                    int savedRow = -1;
                                                    int savedCol = -1;
                                                    
                                                    if (!string.IsNullOrWhiteSpace(currentCol) && int.TryParse(currentVal, out savedRow))
                                                    {
                                                        savedCol = ConfiguracionService.GetExcelColumnIndex(currentCol);
                                                        esSeleccionado = (localRow == (savedRow - 1) && localCol == savedCol);
                                                    }
                                                    else if (currentVal.Contains(","))
                                                    {
                                                        var parts = currentVal.Split(',');
                                                        if (parts.Length == 2 && int.TryParse(parts[0], out savedCol) && int.TryParse(parts[1], out savedRow))
                                                        {
                                                            esSeleccionado = (localRow == (savedRow - 1) && localCol == savedCol);
                                                        }
                                                    }

                                                    <td @onclick="() => SeleccionarCeldaFilaDesdePlantilla(localRow, localCol)"
                                                        class="px-3 py-1.5 text-xs border-r font-black transition-all select-none cursor-pointer text-center relative overflow-visible @(esSeleccionado ? "bg-[#0f172a] text-white border border-solid border-[#0f172a] shadow-lg scale-[1.02] z-10 cell-selected" : "bg-emerald-50/45 text-emerald-800 hover:bg-emerald-100/70 border border-dashed border-emerald-200/50 hover:border-emerald-500 hover:scale-[1.01]")"
                                                        title="Haga clic para seleccionar esta celda para @campoSeleccionandoModal">
                                                        @if (esSeleccionado)
                                                        {
                                                            <div class="relative w-full h-full flex items-center justify-center overflow-visible">
                                                                <span>@cellValue</span>
                                                                <div class="absolute bottom-full left-1/2 px-2.5 py-1 bg-[#0f172a] text-white text-[9px] font-black uppercase tracking-wider rounded-lg shadow-xl z-[9999] whitespace-nowrap pointer-events-none select-none flex items-center gap-1 border border-slate-700 premium-tooltip-breath">
                                                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                                                    <span>Celda @(GetExcelColumnName(localCol))@(localRow + 1) (@campoSeleccionandoModal)</span>
                                                                    <!-- Down Arrow -->
                                                                    <div class="absolute top-full left-1/2 transform -translate-x-1/2 border-[5px] border-solid border-transparent border-t-[#0f172a]"></div>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            @cellValue
                                                        }
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td class="px-3 py-1.5 text-xs text-slate-650 border-r border-slate-200 font-medium truncate min-w-[120px] max-w-[240px] hover:overflow-visible hover:whitespace-normal" title="@cellValue">
                                                        @cellValue
                                                    </td>
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4.5 border-t border-slate-150 flex justify-end gap-2 bg-slate-50">
                <button @onclick="CerrarModalVerPlantilla" class="px-5 py-2.5 bg-[#0f172a] hover:bg-slate-800 text-white rounded-xl text-[10px] font-black uppercase tracking-wider shadow-md hover:scale-[1.01] active:scale-[0.98] transition-all select-none cursor-pointer">
                    Cerrar Vista
                </button>
            </div>
            
        </div>
    </div>
}

<style>
    .config-grid {
        display: grid !important;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)) !important;
        gap: 12px !important;
        width: 100% !important;
    }
    .config-grid .flex-col label {
        font-size: 8px !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-transform: uppercase !important;
        display: block !important;
        max-width: 100% !important;
    }
    .config-grid-4 {
        display: grid !important;
        grid-template-columns: 1fr !important;
        gap: 12px !important;
        width: 100% !important;
    }
    @@media (min-width: 480px) {
        .config-grid-4 {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
    @@media (min-width: 1100px) {
        .config-grid-4 {
            grid-template-columns: repeat(3, 1fr) !important;
        }
    }
    @@media (min-width: 1400px) {
        .config-grid-4 {
            grid-template-columns: repeat(4, 1fr) !important;
        }
    }
    .config-grid-4 .flex-col label {
        font-size: 8px !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-transform: uppercase !important;
        display: block !important;
        max-width: 100% !important;
    }
    @@keyframes pulse-breath {
        0%, 100% {
            opacity: 0.20;
            transform: translate(-50%, -6px) scale(0.95);
        }
        50% {
            opacity: 1;
            transform: translate(-50%, -20px) scale(1.02);
        }
    }
    .premium-tooltip-breath {
        animation: pulse-breath 2.5s ease-in-out infinite !important;
    }
    
    /* Excel Table Sticky Headers and Columns (Freeze Panes) */
    .excel-preview-table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
    }
    
    /* Sticky Top Headers (A, B, C...) */
    .excel-preview-table thead tr th {
        position: sticky !important;
        top: 0 !important;
        z-index: 20 !important;
        background-color: #f8fafc !important; /* bg-slate-50 equivalent */
        border-bottom: 2px solid #cbd5e1 !important; /* border-slate-300 */
        border-right: 1px solid #cbd5e1 !important;
    }
    
    /* Sticky Left Columns (1, 2, 3...) */
    .excel-preview-table tbody tr td:first-child {
        position: sticky !important;
        left: 0 !important;
        z-index: 10 !important;
        background-color: #f1f5f9 !important; /* bg-slate-100 equivalent */
        border-right: 2px solid #cbd5e1 !important; /* border-slate-300 */
        border-bottom: 1px solid #e2e8f0 !important;
        font-weight: 900 !important;
        color: #475569 !important; /* slate-600 */
    }
    
    /* Sticky Corner Cell (top-left empty header) */
    .excel-preview-table thead tr th:first-child {
        position: sticky !important;
        top: 0 !important;
        left: 0 !important;
        z-index: 30 !important; /* highest priority corner cell */
        background-color: #e2e8f0 !important; /* bg-slate-200 equivalent */
        border-right: 2px solid #cbd5e1 !important; /* border-slate-300 */
        border-bottom: 2px solid #cbd5e1 !important;
    }
    
    /* Interactive hover cell styles with minimalist border animation scoped only to the Excel template preview */
    .excel-preview-table tbody tr td:not(:first-child) {
        position: relative !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }
    .excel-preview-table tbody tr td:not(:first-child):not(.cell-selected):hover {
        box-shadow: inset 0 0 0 2px #0f172a !important;
        background-color: rgba(15, 23, 42, 0.03) !important;
        color: #0f172a !important;
        transform: scale(1.015) !important;
        z-index: 5 !important;
    }
    
    /* Spreadsheet style header highlighting on cell hover */
    .excel-preview-table .header-highlight,
    .excel-preview-table tbody tr td.header-highlight,
    .excel-preview-table thead tr th.header-highlight {
        background-color: #0f172a !important;
        color: #ffffff !important;
        transition: all 0.12s ease-in-out !important;
    }
</style>

@code {
    private List<RegistroVentasGrifo> grifosList = new();
    private RegistroVentasGrifo? grifoSeleccionado = null;
    private bool _shouldScrollSelectedCell = false;

    private bool mostrarModalVerPlantilla = false;
    private string plantillaExcelNombre = "";
    private List<List<string>> plantillaExcelFilas = new();
    private List<string> plantillaExcelHojas = new();
    private string plantillaExcelHojaSeleccionada = "";

    private readonly string[] mapeoFilasKeys = {
        "Venta_GPL", "Venta_GNV", "Total_venta_acumulada", "Total_Tarjeta_de_Credito_Liquidos",
        "Total_Tarjeta_de_Credito_GLP", "Total_Tarjeta_de_Credito_GNV", "ErrorMaquina",
        "Recaudo_Cofide_GNV", "Gastos", "Ventas_con_transferencia"
    };

    private readonly string[] columnasEscrituraKeys = {
        "Venta_GPL", "Venta_GNV", "Total_venta_acumulada", "Total_Tarjeta_de_Credito_Liquidos",
        "Total_Tarjeta_de_Credito_GLP", "Total_Tarjeta_de_Credito_GNV", "ErrorMaquina",
        "Recaudo_Cofide_GNV", "Gastos", "Ventas_con_transferencia", "DescuentoLiquidos",
        "DescuentoGLP", "Hermes_monto_liquido", "Hermes_monto_GLP", "Hermes_monto_GNV1", "Hermes_monto_GNV2"
    };

    private bool mostrarModalNuevoGrifo = false;
    private string nuevoGrifoNombre = "";

    private bool mostrarModalCliente = false;
    private bool isEditingClient = false;
    private int editingClienteId = 0;
    private string nuevoClienteColumna = "";
    private string nuevoClienteNombre = "";

    protected override void OnInitialized()
    {
        System.Text.Encoding.RegisterProvider(System.Text.CodePagesEncodingProvider.Instance);
        CargarConfiguracion();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScrollSelectedCell)
        {
            _shouldScrollSelectedCell = false;
            await Task.Delay(250); // Give the modal animations and rendering enough time to stabilize
            try
            {
                await JSRuntime.InvokeVoidAsync("scrollSelectedCellIntoView");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error triggering scrollSelectedCellIntoView: " + ex.Message);
            }
        }
    }

    private void CargarConfiguracion()
    {
        grifosList = ConfiguracionService.ObtenerGrifosDB();
        if (grifoSeleccionado != null)
        {
            var fresh = grifosList.Find(g => g.Id == grifoSeleccionado.Id);
            if (fresh != null)
            {
                grifoSeleccionado = fresh;
            }
        }
    }

    private string GetConfigValue(string propName, bool isCol)
    {
        if (grifoSeleccionado == null) return "";
        string dbFieldName = (isCol ? "Col_" : "Fila_") + propName;
        var prop = typeof(RegistroVentasConfiguracion).GetProperty(dbFieldName);
        return (prop?.GetValue(grifoSeleccionado.Configuracion) as string) ?? "";
    }

    private string GetConfigLabel(string propName, bool isCol)
    {
        string val = GetConfigValue(propName, isCol);
        if (string.IsNullOrWhiteSpace(val)) return "Sin Valor";
        
        if (!isCol) // Row configurations
        {
            int colIndex = -1;
            int rowIndex = -1;
            
            if (val.Contains(","))
            {
                var parts = val.Split(',');
                if (parts.Length == 2 && int.TryParse(parts[0], out int c) && int.TryParse(parts[1], out int r))
                {
                    colIndex = c;
                    rowIndex = r;
                }
            }
            else if (int.TryParse(val, out int r))
            {
                rowIndex = r;
                string customCol = GetConfigValue(propName, true);
                if (!string.IsNullOrWhiteSpace(customCol))
                {
                    int parsedCol = ConfiguracionService.GetExcelColumnIndex(customCol);
                    if (parsedCol >= 0)
                    {
                        colIndex = parsedCol;
                    }
                }
            }
            
            if (colIndex >= 0 && rowIndex >= 1)
            {
                string colLetter = GetExcelColumnName(colIndex);
                return $"{colLetter}{rowIndex}";
            }
            
            return $"Fila {val}"; // legacy fallback
        }
        return val; // columns
    }

    private string GetConfigLabelFull(string propName)
    {
        string val = GetConfigValue(propName, false);
        if (string.IsNullOrWhiteSpace(val)) return "Sin Asignar";
        
        int colIndex = -1;
        int rowIndex = -1;
        
        if (val.Contains(","))
        {
            var parts = val.Split(',');
            if (parts.Length == 2 && int.TryParse(parts[0], out int c) && int.TryParse(parts[1], out int r))
            {
                colIndex = c;
                rowIndex = r;
            }
        }
        else if (int.TryParse(val, out int r))
        {
            rowIndex = r;
            string customCol = GetConfigValue(propName, true);
            if (!string.IsNullOrWhiteSpace(customCol))
            {
                int parsedCol = ConfiguracionService.GetExcelColumnIndex(customCol);
                if (parsedCol >= 0)
                {
                    colIndex = parsedCol;
                }
            }
        }
        
        if (colIndex >= 0 && rowIndex >= 1)
        {
            string colLetter = GetExcelColumnName(colIndex);
            return $"{colLetter}{rowIndex} (Columna: {colIndex}, Fila: {rowIndex})";
        }
        
        return $"Fila {val}";
    }

    private void SetConfigValue(string propName, bool isCol, string val)
    {
        if (grifoSeleccionado == null) return;
        string dbFieldName = (isCol ? "Col_" : "Fila_") + propName;
        var prop = typeof(RegistroVentasConfiguracion).GetProperty(dbFieldName);
        prop?.SetValue(grifoSeleccionado.Configuracion, val ?? "");
    }

    private void CancelarEdicion()
    {
        CargarConfiguracion();
        grifoSeleccionado = null;
        ToastService.Success("Edición cancelada.");
    }

    private void SeleccionarGrifo(int id)
    {
        CargarConfiguracion();
        grifoSeleccionado = grifosList.Find(g => g.Id == id);
    }

    private void GuardarConfiguracion()
    {
        if (grifoSeleccionado == null) return;

        try
        {
            ConfiguracionService.GuardarGrifoCompletoDB(grifoSeleccionado);
            CargarConfiguracion();
            ToastService.Success($"Configuración de {grifoSeleccionado.Nombre} guardada correctamente.");
            grifoSeleccionado = null;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar la configuración: " + ex.Message);
        }
    }

    private void AbrirModalAgregarGrifo()
    {
        nuevoGrifoNombre = "";
        mostrarModalNuevoGrifo = true;
    }

    private void CerrarModalAgregarGrifo()
    {
        mostrarModalNuevoGrifo = false;
    }

    private void AgregarNuevoGrifo()
    {
        if (string.IsNullOrWhiteSpace(nuevoGrifoNombre))
        {
            ToastService.Error("Ingresa el nombre del nuevo grifo.");
            return;
        }

        string grifoNameUpper = nuevoGrifoNombre.Trim().ToUpper();
        if (grifosList.Exists(g => g.Nombre.Equals(grifoNameUpper, StringComparison.OrdinalIgnoreCase)))
        {
            ToastService.Error("Este grifo ya existe en la configuración.");
            return;
        }

        var nuevoGrifo = new RegistroVentasGrifo
        {
            Nombre = grifoNameUpper,
            Configuracion = new RegistroVentasConfiguracion()
        };

        try
        {
            ConfiguracionService.GuardarGrifoCompletoDB(nuevoGrifo);
            CargarConfiguracion();
            mostrarModalNuevoGrifo = false;
            
            var created = grifosList.Find(g => g.Nombre.Equals(grifoNameUpper, StringComparison.OrdinalIgnoreCase));
            if (created != null)
            {
                SeleccionarGrifo(created.Id);
            }
            ToastService.Success($"Grifo {grifoNameUpper} creado correctamente.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al crear el grifo: " + ex.Message);
        }
    }

    private async Task ConfirmarEliminarGrifo()
    {
        if (grifoSeleccionado == null) return;

        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"¿Estás seguro de que deseas eliminar permanentemente el grifo {grifoSeleccionado.Nombre}?");
        if (confirm)
        {
            EliminarGrifoActual();
        }
    }

    private void EliminarGrifoActual()
    {
        if (grifoSeleccionado == null) return;
        string name = grifoSeleccionado.Nombre;
        try
        {
            ConfiguracionService.EliminarGrifoPorIdDB(grifoSeleccionado.Id);
            CargarConfiguracion();
            grifoSeleccionado = null;
            ToastService.Success($"El grifo {name} ha sido eliminado.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al eliminar: " + ex.Message);
        }
    }

    private void AbrirModalAgregarCliente()
    {
        isEditingClient = false;
        nuevoClienteColumna = "";
        nuevoClienteNombre = "";
        mostrarModalCliente = true;
    }

    private void AbrirModalEditarCliente(int id, string col, string name)
    {
        isEditingClient = true;
        editingClienteId = id;
        nuevoClienteColumna = col;
        nuevoClienteNombre = name;
        mostrarModalCliente = true;
    }

    private void CerrarModalAgregarCliente()
    {
        mostrarModalCliente = false;
    }

    private void GuardarCliente()
    {
        if (grifoSeleccionado == null) return;

        if (string.IsNullOrWhiteSpace(nuevoClienteColumna) || string.IsNullOrWhiteSpace(nuevoClienteNombre))
        {
            ToastService.Error("Completa todos los campos obligatorios.");
            return;
        }

        string colUpper = nuevoClienteColumna.Trim().ToUpper();
        string nameTrim = nuevoClienteNombre.Trim();

        if (isEditingClient)
        {
            var cli = grifoSeleccionado.ClientesCredito.Find(c => c.Id == editingClienteId);
            if (cli != null)
            {
                cli.Columna = colUpper;
                cli.ClienteNombre = nameTrim;
            }
            ToastService.Success("Cliente editado temporalmente.");
        }
        else
        {
            if (grifoSeleccionado.ClientesCredito.Exists(c => c.Columna.Equals(colUpper, StringComparison.OrdinalIgnoreCase)))
            {
                ToastService.Error($"La columna {colUpper} ya está asignada a un cliente.");
                return;
            }
            grifoSeleccionado.ClientesCredito.Add(new RegistroVentasClienteCredito
            {
                GrifoId = grifoSeleccionado.Id,
                Columna = colUpper,
                ClienteNombre = nameTrim
            });
            ToastService.Success("Cliente agregado temporalmente.");
        }

        mostrarModalCliente = false;
    }

    private void EliminarCliente(int id)
    {
        if (grifoSeleccionado == null) return;
        grifoSeleccionado.ClientesCredito.RemoveAll(c => c.Id == id);
        ToastService.Success("Cliente removido temporalmente.");
    }

    private async Task CargarPlantillaArchivo(InputFileChangeEventArgs e)
    {
        if (grifoSeleccionado == null) return;
        var file = e.File;
        if (file != null)
        {
            try
            {
                string plantillasDir = Path.Combine(env.WebRootPath, "bd", "plantillas");
                if (!Directory.Exists(plantillasDir))
                {
                    Directory.CreateDirectory(plantillasDir);
                }

                string ext = Path.GetExtension(file.Name);
                if (ext.ToLower() != ".xlsx")
                {
                    ToastService.Error("Solo se permiten archivos Excel (.xlsx).");
                    return;
                }

                string fileName = file.Name;
                string filePath = Path.Combine(plantillasDir, fileName);

                using (var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
                using (var fileStream = new FileStream(filePath, FileMode.Create))
                {
                    await stream.CopyToAsync(fileStream);
                }

                grifoSeleccionado.Plantilla = fileName;
                ConfiguracionService.GuardarGrifoCompletoDB(grifoSeleccionado);
                CargarConfiguracion();

                ToastService.Success($"Plantilla '{fileName}' cargada y guardada exitosamente.");
            }
            catch (Exception ex)
            {
                ToastService.Error("Error al cargar la plantilla: " + ex.Message);
            }
        }
    }

    private void AbrirModalVerPlantilla()
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla)) return;
        
        try
        {
            string plantillasDir = Path.Combine(env.WebRootPath, "bd", "plantillas");
            string filePath = Path.Combine(plantillasDir, grifoSeleccionado.Plantilla);
            if (!File.Exists(filePath))
            {
                ToastService.Error("El archivo de la plantilla no se encuentra en el servidor.");
                return;
            }

            plantillaExcelNombre = grifoSeleccionado.Plantilla;
            plantillaExcelHojas.Clear();

            using (var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
            using (var reader = ExcelReaderFactory.CreateOpenXmlReader(stream))
            {
                do
                {
                    plantillaExcelHojas.Add(reader.Name);
                } while (reader.NextResult());
            }

            if (plantillaExcelHojas.Any())
            {
                CargarDatosHojaExcel(plantillaExcelHojas.First());
            }

            mostrarModalVerPlantilla = true;
            _shouldScrollSelectedCell = true;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al abrir la plantilla: " + ex.Message);
        }
    }

    private void CargarDatosHojaExcel(string sheetName)
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla)) return;

        try
        {
            string plantillasDir = Path.Combine(env.WebRootPath, "bd", "plantillas");
            string filePath = Path.Combine(plantillasDir, grifoSeleccionado.Plantilla);

            plantillaExcelHojaSeleccionada = sheetName;
            plantillaExcelFilas.Clear();

            using (var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
            using (var reader = ExcelReaderFactory.CreateOpenXmlReader(stream))
            {
                bool found = false;
                do
                {
                    if (string.Equals(reader.Name, sheetName, StringComparison.OrdinalIgnoreCase))
                    {
                        found = true;
                        break;
                    }
                } while (reader.NextResult());

                if (found)
                {
                    int maxRows = 100;
                    int currentRow = 0;
                    while (reader.Read() && currentRow < maxRows)
                    {
                        var row = new List<string>();
                        for (int i = 0; i < reader.FieldCount; i++)
                        {
                            var val = reader.GetValue(i);
                            row.Add(val?.ToString() ?? "");
                        }
                        plantillaExcelFilas.Add(row);
                        currentRow++;
                    }
                }
            }
            _shouldScrollSelectedCell = true;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al leer la hoja de Excel: " + ex.Message);
        }
    }

    private string campoSeleccionandoModal = "";

    private void ActivarSeleccionColumnaFecha()
    {
        if (grifoSeleccionado == null) return;
        if (string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla))
        {
            ToastService.Error("Carga primero un archivo de plantilla Excel para poder seleccionar visualmente.");
            return;
        }

        campoSeleccionandoModal = "ColumnaFecha";
        AbrirModalVerPlantilla();
    }

    private void LimpiarColumnaFecha()
    {
        if (grifoSeleccionado == null) return;
        grifoSeleccionado.Configuracion.ColumnaFecha = -1; // -1 represents empty/no value
        grifoSeleccionado.Configuracion.FilaFecha = -1;    // -1 represents empty/no value
        ToastService.Success("Celda Fecha removida (sin asignar). Recuerda Guardar los cambios.");
    }

    private void SeleccionarCeldaDesdePlantilla(int rowIndex, int colIndex)
    {
        if (grifoSeleccionado == null) return;

        if (campoSeleccionandoModal == "ColumnaFecha")
        {
            grifoSeleccionado.Configuracion.ColumnaFecha = colIndex;
            grifoSeleccionado.Configuracion.FilaFecha = rowIndex + 1; // 1-based index
            if (colIndex >= 0 && rowIndex >= 0)
            {
                string colLetter = GetExcelColumnName(colIndex);
                int rowNum = rowIndex + 1;
                ToastService.Success($"Celda de Fecha establecida en {colLetter}{rowNum} (Columna: {colIndex}, Fila: {rowNum}). Recuerda Guardar los cambios.");
            }
            else
            {
                ToastService.Success("Celda de Fecha establecida sin valor. Recuerda Guardar los cambios.");
            }
            CerrarModalVerPlantilla();
        }
    }

    private void ActivarSeleccionFila(string propName)
    {
        if (grifoSeleccionado == null) return;
        if (string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla))
        {
            ToastService.Error("Carga primero un archivo de plantilla Excel para poder seleccionar visualmente.");
            return;
        }

        campoSeleccionandoModal = propName;
        AbrirModalVerPlantilla();
    }

    private void LimpiarFila(string propName)
    {
        if (grifoSeleccionado == null) return;
        SetConfigValue(propName, true, "");
        SetConfigValue(propName, false, "");
        ToastService.Success($"Fila y Columna para {propName} removidas. Recuerda Guardar los cambios.");
    }

    private void SeleccionarCeldaFilaDesdePlantilla(int rowIndex, int colIndex)
    {
        if (grifoSeleccionado == null || string.IsNullOrWhiteSpace(campoSeleccionandoModal)) return;

        if (mapeoFilasKeys.Contains(campoSeleccionandoModal))
        {
            if (rowIndex >= 0 && colIndex >= 0)
            {
                int rowNum = rowIndex + 1;
                string colLetter = GetExcelColumnName(colIndex);
                SetConfigValue(campoSeleccionandoModal, true, colLetter);
                SetConfigValue(campoSeleccionandoModal, false, rowNum.ToString());
                ToastService.Success($"Fila y Columna para {campoSeleccionandoModal} establecidas en {colLetter}{rowNum}. Recuerda Guardar los cambios.");
            }
            else
            {
                SetConfigValue(campoSeleccionandoModal, true, "");
                SetConfigValue(campoSeleccionandoModal, false, "");
                ToastService.Success($"Fila para {campoSeleccionandoModal} desasignada. Recuerda Guardar los cambios.");
            }
            CerrarModalVerPlantilla();
        }
    }

    private void CerrarModalVerPlantilla()
    {
        mostrarModalVerPlantilla = false;
        plantillaExcelFilas.Clear();
        campoSeleccionandoModal = "";
    }

    private string GetExcelColumnName(int columnNumber)
    {
        int dividend = columnNumber + 1;
        string columnName = String.Empty;
        int modulo;

        while (dividend > 0)
        {
            modulo = (dividend - 1) % 26;
            columnName = Convert.ToChar(65 + modulo).ToString() + columnName;
            dividend = (int)((dividend - modulo) / 26);
        }

        return columnName;
    }
