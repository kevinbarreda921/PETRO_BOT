    private void CargarDatosHojaExcel(string sheetName)
    {
        if (grifoSeleccionado == null) return;
        if (!viendoRegistroVentasModal && string.IsNullOrWhiteSpace(grifoSeleccionado.Plantilla)) return;
        if (viendoRegistroVentasModal && string.IsNullOrWhiteSpace(archivoRegistroVentasNombre)) return;

        try
        {
            string filePath = "";
            string baseWebRoot = ConfiguracionService.ObtenerWebRootPath(env.WebRootPath);
            if (viendoRegistroVentasModal)
            {
                filePath = Path.Combine(baseWebRoot, "bd", "RegistroVentas", "RegistroVentas", archivoRegistroVentasNombre);
            }
            else
            {
                filePath = Path.Combine(baseWebRoot, "bd", "RegistroVentas", "Plantillas", grifoSeleccionado.Plantilla);
            }

            plantillaExcelHojaSeleccionada = sheetName;
            plantillaExcelFilas.Clear();
            plantillaExcelColumnWidths.Clear();

            ExcelPackage.License.SetNonCommercialPersonal("PETROBOT");
            using (var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
            using (var package = new ExcelPackage(stream))
            {
                var worksheet = package.Workbook.Worksheets[sheetName];
                if (worksheet != null)
                {
                    int maxRows = viendoRegistroVentasModal ? 40 : 100;
                    int maxCols = worksheet.Dimension?.End.Column ?? 1;
                    int endRow = Math.Min(worksheet.Dimension?.End.Row ?? 1, maxRows);

                    // Guardar los anchos de columna
                    for (int c = 1; c <= maxCols; c++)
                    {
                        plantillaExcelColumnWidths.Add(worksheet.Column(c).Width);
                    }

                    // Cargar filas y celdas con estilo
                    for (int r = 1; r <= endRow; r++)
                    {
                        var row = new List<CeldaExcelInfo>();
                        for (int c = 1; c <= maxCols; c++)
                        {
                            var cell = worksheet.Cells[r, c];
                            var cellInfo = new CeldaExcelInfo
                            {
                                Valor = cell.Text ?? "",
                                IsBold = cell.Style.Font.Bold,
                                IsItalic = cell.Style.Font.Italic,
                                FontSize = (int?)cell.Style.Font.Size
                            };

                            // Obtener alineación
                            switch (cell.Style.HorizontalAlignment)
                            {
                                case ExcelHorizontalAlignment.Left:
                                    cellInfo.Alignment = "left";
                                    break;
                                case ExcelHorizontalAlignment.Center:
                                    cellInfo.Alignment = "center";
                                    break;
                                case ExcelHorizontalAlignment.Right:
                                    cellInfo.Alignment = "right";
                                    break;
                                default:
                                    cellInfo.Alignment = "";
                                    break;
                            }

                            // Obtener color de fondo
                            if (cell.Style.Fill.PatternType != ExcelFillStyle.None)
                            {
                                cellInfo.ColorFondoHex = GetHexColor(cell.Style.Fill.BackgroundColor);
                            }

                            // Obtener color de texto
                            if (cell.Style.Font.Color != null)
                            {
                                cellInfo.ColorTextoHex = GetHexColor(cell.Style.Font.Color);
                            }

                            row.Add(cellInfo);
                        }
                        plantillaExcelFilas.Add(row);
                    }
                }
            }
            _shouldScrollSelectedCell = true;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al leer la hoja de Excel: " + ex.Message);
        }
    }

    private string GetHexColor(ExcelColor color)
    {
        if (color == null) return "";
        try
        {
            string hex = color.LookupColor() ?? "";
            if (hex.StartsWith("#")) hex = hex.Substring(1);
            if (!string.IsNullOrEmpty(hex))
            {
                if (hex.Length == 8) hex = hex.Substring(2); // Remove Alpha if present
                return "#" + hex;
            }
        }
        catch
        {
            try
            {
                string hex = color.Rgb ?? "";
                if (hex.StartsWith("#")) hex = hex.Substring(1);
                if (!string.IsNullOrEmpty(hex))
                {
                    if (hex.Length == 8) hex = hex.Substring(2);
                    return "#" + hex;
                }
            }
            catch {}
        }
        return "";
    }

    private string GetCeldaStyle(CeldaExcelInfo? celda, bool esSeleccionado, bool tieneMapeo)
    {
        if (celda == null) return "";
        var styles = new List<string>();

        // Background color
        if (!string.IsNullOrEmpty(celda.ColorFondoHex))
        {
            styles.Add($"background-color: {celda.ColorFondoHex} !important");
        }

        // Text color
        if (!string.IsNullOrEmpty(celda.ColorTextoHex))
        {
            styles.Add($"color: {celda.ColorTextoHex} !important");
        }

        // Font styles
        if (celda.IsBold) styles.Add("font-weight: bold !important");
        if (celda.IsItalic) styles.Add("font-style: italic !important");
        if (celda.FontSize > 0) styles.Add($"font-size: {celda.FontSize}pt !important");

        // Alignment
        if (!string.IsNullOrEmpty(celda.Alignment))
        {
            styles.Add($"text-align: {celda.Alignment} !important");
        }

        // Selected/Mapped outlines
        if (esSeleccionado)
        {
            styles.Add("outline: 3px solid #10b981 !important");
            styles.Add("outline-offset: -3px !important");
            styles.Add("z-index: 10 !important");
        }
        else if (tieneMapeo)
        {
            styles.Add("opacity: 0.65 !important");
        }

        return string.Join("; ", styles);
    }

