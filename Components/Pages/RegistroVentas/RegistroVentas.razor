                        <span class="text-[9px] font-black text-emerald-600 uppercase tracking-wider block mb-1">Reportes Diarios</span>
                        <span class="text-xl font-black text-emerald-800 line-height-1">
                            @archivosReporteDiario.Count
                        </span>
                    </div>
                    <div class="bg-emerald-100 rounded-xl p-2 flex items-center justify-center text-emerald-600 shrink-0">
