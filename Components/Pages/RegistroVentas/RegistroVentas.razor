@page "/RegistroVentas"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using PETRO_BOT.Services.Services
@using System.Diagnostics
@using PETRO_BOT.Models.Log

<div class="flex flex-col gap-6 animate-new-row">


    <!-- ============================================== -->
    <!-- BOTTOM GRID: THE SYSTEM CONTROL & PROCESSED LOGS -->
    <!-- ============================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

        <!-- Left Column: Control & Upload boxes, styled EXACTLY like the Transaction Performance mockup -->
        <div class="lg:col-span-5 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 overflow-y-auto custom-scrollbar relative" style="height: calc(100vh - 160px);">
            @if (isLoading)
            {
                <LoadingRayo />
            }
            <div>
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4">
                    <div>
                        <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest block">Centro de Procesamiento</h3>
                        <span class="text-[10px] text-slate-400 font-bold block mt-0.5">Control de planillas y carga de reportes</span>
                    </div>
                </div>

                <!-- Parameters inside Mockup visual grids -->
                <div class="grid grid-cols-1 @(showDiaActivar ? "sm:grid-cols-2" : "sm:grid-cols-1") gap-4 mb-4">
                    
                    <!-- Select item 1 (Trabajo) -->
                    <div class="p-3 bg-slate-50 border border-slate-150 rounded-2xl relative">
                        <label class="block text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1.5 ml-0.5">
                            Acción de Trabajo
                        </label>
                        <div class="w-full bg-white border border-slate-200 rounded-xl px-3 py-2 text-xs font-bold text-slate-800 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-100/50 transition-all select-none"
                             @onclick="ToggleTrabajo">
                            <span>@trabajoSeleccionado</span>
                            <svg class="w-4 h-4 text-slate-500 transition-transform duration-200 @(showTrabajo ? "rotate-180 text-slate-800" : "")"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                        @if (showTrabajo)
                        {
                            <div class="absolute left-3 right-3 mt-2 bg-white rounded-xl shadow-2xl border border-slate-200 py-1.5 z-50 overflow-hidden animate-calendar-in select-none">
                                @foreach (var trabajo in trabajos)
                                {
                                    <div class="px-3 py-2 hover:bg-slate-50 text-slate-700 hover:text-slate-900 cursor-pointer text-xs font-bold uppercase tracking-wider transition-colors"
                                         @onclick:stopPropagation="true"
                                         @onclick="() => SeleccionarTrabajo(trabajo)">
                                        @trabajo
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Select item 2 (Fecha with DatePicker, visible only when showDiaActivar is true) -->
                    @if (showDiaActivar)
                    {
                        <div class="p-3 bg-slate-50 border border-slate-150 rounded-2xl relative">
                            <label class="block text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1.5 ml-0.5">
                                Fecha de Conciliación
                            </label>
                            <div @onclick="ToggleCalendario" 
                                 class="w-full bg-white border border-slate-200 rounded-xl px-3 py-2 text-xs font-bold text-slate-800 outline-none hover:border-slate-300 transition-all cursor-pointer flex items-center justify-between select-none @(mostrarCalendario ? "border-slate-400 ring-2 ring-slate-200/50" : "")">
                                <span class="font-mono">@fechaSeleccionada.ToString("dd/MM/yyyy")</span>
                                <svg class="w-4 h-4 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            
                            @if (mostrarCalendario)
                            {
                                <!-- Invisible Backdrop close -->
                                <div class="fixed inset-0 z-40 bg-transparent" @onclick="CerrarCalendario"></div>

                                <!-- Popover calendar in LIGHT Mode -->
                                <div class="absolute right-3 shadow-2xl"
                                     @onclick:stopPropagation="true"
                                     style="position: absolute; top: calc(100% + 8px); width: 260px; background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 20px; padding: 14px; z-index: 50; font-family: system-ui, -apple-system, sans-serif; animation: calendarFadeIn 0.2s cubic-bezier(0.16, 1, 0.3, 1);">
                                    
                                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                                        <button type="button" @onclick="MesAnterior" 
                                                 class="p-1 rounded-md bg-white border border-slate-200 text-slate-500 hover:text-slate-900 hover:bg-slate-55 transition-all cursor-pointer">
                                            <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
                                        </button>
                                        <span style="font-size: 9px; font-weight: 900; color: #1e293b; text-transform: uppercase; letter-spacing: 0.1em;">
                                            @mesVisualizado.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES"))
                                        </span>
                                        <button type="button" @onclick="MesSiguiente" 
                                                 class="p-1 rounded-md bg-white border border-slate-200 text-slate-500 hover:text-slate-900 hover:bg-slate-55 transition-all cursor-pointer">
                                            <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                                        </button>
                                    </div>

                                    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; text-align: center; margin-bottom: 6px; border-bottom: 1px solid #f1f5f9; padding-bottom: 4px;">
                                        @foreach (var diaSem in new[] { "DO", "LU", "MA", "MI", "JU", "VI", "SA" })
                                        {
                                            <span style="font-size: 8px; font-weight: 800; color: #94a3b8;">@diaSem</span>
                                        }
                                    </div>

                                    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; justify-items: center; align-items: center;">
                                        @for (int i = 0; i < ObtenerDesfasePrimerDia(); i++)
                                        {
                                            <div style="width: 28px; height: 28px;"></div>
                                        }
                                        @for (int dia = 1; dia <= DateTime.DaysInMonth(mesVisualizado.Year, mesVisualizado.Month); dia++)
                                        {
                                            var diaActual = dia; 
                                            var fechaCelda = new DateTime(mesVisualizado.Year, mesVisualizado.Month, diaActual);
                                            var esSeleccionado = fechaCelda.Date == fechaSeleccionada.Date;
                                            var esHoy = fechaCelda.Date == DateTime.Today;

                                            if (esSeleccionado)
                                            {
                                                <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 900; border-radius: 8px; border: none; background-color: #0f172a; color: #ffffff; cursor: pointer; box-shadow: 0 4px 10px rgba(15, 23, 42, 0.15);">@diaActual</button>
                                            }
                                            else if (esHoy)
                                            {
                                                <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 900; border-radius: 8px; border: 1px solid rgba(15, 23, 42, 0.15); background-color: rgba(15, 23, 42, 0.05); color: #0f172a; cursor: pointer;">@diaActual</button>
                                            }
                                            else
                                            {
                                                <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)" class="hover:bg-slate-100 hover:text-slate-900" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; border-radius: 8px; border: none; background-color: transparent; color: #64748b; cursor: pointer; transition: all 0.15s;">@diaActual</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Excel Upload Slots -->
                <div class="flex flex-col gap-3 mb-5">
                    
                    @if (EstadoAdjuntadoRegistroVentas == false)
                    {
                        <div class="group relative w-full">
                            <label for="file-upload" class="w-full bg-slate-50 border-2 border-dashed border-slate-200 hover:border-slate-400 hover:bg-slate-100/50 rounded-2xl px-4 py-3.5 flex items-center justify-between transition-all duration-300 cursor-pointer select-none">
                                <div class="flex flex-col">
                                    <span class="text-[11px] font-black text-slate-800">Registro de Ventas</span>
                                    <span class="text-[8px] text-slate-500 font-bold uppercase tracking-wider mt-0.5">Formatos de planilla admitidos: (.xlsx)</span>
                                </div>
                                <span class="p-1.5 bg-white border border-slate-200 rounded-lg group-hover:bg-[#0f172a] group-hover:text-white group-hover:border-[#0f172a] text-slate-600 transition-all shrink-0">
                                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                </span>
                            </label>
                            <InputFile id="file-upload" OnChange="SubirArchivo" accept=".xlsx" class="hidden" />
                        </div>
                    }
                    else
                    {
                        <SuccessCargaFile File="@(archivosRegistroVentas.FirstOrDefault() ?? "registro_ventas.xlsx")"/>
                    }

                    @if (EstadoAdjuntadoReportediario == false)
                    {
                        <div class="group relative w-full">
                            <label for="file-upload_multi" class="w-full bg-slate-50 border-2 border-dashed border-slate-200 hover:border-slate-400 hover:bg-slate-100/50 rounded-2xl px-4 py-3.5 flex items-center justify-between transition-all duration-300 cursor-pointer select-none">
                                <div class="flex flex-col">
                                    <span class="text-[11px] font-black text-slate-800">Reportes Diarios Consolidados</span>
                                    <span class="text-[8px] text-slate-500 font-bold uppercase tracking-wider mt-0.5">Se pueden adjuntar múltiples archivos (.xlsx)</span>
                                </div>
                                <span class="p-1.5 bg-white border border-slate-200 rounded-lg group-hover:bg-[#0f172a] group-hover:text-white group-hover:border-[#0f172a] text-slate-600 transition-all shrink-0">
                                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                </span>
                            </label>
                            <InputFile id="file-upload_multi" OnChange="SubirArchivoMulti" multiple accept=".xlsx" class="hidden" />
                        </div>
                    }
                    else
                    {
                        <SuccessCargaFile File="@($"{archivosReporteDiario.Count} reportes diarios consolidados")" />
                    }

                </div>

                <!-- Footer Buttons stacked inside mockup visual ratios -->
                <div class="flex flex-col sm:flex-row gap-2.5">
                    <button disabled="@(isLoading || !(EstadoAdjuntadoRegistroVentas || EstadoAdjuntadoReportediario))" 
                            @onclick="AbrirModalAdjuntos" 
                            class="flex-1 bg-white text-slate-700 border border-slate-200 rounded-xl py-3 text-[10px] font-black uppercase tracking-wider hover:bg-slate-50 transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 disabled:cursor-not-allowed shadow-sm">
                        Ver adjuntos
                    </button>
                    <button @onclick="EjecutarProceso"
                            disabled="@isLoading"
                            class="flex-1 bg-[#0f172a] text-white rounded-xl py-3 text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all flex items-center justify-center gap-1.5 cursor-pointer select-none disabled:opacity-75">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <span>Ejecutar Proceso</span>
                    </button>
                    <button disabled="@isLoading" 
                            @onclick="CancelarRegistroVentas" 
                            class="px-4 py-3 bg-white border border-slate-200 hover:bg-rose-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 shadow-sm">
                        Limpiar
                    </button>
                </div>

            </div>
        </div>

        <!-- Right Column: Processed logs table, styled EXACTLY like the Asset rows in Mockup -->
        <div class="lg:col-span-7 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full overflow-hidden">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                    <div class="flex items-center gap-2">
                        <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Archivos Procesados</h3>
                        <span class="px-2 py-0.5 bg-slate-100 text-[#0f172a] rounded-full text-[9px] font-black select-none">
                            @(archivosProcesados?.Count ?? 0)
                        </span>
                    </div>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest cursor-pointer hover:text-slate-800" @onclick='() => ToastService.Info("Ver logs históricos")'>Historial</span>
                </div>

                <!-- Circular asset row items styled exactly like mockup 1 -->
                <div class="flex flex-col gap-3.5 overflow-y-auto custom-scrollbar flex-1 pr-1">
                    @if (archivosProcesados == null || !archivosProcesados.Any())
                    {
                        <div class="py-12 text-center text-slate-400 italic text-xs font-bold uppercase tracking-widest">
                            Sin archivos procesados
                        </div>
                    }
                    else
                    {
                        @foreach (var archivo in archivosProcesados)
                        {
                            <div class="flex items-center justify-between group/ch hover:bg-slate-50/55 p-2 rounded-2xl border border-transparent hover:border-slate-200 transition-all">
                                <div class="flex items-center gap-3 min-w-0">
                                    
                                    <!-- LED circles in shape of mockup icons -->
                                    <div class="w-9 h-9 rounded-full bg-slate-50 border border-slate-200 flex items-center justify-center shrink-0 shadow-sm">
                                        @if (archivo.Estado == 1)
                                        {
                                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-md shadow-emerald-500/20"></span>
                                        }
                                        else
                                        {
                                            <span class="w-2.5 h-2.5 rounded-full bg-rose-500 shadow-md shadow-rose-500/20"></span>
                                        }
                                    </div>

                                    <div class="min-w-0 flex-1">
                                        <span class="text-xs font-black text-slate-850 block uppercase tracking-wide truncate">@archivo.Grifo</span>
                                        <span class="text-[9px] text-slate-400 font-mono block break-all whitespace-normal" title="@archivo.File">@archivo.File</span>
                                    </div>
                                </div>

                                <div class="text-right shrink-0 flex items-center gap-2">
                                    <div class="hidden sm:block">
                                        @if (archivo.Estado == 1)
                                        {
                                            <span class="text-[9px] bg-emerald-50 text-emerald-700 border border-emerald-100 px-2 py-0.5 rounded-md font-black uppercase">Success</span>
                                        }
                                        else
                                        {
                                            <span class="text-[9px] bg-rose-50 text-rose-700 border border-rose-100 px-2 py-0.5 rounded-md font-black uppercase">Error</span>
                                        }
                                    </div>
                                    <button @onclick="() => AbrirModal(archivo)"
                                            class="bg-[#0f172a] text-white hover:bg-slate-800 px-3.5 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all shadow-md hover:scale-[1.01] active:scale-[0.98] select-none cursor-pointer">
                                        Detalles
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- GLASS DETAILS DIALOG MODAL -->
<!-- ============================================== -->
@if (mostrarModal && archivoSeleccionado != null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[9999] animate-modal-in" 
         @onclick="CerrarModal">
        
        <!-- Modal Card container -->
        <div class="bg-white border border-slate-200 rounded-[28px] shadow-2xl w-full max-w-2xl max-h-[85vh] flex flex-col overflow-hidden"
             @onclick:stopPropagation="true">
            
            <!-- Header bar of popover -->
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50 gap-4">
                <div class="min-w-0 flex-1">
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block mb-0.5">Archivo de Proceso</span>
                    <h3 class="text-xs font-bold text-slate-800 font-mono truncate leading-tight select-all">@archivoSeleccionado.File</h3>
                </div>
                <button @onclick="CerrarModal" 
                        class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- SUB-DASHBOARD STATISTIC COUNTS -->
            <div class="grid grid-cols-2 gap-4 px-6 pt-5">
                <!-- Info count glass card -->
                <div class="bg-blue-50 border border-blue-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm">
                    <div>
                        <span class="text-[9px] font-black text-blue-600 uppercase tracking-wider block mb-1">Informes Info</span>
                        <span class="text-xl font-black text-blue-800 line-height-1">
                            @archivoSeleccionado.Mensajes.Count(m => m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                        </span>
                    </div>
                    <div class="bg-blue-100 rounded-xl p-2 flex items-center justify-center text-blue-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                </div>

                <!-- Error count glass card -->
                <div class="bg-rose-50 border border-rose-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm">
                    <div>
                        <span class="text-[9px] font-black text-rose-600 uppercase tracking-wider block mb-1">Alertas Error</span>
                        <span class="text-xl font-black text-rose-800 line-height-1">
                            @archivoSeleccionado.Mensajes.Count(m => !m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                        </span>
                    </div>
                    <div class="bg-rose-100 rounded-xl p-2 flex items-center justify-center text-rose-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Details logs table custom-scrollbar -->
            <div class="p-6 overflow-y-auto flex-1 custom-scrollbar">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-slate-400 text-[9px] uppercase tracking-wider border-b border-slate-100">
                            <th class="pb-3 font-black w-24">Estado</th>
                            <th class="pb-3 font-black">Descripción</th>
                        </tr>
                    </thead>
                    <tbody class="text-xs">
                        @if (archivoSeleccionado.Mensajes == null || !archivoSeleccionado.Mensajes.Any())
                        {
                            <tr>
                                <td colspan="2" class="py-8 text-center text-slate-400 italic font-medium">
                                    No hay mensajes registrados para este proceso.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var msg in archivoSeleccionado.Mensajes)
                            {
                                <tr class="border-b border-slate-100/60 hover:bg-slate-50/50">
                                    <td class="py-3.5 vertical-top whitespace-nowrap pr-4">
                                        @if (msg.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="inline-flex items-center gap-1.5 bg-blue-50 text-blue-700 border border-blue-100 px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider">
                                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span> @msg.Estado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 bg-rose-50 text-rose-700 border border-rose-100 px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider">
                                                <span class="w-1.5 h-1.5 rounded-full bg-rose-550"></span> @msg.Estado
                                            </span>
                                        }
                                    </td>
                                    <td class="py-3.5 text-slate-700 font-medium text-xs leading-relaxed select-all">
                                        @msg.Descripcion
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Footer close -->
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end bg-slate-50">
                <button @onclick="CerrarModal" 
                        class="px-5 py-2 bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 hover:text-slate-900 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all shadow-sm select-none cursor-pointer">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
}

<!-- 3. MODAL ADJUNTOS DETALLES -->
@if (mostrarModalAdjuntos)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[9998] animate-modal-in" 
         @onclick="CerrarModalAdjuntos">
        
        <div class="bg-white border border-slate-200 rounded-[28px] shadow-2xl w-full max-w-xl max-h-[85vh] flex flex-col overflow-hidden"
             @onclick:stopPropagation="true">
            
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <div>
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block mb-0.5">Archivos Temporales</span>
                    <h3 class="text-xs font-black text-slate-800 uppercase tracking-wider">Documentos Adjuntados</h3>
                </div>
                <button @onclick="CerrarModalAdjuntos" 
                        class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- Counts details widget -->
            <div class="grid grid-cols-2 gap-4 px-6 pt-5">
                <!-- Sales channel count -->
                <div class="bg-blue-50 border border-blue-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm">
                    <div>
                        <span class="text-[9px] font-black text-blue-600 uppercase tracking-wider block mb-1">Registro de Ventas</span>
                        <span class="text-xl font-black text-blue-800 line-height-1">
                            @archivosRegistroVentas.Count
                        </span>
                    </div>
                    <div class="bg-blue-100 rounded-xl p-2 flex items-center justify-center text-blue-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                    </div>
                </div>

                <!-- Daily logs count -->
                <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm">
                    <div>
                        <span class="text-[9px] font-black text-emerald-600 uppercase tracking-wider block mb-1">Reportes Diarios</span>
                        <span class="text-xl font-black text-emerald-800 line-height-1">
                            @archivosReporteDiario.Count
                        </span>
                    </div>
                    <div class="bg-emerald-100 rounded-xl p-2 flex items-center justify-center text-emerald-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7v12m0 0l-4-4m4 4l-4-4m0 6V7m0 0l-4 4m4-4l4 4"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- List box attachments rounded blocks -->
            <div class="p-6 overflow-y-auto flex-1 flex flex-col gap-5 custom-scrollbar">
                
                <!-- Box 1: Sales sheets -->
                <div class="bg-slate-50 border border-slate-150 rounded-[20px] p-5">
                    <div class="flex items-center gap-2 border-b border-slate-200 pb-3 mb-3">
                        <span class="w-1.5 h-3 bg-blue-500 rounded-full"></span>
                        <h4 class="text-[11px] font-black text-slate-800 uppercase tracking-wider">Planillas de Registro de Venta</h4>
                    </div>
                    
                    <div class="max-h-[160px] overflow-y-auto pr-1 custom-scrollbar">
                        @if (!archivosRegistroVentas.Any())
                        {
                            <span class="text-xs text-slate-400 italic block py-2">Ningún archivo adjuntado.</span>
                        }
                        else
                        {
                            <ul class="flex flex-col gap-2">
                                @foreach (var archivo in archivosRegistroVentas)
                                {
                                    <li class="bg-white border border-slate-200 rounded-xl px-3 py-2.5 flex items-center justify-between font-mono text-[11px] text-slate-700 shadow-sm">
                                        <span class="truncate pr-4 select-all">@archivo</span>
                                        <svg class="w-4.5 h-4.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <!-- Box 2: Daily sheets -->
                <div class="bg-slate-50 border border-slate-150 rounded-[20px] p-5">
                    <div class="flex items-center gap-2 border-b border-slate-200 pb-3 mb-3">
                        <span class="w-1.5 h-3 bg-emerald-500 rounded-full"></span>
                        <h4 class="text-[11px] font-black text-slate-800 uppercase tracking-wider">Planillas de Reporte Diario</h4>
                    </div>
                    
                    <div class="max-h-[160px] overflow-y-auto pr-1 custom-scrollbar">
                        @if (!archivosReporteDiario.Any())
                        {
                            <span class="text-xs text-slate-400 italic block py-2">Ningún archivo adjuntado.</span>
                        }
                        else
                        {
                            <ul class="flex flex-col gap-2">
                                @foreach (var archivo in archivosReporteDiario)
                                {
                                    <li class="bg-white border border-slate-200 rounded-xl px-3 py-2.5 flex items-center justify-between font-mono text-[11px] text-slate-700 shadow-sm">
                                        <span class="truncate pr-4 select-all">@archivo</span>
                                        <svg class="w-4.5 h-4.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

            </div>

            <!-- Footer close -->
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end bg-slate-50">
                <button @onclick="CerrarModalAdjuntos" 
                        class="px-5 py-2 bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 hover:text-slate-900 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all shadow-sm select-none cursor-pointer">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        EliminarAarchivos_Ventas_y_Diario();
        await CargarReporteProceso();
    }

    string[] trabajos =
    {
        "Seleccionar",
        "Procesar Hoy",
        "Procesar Día",
        "Procesar Mes"
    };

    string trabajoSeleccionado = "Seleccionar";
    int diaSeleccionado = 0;
    private DateTime fechaSeleccionada = DateTime.Today;
    private DateTime mesVisualizado = DateTime.Today;
    private bool mostrarCalendario = false;

    private void ToggleCalendario()
    {
        mostrarCalendario = !mostrarCalendario;
        if (mostrarCalendario)
        {
            mesVisualizado = new DateTime(fechaSeleccionada.Year, fechaSeleccionada.Month, 1);
        }
    }

    private void CerrarCalendario()
    {
        mostrarCalendario = false;
    }

    private void MesAnterior()
    {
        mesVisualizado = mesVisualizado.AddMonths(-1);
    }

    private void MesSiguiente()
    {
        mesVisualizado = mesVisualizado.AddMonths(1);
    }

    private void SeleccionarFecha(DateTime fecha)
    {
        fechaSeleccionada = fecha;
        mostrarCalendario = false;
        ToastService.Success($"Fecha de registro establecida: {fecha.ToString("dd/MM/yyyy")}");
    }

    private void EstablecerHoy()
    {
        fechaSeleccionada = DateTime.Today;
        mesVisualizado = DateTime.Today;
        mostrarCalendario = false;
        ToastService.Success("Establecido el día de hoy.");
    }

    private void LimpiarCalendario()
    {
        fechaSeleccionada = DateTime.Today;
        mesVisualizado = DateTime.Today;
        mostrarCalendario = false;
    }

    private int ObtenerDesfasePrimerDia()
    {
        var primerDia = new DateTime(mesVisualizado.Year, mesVisualizado.Month, 1);
        return (int)primerDia.DayOfWeek;
    }

    bool showTrabajo;
    bool showDia;
    bool showDiaActivar;

    void ToggleTrabajo()
    {
        showTrabajo = !showTrabajo;
        showDia = false;
    }

    void ToggleDia()
    {
        showDia = !showDia;
        showTrabajo = false;
    }

    void SeleccionarDia(int dia)
    {
        diaSeleccionado = dia;
        showDia = false;
    }

    void SeleccionarTrabajo(string trabajo)
    {
        trabajoSeleccionado = trabajo;
        showTrabajo = false;
        switch (trabajo)
        {
            case "Procesar Hoy":
                showDiaActivar = false;
                break;
            case "Procesar Día":
                showDiaActivar = true;
                break;
            case "Procesar Mes":
                showDiaActivar = false;
                break;
            default:
                break;
        };
        ToastService.Info($"Trabajo cambiado a: {trabajo}");
    }

    private void LimpiarArchivoReporteProceso()
    {
        try
        {
            // Limpiar la memoria de logs estáticos acumulada en RAM
            LoggerService.LimpiarLogs();

            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            System.IO.File.WriteAllText(rutaLog, "[]");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al limpiar reporte_proceso.json: " + ex.Message);
        }
    }

    void CancelarRegistroVentas()
    {
        EstadoAdjuntadoRegistroVentas = false;
        EstadoAdjuntadoReportediario = false;
        archivosProcesados.Clear();
        listaArchivossubir.Clear();
        archivosRegistroVentas.Clear();
        archivosReporteDiario.Clear();
        trabajoSeleccionado = "Seleccionar";
        showDiaActivar = false;
        StateHasChanged();
        // Limpiar reporte_proceso.json
        LimpiarArchivoReporteProceso();
        EliminarAarchivos_Ventas_y_Diario();
        ToastService.Info("Operación cancelada. Archivos adjuntos eliminados.");
    }

    void EliminarAarchivos_Ventas_y_Diario()
    {
        // Eliminar físicamente los archivos del disco
        try
        {
            var rutaVentas = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (Directory.Exists(rutaVentas))
            {
                foreach (var archivo in Directory.GetFiles(rutaVentas))
                {
                    File.Delete(archivo);
                }
            }

            var rutaReportes = Path.Combine(env.WebRootPath, "uploads/ReporteDiario");
            if (Directory.Exists(rutaReportes))
            {
                foreach (var archivo in Directory.GetFiles(rutaReportes))
                {
                    File.Delete(archivo);
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al borrar archivos: " + ex.Message);
        }
    }

    bool isLoading = false;

    async Task EjecutarProceso()
    {
        if (trabajoSeleccionado != "Seleccionar")
        {
            if (EstadoAdjuntadoRegistroVentas != false)
            {
                if (EstadoAdjuntadoReportediario != false)
                {
                    if (trabajoSeleccionado == "Procesar Hoy")
                    {
                        string fechaFormateada = DateTime.Today.ToString("d/MM/yyyy");
                        ToastService.Info($"Procesando el día de hoy: {fechaFormateada}");
                        isLoading = true;
                        LimpiarArchivoReporteProceso();
                        archivosProcesados.Clear();
                        StateHasChanged();
                        await ProcesarArchivos(trabajoSeleccionado, fechaFormateada);
                        await CargarReporteProceso();
                    }
                    else if (trabajoSeleccionado == "Procesar Día")
                    {
                        string fechaFormateada = fechaSeleccionada.ToString("d/MM/yyyy");
                        ToastService.Info($"Procesando fecha seleccionada: {fechaFormateada}");
                        isLoading = true;
                        LimpiarArchivoReporteProceso();
                        archivosProcesados.Clear();
                        StateHasChanged();
                        await ProcesarArchivos(trabajoSeleccionado, fechaFormateada);
                        await CargarReporteProceso();
                    } 
                    else
                    {
                        ToastService.Info("Procesando el mes completo...");
                        isLoading = true;
                        LimpiarArchivoReporteProceso();
                        archivosProcesados.Clear();
                        StateHasChanged();
                        await ProcesarArchivos(trabajoSeleccionado, "");
                        await CargarReporteProceso();
                    }

                    // Descargar automáticamente el archivo consolidado
                    await DescargarArchivoConsolidado();
                    
                    isLoading = false;
                }
                else
                {
                    ToastService.Error("Adjuntar reporte diario");
                }
            }
            else
            {
                ToastService.Error("Adjuntar registro de ventas");
            }
        } else
        {
            ToastService.Error("Seleccione un trabajo");
        }
    }

    private async Task DescargarArchivoConsolidado()
    {
        try
        {
            var rutaVentas = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (Directory.Exists(rutaVentas))
            {
                var archivos = Directory.GetFiles(rutaVentas, "*.xlsx");
                if (archivos.Length > 0)
                {
                    string nombreArchivo = Path.GetFileName(archivos[0]);
                    ToastService.Info($"Iniciando descarga de {nombreArchivo}...");
                    await JSRuntime.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = '/uploads/RegistroVentas/{nombreArchivo}'; a.download = '{nombreArchivo}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);");
                }
                else
                {
                    ToastService.Warning("No se encontró ningún archivo consolidado para descargar en uploads/RegistroVentas.");
                }
            }
            else
            {
                ToastService.Error("La carpeta de destino uploads/RegistroVentas no existe.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al descargar el archivo: " + ex.Message);
        }
    }

    private async Task CargarReporteProceso()
    {
        try
        {
            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            if (System.IO.File.Exists(rutaLog))
            {
                string jsonContent = await System.IO.File.ReadAllTextAsync(rutaLog);
                var logsProcesados = System.Text.Json.JsonSerializer.Deserialize<List<LogProcesoGrifo>>(jsonContent);
                
                if (logsProcesados != null)
                {
                    foreach (var log in logsProcesados)
                    {
                        int estado = log.Mensajes.All(m => m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase)) ? 1 : 2;
                        
                        var nuevoArchivo = new ArchivoInfo
                        {
                            Id = Guid.NewGuid(),
                            Grifo = log.Grifo,
                            File = log.Archivo,
                            Estado = estado,
                            Mensajes = log.Mensajes
                        };
                        archivosProcesados.Add(nuevoArchivo);
                        StateHasChanged();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el reporte: " + ex.Message);
        }
    }

    private string mensaje = "";
    private bool EstadoAdjuntadoRegistroVentas;

    private async Task SubirArchivo(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;

            var extension = Path.GetExtension(archivo.Name).ToLower();
            if (extension != ".xlsx")
            {
                ToastService.Error("Solo se permiten archivos .xlsx");
                return; 
            }

            if (archivo.ContentType != "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
            {
                ToastService.Error("El contenido del archivo no es un Excel válido");
                return;
            }

            var ruta = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (!Directory.Exists(ruta)) Directory.CreateDirectory(ruta);

            var nombreArchivo = $"{archivo.Name}";
            var rutaCompleta = Path.Combine(ruta, nombreArchivo);

            using FileStream fs = new(rutaCompleta, FileMode.Create);
            await archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);

            archivosRegistroVentas.Clear();
            archivosRegistroVentas.Add(archivo.Name);

            mensaje = "Archivo adjuntado correctamente";
            ToastService.Success(mensaje);
            EstadoAdjuntadoRegistroVentas = true;
        }
        catch (Exception ex)
        {
            EstadoAdjuntadoRegistroVentas = false;
            mensaje = ex.Message;
            ToastService.Error("Error: " + mensaje);
        }
    }

    private List<string> listaArchivossubir = new();
    private bool EstadoAdjuntadoReportediario;

    private async Task SubirArchivoMulti(InputFileChangeEventArgs e)
    {
        try
        {
            var ruta = Path.Combine(env.WebRootPath, "uploads/ReporteDiario");

            if (!Directory.Exists(ruta))
            {
                Directory.CreateDirectory(ruta);
            }

            string extensionPermitida = ".xlsx";
            archivosReporteDiario.Clear();

            foreach (var archivo in e.GetMultipleFiles(1000))
            {
                var extension = Path.GetExtension(archivo.Name).ToLower();

                if (extension != extensionPermitida)
                {
                    continue; 
                }

                var nombre = $"{archivo.Name}";
                var rutaCompleta = Path.Combine(ruta, nombre);

                using FileStream fs = new(rutaCompleta, FileMode.Create);

                // Tamaño máximo de 20MB
                await archivo.OpenReadStream(20 * 1024 * 1024).CopyToAsync(fs);

                listaArchivossubir.Add(archivo.Name);
                archivosReporteDiario.Add(archivo.Name);
            }

            if (listaArchivossubir.Any())
            {
                EstadoAdjuntadoReportediario = true;
                mensaje = "Archivo adjuntado correctamente";
                ToastService.Success(mensaje);
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error: " + ex.Message;
            ToastService.Error(mensaje);
            EstadoAdjuntadoReportediario = false;
            Console.WriteLine(ex.Message);
        }
    }

    private bool estaProcesando = false;
    private List<ArchivoInfo> archivosProcesados = new();

    private async Task ProcesarArchivos(string tarea, string dia)
    {
        archivosProcesados.Clear();
        Stopwatch timerGlobal = Stopwatch.StartNew();
        try
        {
            var consolidador = new ConsolidadorVentasService();
            await Task.Run(() => consolidador.Procesar(tarea, dia));
        }
        catch (Exception ex)
        {
            LoggerService.Error("SISTEMA", "Main", $"Ocurrió un error fatal: {ex.Message}");
            Console.WriteLine($"[x] Ocurrió un error fatal:\n{ex.ToString()}");
        }
        finally
        {
            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            LoggerService.GuardarJson(rutaLog);
        }
        timerGlobal.Stop();
        Console.WriteLine("\n" + new string('=', 30));
        Console.WriteLine($"PROCESO FINALIZADO");
        Console.WriteLine($"Tiempo total: {timerGlobal.Elapsed.TotalSeconds:F2} segundos");
        Console.WriteLine(new string('=', 30));
    }

    private bool mostrarModal = false;
    private ArchivoInfo? archivoSeleccionado;

    private void AbrirModal(ArchivoInfo archivo)
    {
        archivoSeleccionado = archivo;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        archivoSeleccionado = null;
    }

    private bool mostrarModalAdjuntos = false;
    private List<string> archivosRegistroVentas = new();
    private List<string> archivosReporteDiario = new();

    private void AbrirModalAdjuntos()
    {
        CargarArchivosAdjuntos();
        mostrarModalAdjuntos = true;
    }

    private void CerrarModalAdjuntos()
    {
        mostrarModalAdjuntos = false;
    }

    private void CargarArchivosAdjuntos()
    {
        try
        {
            archivosRegistroVentas.Clear();
            var rutaVentas = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (Directory.Exists(rutaVentas))
            {
                archivosRegistroVentas = Directory.GetFiles(rutaVentas, "*.xlsx")
                                                  .Select(Path.GetFileName)
                                                  .ToList()!;
            }

            archivosReporteDiario.Clear();
            var rutaReportes = Path.Combine(env.WebRootPath, "uploads/ReporteDiario");
            if (Directory.Exists(rutaReportes))
            {
                archivosReporteDiario = Directory.GetFiles(rutaReportes, "*.xlsx")
                                                 .Select(Path.GetFileName)
                                                 .ToList()!;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al cargar archivos adjuntos: " + ex.Message);
        }
    }

    public class ArchivoInfo
    {
        public Guid Id { get; set; }
        public string Grifo { get; set; }
        public string File { get; set; }
        public int Estado { get; set; }
        public List<LogDetalle> Mensajes { get; set; } = new();
    }
}