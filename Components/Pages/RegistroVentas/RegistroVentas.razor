    private void CargarArchivosAdjuntos()
    {
        try
        {
            archivosRegistroVentas.Clear();
            var rutaVentas = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (Directory.Exists(rutaVentas))
            {
                archivosRegistroVentas = Directory.GetFiles(rutaVentas, "*.xlsx")
                                                  .Select(Path.GetFileName)
                                                  .ToList()!;
            }

            archivosReporteDiario.Clear();
            var rutaReportes = Path.Combine(env.WebRootPath, "uploads/ReporteDiario");
            if (Directory.Exists(rutaReportes))
            {
                archivosReporteDiario = Directory.GetFiles(rutaReportes, "*.xlsx")
                                                 .Select(Path.GetFileName)
                                                 .ToList()!;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al cargar archivos adjuntos: " + ex.Message);
        }
    }

