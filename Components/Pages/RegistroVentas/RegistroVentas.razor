@page "/RegistroVentas"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using PETRO_BOT.Services.Services
@using System.Diagnostics
@using PETRO_BOT.Models.Log
@using PETRO_BOT.Services.Shared

@inject HistorialService HistorialService
<div class="flex flex-col gap-6 animate-new-row">


    <!-- ============================================== -->
    <!-- BOTTOM GRID: THE SYSTEM CONTROL & PROCESSED LOGS -->
    <!-- ============================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

        <!-- Left Column: Control & Upload boxes, styled EXACTLY like the Transaction Performance mockup -->
        <div class="lg:col-span-5 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 overflow-y-auto custom-scrollbar relative animate-fade-in-up anim-delay-75" style="height: calc(100vh - 160px);">
            @if (isLoading)
            {
                <LoadingRayo />
            }
            <div>
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4">
                    <div>
                        <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest block">Centro de Procesamiento</h3>
                        <span class="text-[10px] text-slate-400 font-bold block mt-0.5">Control de planillas y carga de reportes</span>
                    </div>
                </div>

                <!-- Parameters inside Mockup visual grids -->
                <div class="grid grid-cols-1 @(showDiaActivar ? "sm:grid-cols-2" : "sm:grid-cols-1") gap-4 mb-4">
                    
                    <!-- Select item 1 (Trabajo) -->
                    <div class="p-3 @(trabajoSeleccionado != "Seleccionar" ? "bg-emerald-50 border-emerald-200 shadow-sm" : "bg-slate-50 border-slate-150") border rounded-2xl relative transition-all">
                        <label class="block text-[8px] font-black uppercase tracking-widest mb-1.5 ml-0.5 @(trabajoSeleccionado != "Seleccionar" ? "text-emerald-600" : "text-slate-400")">
                            Acción de Trabajo
                        </label>
                        <div class="w-full @(trabajoSeleccionado != "Seleccionar" ? "bg-emerald-100/30 border-emerald-300 text-emerald-900" : "bg-white border-slate-200 text-slate-800") border rounded-xl px-3 py-2 text-xs font-bold flex items-center justify-between cursor-pointer hover:border-slate-300 transition-all select-none"
                             @onclick="ToggleTrabajo">
                            <span>@trabajoSeleccionado</span>
                            <svg class="w-4 h-4 text-slate-500 transition-transform duration-200 @(showTrabajo ? "rotate-180 text-slate-800" : "")"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </div>
                        @if (showTrabajo)
                        {
                            <div class="absolute left-3 right-3 mt-2 bg-white rounded-xl shadow-2xl border border-slate-200 py-1.5 z-50 overflow-hidden animate-calendar-in select-none">
                                @foreach (var trabajo in trabajos)
                                {
                                    <div class="px-3 py-2 hover:bg-slate-50 text-slate-700 hover:text-slate-900 cursor-pointer text-xs font-bold uppercase tracking-wider transition-colors"
                                         @onclick:stopPropagation="true"
                                         @onclick="() => SeleccionarTrabajo(trabajo)">
                                        @trabajo
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Select item 2 (Fecha with DatePicker, visible only when showDiaActivar is true) -->
                    @if (showDiaActivar)
                    {
                        <div class="p-3 border rounded-2xl relative transition-all @(fechasSeleccionadas.Count > 0 ? "bg-emerald-50 border-emerald-300" : "bg-slate-50 border-slate-150")">
                            <label class="block text-[8px] font-black uppercase tracking-widest mb-1.5 ml-0.5 transition-colors @(fechasSeleccionadas.Count > 0 ? "text-emerald-700" : "text-slate-400")">
                                Fecha de Conciliación
                            </label>
                            <div @onclick="ToggleCalendario" 
                                 class="w-full border rounded-xl px-3 py-2 text-xs font-bold outline-none transition-all cursor-pointer flex items-center justify-between select-none @(fechasSeleccionadas.Count > 0 ? "bg-white border-emerald-200 text-emerald-900 hover:border-emerald-400 shadow-sm" : "bg-white border-slate-200 text-slate-800 hover:border-slate-300") @(mostrarCalendario ? (fechasSeleccionadas.Count > 0 ? "ring-2 ring-emerald-200" : "border-slate-400 ring-2 ring-slate-200/50") : "")">
                                <span class="font-mono truncate mr-2" title="@(string.Join(", ", fechasSeleccionadas.OrderBy(d => d).Select(d => d.ToString("dd/MM/yyyy"))))">
                                    @(fechasSeleccionadas.Count == 0 ? "Seleccionar días" : 
                                      string.Join(", ", fechasSeleccionadas.OrderBy(d => d).Select(d => d.ToString("dd/MM"))))
                                </span>
                                <svg class="w-4 h-4 @(fechasSeleccionadas.Count > 0 ? "text-emerald-600" : "text-slate-700")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            
                            @if (mostrarCalendario)
                            {
                                <!-- Invisible Backdrop close -->
                                <div class="fixed inset-0 z-40 bg-transparent" @onclick="CerrarCalendario"></div>

                                <!-- Popover calendar in LIGHT Mode -->
                                <div class="absolute right-3 shadow-2xl"
                                     @onclick:stopPropagation="true"
                                     style="position: absolute; top: calc(100% + 8px); width: 260px; background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 20px; padding: 14px; z-index: 50; font-family: system-ui, -apple-system, sans-serif; animation: calendarFadeIn 0.2s cubic-bezier(0.16, 1, 0.3, 1);">
                                    
                                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                                        <button type="button" @onclick="MesAnterior" 
                                                 class="p-1 rounded-md bg-white border border-slate-200 text-slate-500 hover:text-slate-900 hover:bg-slate-55 transition-all cursor-pointer">
                                            <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
                                        </button>
                                        <span style="font-size: 9px; font-weight: 900; color: #1e293b; text-transform: uppercase; letter-spacing: 0.1em;">
                                            @mesVisualizado.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES"))
                                        </span>
                                        <button type="button" @onclick="MesSiguiente" 
                                                 class="p-1 rounded-md bg-white border border-slate-200 text-slate-500 hover:text-slate-900 hover:bg-slate-55 transition-all cursor-pointer">
                                            <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                                        </button>
                                    </div>

                                    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; text-align: center; margin-bottom: 6px; border-bottom: 1px solid #f1f5f9; padding-bottom: 4px;">
                                        @foreach (var diaSem in new[] { "DO", "LU", "MA", "MI", "JU", "VI", "SA" })
                                        {
                                            <span style="font-size: 8px; font-weight: 800; color: #94a3b8;">@diaSem</span>
                                        }
                                    </div>

                                    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; justify-items: center; align-items: center;">
                                        @for (int i = 0; i < ObtenerDesfasePrimerDia(); i++)
                                        {
                                            <div style="width: 28px; height: 28px;"></div>
                                        }
                                        @for (int dia = 1; dia <= DateTime.DaysInMonth(mesVisualizado.Year, mesVisualizado.Month); dia++)
                                        {
                                            var diaActual = dia; 
                                            var fechaCelda = new DateTime(mesVisualizado.Year, mesVisualizado.Month, diaActual);
                                            var esSeleccionado = fechasSeleccionadas.Contains(fechaCelda.Date);
                                            var esHoy = fechaCelda.Date == DateTime.Today;

                                            if (esSeleccionado)
                                            {
                                                <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 900; border-radius: 8px; border: none; background-color: #0f172a; color: #ffffff; cursor: pointer; box-shadow: 0 4px 10px rgba(15, 23, 42, 0.15);">@diaActual</button>
                                            }
                                            else if (esHoy)
                                            {
                                                <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 900; border-radius: 8px; border: 1px solid rgba(15, 23, 42, 0.15); background-color: rgba(15, 23, 42, 0.05); color: #0f172a; cursor: pointer;">@diaActual</button>
                                            }
                                            else
                                            {
                                                <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)" class="hover:bg-slate-100 hover:text-slate-900" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; border-radius: 8px; border: none; background-color: transparent; color: #64748b; cursor: pointer; transition: all 0.15s;">@diaActual</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Excel Upload Slots -->
                <div class="flex flex-col gap-3 mb-5">
                    
                    @if (EstadoAdjuntadoRegistroVentas == false)
                    {
                        <div class="group relative w-full">
                            <label for="file-upload" class="w-full bg-slate-50 border-2 border-dashed border-slate-200 hover:border-slate-400 hover:bg-slate-100/50 rounded-2xl px-4 py-3.5 flex items-center justify-between transition-all duration-300 cursor-pointer select-none">
                                <span class="flex flex-col">
                                    <span class="text-[11px] font-black text-slate-800">Registro de Ventas</span>
                                    <span class="text-[8px] text-slate-500 font-bold uppercase tracking-wider mt-0.5">Formatos de planilla admitidos: (.xlsx)</span>
                                </span>
                                <span class="p-1.5 bg-white border border-slate-200 rounded-lg group-hover:bg-[#0f172a] group-hover:text-white group-hover:border-[#0f172a] text-slate-600 transition-all shrink-0">
                                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                </span>
                            </label>
                            <InputFile id="file-upload" OnChange="SubirArchivo" accept=".xlsx" class="hidden" />
                        </div>
                    }
                    else
                    {
                        <div class="relative w-full group">
                            <label for="file-upload-reemplazo" class="cursor-pointer block w-full">
                                <SuccessCargaFile File="@(archivosRegistroVentas.FirstOrDefault() ?? "registro_ventas.xlsx")"/>
                                <div class="absolute inset-0 bg-emerald-500/0 group-hover:bg-emerald-500/10 rounded-2xl transition-all flex items-center justify-end px-4 pointer-events-none">
                                    <span class="text-[10px] font-black text-emerald-800 bg-emerald-100 px-2 py-1 rounded-md shadow-sm border border-emerald-300 opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1.5">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                        Reemplazar
                                    </span>
                                </div>
                            </label>
                            <InputFile id="file-upload-reemplazo" OnChange="SubirArchivo" accept=".xlsx" class="hidden" />
                        </div>
                    }

                    @if (EstadoAdjuntadoReportediario == false)
                    {
                        <div class="group relative w-full">
                            <label for="file-upload_multi" class="w-full bg-slate-50 border-2 border-dashed border-slate-200 hover:border-slate-400 hover:bg-slate-100/50 rounded-2xl px-4 py-3.5 flex items-center justify-between transition-all duration-300 cursor-pointer select-none">
                                <span class="flex flex-col">
                                    <span class="text-[11px] font-black text-slate-800">Reportes Diarios Consolidados</span>
                                    <span class="text-[8px] text-slate-500 font-bold uppercase tracking-wider mt-0.5">Se pueden adjuntar múltiples archivos (.xlsx)</span>
                                </span>
                                <span class="p-1.5 bg-white border border-slate-200 rounded-lg group-hover:bg-[#0f172a] group-hover:text-white group-hover:border-[#0f172a] text-slate-600 transition-all shrink-0">
                                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                                </span>
                            </label>
                            <InputFile id="file-upload_multi" OnChange="SubirArchivoMulti" multiple accept=".xlsx" class="hidden" />
                        </div>
                    }
                    else
                    {
                        <div class="relative w-full group">
                            <label for="file-upload_multi_add" class="cursor-pointer block w-full">
                                <SuccessCargaFile File="@($"{archivosReporteDiario.Count} reportes diarios consolidados")" />
                                <div class="absolute inset-0 bg-emerald-500/0 group-hover:bg-emerald-500/10 rounded-2xl transition-all flex items-center justify-end px-4 pointer-events-none">
                                    <span class="text-[10px] font-black text-emerald-800 bg-emerald-100 px-2 py-1 rounded-md shadow-sm border border-emerald-300 opacity-0 group-hover:opacity-100 transition-opacity">
                                        + Adjuntar más
                                    </span>
                                </div>
                            </label>
                            <InputFile id="file-upload_multi_add" OnChange="SubirArchivoMulti" multiple accept=".xlsx" class="hidden" />
                        </div>
                    }

                </div>

                <!-- Footer Buttons stacked inside mockup visual ratios -->
                <div class="flex flex-col sm:flex-row gap-2.5">
                    <button disabled="@(isLoading || !(EstadoAdjuntadoRegistroVentas || EstadoAdjuntadoReportediario))" 
                            @onclick="AbrirModalAdjuntos" 
                            class="flex-1 bg-white text-slate-700 border border-slate-200 rounded-xl py-3 text-[10px] font-black uppercase tracking-wider hover:bg-slate-50 transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 disabled:cursor-not-allowed shadow-sm">
                        Ver adjuntos
                    </button>
                    <button @onclick="EjecutarProceso"
                            disabled="@isLoading"
                            class="flex-1 bg-[#0f172a] text-white rounded-xl py-3 text-[10px] font-black uppercase tracking-wider shadow-md hover:bg-slate-800 hover:scale-[1.01] active:scale-[0.98] transition-all flex items-center justify-center gap-1.5 cursor-pointer select-none disabled:opacity-75">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <span>Ejecutar Proceso</span>
                    </button>
                    <button disabled="@isLoading" 
                            @onclick="CancelarRegistroVentas" 
                            class="px-4 py-3 bg-white border border-slate-200 hover:bg-rose-50 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all active:scale-[0.98] cursor-pointer select-none disabled:opacity-40 shadow-sm">
                        Limpiar
                    </button>
                </div>

            </div>

            <!-- NEW DASHBOARD -->
            @if (MostrarDashboard)
            {
                <div class="mt-auto pt-6 border-t border-slate-100 animate-fade-in-up">
                    <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        Resumen de Ejecución
                    </h3>
                    <div class="grid grid-cols-2 gap-3">
                        <!-- Archivos procesados -->
                        <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm relative overflow-hidden h-[54px]">
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-40">
                                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                            </div>
                            <div class="relative z-10">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Archivos</span>
                                <div class="flex items-baseline gap-1">
                                    <span class="text-base font-black text-white leading-none">@TotalArchivosProcesados</span>
                                    <span class="text-[9px] font-bold text-slate-500">proc.</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Días procesados -->
                        <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm relative overflow-hidden h-[54px]">
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-40">
                                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </div>
                            <div class="relative z-10">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Días Totales</span>
                                <div class="flex items-baseline gap-1">
                                    <span class="text-base font-black text-white leading-none">@TotalDiasProcesados</span>
                                    <span class="text-[9px] font-bold text-slate-500">días</span>
                                </div>
                            </div>
                        </div>

                        <!-- Días Correctos -->
                        <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm relative overflow-hidden h-[54px] border-l-2 border-emerald-500">
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-40">
                                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div class="relative z-10">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Días Correctos</span>
                                <div class="flex items-baseline gap-1">
                                    <span class="text-base font-black text-white leading-none">@TotalDiasCorrectos</span>
                                    <span class="text-[9px] font-bold text-slate-500">días</span>
                                </div>
                            </div>
                        </div>

                        <!-- Días Error -->
                        <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm relative overflow-hidden h-[54px] border-l-2 border-rose-500">
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-40">
                                <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div class="relative z-10">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Días Error</span>
                                <div class="flex items-baseline gap-1">
                                    <span class="text-base font-black text-white leading-none">@TotalDiasError</span>
                                    <span class="text-[9px] font-bold text-slate-500">días</span>
                                </div>
                            </div>
                        </div>

                        <!-- Tiempo demora -->
                        <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm relative overflow-hidden h-[54px]">
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-40">
                                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div class="relative z-10">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-wider block mb-0.5">Duración</span>
                                <div class="flex items-baseline gap-1">
                                    <span class="text-sm font-black text-white leading-none">@TiempoDemoraProceso</span>
                                </div>
                            </div>
                        </div>

                        <!-- Tiempo ahorrado -->
                        <div class="bg-[#1e293b] rounded-2xl p-3 flex flex-col justify-center shadow-sm relative overflow-hidden h-[54px]">
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-40">
                                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            </div>
                            <div class="relative z-10">
                                <span class="text-[8px] font-black text-emerald-500 uppercase tracking-wider block mb-0.5">Tiempo Ahorrado</span>
                                <div class="flex items-baseline gap-1">
                                    <span class="text-sm font-black text-white leading-none">@TiempoAhorrado</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Right Column: Processed logs table, styled EXACTLY like the Asset rows in Mockup -->
        <div class="lg:col-span-7 bg-white border border-slate-200/60 rounded-[30px] p-6 flex flex-col hover:border-slate-300 hover:shadow-lg transition-all duration-300 animate-fade-in-up anim-delay-150" style="height: calc(100vh - 160px);">
            <div class="flex flex-col h-full overflow-hidden">
                
                @if (archivoRegistroVentasInfo != null)
                {
                    <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                        <div class="flex items-center gap-2">
                            <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Archivo Registro de Ventas</h3>
                        </div>
                    </div>
                    
                    <div class="overflow-hidden bg-white border border-slate-200 rounded-2xl shadow-sm mb-6 shrink-0">
                        <table class="w-full text-left border-collapse">
                            <thead style="background-color: #1e293b !important;">
                                <tr class="text-[10px] font-black uppercase tracking-wider" style="color: #ffffff !important;">
                                    <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Archivo</th>
                                    <th class="py-3 px-4 w-28 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">Estado</th>
                                    <th class="py-3 px-4 text-right w-40" style="background-color: #1e293b !important; color: #ffffff !important;">Acción</th>
                                </tr>
                            </thead>
                            <tbody class="text-xs text-slate-700">
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="py-3.5 px-4 font-bold text-slate-800">
                                        @archivoRegistroVentasInfo.File
                                    </td>
                                    <td class="py-3.5 px-4 text-center">
                                        @if (archivoRegistroVentasInfo.Estado == 1)
                                        {
                                            <div class="inline-flex p-1 bg-emerald-500 border border-emerald-400 rounded-lg text-white shadow-sm">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="inline-flex p-1 bg-rose-500 border border-rose-400 rounded-lg text-white shadow-sm">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                                            </div>
                                        }
                                    </td>
                                    <td class="py-3.5 px-4 text-right">
                                        <button @onclick="() => AbrirModal(archivoRegistroVentasInfo)" class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-[#0f172a] hover:bg-slate-800 text-white rounded-full text-[10px] font-black uppercase tracking-widest transition-all hover:scale-[1.02] active:scale-[0.98] shadow-sm cursor-pointer select-none">
                                            Detalles
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                }

                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4 shrink-0">
                    <div class="flex items-center gap-2">
                        <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest">Archivos Procesados</h3>
                        <span class="px-2 py-0.5 bg-slate-100 text-[#0f172a] rounded-full text-[9px] font-black select-none">
                            @(archivosProcesados?.Count ?? 0)
                        </span>
                    </div>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest cursor-pointer hover:text-slate-800" @onclick='() => ToastService.Info("Ver logs históricos")'>Historial</span>
                </div>

                <!-- Table layout exactly like mockup -->
                <div class="overflow-auto custom-scrollbar bg-white border border-slate-200 rounded-2xl shadow-sm flex-1">
                    <table class="w-full text-left border-collapse">
                        <thead class="sticky top-0 z-10" style="background-color: #1e293b !important;">
                            <tr class="text-[10px] font-black uppercase tracking-wider" style="color: #ffffff !important;">
                                <th class="py-3 px-4 w-12 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">#</th>
                                <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Grifo</th>
                                <th class="py-3 px-4 w-28 text-center" style="background-color: #1e293b !important; color: #ffffff !important;">Estado</th>
                                <th class="py-3 px-4 text-right w-40" style="background-color: #1e293b !important; color: #ffffff !important;">Acción</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs text-slate-700 divide-y divide-slate-100">
                            @if (archivosProcesados == null || !archivosProcesados.Any())
                            {
                                @if (!estaProcesando)
                                {
                                    <tr>
                                        <td colspan="4" class="py-12 text-center text-slate-400 italic font-bold uppercase tracking-widest bg-white text-xs">
                                            Sin archivos procesados
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                int contador = 1;
                                @foreach (var archivo in archivosProcesados)
                                {
                                    <tr class="hover:bg-slate-50/50 transition-all duration-205">
                                        <td class="py-2.5 px-4 bg-white text-center font-black text-slate-400 text-[10px]">
                                            @contador.
                                        </td>
                                        <td class="py-2.5 px-4 bg-white">
                                            <div class="flex items-center gap-3">
                                                @if (archivo.Estado == 1)
                                                {
                                                    <div class="inline-flex items-center justify-center p-1 bg-emerald-500 border border-emerald-400 rounded-lg text-white shadow-sm shrink-0" title="Success">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="inline-flex items-center justify-center p-1 bg-rose-500 border border-rose-400 rounded-lg text-white shadow-sm shrink-0" title="Error">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                    </div>
                                                }
                                                <div class="flex flex-col">
                                                    <span class="text-xs font-black text-slate-850 block uppercase tracking-wide truncate">@archivo.Grifo</span>
                                                    <span class="text-[9px] text-slate-400 font-mono block break-all whitespace-normal" title="@archivo.File">@archivo.File</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-2.5 px-4 bg-white text-center">
                                            @if (archivo.Estado == 1)
                                            {
                                                <span class="text-[9px] bg-emerald-50 text-emerald-700 border border-emerald-100 px-2 py-0.5 rounded-md font-black uppercase inline-block">Success</span>
                                            }
                                            else
                                            {
                                                <span class="text-[9px] bg-rose-50 text-rose-700 border border-rose-100 px-2 py-0.5 rounded-md font-black uppercase inline-block">Error</span>
                                            }
                                        </td>
                                        <td class="py-2.5 px-4 bg-white text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <button @onclick="() => AbrirModal(archivo)"
                                                        class="bg-[#0f172a] text-white hover:bg-slate-800 px-3.5 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all shadow-sm hover:scale-[1.01] active:scale-[0.98] select-none cursor-pointer">
                                                    Detalles
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    contador++;
                                }
                            }

                            @if (estaProcesando)
                            {
                                <tr class="animate-pulse bg-slate-50/50">
                                    <td class="py-2.5 px-4 bg-white text-center">
                                        <div class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-200 border border-slate-300 shadow-sm">
                                            <svg class="w-3.5 h-3.5 text-slate-400 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        </div>
                                    </td>
                                    <td class="py-2.5 px-4 bg-white">
                                        <span class="text-xs font-black text-slate-500 block uppercase tracking-wide truncate">Procesando y Consolidando...</span>
                                        <span class="text-[9px] text-slate-400 font-mono block break-all whitespace-normal">Por favor espere, leyendo datos</span>
                                    </td>
                                    <td class="py-2.5 px-4 bg-white text-center">
                                    </td>
                                    <td class="py-2.5 px-4 bg-white text-right">
                                        <span class="text-[9px] bg-slate-100 text-slate-500 border border-slate-200 px-2 py-0.5 rounded-md font-black uppercase inline-block">En progreso</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- GLASS DETAILS DIALOG MODAL -->
<!-- ============================================== -->
@if (mostrarModal && archivoSeleccionado != null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[9999] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModal"></div>
        
        <!-- Modal Card container -->
        <div class="bg-white border border-slate-200 rounded-[28px] shadow-2xl w-max max-w-[95vw] max-h-[85vh] flex flex-col overflow-hidden relative z-10"
             @onclick:stopPropagation="true">
            
            <!-- Header bar of popover -->
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50 gap-4">
                <div class="min-w-0 flex-1">
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block mb-0.5">Archivo de Proceso</span>
                    <h3 class="text-xs font-bold text-slate-800 font-mono truncate leading-tight select-all">@archivoSeleccionado.File</h3>
                </div>
                <button @onclick="CerrarModal" 
                        class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- SUB-DASHBOARD STATISTIC COUNTS -->
            <div class="grid grid-cols-2 gap-4 px-6 pt-5">
                <!-- Info count glass card -->
                <div class="bg-blue-50 border border-blue-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm cursor-pointer transition-all hover:bg-blue-100/50 @(filtroModal == "INFO" ? "ring-2 ring-blue-400 shadow-md scale-[1.02]" : "opacity-80 hover:opacity-100 hover:scale-[1.01]")"
                     @onclick='() => filtroModal = (filtroModal == "INFO" ? "TODOS" : "INFO")'>
                    <div>
                        <span class="text-[9px] font-black text-blue-600 uppercase tracking-wider block mb-1">Informes Info</span>
                        <span class="text-xl font-black text-blue-800 line-height-1">
                            @archivoSeleccionado.Mensajes.Count(m => m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                        </span>
                    </div>
                    <div class="bg-blue-100 rounded-xl p-2 flex items-center justify-center text-blue-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                </div>

                <!-- Error count glass card -->
                <div class="bg-rose-50 border border-rose-100 rounded-2xl p-3.5 flex items-center justify-between shadow-sm cursor-pointer transition-all hover:bg-rose-100/50 @(filtroModal == "ERROR" ? "ring-2 ring-rose-400 shadow-md scale-[1.02]" : "opacity-80 hover:opacity-100 hover:scale-[1.01]")"
                     @onclick='() => filtroModal = (filtroModal == "ERROR" ? "TODOS" : "ERROR")'>
                    <div>
                        <span class="text-[9px] font-black text-rose-600 uppercase tracking-wider block mb-1">Alertas Error</span>
                        <span class="text-xl font-black text-rose-800 line-height-1">
                            @archivoSeleccionado.Mensajes.Count(m => !m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                        </span>
                    </div>
                    <div class="bg-rose-100 rounded-xl p-2 flex items-center justify-center text-rose-600 shrink-0">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Details logs table custom-scrollbar -->
            <div class="p-6 overflow-y-auto flex-1 custom-scrollbar">
                <div class="overflow-hidden bg-white border border-slate-200 rounded-2xl shadow-sm">
                    <table class="w-full text-left border-collapse">
                        <thead style="background-color: #1e293b !important;">
                            <tr class="text-[10px] font-black uppercase tracking-wider" style="color: #ffffff !important;">
                                <th class="py-3 px-4 w-32" style="background-color: #1e293b !important; color: #ffffff !important;">Estado</th>
                                <th class="py-3 px-4" style="background-color: #1e293b !important; color: #ffffff !important;">Descripción</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs text-slate-700 divide-y divide-slate-100">
                        @{
                            var mensajesMostrados = archivoSeleccionado.Mensajes.Where(m => 
                                filtroModal == "TODOS" || 
                                (filtroModal == "INFO" && m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase)) ||
                                (filtroModal == "ERROR" && !m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                            ).ToList();
                        }
                        @if (mensajesMostrados == null || !mensajesMostrados.Any())
                        {
                            <tr>
                                <td colspan="2" class="py-8 text-center text-slate-400 italic font-medium">
                                    No hay mensajes para mostrar.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var msg in mensajesMostrados)
                            {
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="py-3.5 px-4 vertical-top whitespace-nowrap">
                                        @if (msg.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="inline-flex items-center gap-1.5 bg-blue-50 text-blue-700 border border-blue-100 px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider">
                                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span> @msg.Estado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 bg-rose-50 text-rose-700 border border-rose-100 px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider">
                                                <span class="w-1.5 h-1.5 rounded-full bg-rose-550"></span> @msg.Estado
                                            </span>
                                        }
                                    </td>
                                    <td class="py-3.5 px-4 font-medium leading-relaxed select-all">
                                        @msg.Descripcion
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    </table>
                </div>
            </div>

            <!-- Footer close -->
            <div class="px-6 py-4.5 border-t border-slate-100 flex justify-end bg-slate-50">
                <button @onclick="CerrarModal" 
                        class="px-5 py-2 bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 hover:text-slate-900 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all shadow-sm select-none cursor-pointer">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
}

<!-- 3. MODAL ADJUNTOS DETALLES -->
@if (mostrarModalAdjuntos)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center p-4 z-[9998] animate-modal-in">
        <div class="fixed inset-0 z-[-1]" @onclick="CerrarModalAdjuntos"></div>
        
        <div class="bg-white border border-slate-200 rounded-[28px] shadow-2xl w-full max-w-xl max-h-[85vh] flex flex-col overflow-hidden relative z-10"
             @onclick:stopPropagation="true">
            
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <div>
                    <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block mb-0.5">Archivos Temporales</span>
                    <h3 class="text-xs font-black text-slate-800 uppercase tracking-wider">Documentos Adjuntados</h3>
                </div>
                <button @onclick="CerrarModalAdjuntos" 
                        class="p-1.5 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all cursor-pointer">
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- Counts details widget -->
            <div class="grid grid-cols-2 gap-4 px-6 pt-5">
