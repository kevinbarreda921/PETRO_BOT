@page "/RegistroVentas"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using PETRO_BOT.Services.Services
@using System.Diagnostics
@using PETRO_BOT.Models.Log

<div class="flex flex-col lg:flex-row gap-6 items-start">

    <!-- PANEL DE PARÁMETROS -->
    <div class="w-full lg:w-[320px] bg-white rounded-[35px] p-8 shadow-sm flex flex-col gap-6 relative z-30 border border-slate-50 overflow-hidden">
        
        <div class="flex items-center justify-between border-b border-slate-100 pb-5">
            <h2 class="text-sm font-black text-slate-800 uppercase tracking-[0.2em]">Parámetros</h2>
            <span class="h-2 w-2 bg-emerald-400 rounded-full animate-pulse"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-1 gap-5">

            <!-- ===================== -->
            <!-- TRABAJO -->
            <!-- ===================== -->
            <div class="relative">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                    Trabajo
                </label>
                
                <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                     @onclick="ToggleTrabajo">
                    <span>@trabajoSeleccionado</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showTrabajo ? "rotate-180" : "")"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showTrabajo)
                {
                    <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 overflow-hidden">
                        @foreach (var trabajo in trabajos)
                        {
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarTrabajo(trabajo)">
                                @trabajo
                            </div>
                        }
                    </div>
                }
            </div>
            <!-- ===================== -->
            <!-- FECHA (CALENDARIO MINIMALISTA) -->
            <!-- ===================== -->            @if (showDiaActivar)
            {
                <div class="relative">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                        Fecha
                    </label>
                    <div class="relative" style="position: relative;">
                        <!-- Input visual que al hacer click abre el calendario -->
                        <div @onclick="ToggleCalendario" 
                             class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 pr-10 text-sm font-medium text-slate-600 outline-none hover:border-slate-300 transition-all cursor-pointer flex items-center justify-between select-none @(mostrarCalendario ? "border-[#0186B5] ring-2 ring-[#0186B5]/10" : "")"
                             style="display: flex; align-items: center; justify-content: space-between; position: relative; cursor: pointer;">
                            <span>@fechaSeleccionada.ToString("d/MM/yyyy")</span>
                            <div class="text-slate-400" style="color: #94a3b8; display: flex; align-items: center;">
                                <svg class="w-4 h-4" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                        </div>

                        @if (mostrarCalendario)
                        {
                            <!-- Backdrop invisible para cerrar al hacer click fuera -->
                            <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 40; background-color: transparent;" @onclick="CerrarCalendario"></div>

                            <!-- Contenedor del Calendario flotante -->
                            <div class="absolute shadow-xl"
                                 @onclick:stopPropagation="true"
                                 style="position: absolute; top: calc(100% + 6px); left: 0; width: 280px; background-color: #ffffff; border: 1.5px solid #0186B5; border-radius: 20px; padding: 18px; z-index: 50; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); font-family: system-ui, -apple-system, sans-serif; transition: all 0.2s ease-in-out; transform-origin: top left; animation: calendarFadeIn 0.15s ease-out;">
                                
                                <!-- Encabezado: Mes y Año + Navegación -->
                                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                                    <button type="button" @onclick="MesAnterior" 
                                            style="background: transparent; border: none; cursor: pointer; color: #64748b; padding: 6px; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"
                                            onmouseover="this.style.backgroundColor='#f1f5f9'; this.style.color='#1e293b';"
                                            onmouseout="this.style.backgroundColor='transparent'; this.style.color='#64748b';">
                                        <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
                                        </svg>
                                    </button>
                                    
                                    <span style="font-size: 11px; font-weight: 800; color: #1e293b; text-transform: uppercase; letter-spacing: 0.1em;">
                                        @mesVisualizado.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES"))
                                    </span>
                                    
                                    <button type="button" @onclick="MesSiguiente" 
                                            style="background: transparent; border: none; cursor: pointer; color: #64748b; padding: 6px; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"
                                            onmouseover="this.style.backgroundColor='#f1f5f9'; this.style.color='#1e293b';"
                                            onmouseout="this.style.backgroundColor='transparent'; this.style.color='#64748b';">
                                        <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
                                        </svg>
                                    </button>
                                </div>

                                <!-- Días de la semana en formato grid 7 columnas -->
                                <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; margin-bottom: 8px; border-bottom: 1px solid #f1f5f9; padding-bottom: 6px;">
                                    @foreach (var diaSem in new[] { "DO", "LU", "MA", "MI", "JU", "VI", "SA" })
                                    {
                                        <span style="font-size: 9px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">@diaSem</span>
                                    }
                                </div>

                                <!-- Grid de días - 7 columnas -->
                                <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; justify-items: center; align-items: center;">
                                    @* Celdas vacías para el desfase del primer día del mes *@
                                    @for (int i = 0; i < ObtenerDesfasePrimerDia(); i++)
                                    {
                                        <div style="width: 32px; height: 32px;"></div>
                                    }

                                    @* Días del mes *@
                                    @for (int dia = 1; dia <= DateTime.DaysInMonth(mesVisualizado.Year, mesVisualizado.Month); dia++)
                                    {
                                        var diaActual = dia; 
                                        var fechaCelda = new DateTime(mesVisualizado.Year, mesVisualizado.Month, diaActual);
                                        var esSeleccionado = fechaCelda.Date == fechaSeleccionada.Date;
                                        var esHoy = fechaCelda.Date == DateTime.Today;

                                        if (esSeleccionado)
                                        {
                                            <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)"
                                                    style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; border-radius: 10px; border: none; background-color: #0186B5; color: #ffffff; cursor: pointer; box-shadow: 0 4px 10px rgba(1, 134, 181, 0.3); transition: all 0.15s;">
                                                @diaActual
                                            </button>
                                        }
                                        else if (esHoy)
                                        {
                                            <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)"
                                                    style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; border-radius: 10px; border: none; background-color: rgba(1, 134, 181, 0.1); color: #0186B5; cursor: pointer; transition: all 0.15s;"
                                                    onmouseover="this.style.backgroundColor='rgba(1, 134, 181, 0.2)';"
                                                    onmouseout="this.style.backgroundColor='rgba(1, 134, 181, 0.1)';">
                                                @diaActual
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" @onclick="() => SeleccionarFecha(fechaCelda)"
                                                    style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; border-radius: 10px; border: none; background-color: transparent; color: #475569; cursor: pointer; transition: all 0.15s;"
                                                    onmouseover="this.style.backgroundColor='#f1f5f9'; this.style.color='#0f172a';"
                                                    onmouseout="this.style.backgroundColor='transparent'; this.style.color='#475569';">
                                                @diaActual
                                            </button>
                                        }
                                    }
                                </div>

                                <!-- Accesos rápidos minimalistas en el pie del calendario -->
                                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 14px; padding-top: 10px; border-top: 1px solid #f1f5f9;">
                                    <button type="button" @onclick="EstablecerHoy" 
                                            style="background: transparent; border: none; cursor: pointer; font-size: 10px; font-weight: 800; color: #0186B5; text-transform: uppercase; letter-spacing: 0.05em; padding: 4px 8px; border-radius: 6px; transition: background 0.2s;"
                                            onmouseover="this.style.backgroundColor='rgba(1, 134, 181, 0.05)';"
                                            onmouseout="this.style.backgroundColor='transparent';">
                                        Hoy
                                    </button>
                                    <button type="button" @onclick="LimpiarCalendario" 
                                            style="background: transparent; border: none; cursor: pointer; font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; padding: 4px 8px; border-radius: 6px; transition: background 0.2s;"
                                            onmouseover="this.style.backgroundColor='#f1f5f9'; this.style.color='#64748b';"
                                            onmouseout="this.style.backgroundColor='transparent'; this.style.color='#94a3b8';">
                                        Borrar
                                    </button>
                                </div>

                            </div>
                            
                            <style>
                                @@keyframes calendarFadeIn {
                                    from { opacity: 0; transform: scale(0.95) translateY(-5px); }
                                    to { opacity: 1; transform: scale(1) translateY(0); }
                                }
                            </style>
                        }
                    </div>
                </div>
            }

        </div>

        @if (EstadoAdjuntadoRegistroVentas==false)
        {
            <div class="space-y-2">

                <label class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1">
                    Adjuntar
                </label>

                <div class="group relative w-full">

                    <label for="file-upload"
                           class="w-full bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl px-4 py-2 flex items-center justify-between hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer">

                        <span class="text-[11px] font-bold text-slate-600">
                            Adjuntar registro ventas
                        </span>

                        <span class="p-1.5 bg-white rounded-lg shadow-sm group-hover:scale-105 transition-transform">
                            <svg class="w-4 h-4 text-emerald-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M12 4v16m8-8H4">
                                </path>
                            </svg>
                        </span>

                    </label>

                    <InputFile id="file-upload"
                               OnChange="SubirArchivo"
                               accept=".xlsx"
                               class="hidden" />

                </div>

            </div>

        }
        else
        {
               <SuccessCargaFile File="registro_ventaas.xlsx"/>
        }

        @if (EstadoAdjuntadoReportediario == false)
        {
            <div class="space-y-2">

                <label class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1">
                    Adjuntar
                </label>

                <div class="group relative w-full">

                    <label for="file-upload_multi"
                           class="w-full bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl px-4 py-2 flex items-center justify-between hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer">

                        <span class="text-[11px] font-bold text-slate-600">
                            Adjuntar reporte diario
                        </span>

                        <span class="p-1.5 bg-white rounded-lg shadow-sm group-hover:scale-105 transition-transform">
                            <svg class="w-4 h-4 text-emerald-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M12 4v16m8-8H4">
                                </path>
                            </svg>
                        </span>

                    </label>

                    <InputFile id="file-upload_multi"
                               class="hidden"
                               OnChange="SubirArchivoMulti"
                               multiple
                               accept=".xlsx" />

                </div>

            </div>
        }
        else
        {
            <SuccessCargaFile File="reporte_diario.xlsx" />
        }




        <div class="flex flex-col gap-3 mt-auto pt-4 border-t border-slate-100">
    
            <!-- Botón Ver Adjuntos (Con el mismo diseño del de Cancelar Operación, habilitado si hay archivos) -->
            <button disabled="@(isLoading || !(EstadoAdjuntadoRegistroVentas || EstadoAdjuntadoReportediario))" 
                    @onclick="AbrirModalAdjuntos" 
                    class="w-full bg-white text-slate-500 border border-slate-200 rounded-xl py-3.5 text-sm font-medium hover:bg-[#eff6ff] hover:text-[#2563eb] hover:border-[#bfdbfe] transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white disabled:hover:text-slate-500 disabled:hover:border-slate-200 cursor-pointer">
                Ver adjuntos
            </button>

            <!-- Botón Ejecutar con estado Loading -->
            <button @onclick="EjecutarProceso"
                    disabled="@isLoading"
                    class="w-full bg-[#0186B5] text-white rounded-xl py-3.5 flex items-center justify-center gap-2.5 shadow-sm hover:bg-[#017099] transition-all active:scale-[0.98] font-medium disabled:opacity-75 disabled:cursor-not-allowed disabled:hover:bg-[#0186B5] disabled:active:scale-100 cursor-pointer">
                @if (isLoading)
                {
                   <LoadingRayo/>
                }
                else
                {
                    <!-- Icono normal -->
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <span class="text-sm">Ejecutar Proceso</span>
                }
            </button>
          
            <button disabled="@isLoading" @onclick="CancelarRegistroVentas" class="w-full bg-white text-slate-500 border border-slate-200 rounded-xl py-3.5 text-sm font-medium hover:bg-red-50 hover:text-red-600 hover:border-red-200 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white disabled:hover:text-slate-500 disabled:hover:border-slate-200 cursor-pointer">
                Cancelar Operación
            </button>

        </div>

    </div>

    <!-- PANEL DE TABLA -->
    <div class="flex-1 bg-white w-full rounded-[30px] p-6 shadow-sm border border-slate-50 overflow-hidden" style="position: relative; min-height: 250px;">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-800">Archivos procesados</h2>
            <button class="text-[#017099] text-sm font-bold hover:underline decoration-2 underline-offset-4">Download CSV</button>
        </div>
        <div class="overflow-x-auto custom-scrollbar" style="max-height: calc(100vh - 260px); overflow-y: auto; padding-right: 4px;">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[11px] uppercase tracking-[0.2em] border-b border-slate-50">
                        <!-- Reducido de pb-5 a pb-3 -->
                        <th class="pb-3 font-black w-px whitespace-nowrap pr-4">#</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap pr-8">Grifo</th>
                        <th class="pb-3 font-black">File</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap px-4">Estado</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap text-right">Acción</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    @if (archivosProcesados == null || !archivosProcesados.Any())
                    {
                        <tr>
                            <td colspan="5" style="padding: 48px 0; text-align: center; border: none;">
                                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;">
                                    <svg style="width: 32px; height: 32px; color: #94a3b8;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                    </svg>
                                    <span style="font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.15em;">Sin archivos procesados</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var archivo in archivosProcesados)
                        {
                            @* Agregamos @key para eficiencia y la clase animate-new-row para el efecto *@
                            <tr @key="archivo.Id" class="border-b border-slate-50 group hover:bg-slate-50/50 transition-colors animate-new-row">

                                @* Número de registro con un toque más tenue *@
                                <td class="py-3 text-[11px] text-slate-300 font-bold whitespace-nowrap">
                                    #@(archivosProcesados.IndexOf(archivo) + 1)
                                </td>

                                <td class="py-3 pr-8 whitespace-nowrap">
                                    <span class="font-bold text-slate-700 text-sm">@archivo.Grifo</span>
                                </td>

                                <td class="py-3">
                                    @* Un gris un poco más suave para el nombre del archivo mejora el minimalismo *@
                                    <span class="text-slate-500 font-medium text-sm">@archivo.File</span>
                                </td>

                                @if (archivo.Estado == 1)
                                {
                                    <td class="py-3 px-4 whitespace-nowrap">
                                        <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Success
                                        </span>
                                    </td>
                                }
                                else
                                {
                                    <td class="py-3 whitespace-nowrap px-4">
                                        <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-rose-50 text-rose-600 rounded-md text-[10px] font-black uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> Error
                                        </span>
                                    </td>
                                }

                                <td class="py-3 text-right whitespace-nowrap">
                                    @* Botón un poco más compacto para mantener la línea limpia *@
                                    <button id="@archivo.File"
                                            @onclick="() => AbrirModal(archivo)"
                                            class="bg-[#017099] text-white px-4 py-1.5 rounded-lg text-[11px] font-bold hover:shadow-md active:scale-95 transition-all outline-none cursor-pointer">
                                        Ver detalles
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (isLoading)
        {
            <LoadingRayo/>
        }
    </div>



</div>

@if (mostrarModal && archivoSeleccionado != null)
{
    <!-- MODAL OVERLAY (FONDO CON OPACIDAD MÍNIMA QUE PERMITE CERRAR AL HACER CLICK AFUERA) -->
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 9999; padding: 20px;" 
         @onclick="CerrarModal">
        
        <!-- CONTENEDOR DEL MODAL (TAMAÑO AUTO-AJUSTABLE A LA TABLA, DETIENE LA PROPAGACIÓN DE CLIC) -->
        <div style="background-color: #ffffff; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); border: 1px solid #f1f5f9; width: auto; min-width: 0px; max-width: 750px; max-height: 80vh; display: flex; flex-direction: column; overflow: hidden;"
             @onclick:stopPropagation="true">
            
            <!-- HEADER (CON EL NOMBRE DEL ARCHIVO COMO TÍTULO) -->
            <div style="padding: 16px 20px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; background-color: #f8fafc; gap: 20px;">
                <div style="flex: 1; min-width: 0;">
                    <span style="font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 2px;">Archivo de Proceso</span>
                    <h3 style="font-size: 13px; font-weight: 800; color: #1e293b; margin: 0; word-break: break-all; font-family: monospace; line-height: 1.4;">@archivoSeleccionado.File</h3>
                </div>
                <button @onclick="CerrarModal" 
                        style="background: none; border: none; cursor: pointer; padding: 8px; border-radius: 50%; color: #94a3b8; display: flex; align-items: center; justify-content: center; transition: all 0.2s;" 
                        onmouseover="this.style.backgroundColor='#e2e8f0'; this.style.color='#475569';" 
                        onmouseout="this.style.backgroundColor='transparent'; this.style.color='#94a3b8';">
                    <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- DASHBOARD DE CONTADORES MINIMALISTA -->
            <div style="display: flex; gap: 16px; padding: 16px 20px 0 20px;">
                <!-- CARD INFO -->
                <div style="flex: 1; background-color: #eff6ff; border: 1px solid #bfdbfe; border-radius: 16px; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);">
                    <div>
                        <span style="font-size: 9px; font-weight: 700; color: #2563eb; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 4px;">Mensajes Info</span>
                        <span style="font-size: 20px; font-weight: 900; color: #1e3a8a; line-height: 1;">
