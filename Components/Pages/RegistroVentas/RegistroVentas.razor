    private async Task CargarReporteProceso()
    {
        try
        {
            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            if (System.IO.File.Exists(rutaLog))
            {
                string jsonContent = await System.IO.File.ReadAllTextAsync(rutaLog);
                var logsProcesados = System.Text.Json.JsonSerializer.Deserialize<List<LogProcesoGrifo>>(jsonContent);
                
                if (logsProcesados != null)
                {
                    archivosProcesados.Clear();
                    var mensajesEscritura = new List<LogDetalle>();

                    foreach (var log in logsProcesados)
                    {
                        var mensajesLectura = new List<LogDetalle>();

                        foreach (var msg in log.Mensajes)
                        {
                            bool isWritingError = (msg.Descripcion.TrimStart().StartsWith("El grifo", StringComparison.OrdinalIgnoreCase) && !msg.Descripcion.Contains("procesado correctamente")) || 
                                                  msg.Descripcion.StartsWith("No se encontró", StringComparison.OrdinalIgnoreCase) ||
                                                  log.Archivo == "MAESTRO";

                            if (isWritingError)
                            {
                                mensajesEscritura.Add(msg);
                            }
                            else
                            {
                                mensajesLectura.Add(msg);
                            }
                        }

                        if (log.Archivo != "MAESTRO")
                        {
                            int estado = mensajesLectura.All(m => m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase)) ? 1 : 2;
                            archivosProcesados.Add(new ArchivoInfo
                            {
                                Id = Guid.NewGuid(),
                                Grifo = log.Grifo,
                                File = log.Archivo,
                                Estado = estado,
                                Mensajes = mensajesLectura
                            });
                        }
                    }

                    if (mensajesEscritura.Any())
                    {
                        archivoRegistroVentasInfo = new ArchivoInfo
                        {
                            Id = Guid.NewGuid(),
                            Grifo = "MAESTRO",
                            File = archivosRegistroVentas.FirstOrDefault() ?? "registro_ventas.xlsx",
                            Estado = mensajesEscritura.All(m => m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase)) ? 1 : 2,
                            Mensajes = mensajesEscritura
                        };
                    }
                    else
                    {
                        archivoRegistroVentasInfo = null;
                    }
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el reporte: " + ex.Message);
        }
    }

