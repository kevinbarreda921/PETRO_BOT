@page "/RegistroVentas"
@using PETRO_BOT.Services
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService

<div class="flex flex-col lg:flex-row gap-6 items-start">

    <!-- PANEL DE PARÁMETROS -->
    <div class="w-full lg:w-[320px] bg-white rounded-[35px] p-8 shadow-sm flex flex-col gap-6 relative z-30 border border-slate-50 overflow-hidden">
        
        <div class="flex items-center justify-between border-b border-slate-100 pb-5">
            <h2 class="text-sm font-black text-slate-800 uppercase tracking-[0.2em]">Parámetros</h2>
            <span class="h-2 w-2 bg-emerald-400 rounded-full animate-pulse"></span>
        </div>

        @if (EstadoAdjuntadoRegistroVentas==false)
        {
            <div class="space-y-2">

                <label class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1">
                    Adjuntar
                </label>

                <div class="group relative w-full">

                    <label for="file-upload"
                           class="w-full bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl px-4 py-2 flex items-center justify-between hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer">

                        <span class="text-[11px] font-bold text-slate-600">
                            Adjuntar registro ventas
                        </span>

                        <span class="p-1.5 bg-white rounded-lg shadow-sm group-hover:scale-105 transition-transform">
                            <svg class="w-4 h-4 text-emerald-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M12 4v16m8-8H4">
                                </path>
                            </svg>
                        </span>

                    </label>

                    <InputFile id="file-upload"
                               OnChange="SubirArchivo"
                               accept=".xlsx"
                               class="hidden" />

                </div>

            </div>

        }
        else
        {
               <SuccessCargaFile File="registro_ventaas.xlsx"/>
        }
     

        <div class="grid grid-cols-1 md:grid-cols-1 gap-5">

            <!-- ===================== -->
            <!-- TRABAJO -->
            <!-- ===================== -->
            <div class="relative">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                    Trabajo
                </label>
                
                <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                     @onclick="ToggleTrabajo">
                    <span>@trabajoSeleccionado</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showTrabajo ? "rotate-180" : "")"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showTrabajo)
                {
                    <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 overflow-hidden">
                        @foreach (var trabajo in trabajos)
                        {
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarTrabajo(trabajo)">
                                @trabajo
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- ===================== -->
            <!-- MES -->
            <!-- ===================== -->
            @if (showMesActivar){
            <div class="relative">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                    Mes
                </label>
                
                <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                     @onclick="ToggleMes">
                    <span>@mesSeleccionado</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showMes ? "rotate-180" : "")"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showMes)
                {
                    <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 max-h-48 overflow-y-auto custom-scrollbar">
                        @foreach (var mes in meses)
                        {
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarMes(mes)">
                                @mes
                            </div>
                        }
                    </div>
                }
            </div>
            }

            <!-- ===================== -->
            <!-- DÍA -->
            <!-- ===================== -->
            @if (showDiaActivar)
            {
                <div class="relative">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                        Día
                    </label>

                    <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                    @onclick="ToggleDia">
                        <span>@(diaSeleccionado == 0 ? "Seleccionar" : diaSeleccionado.ToString())</span>
                        <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showDia ? "rotate-180" : "")"
                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>

                    @if (showDia)
                    {
                        <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 max-h-48 overflow-y-auto custom-scrollbar">
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                            @onclick:stopPropagation="true"
                            @onclick="() => SeleccionarDia(0)">
                                Seleccionar
                            </div>
                            @foreach (var dia in Enumerable.Range(1, 31))
                            {
                                <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                @onclick:stopPropagation="true"
                                @onclick="() => SeleccionarDia(dia)">
                                    @dia
                                </div>
                            }
                        </div>
                }
            </div>
            }

        </div>

        @if (EstadoAdjuntadoReportediario == false)
        {
            <div class="space-y-2">

                <label class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1">
                    Adjuntar
                </label>

                <div class="group relative w-full">

                    <label for="file-upload_multi"
                    class="w-full bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl px-4 py-2 flex items-center justify-between hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer">

                        <span class="text-[11px] font-bold text-slate-600">
                            Adjuntar reporte diario
                        </span>

                        <span class="p-1.5 bg-white rounded-lg shadow-sm group-hover:scale-105 transition-transform">
                            <svg class="w-4 h-4 text-emerald-500"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 4v16m8-8H4">
                                </path>
                            </svg>
                        </span>

                    </label>

                    <InputFile id="file-upload_multi" OnChange="SubirArchivoMulti" multiple accept=".xlsx" />

                </div>

            </div>
        }
        else
        {
            <SuccessCargaFile File="registro_ventaas.xlsx" />
        }




        <div class="flex flex-col gap-3 mt-auto pt-4 border-t border-slate-100">
    
            <!-- Botón Ejecutar con estado Loading -->
            <button @onclick="EjecutarProceso"
                    disabled="@isLoading"
                    class="w-full bg-[#0186B5] text-white rounded-xl py-3.5 flex items-center justify-center gap-2.5 shadow-sm hover:bg-[#017099] transition-all active:scale-[0.98] font-medium disabled:opacity-75 disabled:cursor-not-allowed disabled:hover:bg-[#0186B5] disabled:active:scale-100">
                @if (isLoading)
                {
                   <LoadingRayo/>
                }
                else
                {
                    <!-- Icono normal -->
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <span class="text-sm">Ejecutar Proceso</span>
                }
            </button>
          
            <button disabled="@isLoading" @onclick="CancelarRegistroVentas" class="w-full bg-white text-slate-500 border border-slate-200 rounded-xl py-3.5 text-sm font-medium hover:bg-red-50 hover:text-red-600 hover:border-red-200 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white disabled:hover:text-slate-500 disabled:hover:border-slate-200">
                Cancelar Operación
            </button>

        </div>

    </div>

    <!-- PANEL DE TABLA -->
    <div class="flex-1 bg-white w-full rounded-[30px] p-6 shadow-sm border border-slate-50 overflow-hidden">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-800">Archivos procesados</h2>
            <button class="text-[#017099] text-sm font-bold hover:underline decoration-2 underline-offset-4">Download CSV</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[11px] uppercase tracking-[0.2em] border-b border-slate-50">
                        <!-- Reducido de pb-5 a pb-3 -->
                        <th class="pb-3 font-black w-px whitespace-nowrap pr-4">#</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap pr-8">Grifo</th>
                        <th class="pb-3 font-black">File</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap px-4">Estado</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap text-right">Acción</th>
                    </tr>
                </thead>
                <tbody class="text-sm">

                    <!-- Reducido de py-5 a py-3 -->
                    <tr class="border-b border-slate-50 group hover:bg-slate-50/50 transition-colors">
                        <td class="py-3 text-slate-400 font-bold whitespace-nowrap">01</td>
                        <td class="py-3 whitespace-nowrap pr-8">
                            <span class="font-bold text-slate-700">BRASIL</span>
                        </td>
                        <td class="py-3">
                            <span class="font-bold text-slate-700">reporte_anuaSSSSSSSSSSSSSSSSSSSSSSSSSSSSl_2024.pdf</span>
                        </td>
                        <td class="py-3 whitespace-nowrap px-4">
                            <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-emerald-50 text-emerald-600 rounded-md text-[10px] font-black uppercase tracking-wider">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Success
                            </span>
                        </td>
                        <td class="py-3 text-right whitespace-nowrap">
                            <button class="bg-[#017099] text-white px-5 py-2 rounded-xl text-xs font-bold hover:brightness-110 transition-all shadow-sm">
                                Ver detalles
                            </button>
                        </td>
                    </tr>
                    <tr class="border-b border-slate-50 group hover:bg-slate-50/50 transition-colors">
                        <td class="py-3 text-slate-400 font-bold whitespace-nowrap">01</td>
                        <td class="py-3 whitespace-nowrap pr-8">
                            <span class="font-bold text-slate-700">BRASIL</span>
                        </td>
                        <td class="py-3">
                            <span class="font-bold text-slate-700">reporte_anuaSSSSSSSSSSSSSSSSSSSSSSSSSSl_2024.pdf</span>
                        </td>
                        <td class="py-3 whitespace-nowrap px-4">
                            <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-rose-50 text-rose-600 rounded-md text-[10px] font-black uppercase tracking-wider">
                                <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> Error
                            </span>
                        </td>
                        <td class="py-3 text-right whitespace-nowrap">
                            <button class="bg-[#017099] text-white px-5 py-2 rounded-xl text-xs font-bold hover:brightness-110 transition-all shadow-sm">
                                Ver detalles
                            </button>
                        </td>
                    </tr>

                    @foreach (var archivo in archivosProcesados)
                    {
                        @* Agregamos @key para eficiencia y la clase animate-new-row para el efecto *@
                        <tr @key="archivo.Id" class="border-b border-slate-50 group hover:bg-slate-50/50 transition-colors animate-new-row">

                            @* Número de registro con un toque más tenue *@
                            <td class="py-3 text-[11px] text-slate-300 font-bold whitespace-nowrap">
                                #@(archivosProcesados.IndexOf(archivo) + 1)
                            </td>

                            <td class="py-3 pr-8 whitespace-nowrap">
                                <span class="font-bold text-slate-700 text-sm">@archivo.Grifo</span>
                            </td>

                            <td class="py-3">
                                @* Un gris un poco más suave para el nombre del archivo mejora el minimalismo *@
                                <span class="text-slate-500 font-medium text-sm">@archivo.File</span>
                            </td>

                            <td class="py-3 px-4 whitespace-nowrap">
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Success
                                </span>
                            </td>

                            <td class="py-3 text-right whitespace-nowrap">
                                @* Botón un poco más compacto para mantener la línea limpia *@
                                <button class="bg-[#017099] text-white px-4 py-1.5 rounded-lg text-[11px] font-bold hover:shadow-md active:scale-95 transition-all outline-none">
                                    Ver detalles
                                </button>
                            </td>
                        </tr>
                    }


                    <!-- Repite py-3 en el resto de los <tr> -->
                </tbody>
            </table>
        </div>
    </div>



</div>


@code {

    string[] trabajos =
    {
        "Seleccionar",
        "Procesar Hoy",
        "Procesar Día",
        "Procesar Mes"
    };

    string[] meses =
    {
        "Seleccionar",
        "Enero",
        "Febrero",
        "Marzo",
        "Abril",
        "Mayo",
        "Junio",
        "Julio",
        "Agosto",
        "Septiembre",
        "Octubre",
        "Noviembre",
        "Diciembre"
    };

    string trabajoSeleccionado = "Seleccionar";
    string mesSeleccionado = "Seleccionar";
    int diaSeleccionado = 0;

    bool showTrabajo;
    bool showMes;
    bool showDia;
    bool showMesActivar;
    bool showDiaActivar;


    void ToggleTrabajo()
    {
        showTrabajo = !showTrabajo;
        showMes = false; 
        showDia = false;
    }

    void ToggleMes()
    {
        showMes = !showMes;
        showTrabajo = false;
        showDia = false;
    }

    void ToggleDia()
    {
        showDia = !showDia;
        showTrabajo = false;
        showMes = false;
    }
    void SeleccionarMes(string mes)
    {
        mesSeleccionado = mes;
        showMes = false;
    }

    void SeleccionarDia(int dia)
    {
        diaSeleccionado = dia;
        showDia = false;
    }

    void SeleccionarTrabajo(string trabajo)
    {
        trabajoSeleccionado = trabajo;
        showTrabajo = false;
        switch (trabajo)
        {
            case "Procesar Hoy":
                showMesActivar = false;
                showDiaActivar = false;
                break;
            case "Procesar Día":
                showMesActivar = true;
                showDiaActivar = true;
                break;
            case "Procesar Mes":
                showMesActivar = true;
                showDiaActivar = false;
                break;
            default:
                break;
        };


    }

    void CancelarRegistroVentas()
    {
        EstadoAdjuntadoRegistroVentas = false;
        EstadoAdjuntadoReportediario = false;
    }

    bool isLoading = false;

    async Task EjecutarProceso()
    {
        isLoading = true;
        // await Task.Delay(3000);
        await ProcesarArchivos();
        isLoading = false;
    }


    private string mensaje = "";
    private bool EstadoAdjuntadoRegistroVentas;

    private async Task SubirArchivo(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;

            var extension = Path.GetExtension(archivo.Name).ToLower();
            if (extension != ".xlsx")
            {
                ToastService.Error("Solo se permiten archivos .xlsx");
                return; 
            }

            if (archivo.ContentType != "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
            {
                ToastService.Error("El contenido del archivo no es un Excel válido");
                return;
            }

            var ruta = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (!Directory.Exists(ruta)) Directory.CreateDirectory(ruta);

            var nombreArchivo = $"{Guid.NewGuid()}_{archivo.Name}";
            var rutaCompleta = Path.Combine(ruta, nombreArchivo);

            using FileStream fs = new(rutaCompleta, FileMode.Create);
            await archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);

            mensaje = "Archivo adjuntado correctamente";
            ToastService.Success(mensaje);
            EstadoAdjuntadoRegistroVentas = true;
        }
        catch (Exception ex)
        {
            EstadoAdjuntadoRegistroVentas = false;
            mensaje = ex.Message;
            ToastService.Error("Error: " + mensaje);
        }
    }

    private List<string> listaArchivossubir = new();
    private bool EstadoAdjuntadoReportediario;

    private async Task SubirArchivoMulti(InputFileChangeEventArgs e)
    {
        try
        {
            var ruta = Path.Combine(env.WebRootPath, "uploads/ReporteDiario");

            if (!Directory.Exists(ruta))
            {
                Directory.CreateDirectory(ruta);
            }

            foreach (var archivo in e.GetMultipleFiles())
            {
                var nombre = $"{Guid.NewGuid()}_{archivo.Name}";

                var rutaCompleta = Path.Combine(ruta, nombre);

                using FileStream fs = new(rutaCompleta, FileMode.Create);

                await archivo.OpenReadStream(20 * 1024 * 1024)
                    .CopyToAsync(fs);

                listaArchivossubir.Add(archivo.Name);
            }
            EstadoAdjuntadoReportediario = true;
        }
        catch (Exception ex)
        {
            EstadoAdjuntadoReportediario = false;
            Console.WriteLine(ex.Message);
        }
    }


    private bool estaProcesando = false;
    private List<ArchivoInfo> archivosProcesados = new();

    private async Task ProcesarArchivos()
    {
        estaProcesando = true;
        archivosProcesados.Clear();

        // Simulación de tu listado de archivos XLSX
        var listaDeRutas = new List<string> { "archivo1.xlsx", "archivo2.xlsx", "archivo3.xlsx" };

        foreach (var ruta in listaDeRutas)
        {
            // 1. Aquí va tu lógica de lectura (NPOI, ClosedXML, etc.)
            await Task.Delay(1000); // Simulando tiempo de lectura

            // 2. Creamos el objeto con la info del archivo terminado
            var nuevoArchivo = new ArchivoInfo
            {
                Id = Guid.NewGuid(),
                Grifo = "PRUEBA",
                File = ruta,
                Estado = 1
            };

            // 3. Insertamos directamente en la lista
            archivosProcesados.Add(nuevoArchivo);

            // 4. Notificamos a Blazor que debe renderizar el nuevo <tr>
            StateHasChanged();
        }

        estaProcesando = false;
    }

    public class ArchivoInfo
    {
        public Guid Id { get; set; }
        public string Grifo { get; set; }
        public string File { get; set; }
        public int Estado { get; set; }
    }

  
    private void ShowSuccess()
    {
        ToastService.Success("Registro guardado correctamente.");
    }

    private void ShowError()
    {
        ToastService.Error("Ocurrió un error inesperado.");
    }

    private void ShowWarning()
    {
        ToastService.Warning("Debes completar los campos.");
    }

    private void ShowInfo()
    {
        ToastService.Info("Nueva actualización disponible.");
    }

}