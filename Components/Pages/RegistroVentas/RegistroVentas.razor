@page "/RegistroVentas"
@rendermode InteractiveServer

<!-- Overlay -->
@* @if (showTrabajo || showMes || showDia)
{
    <div class="fixed inset-0 z-40"
         @onclick="CerrarTodo">
    </div>
} *@

<div class="flex flex-col lg:flex-row gap-6 items-start">

    <div class="w-full lg:w-[320px] bg-white rounded-[35px] p-8 shadow-sm flex flex-col gap-6 relative z-30 border border-slate-50">
        <h2 class="text-xs font-black text-slate-800 uppercase tracking-widest border-b border-slate-50 pb-4">Parámetros</h2>
        <div class="relative">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Adjuntar Registro ventas</label>
            <div class="mt-4">
                <label for="file-upload" class="w-full bg-emerald-500 rounded-2xl py-4 flex items-center justify-center gap-3 text-white shadow-lg shadow-emerald-100 hover:bg-emerald-600 transition-all cursor-pointer">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-width="2.5" d="M12 4v16m8-8H4"></path>
                    </svg>
                    <span class="text-sm font-bold">Adjuntar Excel</span>
                </label>
                <input id="file-upload" type="file" class="hidden">
            </div>
        </div>


    


     
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- ===================== -->
            <!-- TRABAJO -->
            <!-- ===================== -->

            <div class="relative">

                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">
                    Trabajo
                </label>

                <div class="w-full bg-slate-50 rounded-2xl px-5 py-4 text-sm font-bold flex items-center justify-between cursor-pointer hover:bg-slate-100"
                     @onclick="ToggleTrabajo">

                    <span>@trabajoSeleccionado</span>

                    <svg class="w-4 h-4 text-slate-400"
                         fill="none"
                         stroke="currentColor"
                         viewBox="0 0 24 24">
                        <path stroke-width="3" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showTrabajo)
                {
                    <div class="absolute top-[calc(100%+8px)] left-0 w-full bg-white rounded-2xl shadow-2xl border py-2 z-50">

                        @foreach (var trabajo in trabajos)
                        {
                            <div class="px-5 py-3 hover:bg-indigo-50 hover:text-indigo-600 cursor-pointer text-sm font-medium"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarTrabajo(trabajo)">
                                @trabajo
                            </div>
                        }

                    </div>
                }

            </div>

            <!-- ===================== -->
            <!-- MES -->
            <!-- ===================== -->

            <div class="relative">

                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">
                    Mes
                </label>

                <div class="w-full bg-slate-50 rounded-2xl px-5 py-4 text-sm font-bold flex items-center justify-between cursor-pointer hover:bg-slate-100"
                     @onclick="ToggleMes">

                    <span>@mesSeleccionado</span>

                    <svg class="w-4 h-4 text-slate-400"
                         fill="none"
                         stroke="currentColor"
                         viewBox="0 0 24 24">
                        <path stroke-width="3" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showMes)
                {
                    <div class="absolute top-[calc(100%+8px)] left-0 w-full bg-white rounded-2xl shadow-2xl border py-2 z-50 max-h-48 overflow-y-auto">

                        @foreach (var mes in meses)
                        {
                            <div class="px-5 py-2 hover:bg-indigo-50 hover:text-indigo-600 cursor-pointer text-sm font-medium"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarMes(mes)">
                                @mes
                            </div>
                        }

                    </div>
                }

            </div>

            <!-- ===================== -->
            <!-- DIA -->
            <!-- ===================== -->

            <div class="relative">

                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">
                    Día
                </label>

                <div class="w-full bg-slate-50 rounded-2xl px-5 py-4 text-sm font-bold flex items-center justify-between cursor-pointer hover:bg-slate-100"
                     @onclick="ToggleDia">

                    <span>@diaSeleccionado</span>

                    <svg class="w-4 h-4 text-slate-400"
                         fill="none"
                         stroke="currentColor"
                         viewBox="0 0 24 24">
                        <path stroke-width="3" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showDia)
                {
                    <div class="absolute top-[calc(100%+8px)] left-0 w-full bg-white rounded-2xl shadow-2xl border py-2 z-50 max-h-48 overflow-y-auto">

                        @for (int i = 0; i <= 31; i++)
                        {
                            <div class="px-5 py-2 hover:bg-indigo-50 hover:text-indigo-600 cursor-pointer text-sm font-medium"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarDia(i)">
                                @i
                            </div>
                        }

                    </div>
                }

            </div>

        </div>





        <div class="mt-4">
            <label for="file-upload" class="w-full bg-emerald-500 rounded-2xl py-4 flex items-center justify-center gap-3 text-white shadow-lg shadow-emerald-100 hover:bg-emerald-600 transition-all cursor-pointer">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-sm font-bold">Adjuntar diario y ejecutar</span>
            </label>
            <input id="file-upload" type="file" class="hidden">
        </div>

        <div class="mt-4">
            <button type="button" class="w-full bg-red-500 rounded-2xl py-4 flex items-center justify-center gap-3 text-white shadow-lg shadow-red-100 hover:bg-red-600 transition-all font-bold">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span class="text-sm font-bold">Cancelar</span>
            </button>
        </div>

    </div>
    <div class="flex-1 bg-white rounded-[30px] p-8 shadow-sm border border-slate-50 overflow-hidden">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold">Project Details</h2>
            <button class="text-indigo-600 text-sm font-bold hover:underline">Download CSV</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[11px] uppercase tracking-widest border-b border-slate-50">
                        <th class="pb-4 font-black">Project Name</th>
                        <th class="pb-4 font-black">Team</th>
                        <th class="pb-4 font-black">Status</th>
                        <th class="pb-4 font-black">Progresss</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <tr class="border-b border-slate-50/50 group hover:bg-slate-50/50 transition-colors">
                        <td class="py-4 font-bold">Dashboard Redesign</td>
                        <td class="py-4">
                            <div class="flex -space-x-2">
                                <div class="w-7 h-7 rounded-full border-2 border-white bg-indigo-100"></div>
                                <div class="w-7 h-7 rounded-full border-2 border-white bg-pink-100"></div>
                            </div>
                        </td>
                        <td class="py-4">
                            <span class="px-3 py-1 bg-green-100 text-green-600 rounded-full text-[10px] font-black uppercase">Active</span>
                        </td>
                        <td class="py-4">
                            <div class="w-24 bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-indigo-600 h-full w-[80%]"></div>
                            </div>
                        </td>
                    </tr>
                    <tr class="border-b border-slate-50/50 group hover:bg-slate-50/50 transition-colors">
                        <td class="py-4 font-bold">App Ventas Win</td>
                        <td class="py-4">
                            <div class="flex -space-x-2">
                                <div class="w-7 h-7 rounded-full border-2 border-white bg-orange-100"></div>
                            </div>
                        </td>
                        <td class="py-4">
                            <span class="px-3 py-1 bg-orange-100 text-orange-600 rounded-full text-[10px] font-black uppercase">Pending</span>
                        </td>
                        <td class="py-4">
                            <div class="w-24 bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-orange-500 h-full w-[45%]"></div>
                            </div>
                        </td>
                    </tr>
                    <tr class="group hover:bg-slate-50/50 transition-colors">
                        <td class="py-4 font-bold">Ticket #20751 Optimization</td>
                        <td class="py-4">
                            <div class="flex -space-x-2">
                                <div class="w-7 h-7 rounded-full border-2 border-white bg-slate-200"></div>
                                <div class="w-7 h-7 rounded-full border-2 border-white bg-slate-300"></div>
                            </div>
                        </td>
                        <td class="py-4">
                            <span class="px-3 py-1 bg-slate-100 text-slate-500 rounded-full text-[10px] font-black uppercase">Paused</span>
                        </td>
                        <td class="py-4">
                            <div class="w-24 bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-slate-400 h-full w-[100%]"></div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* <script src="/js/registroventas/registro_ventas.js"></script> *@

@* <script src="c:\users\kbarreda\source\repos\blazorapp3\wwwroot\js\registroventas\registro_ventas.js"></script> *@

@code {
    // =========================
    // DATOS
    // =========================

    string[] trabajos =
    {
        "Seleccionar",
        "Procesar Hoy",
        "Procesar Día",
        "Procesar Mes"
    };

    string[] meses =
    {
        "Seleccionar",
        "Enero",
        "Febrero",
        "Marzo",
        "Abril",
        "Mayo",
        "Junio",
        "Julio",
        "Agosto",
        "Septiembre",
        "Octubre",
        "Noviembre",
        "Diciembre"
    };

    // =========================
    // SELECCIONADOS
    // =========================

    string trabajoSeleccionado = "Seleccionar";
    string mesSeleccionado = "Seleccionar";
    int diaSeleccionado = 0;

    // =========================
    // DROPDOWNS
    // =========================

    bool showTrabajo;
    bool showMes;
    bool showDia;

    // =========================
    // TOGGLE
    // =========================

    void ToggleTrabajo()
    {
        showTrabajo = !showTrabajo;
    }

    void ToggleMes()
    {
        showMes = !showMes;
    }

    void ToggleDia()
    {
        showDia = !showDia;
    }

    // =========================
    // SELECT
    // =========================

    void SeleccionarTrabajo(string trabajo)
    {
        trabajoSeleccionado = trabajo;
        showTrabajo = false;
    }

    void SeleccionarMes(string mes)
    {
        mesSeleccionado = mes;
        showMes = false;
    }

    void SeleccionarDia(int dia)
    {
        diaSeleccionado = dia;
        showDia = false;
    }

    // void CerrarTodo()
    // {
    //     showTrabajo = false;
    //     showMes = false;
    //     showDia = false;
    // }
}