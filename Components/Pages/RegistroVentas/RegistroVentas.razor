@page "/RegistroVentas"
@using PETRO_BOT.Services.Toast
@using PETRO_BOT.Components.Pages.Elementos
@rendermode InteractiveServer
@inject IWebHostEnvironment env
@inject ToastService ToastService
@using PETRO_BOT.Services.Services
@using System.Diagnostics
@using PETRO_BOT.Models.Log

<div class="flex flex-col lg:flex-row gap-6 items-start">

    <!-- PANEL DE PARÁMETROS -->
    <div class="w-full lg:w-[320px] bg-white rounded-[35px] p-8 shadow-sm flex flex-col gap-6 relative z-30 border border-slate-50 overflow-hidden">
        
        <div class="flex items-center justify-between border-b border-slate-100 pb-5">
            <h2 class="text-sm font-black text-slate-800 uppercase tracking-[0.2em]">Parámetros</h2>
            <span class="h-2 w-2 bg-emerald-400 rounded-full animate-pulse"></span>
        </div>

        @if (EstadoAdjuntadoRegistroVentas==false)
        {
            <div class="space-y-2">

                <label class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1">
                    Adjuntar
                </label>

                <div class="group relative w-full">

                    <label for="file-upload"
                           class="w-full bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl px-4 py-2 flex items-center justify-between hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer">

                        <span class="text-[11px] font-bold text-slate-600">
                            Adjuntar registro ventas
                        </span>

                        <span class="p-1.5 bg-white rounded-lg shadow-sm group-hover:scale-105 transition-transform">
                            <svg class="w-4 h-4 text-emerald-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M12 4v16m8-8H4">
                                </path>
                            </svg>
                        </span>

                    </label>

                    <InputFile id="file-upload"
                               OnChange="SubirArchivo"
                               accept=".xlsx"
                               class="hidden" />

                </div>

            </div>

        }
        else
        {
               <SuccessCargaFile File="registro_ventaas.xlsx"/>
        }
     

        <div class="grid grid-cols-1 md:grid-cols-1 gap-5">

            <!-- ===================== -->
            <!-- TRABAJO -->
            <!-- ===================== -->
            <div class="relative">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                    Trabajo
                </label>
                
                <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                     @onclick="ToggleTrabajo">
                    <span>@trabajoSeleccionado</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showTrabajo ? "rotate-180" : "")"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showTrabajo)
                {
                    <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 overflow-hidden">
                        @foreach (var trabajo in trabajos)
                        {
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarTrabajo(trabajo)">
                                @trabajo
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- ===================== -->
            <!-- MES -->
            <!-- ===================== -->
            @if (showMesActivar){
            <div class="relative">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                    Mes
                </label>
                
                <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                     @onclick="ToggleMes">
                    <span>@mesSeleccionado</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showMes ? "rotate-180" : "")"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>

                @if (showMes)
                {
                    <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 max-h-48 overflow-y-auto custom-scrollbar">
                        @foreach (var mes in meses)
                        {
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => SeleccionarMes(mes)">
                                @mes
                            </div>
                        }
                    </div>
                }
            </div>
            }

            <!-- ===================== -->
            <!-- DÍA -->
            <!-- ===================== -->
            @if (showDiaActivar)
            {
                <div class="relative">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">
                        Día
                    </label>

                    <div class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium text-slate-600 flex items-center justify-between cursor-pointer hover:border-slate-300 hover:bg-slate-50 transition-all"
                    @onclick="ToggleDia">
                        <span>@(diaSeleccionado == 0 ? "Seleccionar" : diaSeleccionado.ToString())</span>
                        <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 @(showDia ? "rotate-180" : "")"
                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>

                    @if (showDia)
                    {
                        <div class="absolute top-[calc(100%+4px)] left-0 w-full bg-white rounded-xl shadow-lg border border-slate-100 py-1.5 z-50 max-h-48 overflow-y-auto custom-scrollbar">
                            <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                            @onclick:stopPropagation="true"
                            @onclick="() => SeleccionarDia(0)">
                                Seleccionar
                            </div>
                            @foreach (var dia in Enumerable.Range(1, 31))
                            {
                                <div class="px-4 py-2.5 hover:bg-slate-50 text-slate-600 hover:text-slate-900 cursor-pointer text-sm transition-colors"
                                @onclick:stopPropagation="true"
                                @onclick="() => SeleccionarDia(dia)">
                                    @dia
                                </div>
                            }
                        </div>
                }
            </div>
            }

        </div>

        @if (EstadoAdjuntadoReportediario == false)
        {
            <div class="space-y-2">

                <label class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1">
                    Adjuntar
                </label>

                <div class="group relative w-full">

                    <label for="file-upload_multi"
                    class="w-full bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl px-4 py-2 flex items-center justify-between hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer">

                        <span class="text-[11px] font-bold text-slate-600">
                            Adjuntar reporte diario
                        </span>

                        <span class="p-1.5 bg-white rounded-lg shadow-sm group-hover:scale-105 transition-transform">
                            <svg class="w-4 h-4 text-emerald-500"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 4v16m8-8H4">
                                </path>
                            </svg>
                        </span>

                    </label>

                    <InputFile id="file-upload_multi" OnChange="SubirArchivoMulti" multiple accept=".xlsx" />

                </div>

            </div>
        }
        else
        {
            <SuccessCargaFile File="registro_ventaas.xlsx" />
        }




        <div class="flex flex-col gap-3 mt-auto pt-4 border-t border-slate-100">
    
            <!-- Botón Ejecutar con estado Loading -->
            <button @onclick="EjecutarProceso"
                    disabled="@isLoading"
                    class="w-full bg-[#0186B5] text-white rounded-xl py-3.5 flex items-center justify-center gap-2.5 shadow-sm hover:bg-[#017099] transition-all active:scale-[0.98] font-medium disabled:opacity-75 disabled:cursor-not-allowed disabled:hover:bg-[#0186B5] disabled:active:scale-100 cursor-pointer">
                @if (isLoading)
                {
                   <LoadingRayo/>
                }
                else
                {
                    <!-- Icono normal -->
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <span class="text-sm">Ejecutar Proceso</span>
                }
            </button>
          
            <button disabled="@isLoading" @onclick="CancelarRegistroVentas" class="w-full bg-white text-slate-500 border border-slate-200 rounded-xl py-3.5 text-sm font-medium hover:bg-red-50 hover:text-red-600 hover:border-red-200 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white disabled:hover:text-slate-500 disabled:hover:border-slate-200 cursor-pointer">
                Cancelar Operación
            </button>

        </div>

    </div>

    <!-- PANEL DE TABLA -->
    <div class="flex-1 bg-white w-full rounded-[30px] p-6 shadow-sm border border-slate-50 overflow-hidden">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-800">Archivos procesados</h2>
            <button class="text-[#017099] text-sm font-bold hover:underline decoration-2 underline-offset-4">Download CSV</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-400 text-[11px] uppercase tracking-[0.2em] border-b border-slate-50">
                        <!-- Reducido de pb-5 a pb-3 -->
                        <th class="pb-3 font-black w-px whitespace-nowrap pr-4">#</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap pr-8">Grifo</th>
                        <th class="pb-3 font-black">File</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap px-4">Estado</th>
                        <th class="pb-3 font-black w-px whitespace-nowrap text-right">Acción</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    @if (isLoading)
                    {
                       <LoadingRayo/>
                     }
              
                    @foreach (var archivo in archivosProcesados)
                    {
                        @* Agregamos @key para eficiencia y la clase animate-new-row para el efecto *@
                        <tr @key="archivo.Id" class="border-b border-slate-50 group hover:bg-slate-50/50 transition-colors animate-new-row">

                            @* Número de registro con un toque más tenue *@
                            <td class="py-3 text-[11px] text-slate-300 font-bold whitespace-nowrap">
                                #@(archivosProcesados.IndexOf(archivo) + 1)
                            </td>

                            <td class="py-3 pr-8 whitespace-nowrap">
                                <span class="font-bold text-slate-700 text-sm">@archivo.Grifo</span>
                            </td>

                            <td class="py-3">
                                @* Un gris un poco más suave para el nombre del archivo mejora el minimalismo *@
                                <span class="text-slate-500 font-medium text-sm">@archivo.File</span>
                            </td>

                            @if (archivo.Estado == 1)
                            {
                                <td class="py-3 px-4 whitespace-nowrap">
                                    <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[10px] font-black uppercase tracking-wider">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Success
                                    </span>
                                </td>
                            }
                            else
                            {
                                <td class="py-3 whitespace-nowrap px-4">
                                    <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-rose-50 text-rose-600 rounded-md text-[10px] font-black uppercase tracking-wider">
                                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> Error
                                    </span>
                                </td>
                            }

                            <td class="py-3 text-right whitespace-nowrap">
                                @* Botón un poco más compacto para mantener la línea limpia *@
                                <button id="@archivo.File"
                                        @onclick="() => AbrirModal(archivo)"
                                        class="bg-[#017099] text-white px-4 py-1.5 rounded-lg text-[11px] font-bold hover:shadow-md active:scale-95 transition-all outline-none cursor-pointer">
                                    Ver detalles
                                </button>
                            </td>
                        </tr>
                    }


                    <!-- Repite py-3 en el resto de los <tr> -->
                </tbody>
            </table>
        </div>
    </div>



</div>

@if (mostrarModal && archivoSeleccionado != null)
{
    <!-- MODAL OVERLAY (FONDO CON OPACIDAD MÍNIMA QUE PERMITE CERRAR AL HACER CLICK AFUERA) -->
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 9999; padding: 20px;" 
         @onclick="CerrarModal">
        
        <!-- CONTENEDOR DEL MODAL (TAMAÑO AUTO-AJUSTABLE A LA TABLA, DETIENE LA PROPAGACIÓN DE CLIC) -->
        <div style="background-color: #ffffff; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); border: 1px solid #f1f5f9; width: auto; min-width: 0px; max-width: 750px; max-height: 80vh; display: flex; flex-direction: column; overflow: hidden;"
             @onclick:stopPropagation="true">
            
            <!-- HEADER (CON EL NOMBRE DEL ARCHIVO COMO TÍTULO) -->
            <div style="padding: 16px 20px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; background-color: #f8fafc; gap: 20px;">
                <div style="flex: 1; min-width: 0;">
                    <span style="font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 2px;">Archivo de Proceso</span>
                    <h3 style="font-size: 13px; font-weight: 800; color: #1e293b; margin: 0; word-break: break-all; font-family: monospace; line-height: 1.4;">@archivoSeleccionado.File</h3>
                </div>
                <button @onclick="CerrarModal" 
                        style="background: none; border: none; cursor: pointer; padding: 8px; border-radius: 50%; color: #94a3b8; display: flex; align-items: center; justify-content: center; transition: all 0.2s;" 
                        onmouseover="this.style.backgroundColor='#e2e8f0'; this.style.color='#475569';" 
                        onmouseout="this.style.backgroundColor='transparent'; this.style.color='#94a3b8';">
                    <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- CONTENIDO DE LA TABLA MINIMALISTA -->
            <div style="padding: 20px; overflow-y: auto; flex: 1;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 12px;">
                    <thead>
                        <tr style="border-bottom: 2px solid #f1f5f9; color: #94a3b8; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em;">
                            <th style="padding-bottom: 8px; font-weight: 700; width: 85px;">Estado</th>
                            <th style="padding-bottom: 8px; font-weight: 700;">Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (archivoSeleccionado.Mensajes == null || !archivoSeleccionado.Mensajes.Any())
                        {
                            <tr>
                                <td colspan="2" style="padding: 24px 0; text-align: center; color: #94a3b8; font-style: italic;">
                                    No hay mensajes registrados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var msg in archivoSeleccionado.Mensajes)
                            {
                                <tr style="border-bottom: 1px solid #f8fafc;">
                                    <td style="padding: 10px 0; vertical-align: top; white-space: nowrap; padding-right: 15px;">
                                        @if (msg.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span style="display: inline-flex; align-items: center; gap: 5px; background-color: #eff6ff; color: #2563eb; border-radius: 6px; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; padding: 2px 8px;">
                                                <span style="width: 5px; height: 5px; border-radius: 50%; background-color: #3b82f6;"></span> @msg.Estado
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="display: inline-flex; align-items: center; gap: 5px; background-color: #fef2f2; color: #dc2626; border-radius: 6px; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; padding: 2px 8px;">
                                                <span style="width: 5px; height: 5px; border-radius: 50%; background-color: #ef4444;"></span> @msg.Estado
                                            </span>
                                        }
                                    </td>
                                    <td style="padding: 10px 0; color: #475569; font-weight: 500; font-size: 11px; line-height: 1.4; word-break: break-word;">
                                        @msg.Descripcion
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- PIE DE PAGINA -->
            <div style="padding: 12px 20px; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end; background-color: #f8fafc;">
                <button @onclick="CerrarModal" 
                        style="background-color: #f1f5f9; border: none; cursor: pointer; padding: 8px 16px; border-radius: 10px; color: #475569; font-weight: 700; font-size: 11px; transition: background-color 0.2s;"
                        onmouseover="this.style.backgroundColor='#e2e8f0';"
                        onmouseout="this.style.backgroundColor='#f1f5f9';">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
}

@code {

    string[] trabajos =
    {
        "Seleccionar",
        "Procesar Hoy",
        "Procesar Día",
        "Procesar Mes"
    };

    string[] meses =
    {
        "Seleccionar",
        "Enero",
        "Febrero",
        "Marzo",
        "Abril",
        "Mayo",
        "Junio",
        "Julio",
        "Agosto",
        "Septiembre",
        "Octubre",
        "Noviembre",
        "Diciembre"
    };

    string trabajoSeleccionado = "Seleccionar";
    string mesSeleccionado = "Seleccionar";
    int diaSeleccionado = 0;

    bool showTrabajo;
    bool showMes;
    bool showDia;
    bool showMesActivar;
    bool showDiaActivar;


    void ToggleTrabajo()
    {
        showTrabajo = !showTrabajo;
        showMes = false; 
        showDia = false;
    }

    void ToggleMes()
    {
        showMes = !showMes;
        showTrabajo = false;
        showDia = false;
    }

    void ToggleDia()
    {
        showDia = !showDia;
        showTrabajo = false;
        showMes = false;
    }
    void SeleccionarMes(string mes)
    {
        mesSeleccionado = mes;
        showMes = false;
    }

    void SeleccionarDia(int dia)
    {
        diaSeleccionado = dia;
        showDia = false;
    }

    void SeleccionarTrabajo(string trabajo)
    {
        trabajoSeleccionado = trabajo;
        showTrabajo = false;
        switch (trabajo)
        {
            case "Procesar Hoy":
                showMesActivar = false;
                showDiaActivar = false;
                break;
            case "Procesar Día":
                showMesActivar = true;
                showDiaActivar = true;
                break;
            case "Procesar Mes":
                showMesActivar = true;
                showDiaActivar = false;
                break;
            default:
                break;
        };


    }

    void CancelarRegistroVentas()
    {
        EstadoAdjuntadoRegistroVentas = false;
        EstadoAdjuntadoReportediario = false;
    }

    bool isLoading = false;

    async Task EjecutarProceso()
    {
        isLoading = true;
        await ProcesarArchivos();
        await CargarReporteProceso();
        isLoading = false;
    }

    private async Task CargarReporteProceso()
    {
        try
        {
            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            if (System.IO.File.Exists(rutaLog))
            {
                string jsonContent = await System.IO.File.ReadAllTextAsync(rutaLog);
                var logsProcesados = System.Text.Json.JsonSerializer.Deserialize<List<LogProcesoGrifo>>(jsonContent);
                
                if (logsProcesados != null)
                {
                    archivosProcesados.Clear();
                    foreach (var log in logsProcesados)
                    {
                        int estado = log.Mensajes.All(m => m.Estado.Equals("INFO", StringComparison.OrdinalIgnoreCase)) ? 1 : 2;
                        
                        var nuevoArchivo = new ArchivoInfo
                        {
                            Id = Guid.NewGuid(),
                            Grifo = log.Grifo,
                            File = log.Archivo,
                            Estado = estado,
                            Mensajes = log.Mensajes
                        };
                        archivosProcesados.Add(nuevoArchivo);
                        StateHasChanged();
                        await Task.Delay(1000);

                    }
                   
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el reporte: " + ex.Message);
        }
    }


    private string mensaje = "";
    private bool EstadoAdjuntadoRegistroVentas;

    private async Task SubirArchivo(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;

            var extension = Path.GetExtension(archivo.Name).ToLower();
            if (extension != ".xlsx")
            {
                ToastService.Error("Solo se permiten archivos .xlsx");
                return; 
            }

            if (archivo.ContentType != "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
            {
                ToastService.Error("El contenido del archivo no es un Excel válido");
                return;
            }

            var ruta = Path.Combine(env.WebRootPath, "uploads/RegistroVentas");
            if (!Directory.Exists(ruta)) Directory.CreateDirectory(ruta);

            var nombreArchivo = $"{Guid.NewGuid()}_{archivo.Name}";
            var rutaCompleta = Path.Combine(ruta, nombreArchivo);

            using FileStream fs = new(rutaCompleta, FileMode.Create);
            await archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);

            mensaje = "Archivo adjuntado correctamente";
            ToastService.Success(mensaje);
            EstadoAdjuntadoRegistroVentas = true;
        }
        catch (Exception ex)
        {
            EstadoAdjuntadoRegistroVentas = false;
            mensaje = ex.Message;
            ToastService.Error("Error: " + mensaje);
        }
    }

    private List<string> listaArchivossubir = new();
    private bool EstadoAdjuntadoReportediario;

    private async Task SubirArchivoMulti(InputFileChangeEventArgs e)
    {
        try
        {
            var ruta = Path.Combine(env.WebRootPath, "uploads/ReporteDiario");

            if (!Directory.Exists(ruta))
            {
                Directory.CreateDirectory(ruta);
            }

            string extensionPermitida = ".xlsx";

            foreach (var archivo in e.GetMultipleFiles(20))
            {
                var extension = Path.GetExtension(archivo.Name).ToLower();

                if (extension != extensionPermitida)
                {
                    continue; 
                }

                var nombre = $"{Guid.NewGuid()}_{archivo.Name}";
                var rutaCompleta = Path.Combine(ruta, nombre);

                using FileStream fs = new(rutaCompleta, FileMode.Create);

                // Tamaño máximo de 20MB
                await archivo.OpenReadStream(20 * 1024 * 1024).CopyToAsync(fs);

                listaArchivossubir.Add(archivo.Name);
            }

            if (listaArchivossubir.Any())
            {
                EstadoAdjuntadoReportediario = true;
            }
        }
        catch (Exception ex)
        {
            EstadoAdjuntadoReportediario = false;
            Console.WriteLine(ex.Message);
        }
    }


    private bool estaProcesando = false;
    private List<ArchivoInfo> archivosProcesados = new();

    private async Task ProcesarArchivos()
    {
        Stopwatch timerGlobal = Stopwatch.StartNew();
        try
        {
            var consolidador = new ConsolidadorVentasService();
            await Task.Run(() => consolidador.Procesar());
        }
        catch (Exception ex)
        {
            LoggerService.Error("SISTEMA", "Main", $"Ocurrió un error fatal: {ex.Message}");
            Console.WriteLine($"[x] Ocurrió un error fatal:\n{ex.ToString()}");
        }
        finally
        {
            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            LoggerService.GuardarJson(rutaLog);
        }
        timerGlobal.Stop();
        Console.WriteLine("\n" + new string('=', 30));
        Console.WriteLine($"PROCESO FINALIZADO");
        Console.WriteLine($"Tiempo total: {timerGlobal.Elapsed.TotalSeconds:F2} segundos");
        Console.WriteLine(new string('=', 30));
    }

