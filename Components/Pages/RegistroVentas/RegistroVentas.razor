    private async Task SubirArchivoMulti(InputFileChangeEventArgs e)
    {
        try
        {
            var ruta = Path.Combine(ConfiguracionService.ObtenerWebRootPath(env.WebRootPath), "uploads/ReporteDiario");

            if (!Directory.Exists(ruta))
            {
                Directory.CreateDirectory(ruta);
            }

            string extensionPermitida = ".xlsx";
            archivosReporteDiario.Clear();

            foreach (var archivo in e.GetMultipleFiles(1000))
            {
                var extension = Path.GetExtension(archivo.Name).ToLower();

                if (extension != extensionPermitida)
                {
                    continue; 
                }

                var nombre = $"{archivo.Name}";
                var rutaCompleta = Path.Combine(ruta, nombre);

                using FileStream fs = new(rutaCompleta, FileMode.Create);

                // Tamaño máximo de 20MB
                await archivo.OpenReadStream(20 * 1024 * 1024).CopyToAsync(fs);

                listaArchivossubir.Add(archivo.Name);
                archivosReporteDiario.Add(archivo.Name);
            }

            if (listaArchivossubir.Any())
            {
                EstadoAdjuntadoReportediario = true;
                mensaje = "Archivo adjuntado correctamente";
                ToastService.Success(mensaje);
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error: " + ex.Message;
            ToastService.Error(mensaje);
            EstadoAdjuntadoReportediario = false;
            Console.WriteLine(ex.Message);
        }
    }

    private bool estaProcesando = false;
    private List<ArchivoInfo> archivosProcesados = new();

    private async Task ProcesarArchivos(string tarea, string dia)
    {
        estaProcesando = true;
        archivosProcesados.Clear();
        MostrarDashboard = false;
        StateHasChanged();

        Stopwatch timerGlobal = Stopwatch.StartNew();
        try
        {
            var consolidador = new ConsolidadorVentasService();
            await Task.Run(() => consolidador.Procesar(tarea, dia));
        }
        catch (Exception ex)
        {
            LoggerService.Error("SISTEMA", "Main", $"Ocurrió un error fatal: {ex.Message}");
            Console.WriteLine($"[x] Ocurrió un error fatal:\n{ex.ToString()}");
        }
        finally
        {
            string rutaLog = System.IO.Path.GetFullPath(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"..\..\..\Json\JsonRegistroVentas\", "reporte_proceso.json"));
            LoggerService.GuardarJson(rutaLog);
            await CargarReporteProceso();
            
            timerGlobal.Stop();
            if (timerGlobal.Elapsed.TotalMinutes >= 1)
            {
                TiempoDemoraProceso = $"{(int)timerGlobal.Elapsed.TotalMinutes}m {timerGlobal.Elapsed.Seconds}s";
            }
            else
            {
                TiempoDemoraProceso = $"{timerGlobal.Elapsed.TotalSeconds:F1}s";
            }

            int diasPorArchivo = 0;
            if (tarea == "Procesar Día")
            {
                diasPorArchivo = fechasSeleccionadas.Count;
            }
            else
            {
                if (fechasSeleccionadas.Any())
                {
                    var fechaRef = fechasSeleccionadas.First();
                    diasPorArchivo = DateTime.DaysInMonth(fechaRef.Year, fechaRef.Month);
                }
                else
                {
                    diasPorArchivo = 30;
                }
            }

            TotalArchivosProcesados = archivosProcesados.Count;
            TotalDiasProcesados = TotalArchivosProcesados * diasPorArchivo;
            
            TotalDiasCorrectos = 0;
            if (archivoRegistroVentasInfo != null && archivoRegistroVentasInfo.Mensajes != null)
            {
                TotalDiasCorrectos = archivoRegistroVentasInfo.Mensajes.Count(m => 
                    m.Descripcion.Contains("guardado con éxito", StringComparison.OrdinalIgnoreCase));
            }
            
            TotalDiasError = TotalDiasProcesados - TotalDiasCorrectos;
            if (TotalDiasError < 0) TotalDiasError = 0;
            
            try
            {
                HistorialService.RegistrarEjecucion("Registro de Ventas", TotalArchivosProcesados, TotalDiasCorrectos, timerGlobal.Elapsed.TotalSeconds);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[x] Error guardando historial: {ex.Message}");
            }
            
            int minutosAhorrados = TotalDiasCorrectos * 10;
            int totalHoras = minutosAhorrados / 60;
            int minutosRestantes = minutosAhorrados % 60;
            int diasLaborables = totalHoras / 8;
            int horasRestantes = totalHoras % 8;

            if (diasLaborables > 0)
            {
                string dias = diasLaborables == 1 ? "1 día lab." : $"{diasLaborables} días lab.";
                if (horasRestantes > 0)
                {
                    TiempoAhorrado = $"{dias} y {horasRestantes} h";
                }
                else if (minutosRestantes > 0)
                {
                    TiempoAhorrado = $"{dias} y {minutosRestantes} min";
                }
                else
                {
                    TiempoAhorrado = dias;
                }
            }
            else if (totalHoras > 0)
            {
                TiempoAhorrado = $"{totalHoras}h {minutosRestantes}m";
            }
            else
            {
                TiempoAhorrado = $"{minutosRestantes} min";
            }

            MostrarDashboard = true;
            estaProcesando = false;
            await InvokeAsync(StateHasChanged);
        }
        Console.WriteLine("\n" + new string('=', 30));
        Console.WriteLine($"PROCESO FINALIZADO");
        Console.WriteLine($"Tiempo total: {timerGlobal.Elapsed.TotalSeconds:F2} segundos");
        Console.WriteLine(new string('=', 30));
    }

