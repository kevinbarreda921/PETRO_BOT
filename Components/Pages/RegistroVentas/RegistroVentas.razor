                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7v12m0 0l-4-4m4 4l-4-4m0 6V7m0 0l-4 4m4-4l4 4"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- List box attachments rounded blocks -->
            <div class="p-6 overflow-y-auto flex-1 flex flex-col gap-5 custom-scrollbar">
                
                <!-- Box 1: Sales sheets -->
                <div class="bg-slate-50 border border-slate-150 rounded-[20px] p-5">
                    <div class="flex items-center gap-2 border-b border-slate-200 pb-3 mb-3">
                        <span class="w-1.5 h-3 bg-blue-500 rounded-full"></span>
                        <h4 class="text-[11px] font-black text-slate-800 uppercase tracking-wider">Planillas de Registro de Venta</h4>
                    </div>
                    
                    <div class="max-h-[160px] overflow-y-auto pr-1 custom-scrollbar">
                        @if (!archivosRegistroVentas.Any())
                        {
                            <span class="text-xs text-slate-400 italic block py-2">Ningún archivo adjuntado.</span>
                        }
                        else
                        {
                            <ul class="flex flex-col gap-2">
                                @foreach (var archivo in archivosRegistroVentas)
                                {
                                    <li class="bg-white border border-slate-200 rounded-xl px-3 py-2 flex items-center justify-between font-mono text-[11px] text-slate-700 shadow-sm hover:border-slate-350 transition-all">
                                        <span class="truncate pr-4 select-all text-slate-800 font-semibold">@archivo</span>
                                        <button @onclick="() => EliminarArchivoVenta(archivo)" type="button" class="p-1.5 bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-200/60 rounded-xl transition-all cursor-pointer flex items-center justify-center shrink-0 shadow-sm hover:scale-[1.03]" title="Eliminar archivo">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <!-- Box 2: Daily sheets -->
                <div class="bg-slate-50 border border-slate-150 rounded-[20px] p-5">
                    <div class="flex items-center gap-2 border-b border-slate-200 pb-3 mb-3">
                        <span class="w-1.5 h-3 bg-emerald-500 rounded-full"></span>
                        <h4 class="text-[11px] font-black text-slate-800 uppercase tracking-wider">Planillas de Reporte Diario</h4>
                    </div>
                    
                    <div class="max-h-[160px] overflow-y-auto pr-1 custom-scrollbar">
                        @if (!archivosReporteDiario.Any())
                        {
                            <span class="text-xs text-slate-400 italic block py-2">Ningún archivo adjuntado.</span>
                        }
                        else
                        {
                            <ul class="flex flex-col gap-2">
                                @foreach (var archivo in archivosReporteDiario)
                                {
                                    <li class="bg-white border border-slate-200 rounded-xl px-3 py-2 flex items-center justify-between font-mono text-[11px] text-slate-700 shadow-sm hover:border-slate-350 transition-all">
                                        <span class="truncate pr-4 select-all text-slate-800 font-semibold">@archivo</span>
                                        <button @onclick="() => EliminarArchivoDiario(archivo)" type="button" class="p-1.5 bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-200/60 rounded-xl transition-all cursor-pointer flex items-center justify-center shrink-0 shadow-sm hover:scale-[1.03]" title="Eliminar archivo">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

            </div>

